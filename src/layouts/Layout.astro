---
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const {
  title = 'Jake Fixes Tech — Computer Repair & Tech Services in Littleton, NH',
  description = 'Affordable, honest computer repair, tech support and website design serving Littleton, NH and the North Country. Call or text (802) 234-1552.',
  image = 'https://jakefixestech.com/hero.jpg'
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, 'https://jakefixestech.com');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta name="generator" content={Astro.generator} />

    <!-- Primary SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Jake Charland — Jake Fixes Tech LLC" />
    <meta name="keywords" content="computer repair Littleton NH, tech support North Country, laptop repair New Hampshire, virus removal NH, data recovery NH, website design Littleton NH" />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph (Facebook, LinkedIn sharing) -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />
    <meta property="og:site_name" content="Jake Fixes Tech" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />

    <!-- Local Business Schema -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "LocalBusiness",
        "name": "Jake Fixes Tech LLC",
        "description": "Affordable computer repair, tech support and website design serving Littleton NH and the North Country.",
        "url": "https://jakefixestech.com",
        "telephone": "+18022341552",
        "email": "jake@jakefixestech.com",
        "address": {
          "@type": "PostalAddress",
          "streetAddress": "28 Groves Street Apt 1",
          "addressLocality": "Littleton",
          "addressRegion": "NH",
          "postalCode": "03561",
          "addressCountry": "US"
        },
        "geo": {
          "@type": "GeoCoordinates",
          "latitude": 44.3045,
          "longitude": -71.7745
        },
        "openingHoursSpecification": [
          {
            "@type": "OpeningHoursSpecification",
            "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
            "opens": "17:00",
            "closes": "19:30"
          },
          {
            "@type": "OpeningHoursSpecification",
            "dayOfWeek": ["Saturday", "Sunday"],
            "opens": "09:00",
            "closes": "16:00"
          }
        ],
        "priceRange": "$$",
        "areaServed": "Littleton NH and surrounding areas"
      }
    </script>

    <!-- Google Analytics 4 via Partytown (zero Lighthouse impact) -->
    <script type="text/partytown" src="https://www.googletagmanager.com/gtag/js?id=G-7C6PE3V9LJ"></script>
    <script type="text/partytown">
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-7C6PE3V9LJ');
    </script>
  </head>

  <body>
    <Navbar />
    <main>
      <slot />
    </main>
    <Footer />

    <!-- Scavenger hunt search redirect: catches phrases typed into the site search
         bar and redirects to hidden hunt pages. Placed at end of body so document.body
         is guaranteed to exist before MutationObserver runs. -->
    <script is:inline>
      (function() {
        'use strict';

        const SCAVENGER_PHRASES = {
          "lets go":   "/h/lets-go",
          "let's go":  "/h/lets-go",
        };

        function normalize(str) {
          return (str || "")
            .toLowerCase()
            .trim()
            .replace(/[.,!?;:"]/g, "")
            .replace(/\s+/g, " ");
        }

        function checkPhrase(rawText) {
          const normalized = normalize(rawText);
          if (SCAVENGER_PHRASES[normalized]) {
            return SCAVENGER_PHRASES[normalized];
          }
          const noApos = normalized.replace(/'/g, "");
          if (SCAVENGER_PHRASES[noApos]) {
            return SCAVENGER_PHRASES[noApos];
          }
          return null;
        }

        function handleTrigger(targetUrl, event) {
          if (event) {
            event.preventDefault();
            event.stopPropagation();
          }
          setTimeout(function() {
            window.location.href = targetUrl;
          }, 150);
        }

        function attachListeners() {
          const searchInputs = document.querySelectorAll(
            'input[type="search"], input[name*="search" i], input[id*="search" i], input[class*="search" i], input[placeholder*="search" i]'
          );

          searchInputs.forEach(function(input) {
            if (input.dataset.scavengerWired) return;
            input.dataset.scavengerWired = "true";

            input.addEventListener("keydown", function(e) {
              if (e.key === "Enter") {
                const target = checkPhrase(input.value);
                if (target) {
                  handleTrigger(target, e);
                }
              }
            });

            const form = input.closest("form");
            if (form && !form.dataset.scavengerWired) {
              form.dataset.scavengerWired = "true";
              form.addEventListener("submit", function(e) {
                const target = checkPhrase(input.value);
                if (target) {
                  handleTrigger(target, e);
                }
              });
            }
          });
        }

        // Safe init — guarantees document.body exists before observing
        function init() {
          attachListeners();

          if (document.body) {
            const observer = new MutationObserver(attachListeners);
            observer.observe(document.body, { childList: true, subtree: true });
          }
        }

        if (document.readyState === "loading") {
          document.addEventListener("DOMContentLoaded", init);
        } else {
          init();
        }
      })();
    </script>
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
  }
</style>