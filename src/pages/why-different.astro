<style>
  /* ===== ANIMATED HERO ===== */
  #hero-svg {
    position: relative;
    width: 100%;
    height: 72vh;
    min-height: 460px;
    max-height: 720px;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #1e3a8a;
  }

  .hero-bg-desktop, .hero-bg-mobile {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }
  .hero-bg-desktop { display: block; }
  .hero-bg-mobile  { display: none; }

  /* ===== TIMING =====
     0.2–1.0s   Hero text fades up
     0.6–4.0s   Agency car/bar slowly chugs across (3.4s journey)
     0.6–1.4s   Jake car/bar zooms across (~0.8s journey)
     1.6s       WIN badge pops + sparkles begin
     0.8–2.6s   Score rings fill (staggered)
     1.6–2.8s   Score numbers count up
  */

  /* === SPEED RACE === */
  /* Desktop bars are 280px wide; mobile 336px. Cars translate to bar end. */

  /* Agency: slow chugging bar — fills to 100% over ~3.4s, then loops */
  .race-bar-agency {
    animation: agencyFill 4s ease-in-out infinite 0.6s;
  }
  @keyframes agencyFill {
    0%   { width: 0; }
    85%  { width: 276px; }
    100% { width: 276px; }
  }
  .race-bar-agency-mob {
    animation: agencyFillMob 4s ease-in-out infinite 0.6s;
  }
  @keyframes agencyFillMob {
    0%   { width: 0; }
    85%  { width: 336px; }
    100% { width: 336px; }
  }
  /* Agency car follows the bar */
  .race-car-agency {
    animation: agencyCarMove 4s ease-in-out infinite 0.6s;
  }
  @keyframes agencyCarMove {
    0%   { transform: translateX(9px); }
    85%  { transform: translateX(271px); }
    100% { transform: translateX(271px); }
  }
  .hero-bg-mobile .race-car-agency {
    animation: agencyCarMoveMob 4s ease-in-out infinite 0.6s;
