---
import Layout from '../layouts/Layout.astro';
import content from '../content/why-different.yml';
---

<Layout
  title="Why My Websites Are Different | Jake Fixes Tech"
  description="See why Jake Fixes Tech builds faster, safer, and more accessible websites than traditional web agencies — at a fraction of the ongoing cost."
>

  <!-- Animated SVG Hero -->
  <section id="hero-svg" aria-label="Why My Websites Are Different">

    <!-- DESKTOP SVG -->
    <svg class="hero-bg-desktop" viewBox="0 0 1440 520" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <defs>
        <linearGradient id="bgGrad" x1="0%" y1="0%" x2="100%" y2="100%">
          <stop offset="0%" style="stop-color:#1e3a8a;stop-opacity:1"/>
          <stop offset="100%" style="stop-color:#2563eb;stop-opacity:1"/>
        </linearGradient>
        <linearGradient id="glowGrad" x1="0%" y1="0%" x2="100%" y2="100%">
          <stop offset="0%" style="stop-color:#3b82f6;stop-opacity:0.25"/>
          <stop offset="100%" style="stop-color:#1d4ed8;stop-opacity:0"/>
        </linearGradient>
      </defs>
      <rect width="1440" height="520" fill="url(#bgGrad)"/>
      <ellipse cx="320" cy="240" rx="380" ry="260" fill="url(#glowGrad)" class="glow-orb-1"/>
      <ellipse cx="1150" cy="280" rx="340" ry="240" fill="url(#glowGrad)" class="glow-orb-2"/>

      <!-- Speed race bars -->
      <g class="speed-race" transform="translate(60, 160)">
        <g transform="translate(0, 0)">
          <text x="0" y="0" fill="white" fill-opacity="0.4" font-size="9" font-family="monospace" letter-spacing="1">TYPICAL AGENCY</text>
          <text x="280" y="0" text-anchor="end" fill="white" fill-opacity="0.35" font-size="9" font-family="monospace">10s</text>
          <rect x="0" y="8" width="280" height="18" rx="9" stroke="white" stroke-opacity="0.15" stroke-width="1.2" fill="white" fill-opacity="0.03"/>
          <line x1="280" y1="4" x2="280" y2="30" stroke="white" stroke-opacity="0.25" stroke-width="1.5" stroke-dasharray="2 3"/>
          <rect x="2" y="10" width="0" height="14" rx="7" fill="white" fill-opacity="0.18" class="race-bar-agency"/>
          <g class="race-car-agency">
            <circle cx="0" cy="17" r="9" fill="white" fill-opacity="0.3"/>
            <circle cx="-2.5" cy="16" r="1.2" fill="#1e3a8a"/>
            <circle cx="2.5" cy="16" r="1.2" fill="#1e3a8a"/>
          </g>
        </g>

        <g transform="translate(0, 60)">
          <text x="0" y="0" fill="white" fill-opacity="0.65" font-size="9" font-family="monospace" letter-spacing="1" font-weight="700">JAKE FIXES TECH</text>
          <text x="280" y="0" text-anchor="end" fill="white" fill-opacity="0.55" font-size="9" font-family="monospace" font-weight="700">&lt;2s</text>
          <rect x="0" y="8" width="280" height="18" rx="9" stroke="white" stroke-opacity="0.28" stroke-width="1.2" fill="white" fill-opacity="0.05"/>
          <line x1="280" y1="4" x2="280" y2="30" stroke="white" stroke-opacity="0.45" stroke-width="1.5"/>
          <rect x="2" y="10" width="0" height="14" rx="7" fill="white" fill-opacity="0.55" class="race-bar-jake"/>
          <g class="speed-lines">
            <line x1="-16" y1="14" x2="-6" y2="14" stroke="white" stroke-opacity="0.4" stroke-width="1.5" stroke-linecap="round"/>
            <line x1="-20" y1="17" x2="-9" y2="17" stroke="white" stroke-opacity="0.3" stroke-width="1.5" stroke-linecap="round"/>
            <line x1="-17" y1="20" x2="-7" y2="20" stroke="white" stroke-opacity="0.4" stroke-width="1.5" stroke-linecap="round"/>
          </g>
          <g class="race-car-jake">
            <circle cx="0" cy="17" r="9" fill="white" fill-opacity="0.7"/>
            <line x1="-4" y1="16" x2="-1" y2="16" stroke="#1e3a8a" stroke-width="1.6" stroke-linecap="round"/>
            <line x1="1" y1="16" x2="4" y2="16" stroke="#1e3a8a" stroke-width="1.6" stroke-linecap="round"/>
            <path d="M-2.5 19.5 Q0 21 2.5 19.5" stroke="#1e3a8a" stroke-width="1" fill="none" stroke-linecap="round"/>
          </g>

          <g class="win-stamp" transform="translate(280, 50)">
            <circle cx="0" cy="0" r="14" fill="white" fill-opacity="0.18" stroke="white" stroke-opacity="0.55" stroke-width="1.5"/>
            <path d="M-6 0 L-1.5 5 L6 -5" stroke="white" stroke-opacity="0.95" stroke-width="2.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
          </g>
        </g>
      </g>

      <!-- Score dashboard -->
      <g class="score-dashboard" transform="translate(1100, 170)">

        <g transform="translate(35, 60)">
          <circle cx="0" cy="0" r="32" stroke="white" stroke-opacity="0.1" stroke-width="5" fill="none"/>
          <circle cx="0" cy="0" r="32" stroke="white" stroke-opacity="0.55" stroke-width="5" fill="none"
            stroke-dasharray="201" stroke-linecap="round"
            transform="rotate(-90)" class="dash-ring dash-ring-1"/>
          <text x="0" y="-1" text-anchor="middle" dominant-baseline="middle" fill="white" fill-opacity="0.9" font-size="16" font-weight="900" font-family="monospace" class="dash-num dash-num-1">100</text>
          <text x="0" y="11" text-anchor="middle" fill="white" fill-opacity="0.4" font-size="6" font-family="monospace">/100</text>
        </g>
        <text x="35" y="115" text-anchor="middle" fill="white" fill-opacity="0.55" font-size="7" font-weight="700" font-family="monospace" letter-spacing="1" class="dash-label dash-label-1">BEST PRACTICES</text>

        <g transform="translate(120, 60)">
          <circle cx="0" cy="0" r="32" stroke="white" stroke-opacity="0.1" stroke-width="5" fill="none"/>
          <circle cx="0" cy="0" r="32" stroke="white" stroke-opacity="0.55" stroke-width="5" fill="none"
            stroke-dasharray="201" stroke-linecap="round"
            transform="rotate(-90)" class="dash-ring dash-ring-2"/>
          <text x="0" y="-1" text-anchor="middle" dominant-baseline="middle" fill="white" fill-opacity="0.9" font-size="16" font-weight="900" font-family="monospace" class="dash-num dash-num-2">100</text>
          <text x="0" y="11" text-anchor="middle" fill="white" fill-opacity="0.4" font-size="6" font-family="monospace">/100</text>
        </g>
        <text x="120" y="115" text-anchor="middle" fill="white" fill-opacity="0.55" font-size="7" font-weight="700" font-family="monospace" letter-spacing="1" class="dash-label dash-label-2">ACCESSIBILITY</text>

        <g transform="translate(205, 60)">
          <circle cx="0" cy="0" r="32" stroke="white" stroke-opacity="0.1" stroke-width="5" fill="none"/>
          <circle cx="0" cy="0" r="32" stroke="white" stroke-opacity="0.55" stroke-width="5" fill="none"
            stroke-dasharray="201" stroke-linecap="round"
            transform="rotate(-90)" class="dash-ring dash-ring-3"/>
          <text x="0" y="-1" text-anchor="middle" dominant-baseline="middle" fill="white" fill-opacity="0.9" font-size="16" font-weight="900" font-family="monospace" class="dash-num dash-num-3">100</text>
          <text x="0" y="11" text-anchor="middle" fill="white" fill-opacity="0.4" font-size="6" font-family="monospace">/100</text>
        </g>
        <text x="205" y="115" text-anchor="middle" fill="white" fill-opacity="0.55" font-size="7" font-weight="700" font-family="monospace" letter-spacing="1" class="dash-label dash-label-3">SEO</text>

        <g transform="translate(290, 60)">
          <circle cx="0" cy="0" r="36" stroke="white" stroke-opacity="0.12" stroke-width="6" fill="none"/>
          <circle cx="0" cy="0" r="36" stroke="white" stroke-opacity="0.65" stroke-width="6" fill="none"
            stroke-dasharray="226" stroke-linecap="round"
            transform="rotate(-90)" class="dash-ring dash-ring-4"/>
          <text x="0" y="-1" text-anchor="middle" dominant-baseline="middle" fill="white" fill-opacity="0.95" font-size="18" font-weight="900" font-family="monospace" class="dash-num dash-num-4">10</text>
          <text x="0" y="13" text-anchor="middle" fill="white" fill-opacity="0.5" font-size="7" font-family="monospace">/10</text>
        </g>
        <text x="290" y="115" text-anchor="middle" fill="white" fill-opacity="0.6" font-size="7" font-weight="700" font-family="monospace" letter-spacing="1" class="dash-label dash-label-4">WAVE ACCESS</text>

        <g class="sparkles">
          <circle cx="35" cy="20" r="1.5" fill="white" fill-opacity="0.5" class="sparkle s1"/>
          <circle cx="120" cy="22" r="1.2" fill="white" fill-opacity="0.45" class="sparkle s2"/>
          <circle cx="205" cy="20" r="1.5" fill="white" fill-opacity="0.5" class="sparkle s3"/>
          <circle cx="290" cy="18" r="2" fill="white" fill-opacity="0.6" class="sparkle s4"/>
        </g>
      </g>

      <!-- Ambient drift dots -->
      <g class="ambient-dots">
        <circle cx="520" cy="120" r="2" fill="white" fill-opacity="0.25" class="float-dot d1"/>
        <circle cx="960" cy="100" r="2.5" fill="white" fill-opacity="0.3" class="float-dot d2"/>
        <circle cx="580" cy="420" r="2" fill="white" fill-opacity="0.25" class="float-dot d3"/>
        <circle cx="880" cy="440" r="2" fill="white" fill-opacity="0.3" class="float-dot d4"/>
      </g>

      <g stroke="white" stroke-opacity="0.04" stroke-width="1">
        <line x1="0" y1="130" x2="1440" y2="130"/>
        <line x1="0" y1="260" x2="1440" y2="260"/>
        <line x1="0" y1="390" x2="1440" y2="390"/>
        <line x1="360" y1="0" x2="360" y2="520"/>
        <line x1="720" y1="0" x2="720" y2="520"/>
        <line x1="1080" y1="0" x2="1080" y2="520"/>
      </g>
    </svg>

    <!-- MOBILE SVG -->
    <svg class="hero-bg-mobile" viewBox="0 0 400 600" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <defs>
        <linearGradient id="bgGradM" x1="0%" y1="0%" x2="100%" y2="100%">
          <stop offset="0%" style="stop-color:#1e3a8a;stop-opacity:1"/>
          <stop offset="100%" style="stop-color:#2563eb;stop-opacity:1"/>
        </linearGradient>
        <linearGradient id="glowGradM" x1="0%" y1="0%" x2="100%" y2="100%">
          <stop offset="0%" style="stop-color:#3b82f6;stop-opacity:0.3"/>
          <stop offset="100%" style="stop-color:#1d4ed8;stop-opacity:0"/>
        </linearGradient>
      </defs>
      <rect width="400" height="600" fill="url(#bgGradM)"/>
      <ellipse cx="100" cy="180" rx="240" ry="200" fill="url(#glowGradM)" class="glow-orb-1"/>
      <ellipse cx="320" cy="500" rx="220" ry="180" fill="url(#glowGradM)" class="glow-orb-2"/>

      <g class="speed-race" transform="translate(30, 65)">
        <g transform="translate(0, 0)">
          <text x="0" y="0" fill="white" fill-opacity="0.4" font-size="8" font-family="monospace">AGENCY</text>
          <text x="340" y="0" text-anchor="end" fill="white" fill-opacity="0.35" font-size="8" font-family="monospace">10s</text>
          <rect x="0" y="5" width="340" height="12" rx="6" stroke="white" stroke-opacity="0.15" stroke-width="1" fill="white" fill-opacity="0.03"/>
          <line x1="340" y1="2" x2="340" y2="20" stroke="white" stroke-opacity="0.25" stroke-width="1.2" stroke-dasharray="2 3"/>
          <rect x="2" y="7" width="0" height="8" rx="4" fill="white" fill-opacity="0.18" class="race-bar-agency-mob"/>
          <g class="race-car-agency">
            <circle cx="0" cy="11" r="6" fill="white" fill-opacity="0.3"/>
            <circle cx="-1.5" cy="10" r="0.8" fill="#1e3a8a"/>
            <circle cx="1.5" cy="10" r="0.8" fill="#1e3a8a"/>
          </g>
        </g>

        <g transform="translate(0, 30)">
          <text x="0" y="0" fill="white" fill-opacity="0.65" font-size="8" font-family="monospace" font-weight="700">JAKE</text>
          <text x="340" y="0" text-anchor="end" fill="white" fill-opacity="0.55" font-size="8" font-family="monospace" font-weight="700">&lt;2s</text>
          <rect x="0" y="5" width="340" height="12" rx="6" stroke="white" stroke-opacity="0.28" stroke-width="1" fill="white" fill-opacity="0.05"/>
          <line x1="340" y1="2" x2="340" y2="20" stroke="white" stroke-opacity="0.45" stroke-width="1.2"/>
          <rect x="2" y="7" width="0" height="8" rx="4" fill="white" fill-opacity="0.55" class="race-bar-jake-mob"/>
          <g class="speed-lines">
            <line x1="-10" y1="9" x2="-3" y2="9" stroke="white" stroke-opacity="0.4" stroke-width="1.2" stroke-linecap="round"/>
            <line x1="-13" y1="12" x2="-5" y2="12" stroke="white" stroke-opacity="0.3" stroke-width="1.2" stroke-linecap="round"/>
          </g>
          <g class="race-car-jake">
            <circle cx="0" cy="11" r="6" fill="white" fill-opacity="0.7"/>
            <line x1="-2.5" y1="10" x2="-0.5" y2="10" stroke="#1e3a8a" stroke-width="1.2" stroke-linecap="round"/>
            <line x1="0.5" y1="10" x2="2.5" y2="10" stroke="#1e3a8a" stroke-width="1.2" stroke-linecap="round"/>
          </g>

          <g class="win-stamp" transform="translate(340, 32)">
            <circle cx="0" cy="0" r="10" fill="white" fill-opacity="0.18" stroke="white" stroke-opacity="0.55" stroke-width="1.2"/>
            <path d="M-4 0 L-1 3 L4 -3" stroke="white" stroke-opacity="0.95" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
          </g>
        </g>
      </g>

      <g class="score-dashboard" transform="translate(20, 485)">
        <g transform="translate(45, 20)">
          <circle cx="0" cy="0" r="18" stroke="white" stroke-opacity="0.1" stroke-width="3" fill="none"/>
          <circle cx="0" cy="0" r="18" stroke="white" stroke-opacity="0.6" stroke-width="3" fill="none"
            stroke-dasharray="113" stroke-linecap="round"
            transform="rotate(-90)" class="dash-ring-mob dash-ring-1"/>
          <text x="0" y="0" text-anchor="middle" dominant-baseline="middle" fill="white" fill-opacity="0.95" font-size="11" font-weight="900" font-family="monospace" class="dash-num-mob dash-num-1">100</text>
        </g>
        <text x="45" y="50" text-anchor="middle" fill="white" fill-opacity="0.6" font-size="6" font-weight="700" font-family="monospace" letter-spacing="0.5" class="dash-label-mob dash-label-1">BEST PRACTICES</text>

        <g transform="translate(135, 20)">
          <circle cx="0" cy="0" r="18" stroke="white" stroke-opacity="0.1" stroke-width="3" fill="none"/>
          <circle cx="0" cy="0" r="18" stroke="white" stroke-opacity="0.6" stroke-width="3" fill="none"
            stroke-dasharray="113" stroke-linecap="round"
            transform="rotate(-90)" class="dash-ring-mob dash-ring-2"/>
          <text x="0" y="0" text-anchor="middle" dominant-baseline="middle" fill="white" fill-opacity="0.95" font-size="11" font-weight="900" font-family="monospace" class="dash-num-mob dash-num-2">100</text>
        </g>
        <text x="135" y="50" text-anchor="middle" fill="white" fill-opacity="0.6" font-size="6" font-weight="700" font-family="monospace" letter-spacing="0.5" class="dash-label-mob dash-label-2">ACCESSIBILITY</text>

        <g transform="translate(225, 20)">
          <circle cx="0" cy="0" r="18" stroke="white" stroke-opacity="0.1" stroke-width="3" fill="none"/>
          <circle cx="0" cy="0" r="18" stroke="white" stroke-opacity="0.6" stroke-width="3" fill="none"
            stroke-dasharray="113" stroke-linecap="round"
            transform="rotate(-90)" class="dash-ring-mob dash-ring-3"/>
          <text x="0" y="0" text-anchor="middle" dominant-baseline="middle" fill="white" fill-opacity="0.95" font-size="11" font-weight="900" font-family="monospace" class="dash-num-mob dash-num-3">100</text>
        </g>
        <text x="225" y="50" text-anchor="middle" fill="white" fill-opacity="0.6" font-size="6" font-weight="700" font-family="monospace" letter-spacing="0.5" class="dash-label-mob dash-label-3">SEO</text>

        <g transform="translate(315, 20)">
          <circle cx="0" cy="0" r="20" stroke="white" stroke-opacity="0.12" stroke-width="3.5" fill="none"/>
          <circle cx="0" cy="0" r="20" stroke="white" stroke-opacity="0.7" stroke-width="3.5" fill="none"
            stroke-dasharray="126" stroke-linecap="round"
            transform="rotate(-90)" class="dash-ring-mob dash-ring-4"/>
          <text x="0" y="0" text-anchor="middle" dominant-baseline="middle" fill="white" fill-opacity="0.95" font-size="12" font-weight="900" font-family="monospace" class="dash-num-mob dash-num-4">10</text>
        </g>
        <text x="315" y="50" text-anchor="middle" fill="white" fill-opacity="0.65" font-size="6" font-weight="700" font-family="monospace" letter-spacing="0.5" class="dash-label-mob dash-label-4">WAVE ACCESS</text>

        <g class="sparkles">
          <circle cx="45" cy="-2" r="1" fill="white" fill-opacity="0.5" class="sparkle s1"/>
          <circle cx="135" cy="-1" r="0.8" fill="white" fill-opacity="0.45" class="sparkle s2"/>
          <circle cx="225" cy="-2" r="1" fill="white" fill-opacity="0.5" class="sparkle s3"/>
          <circle cx="315" cy="-3" r="1.3" fill="white" fill-opacity="0.6" class="sparkle s4"/>
        </g>
      </g>

      <g class="ambient-dots">
        <circle cx="80" cy="220" r="1.5" fill="white" fill-opacity="0.25" class="float-dot d1"/>
        <circle cx="320" cy="240" r="2" fill="white" fill-opacity="0.3" class="float-dot d2"/>
        <circle cx="120" cy="400" r="1.5" fill="white" fill-opacity="0.25" class="float-dot d3"/>
        <circle cx="290" cy="380" r="1.5" fill="white" fill-opacity="0.3" class="float-dot d4"/>
      </g>

      <g stroke="white" stroke-opacity="0.04" stroke-width="1">
        <line x1="0" y1="150" x2="400" y2="150"/>
        <line x1="0" y1="300" x2="400" y2="300"/>
        <line x1="0" y1="450" x2="400" y2="450"/>
        <line x1="133" y1="0" x2="133" y2="600"/>
        <line x1="266" y1="0" x2="266" y2="600"/>
      </g>
    </svg>

    <div id="hero-content">
      <p class="hero-label">{content.headerLabel}</p>
      <h1 id="hero-wordmark">{content.headerTitle}</h1>
      <p id="hero-tagline">{content.headerSubtitle}</p>
      <a href="/web-services" id="hero-cta">
        View Web Packages
        <svg style="height:1rem;width:1rem;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>

    <div id="scroll-hint" aria-hidden="true" role="button" tabindex="-1" onclick="document.getElementById('intro-section').scrollIntoView({behavior:'smooth'})">
      <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" style="height:1.5rem;width:1.5rem;"><path d="M12 5v14M5 12l7 7 7-7"/></svg>
    </div>
  </section>

  <!-- Intro -->
  <section id="intro-section" style="background:white;padding:4rem 1.5rem;">
    <div style="max-width:56rem;margin:0 auto;">
      <h2 style="font-size:1.75rem;font-weight:800;color:#111827;margin-bottom:1rem;">{content.introTitle}</h2>
      <p style="color:#4b5563;line-height:1.85;font-size:1.05rem;margin-bottom:1rem;">{content.introPara1}</p>
      <p style="color:#4b5563;line-height:1.85;font-size:1.05rem;margin-bottom:1rem;">{content.introPara2}</p>
      <p style="color:#4b5563;line-height:1.85;font-size:1.05rem;">{content.introPara3}</p>
    </div>
  </section>

  <!-- Speed Section -->
  <section style="background:#f8fafc;padding:4rem 1.5rem;">
    <div style="max-width:72rem;margin:0 auto;">
      <div style="text-align:center;margin-bottom:3rem;">
        <p style="font-size:0.875rem;font-weight:600;text-transform:uppercase;letter-spacing:0.1em;color:#2563eb;">{content.speedLabel}</p>
        <h2 style="font-size:2rem;font-weight:800;color:#111827;margin-top:0.5rem;">{content.speedTitle}</h2>
        <p style="color:#6b7280;margin-top:0.75rem;max-width:36rem;margin-left:auto;margin-right:auto;line-height:1.75;">{content.speedDesc}</p>
      </div>
      <div id="speed-grid">
        <div class="speed-card">
          <div class="speed-label">Typical Agency Site</div>
          <div class="speed-bar-wrap">
            <div class="speed-bar speed-bar-bad" style="width:85%;"><span>5–15 seconds</span></div>
          </div>
          <p class="speed-note">WordPress with plugins, unoptimized images, shared hosting</p>
        </div>
        <div class="speed-card">
          <div class="speed-label">Jake Fixes Tech Site</div>
          <div class="speed-bar-wrap">
            <div class="speed-bar speed-bar-good" style="width:15%;"><span style="color:#14532d;margin-left:0.5rem;">Under 2s</span></div>
          </div>
          <p class="speed-note">Astro static HTML, Cloudflare global CDN, zero unnecessary JavaScript</p>
        </div>
      </div>
      <div id="stat-cards">
        <div class="stat-card"><div class="stat-number" style="color:#1d4ed8;">5–10x</div><div class="stat-label">Faster Load Time</div><div class="stat-sub">vs typical agency sites</div></div>
        <div class="stat-card"><div class="stat-number" style="color:#1d4ed8;">&lt;2s</div><div class="stat-label">Load Time</div><div class="stat-sub">Globally on Cloudflare</div></div>
        <div class="stat-card"><div class="stat-number" style="color:#15803d;">100/100</div><div class="stat-label">Lighthouse Desktop</div><div class="stat-sub">Every page, every time</div></div>
        <div class="stat-card"><div class="stat-number" style="color:#15803d;">10/10</div><div class="stat-label">WAVE Accessibility</div><div class="stat-sub">Every single page</div></div>
      </div>
    </div>
  </section>

  <!-- Lighthouse / WAVE -->
  <section style="background:white;padding:4rem 1.5rem;">
    <div style="max-width:72rem;margin:0 auto;">
      <div style="text-align:center;margin-bottom:3rem;">
        <p style="font-size:0.875rem;font-weight:600;text-transform:uppercase;letter-spacing:0.1em;color:#2563eb;">{content.scoresLabel}</p>
        <h2 style="font-size:2rem;font-weight:800;color:#111827;margin-top:0.5rem;">{content.scoresTitle}</h2>
      </div>
