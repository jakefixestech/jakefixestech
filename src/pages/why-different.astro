---
import Layout from '../layouts/Layout.astro';
import content from '../content/why-different.yml';
---

<Layout
  title="Why My Websites Are Different | Jake Fixes Tech"
  description="See why Jake Fixes Tech builds faster, safer, and more accessible websites than traditional web agencies — at a fraction of the ongoing cost."
>

  <!-- Hero -->
  <section style="position:relative;overflow:hidden;background-color:rgb(30,64,175);">
    <img src="/hero.jpg" alt="Professional tech workspace with dual monitors" width="1920" height="1080" fetchpriority="high" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;z-index:0;" />
    <div style="position:absolute;inset:0;background:linear-gradient(135deg,rgba(30,64,175,0.88),rgba(37,99,235,0.88));z-index:1;"></div>
    <div style="max-width:56rem;margin:0 auto;padding:5rem 1.5rem 4rem 1.5rem;text-align:center;position:relative;z-index:2;">
      <p style="font-size:0.875rem;font-weight:600;text-transform:uppercase;letter-spacing:0.1em;color:#93c5fd;">{content.headerLabel}</p>
      <h1 style="font-size:2.5rem;font-weight:800;color:white;margin-top:0.5rem;margin-bottom:1rem;">{content.headerTitle}</h1>
      <p style="color:#bfdbfe;font-size:1.1rem;line-height:1.75;max-width:42rem;margin:0 auto;">{content.headerSubtitle}</p>
    </div>
  </section>

  <!-- Intro -->
  <section style="background:white;padding:4rem 1.5rem;">
    <div style="max-width:56rem;margin:0 auto;">
      <h2 style="font-size:1.75rem;font-weight:800;color:#111827;margin-bottom:1rem;">{content.introTitle}</h2>
      <p style="color:#4b5563;line-height:1.85;font-size:1.05rem;margin-bottom:1rem;">{content.introPara1}</p>
      <p style="color:#4b5563;line-height:1.85;font-size:1.05rem;margin-bottom:1rem;">{content.introPara2}</p>
      <p style="color:#4b5563;line-height:1.85;font-size:1.05rem;">{content.introPara3}</p>
    </div>
  </section>

  <!-- Speed Section -->
  <section style="background:#f8fafc;padding:4rem 1.5rem;">
    <div style="max-width:72rem;margin:0 auto;">
      <div style="text-align:center;margin-bottom:3rem;">
        <p style="font-size:0.875rem;font-weight:600;text-transform:uppercase;letter-spacing:0.1em;color:#2563eb;">{content.speedLabel}</p>
        <h2 style="font-size:2rem;font-weight:800;color:#111827;margin-top:0.5rem;">{content.speedTitle}</h2>
        <p style="color:#6b7280;margin-top:0.75rem;max-width:36rem;margin-left:auto;margin-right:auto;line-height:1.75;">{content.speedDesc}</p>
      </div>
      <div id="speed-grid">
        <div class="speed-card">
          <div class="speed-label">Typical Agency Site</div>
          <div class="speed-bar-wrap">
            <div class="speed-bar speed-bar-bad" style="width:85%;"><span>5–15 seconds</span></div>
          </div>
          <p class="speed-note">WordPress with plugins, unoptimized images, shared hosting</p>
        </div>
        <div class="speed-card">
          <div class="speed-label">Jake Fixes Tech Site</div>
          <div class="speed-bar-wrap">
            <div class="speed-bar speed-bar-good" style="width:15%;"><span style="color:#14532d;margin-left:0.5rem;">Under 2s</span></div>
          </div>
          <p class="speed-note">Astro static HTML, Cloudflare global CDN, zero unnecessary JavaScript</p>
        </div>
      </div>
      <div id="stat-cards">
        <div class="stat-card"><div class="stat-number" style="color:#1d4ed8;">5–10x</div><div class="stat-label">Faster Load Time</div><div class="stat-sub">vs typical agency sites</div></div>
        <div class="stat-card"><div class="stat-number" style="color:#1d4ed8;">&lt;2s</div><div class="stat-label">Load Time</div><div class="stat-sub">Globally on Cloudflare</div></div>
        <div class="stat-card"><div class="stat-number" style="color:#15803d;">100/100</div><div class="stat-label">Lighthouse Desktop</div><div class="stat-sub">Every page, every time</div></div>
        <div class="stat-card"><div class="stat-number" style="color:#15803d;">10/10</div><div class="stat-label">WAVE Accessibility</div><div class="stat-sub">Every single page</div></div>
      </div>
    </div>
  </section>

  <!-- Lighthouse / WAVE -->
  <section style="background:white;padding:4rem 1.5rem;">
    <div style="max-width:72rem;margin:0 auto;">
      <div style="text-align:center;margin-bottom:3rem;">
        <p style="font-size:0.875rem;font-weight:600;text-transform:uppercase;letter-spacing:0.1em;color:#2563eb;">{content.scoresLabel}</p>
        <h2 style="font-size:2rem;font-weight:800;color:#111827;margin-top:0.5rem;">{content.scoresTitle}</h2>
      </div>
      <div id="tools-grid">
        <div class="tool-card">
          <div class="tool-icon">🔦</div>
          <h3>{content.tool1Title}</h3>
          <p>{content.tool1Desc}</p>
          <div class="score-box">
            <div class="score-agency">TYPICAL AGENCY: 50–75 Performance</div>
            <div class="score-jake">JAKE FIXES TECH: 100 Desktop · 398–400 Mobile ✅</div>
          </div>
        </div>
        <div class="tool-card">
          <div class="tool-icon">♿</div>
          <h3>{content.tool2Title}</h3>
          <p>{content.tool2Desc}</p>
          <div class="score-box">
            <div class="score-agency">TYPICAL AGENCY: Never checked</div>
            <div class="score-jake">JAKE FIXES TECH: 10 / 10 ✅</div>
          </div>
        </div>
        <div class="tool-card">
          <div class="tool-icon">⚖️</div>
          <h3>{content.tool3Title}</h3>
          <p>{content.tool3Desc}</p>
          <div class="score-box">
            <div class="score-agency">TYPICAL AGENCY: Rarely addressed</div>
            <div class="score-jake">JAKE FIXES TECH: WCAG 2.1 AA ✅</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Accessibility Widget -->
  <section style="background:#f8fafc;padding:4rem 1.5rem;">
    <div style="max-width:56rem;margin:0 auto;">
      <div style="text-align:center;margin-bottom:2.5rem;">
        <p style="font-size:0.875rem;font-weight:600;text-transform:uppercase;letter-spacing:0.1em;color:#2563eb;">{content.widgetLabel}</p>
        <h2 style="font-size:2rem;font-weight:800;color:#111827;margin-top:0.5rem;">{content.widgetTitle}</h2>
        <p style="color:#6b7280;margin-top:0.75rem;max-width:40rem;margin-left:auto;margin-right:auto;line-height:1.75;">{content.widgetDesc}</p>
      </div>
      <div class="widget-compare-grid">
        <div style="background:white;border:2px solid #fca5a5;border-radius:0.75rem;padding:1.5rem;">
          <div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:1rem;">
            <span style="font-size:1.5rem;">⚠️</span>
            <h3 style="font-size:1rem;font-weight:700;color:#991b1b;margin:0;">Accessibility Overlay Widgets</h3>
          </div>
          <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:0.625rem;">
            <li style="font-size:0.875rem;color:#374151;">❌ Layered on top of broken underlying code</li>
            <li style="font-size:0.875rem;color:#374151;">❌ Puts the burden on the visitor to fix it themselves</li>
            <li style="font-size:0.875rem;color:#374151;">❌ Can interfere with real screen readers</li>
            <li style="font-size:0.875rem;color:#374151;">❌ Often costs $500–$1,500/year</li>
            <li style="font-size:0.875rem;color:#374151;">❌ Doesn't guarantee ADA compliance</li>
          </ul>
        </div>
        <div style="background:white;border:2px solid #86efac;border-radius:0.75rem;padding:1.5rem;">
          <div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:1rem;">
            <span style="font-size:1.5rem;">✅</span>
            <h3 style="font-size:1rem;font-weight:700;color:#166534;margin:0;">Built-In Accessibility (My Approach)</h3>
          </div>
          <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:0.625rem;">
            <li style="font-size:0.875rem;color:#374151;">✅ Proper semantic HTML from the ground up</li>
            <li style="font-size:0.875rem;color:#374151;">✅ Works for every visitor without any extra steps</li>
            <li style="font-size:0.875rem;color:#374151;">✅ Compatible with all screen readers and assistive tools</li>
            <li style="font-size:0.875rem;color:#374151;">✅ Included in every build at no extra charge</li>
            <li style="font-size:0.875rem;color:#374151;">✅ Genuine WCAG AA compliance, verified on every page</li>
          </ul>
        </div>
      </div>
      <div style="background:white;border:1px solid #e5e7eb;border-radius:0.75rem;padding:1.5rem;">
        <p style="color:#4b5563;font-size:0.95rem;line-height:1.85;margin:0;">{content.widgetNote}</p>
      </div>
    </div>
  </section>

  <!-- Hidden Costs -->
  <section style="background:white;padding:4rem 1.5rem;">
    <div style="max-width:72rem;margin:0 auto;">
      <div style="text-align:center;margin-bottom:3rem;">
        <p style="font-size:0.875rem;font-weight:600;text-transform:uppercase;letter-spacing:0.1em;color:#2563eb;">{content.costsLabel}</p>
        <h2 style="font-size:2rem;font-weight:800;color:#111827;margin-top:0.5rem;">{content.costsTitle}</h2>
        <p style="color:#6b7280;margin-top:0.75rem;max-width:40rem;margin-left:auto;margin-right:auto;line-height:1.75;">{content.costsDesc}</p>
      </div>
      <div class="compare-cards">
        <div class="compare-header-row">
          <div style="flex:1;min-width:0;"></div>
          <div class="compare-cols">
            <div style="width:220px;text-align:center;font-size:0.8rem;font-weight:700;color:white;text-transform:uppercase;letter-spacing:0.05em;padding:0 1rem;border-right:1px solid rgba(255,255,255,0.2);">Old School Agency</div>
            <div style="width:220px;text-align:center;font-size:0.8rem;font-weight:700;color:white;text-transform:uppercase;letter-spacing:0.05em;padding:0 1rem;">Jake Fixes Tech</div>
          </div>
        </div>
        <div class="compare-card"><div class="compare-feature"><div class="feature-name">SSL Certificate</div><div class="feature-desc">The padlock icon that makes your site secure</div></div><div class="compare-cols"><div class="compare-agency">$50–$700/yr</div><div class="compare-jake">✅ Free (Cloudflare)</div></div></div>
        <div class="compare-card row-alt"><div class="compare-feature"><div class="feature-name">Website Hosting</div><div class="feature-desc">Where your website lives on the internet</div></div><div class="compare-cols"><div class="compare-agency">$30–$100/mo</div><div class="compare-jake">✅ Free (Cloudflare Pages)</div></div></div>
        <div class="compare-card"><div class="compare-feature"><div class="feature-name">Website Backups</div><div class="feature-desc">Saving copies in case something goes wrong</div></div><div class="compare-cols"><div class="compare-agency">$20–$50/mo</div><div class="compare-jake">✅ Free (GitHub)</div></div></div>
        <div class="compare-card row-alt"><div class="compare-feature"><div class="feature-name">CDN &amp; DDoS Protection</div><div class="feature-desc">Global speed boost and attack protection</div></div><div class="compare-cols"><div class="compare-agency">$20–$200/mo</div><div class="compare-jake">✅ Free (Cloudflare)</div></div></div>
        <div class="compare-card"><div class="compare-feature"><div class="feature-name">Platform</div><div class="feature-desc">What the website is built on</div></div><div class="compare-cols"><div class="compare-agency">WordPress (outdated, hack-prone)</div><div class="compare-jake">✅ Astro (modern, static, secure)</div></div></div>
        <div class="compare-card row-alt"><div class="compare-feature"><div class="feature-name">Security Risk</div><div class="feature-desc">How vulnerable your site is to attacks</div></div><div class="compare-cols"><div class="compare-agency">⚠️ High. WordPress is the #1 hacked platform</div><div class="compare-jake">✅ Minimal. Static HTML has no attack surface</div></div></div>
        <div class="compare-card"><div class="compare-feature"><div class="feature-name">Page Load Time</div><div class="feature-desc">How fast your site loads for visitors</div></div><div class="compare-cols"><div class="compare-agency">⚠️ 5–15 seconds</div><div class="compare-jake">✅ Under 2 seconds</div></div></div>
        <div class="compare-card row-alt"><div class="compare-feature"><div class="feature-name">Lighthouse Performance Score</div><div class="feature-desc">Google's official website performance grade</div></div><div class="compare-cols"><div class="compare-agency">⚠️ 50–75 / 100</div><div class="compare-jake">✅ 100 / 100 Desktop — Perfect</div></div></div>
        <div class="compare-card"><div class="compare-feature"><div class="feature-name">ADA / WCAG Accessibility</div><div class="feature-desc">Legal compliance for users with disabilities</div></div><div class="compare-cols"><div class="compare-agency">⚠️ Rarely included</div><div class="compare-jake">✅ Built in, every page</div></div></div>
        <div class="compare-card row-alt"><div class="compare-feature"><div class="feature-name">You Own the Website</div><div class="feature-desc">Full code and content ownership</div></div><div class="compare-cols"><div class="compare-agency">⚠️ Sometimes held hostage</div><div class="compare-jake">✅ Always. It's yours outright</div></div></div>
      </div>
      <div style="margin-top:2rem;background:#fef9c3;border:2px solid #fbbf24;border-radius:0.75rem;padding:1.25rem 1.5rem;">
        <p style="color:#92400e;font-size:0.95rem;line-height:1.75;margin:0;">💡 <strong>Quick math:</strong> {content.costsMath}</p>
      </div>
    </div>
  </section>

  <!-- Transparent Pricing -->
  <section style="background:#eff6ff;padding:4rem 1.5rem;border-top:1px solid #bfdbfe;border-bottom:1px solid #bfdbfe;">
    <div style="max-width:56rem;margin:0 auto;">
      <div style="text-align:center;margin-bottom:2.5rem;">
        <p style="font-size:0.875rem;font-weight:600;text-transform:uppercase;letter-spacing:0.1em;color:#2563eb;">{content.pricingLabel}</p>
        <h2 style="font-size:2rem;font-weight:800;color:#111827;margin-top:0.5rem;">{content.pricingTitle}</h2>
        <p style="color:#4b5563;margin-top:0.75rem;max-width:40rem;margin-left:auto;margin-right:auto;line-height:1.75;">{content.pricingDesc}</p>
      </div>
      <div class="two-col-grid" style="margin-bottom:2rem;">
        <div style="background:white;border:2px solid #fca5a5;border-radius:0.75rem;padding:1.5rem;">
          <div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:1rem;"><span style="font-size:1.5rem;">😬</span><h3 style="font-size:1rem;font-weight:700;color:#991b1b;margin:0;">The "Call for a Quote" Approach</h3></div>
          <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:0.625rem;">
            <li style="font-size:0.875rem;color:#374151;">❌ No prices on the website</li>
            <li style="font-size:0.875rem;color:#374151;">❌ You have to sit through a sales call first</li>
            <li style="font-size:0.875rem;color:#374151;">❌ Price depends on how much they think you'll pay</li>
            <li style="font-size:0.875rem;color:#374151;">❌ Scope creep and surprise fees after the fact</li>
            <li style="font-size:0.875rem;color:#374151;">❌ Hard to compare or budget without a number</li>
          </ul>
        </div>
        <div style="background:white;border:2px solid #86efac;border-radius:0.75rem;padding:1.5rem;">
          <div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:1rem;"><span style="font-size:1.5rem;">✅</span><h3 style="font-size:1rem;font-weight:700;color:#166534;margin:0;">The Jake Fixes Tech Approach</h3></div>
          <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:0.625rem;">
            <li style="font-size:0.875rem;color:#374151;">✅ Every package price is listed publicly</li>
            <li style="font-size:0.875rem;color:#374151;">✅ You know what you're getting before you reach out</li>
            <li style="font-size:0.875rem;color:#374151;">✅ Same price for everyone — no wallet sizing</li>
            <li style="font-size:0.875rem;color:#374151;">✅ What's included is clearly spelled out</li>
            <li style="font-size:0.875rem;color:#374151;">✅ Easy to budget and decide on your own time</li>
          </ul>
        </div>
      </div>
      <div style="background:white;border:1px solid #bfdbfe;border-radius:0.75rem;padding:1.5rem;text-align:center;">
        <p style="color:#1e3a8a;font-size:1rem;font-weight:600;margin-bottom:0.5rem;">Starter from $750 &nbsp;·&nbsp; Professional from $2,000 &nbsp;·&nbsp; Premium from $3,500</p>
        <p style="color:#4b5563;font-size:0.875rem;line-height:1.75;margin-bottom:1.25rem;">{content.pricingNote}</p>
        <a href="/web-services" style="display:inline-flex;align-items:center;gap:0.5rem;background:#2563eb;color:white;font-weight:700;padding:0.75rem 1.75rem;border-radius:0.5rem;text-decoration:none;font-size:0.9rem;">
          See Full Pricing &amp; Packages
          <svg style="height:1rem;width:1rem;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- WordPress vs Astro -->
  <section style="background:#f8fafc;padding:4rem 1.5rem;">
    <div style="max-width:72rem;margin:0 auto;">
      <div style="text-align:center;margin-bottom:3rem;">
        <p style="font-size:0.875rem;font-weight:600;text-transform:uppercase;letter-spacing:0.1em;color:#2563eb;">{content.platformLabel}</p>
        <h2 style="font-size:2rem;font-weight:800;color:#111827;margin-top:0.5rem;">{content.platformTitle}</h2>
        <p style="color:#6b7280;margin-top:0.75rem;max-width:40rem;margin-left:auto;margin-right:auto;line-height:1.75;">{content.platformDesc}</p>
      </div>
      <div id="platform-grid">
        <div class="platform-card platform-bad">
          <div class="platform-header-bad"><h3>WordPress</h3><span class="platform-tag-bad">Old School</span></div>
          <ul class="platform-list">
            <li>⚠️ #1 most hacked website platform</li>
            <li>⚠️ Requires constant plugin updates</li>
            <li>⚠️ Plugins conflict and break things</li>
            <li>⚠️ Database driven. Slow by default</li>
            <li>⚠️ Needs paid hosting to run</li>
            <li>⚠️ Performance requires extra paid plugins</li>
            <li>⚠️ Accessibility requires extra paid plugins</li>
            <li>⚠️ Heavy, bloated pages by default</li>
          </ul>
        </div>
        <div class="platform-card platform-good">
          <div class="platform-header-good"><h3>Astro + Cloudflare</h3><span class="platform-tag-good">Modern Stack</span></div>
          <ul class="platform-list">
            <li>✅ Static HTML. Nothing to hack</li>
            <li>✅ No plugins, no updates to manage</li>
            <li>✅ Nothing to conflict or break</li>
            <li>✅ Pre-built pages. Loads fast</li>
            <li>✅ Free hosting on Cloudflare Pages</li>
            <li>✅ Performance is built in by design</li>
            <li>✅ Accessibility built in from scratch</li>
            <li>✅ Lean, optimized pages</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Bottom Line -->
  <section style="background:white;padding:4rem 1.5rem;">
    <div style="max-width:56rem;margin:0 auto;text-align:center;">
      <h2 style="font-size:2rem;font-weight:800;color:#111827;margin-bottom:1rem;">{content.bottomTitle}</h2>
      <p style="color:#4b5563;line-height:1.85;font-size:1.05rem;margin-bottom:1rem;">{content.bottomPara1}</p>
      <p style="color:#4b5563;line-height:1.85;font-size:1.05rem;margin-bottom:2rem;">{content.bottomPara2}</p>
      <div style="display:flex;flex-wrap:wrap;justify-content:center;gap:1rem;">
        <a href="/web-services" style="display:inline-flex;align-items:center;gap:0.5rem;background:#2563eb;color:white;font-weight:700;padding:0.875rem 2rem;border-radius:0.5rem;text-decoration:none;font-size:1rem;">
          View Web Packages
          <svg style="height:1rem;width:1rem;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
        <a href="/contact" style="display:inline-flex;align-items:center;gap:0.5rem;background:white;color:#1e3a8a;font-weight:700;padding:0.875rem 2rem;border-radius:0.5rem;text-decoration:none;font-size:1rem;border:2px solid #1e3a8a;">
          Get a Free Quote
          <svg style="height:1rem;width:1rem;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </section>

</Layout>

<style>
  #speed-grid { display: flex; flex-direction: column; gap: 1.5rem; max-width: 800px; margin: 0 auto 3rem auto; }
  .speed-card { background: white; border: 1px solid #e5e7eb; border-radius: 0.75rem; padding: 1.5rem; }
  .speed-label { font-weight: 700; color: #111827; margin-bottom: 0.75rem; font-size: 0.95rem; }
  .speed-bar-wrap { background: #f3f4f6; border-radius: 9999px; height: 2.5rem; width: 100%; overflow: hidden; margin-bottom: 0.75rem; display: flex; align-items: center; }
  .speed-bar { height: 100%; border-radius: 9999px; display: flex; align-items: center; padding: 0 1rem; font-weight: 700; font-size: 0.9rem; }
  .speed-bar-bad { background: #fca5a5; color: #7f1d1d; }
  .speed-bar-good { background: #86efac; color: #14532d; min-width: 80px; }
  .speed-note { font-size: 0.8rem; color: #6b7280; margin: 0; }
  #stat-cards { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 1.5rem; max-width: 900px; margin: 0 auto; }
  .stat-card { background: white; border: 1px solid #e5e7eb; border-radius: 0.75rem; padding: 1.5rem; text-align: center; }
  .stat-number { font-size: 2rem; font-weight: 800; line-height: 1; margin-bottom: 0.5rem; }
  .stat-label { font-size: 0.875rem; font-weight: 700; color: #111827; margin-bottom: 0.25rem; }
  .stat-sub { font-size: 0.75rem; color: #6b7280; }
  #tools-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; align-items: stretch; }
  .tool-card { background: #f8fafc; border: 1px solid #e5e7eb; border-radius: 0.75rem; padding: 1.5rem; display: flex; flex-direction: column; }
  .tool-icon { font-size: 2rem; margin-bottom: 0.75rem; }
  .tool-card h3 { font-size: 1.1rem; font-weight: 700; color: #111827; margin-bottom: 0.75rem; }
  .tool-card p { font-size: 0.875rem; color: #374151; line-height: 1.7; }
