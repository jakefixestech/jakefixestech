---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Weekend Pickup Service | Jake Fixes Tech — Littleton, NH"
description="Can't drop off your device during the week? I'll come pick it up. Saturdays and Sundays 9 AM–4 PM. Free within 10 miles of Littleton, tiered pricing beyond.">

  <!-- Animated SVG Hero -->
  <section id="hero-svg" aria-label="Weekend Pickup Service">

    <!-- DESKTOP SVG -->
    <svg class="hero-bg-desktop" viewBox="0 0 1440 520" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <defs>
        <linearGradient id="bgGrad" x1="0%" y1="0%" x2="100%" y2="100%">
          <stop offset="0%" style="stop-color:#1e3a8a;stop-opacity:1"/>
          <stop offset="100%" style="stop-color:#2563eb;stop-opacity:1"/>
        </linearGradient>
        <linearGradient id="glowGrad" x1="0%" y1="0%" x2="100%" y2="100%">
          <stop offset="0%" style="stop-color:#3b82f6;stop-opacity:0.3"/>
          <stop offset="100%" style="stop-color:#1d4ed8;stop-opacity:0"/>
        </linearGradient>
        <radialGradient id="ringGlow" cx="50%" cy="50%" r="50%">
          <stop offset="0%" style="stop-color:white;stop-opacity:0.15"/>
          <stop offset="70%" style="stop-color:white;stop-opacity:0.04"/>
          <stop offset="100%" style="stop-color:white;stop-opacity:0"/>
        </radialGradient>
      </defs>
      <rect width="1440" height="520" fill="url(#bgGrad)"/>
      <ellipse cx="320" cy="260" rx="380" ry="280" fill="url(#glowGrad)" class="glow-orb-1"/>
      <ellipse cx="1150" cy="260" rx="340" ry="260" fill="url(#glowGrad)" class="glow-orb-2"/>

      <!-- LEFT: Distance ring map — concentric tiers around Littleton anchor -->
      <g class="distance-map" transform="translate(220, 260)">
        <ellipse cx="0" cy="0" rx="200" ry="160" fill="url(#ringGlow)" class="map-glow"/>

        <!-- Concentric distance rings: 25mi, 20mi, 15mi, 10mi -->
        <circle cx="0" cy="0" r="150" fill="none" stroke="white" stroke-opacity="0.18" stroke-width="1.2" stroke-dasharray="3 4" class="ring ring-4"/>
        <circle cx="0" cy="0" r="115" fill="none" stroke="white" stroke-opacity="0.22" stroke-width="1.2" stroke-dasharray="3 4" class="ring ring-3"/>
        <circle cx="0" cy="0" r="80" fill="none" stroke="white" stroke-opacity="0.28" stroke-width="1.2" stroke-dasharray="3 4" class="ring ring-2"/>
        <circle cx="0" cy="0" r="45" fill="none" stroke="white" stroke-opacity="0.5" stroke-width="1.5" class="ring ring-1"/>

        <!-- Ring labels -->
        <text x="0" y="-45" text-anchor="middle" fill="white" fill-opacity="0.7" font-size="8" font-weight="700" font-family="monospace" letter-spacing="1" class="ring-label rl-1">10mi · FREE</text>
        <text x="0" y="-80" text-anchor="middle" fill="white" fill-opacity="0.55" font-size="8" font-weight="700" font-family="monospace" letter-spacing="1" class="ring-label rl-2">15mi · $20</text>
        <text x="0" y="-115" text-anchor="middle" fill="white" fill-opacity="0.5" font-size="8" font-weight="700" font-family="monospace" letter-spacing="1" class="ring-label rl-3">20mi · $40</text>
        <text x="0" y="-150" text-anchor="middle" fill="white" fill-opacity="0.45" font-size="8" font-weight="700" font-family="monospace" letter-spacing="1" class="ring-label rl-4">25mi · $60</text>

        <!-- Center pin (Littleton) -->
        <g class="center-pin">
          <path d="M0 -16 C-9 -16 -16 -9 -16 0 C-16 11 0 24 0 24 C0 24 16 11 16 0 C16 -9 9 -16 0 -16 Z"
            fill="white" fill-opacity="0.95" stroke="white" stroke-opacity="1" stroke-width="1.5"/>
          <circle cx="0" cy="-1" r="5" fill="#1e3a8a"/>
        </g>
        <text x="0" y="42" text-anchor="middle" fill="white" fill-opacity="0.9" font-size="10" font-weight="700" font-family="monospace" letter-spacing="1.5">LITTLETON, NH</text>

        <!-- A handful of subtle dots scattered to feel like neighboring towns -->
        <circle cx="-60" cy="-30" r="2" fill="white" fill-opacity="0.4" class="town-dot td-1"/>
        <circle cx="55" cy="-15" r="2" fill="white" fill-opacity="0.4" class="town-dot td-2"/>
        <circle cx="-95" cy="40" r="2" fill="white" fill-opacity="0.35" class="town-dot td-3"/>
        <circle cx="90" cy="55" r="2" fill="white" fill-opacity="0.35" class="town-dot td-4"/>
        <circle cx="-130" cy="-65" r="2" fill="white" fill-opacity="0.3" class="town-dot td-5"/>
        <circle cx="125" cy="-80" r="2" fill="white" fill-opacity="0.3" class="town-dot td-6"/>
      </g>

      <!-- RIGHT: Truck + weekend calendar stack -->
      <g class="right-stack" transform="translate(1080, 175)">

        <!-- Truck — gently bobbing -->
        <g class="truck-group" transform="translate(60, 0)">
          <text x="100" y="0" text-anchor="middle" fill="white" fill-opacity="0.5" font-size="10" font-weight="700" font-family="monospace" letter-spacing="2">PICKUP &amp; DROP OFF</text>
          <g class="truck-bob" transform="translate(0, 22)">
            <!-- Truck body (van shape) -->
            <rect x="0" y="0" width="120" height="40" rx="4" fill="white" fill-opacity="0.18" stroke="white" stroke-opacity="0.6" stroke-width="2"/>
            <!-- Cab nose -->
            <rect x="120" y="10" width="40" height="30" rx="3" fill="white" fill-opacity="0.22" stroke="white" stroke-opacity="0.6" stroke-width="2"/>
            <!-- Windshield -->
            <path d="M124 12 L150 12 L155 24 L124 24 Z" fill="#1e3a8a" fill-opacity="0.4" stroke="white" stroke-opacity="0.45" stroke-width="1.2"/>
            <!-- Side window -->
            <rect x="12" y="8" width="100" height="12" rx="1.5" fill="#1e3a8a" fill-opacity="0.35" stroke="white" stroke-opacity="0.35" stroke-width="1"/>
            <!-- Side panel detail -->
            <rect x="14" y="24" width="100" height="10" rx="1" fill="none" stroke="white" stroke-opacity="0.25" stroke-width="1"/>
            <!-- "JFT" mark on side -->
            <text x="64" y="32" text-anchor="middle" fill="white" fill-opacity="0.7" font-size="7" font-weight="900" font-family="monospace">JAKE FIXES TECH</text>
            <!-- Wheels -->
            <circle cx="28" cy="42" r="7" fill="#1e3a8a" stroke="white" stroke-opacity="0.6" stroke-width="2"/>
            <circle cx="28" cy="42" r="3" fill="white" fill-opacity="0.5"/>
            <circle cx="138" cy="42" r="7" fill="#1e3a8a" stroke="white" stroke-opacity="0.6" stroke-width="2"/>
            <circle cx="138" cy="42" r="3" fill="white" fill-opacity="0.5"/>
            <!-- Headlight -->
            <circle cx="158" cy="32" r="2" fill="white" fill-opacity="0.85"/>
          </g>
        </g>

        <!-- Calendar — Sat/Sun highlighted -->
        <g class="calendar-group" transform="translate(35, 105)">
          <text x="100" y="0" text-anchor="middle" fill="white" fill-opacity="0.5" font-size="10" font-weight="700" font-family="monospace" letter-spacing="2">WEEKENDS · 9–4</text>

          <g class="cal-card" transform="translate(0, 12)">
            <rect x="0" y="0" width="210" height="115" rx="6" fill="white" fill-opacity="0.1" stroke="white" stroke-opacity="0.45" stroke-width="1.5"/>
            <!-- Day labels row -->
            <text x="20" y="20" text-anchor="middle" fill="white" fill-opacity="0.45" font-size="9" font-weight="700" font-family="monospace">M</text>
            <text x="50" y="20" text-anchor="middle" fill="white" fill-opacity="0.45" font-size="9" font-weight="700" font-family="monospace">T</text>
            <text x="80" y="20" text-anchor="middle" fill="white" fill-opacity="0.45" font-size="9" font-weight="700" font-family="monospace">W</text>
            <text x="110" y="20" text-anchor="middle" fill="white" fill-opacity="0.45" font-size="9" font-weight="700" font-family="monospace">T</text>
            <text x="140" y="20" text-anchor="middle" fill="white" fill-opacity="0.45" font-size="9" font-weight="700" font-family="monospace">F</text>
            <text x="170" y="20" text-anchor="middle" fill="white" fill-opacity="0.95" font-size="9" font-weight="700" font-family="monospace">SAT</text>
            <text x="200" y="20" text-anchor="middle" fill="white" fill-opacity="0.95" font-size="9" font-weight="700" font-family="monospace">SUN</text>

            <!-- Day cells (5 weekdays muted + 2 weekend boxes highlighted) -->
            <rect x="10" y="30" width="20" height="20" rx="2" fill="white" fill-opacity="0.04" stroke="white" stroke-opacity="0.15" stroke-width="1"/>
            <rect x="40" y="30" width="20" height="20" rx="2" fill="white" fill-opacity="0.04" stroke="white" stroke-opacity="0.15" stroke-width="1"/>
            <rect x="70" y="30" width="20" height="20" rx="2" fill="white" fill-opacity="0.04" stroke="white" stroke-opacity="0.15" stroke-width="1"/>
            <rect x="100" y="30" width="20" height="20" rx="2" fill="white" fill-opacity="0.04" stroke="white" stroke-opacity="0.15" stroke-width="1"/>
            <rect x="130" y="30" width="20" height="20" rx="2" fill="white" fill-opacity="0.04" stroke="white" stroke-opacity="0.15" stroke-width="1"/>

            <!-- Highlighted Saturday -->
            <g class="cal-day cal-sat">
              <rect x="160" y="30" width="20" height="20" rx="2" fill="white" fill-opacity="0.3" stroke="white" stroke-opacity="0.85" stroke-width="1.5"/>
              <path d="M165 38 L168 41 L175 35" stroke="white" stroke-opacity="0.95" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
            </g>
            <!-- Highlighted Sunday -->
            <g class="cal-day cal-sun">
              <rect x="190" y="30" width="20" height="20" rx="2" fill="white" fill-opacity="0.3" stroke="white" stroke-opacity="0.85" stroke-width="1.5"/>
              <path d="M195 38 L198 41 L205 35" stroke="white" stroke-opacity="0.95" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
            </g>

            <!-- Hours strip -->
            <line x1="10" y1="65" x2="200" y2="65" stroke="white" stroke-opacity="0.18" stroke-width="1"/>
            <g transform="translate(105, 88)">
              <!-- Clock icon -->
              <circle cx="-65" cy="0" r="9" fill="none" stroke="white" stroke-opacity="0.6" stroke-width="1.5"/>
              <line x1="-65" y1="0" x2="-65" y2="-5" stroke="white" stroke-opacity="0.85" stroke-width="1.5" stroke-linecap="round"/>
              <line x1="-65" y1="0" x2="-61" y2="2" stroke="white" stroke-opacity="0.85" stroke-width="1.5" stroke-linecap="round"/>
              <text x="-48" y="2" fill="white" fill-opacity="0.85" font-size="10" font-weight="700" font-family="monospace" letter-spacing="1">9 AM — 4 PM</text>
              <text x="-48" y="14" fill="white" fill-opacity="0.55" font-size="7" font-weight="600" font-family="monospace" letter-spacing="1">BY APPOINTMENT</text>
            </g>
          </g>
        </g>
      </g>

      <!-- Ambient floating dots -->
      <g class="ambient-dots">
        <circle cx="540" cy="120" r="2" fill="white" fill-opacity="0.25" class="float-dot d1"/>
        <circle cx="900" cy="100" r="2.5" fill="white" fill-opacity="0.3" class="float-dot d2"/>
        <circle cx="560" cy="430" r="2" fill="white" fill-opacity="0.25" class="float-dot d3"/>
        <circle cx="860" cy="450" r="2" fill="white" fill-opacity="0.3" class="float-dot d4"/>
      </g>

      <g stroke="white" stroke-opacity="0.04" stroke-width="1">
        <line x1="0" y1="130" x2="1440" y2="130"/>
        <line x1="0" y1="260" x2="1440" y2="260"/>
        <line x1="0" y1="390" x2="1440" y2="390"/>
        <line x1="360" y1="0" x2="360" y2="520"/>
        <line x1="720" y1="0" x2="720" y2="520"/>
        <line x1="1080" y1="0" x2="1080" y2="520"/>
      </g>
    </svg>

    <!-- MOBILE SVG -->
    <svg class="hero-bg-mobile" viewBox="0 0 400 600" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <defs>
        <linearGradient id="bgGradM" x1="0%" y1="0%" x2="100%" y2="100%">
          <stop offset="0%" style="stop-color:#1e3a8a;stop-opacity:1"/>
          <stop offset="100%" style="stop-color:#2563eb;stop-opacity:1"/>
        </linearGradient>
        <linearGradient id="glowGradM" x1="0%" y1="0%" x2="100%" y2="100%">
          <stop offset="0%" style="stop-color:#3b82f6;stop-opacity:0.3"/>
          <stop offset="100%" style="stop-color:#1d4ed8;stop-opacity:0"/>
        </linearGradient>
        <radialGradient id="ringGlowM" cx="50%" cy="50%" r="50%">
          <stop offset="0%" style="stop-color:white;stop-opacity:0.15"/>
          <stop offset="70%" style="stop-color:white;stop-opacity:0.04"/>
          <stop offset="100%" style="stop-color:white;stop-opacity:0"/>
        </radialGradient>
      </defs>
      <rect width="400" height="600" fill="url(#bgGradM)"/>
      <ellipse cx="100" cy="180" rx="220" ry="180" fill="url(#glowGradM)" class="glow-orb-1"/>
      <ellipse cx="320" cy="500" rx="220" ry="180" fill="url(#glowGradM)" class="glow-orb-2"/>

      <!-- TOP: Distance rings (smaller, higher, room for hero text below) -->
      <g class="distance-map" transform="translate(200, 110)">
        <ellipse cx="0" cy="0" rx="140" ry="100" fill="url(#ringGlowM)" class="map-glow"/>

        <circle cx="0" cy="0" r="88" fill="none" stroke="white" stroke-opacity="0.18" stroke-width="1" stroke-dasharray="2 3" class="ring ring-4"/>
        <circle cx="0" cy="0" r="65" fill="none" stroke="white" stroke-opacity="0.22" stroke-width="1" stroke-dasharray="2 3" class="ring ring-3"/>
        <circle cx="0" cy="0" r="45" fill="none" stroke="white" stroke-opacity="0.28" stroke-width="1" stroke-dasharray="2 3" class="ring ring-2"/>
        <circle cx="0" cy="0" r="24" fill="none" stroke="white" stroke-opacity="0.5" stroke-width="1.2" class="ring ring-1"/>

        <text x="0" y="-24" text-anchor="middle" fill="white" fill-opacity="0.7" font-size="6" font-weight="700" font-family="monospace">10mi · FREE</text>
        <text x="0" y="-45" text-anchor="middle" fill="white" fill-opacity="0.55" font-size="6" font-weight="700" font-family="monospace">15mi · $20</text>
        <text x="0" y="-65" text-anchor="middle" fill="white" fill-opacity="0.5" font-size="6" font-weight="700" font-family="monospace">20mi · $40</text>
        <text x="0" y="-88" text-anchor="middle" fill="white" fill-opacity="0.45" font-size="6" font-weight="700" font-family="monospace">25mi · $60</text>

        <g class="center-pin">
          <path d="M0 -10 C-6 -10 -10 -6 -10 0 C-10 7 0 15 0 15 C0 15 10 7 10 0 C10 -6 6 -10 0 -10 Z"
            fill="white" fill-opacity="0.95" stroke="white" stroke-opacity="1" stroke-width="1.2"/>
          <circle cx="0" cy="-1" r="3" fill="#1e3a8a"/>
        </g>
        <text x="0" y="26" text-anchor="middle" fill="white" fill-opacity="0.9" font-size="7" font-weight="700" font-family="monospace" letter-spacing="1">LITTLETON, NH</text>
      </g>

      <!-- BOTTOM: Calendar card + truck — sized to fit 400px width safely with margins -->
      <g class="right-stack" transform="translate(30, 470)">
        <text x="170" y="0" text-anchor="middle" fill="white" fill-opacity="0.5" font-size="8" font-weight="700" font-family="monospace" letter-spacing="2">WEEKENDS · 9–4</text>

        <g class="cal-card" transform="translate(0, 10)">
          <rect x="0" y="0" width="340" height="68" rx="5" fill="white" fill-opacity="0.1" stroke="white" stroke-opacity="0.45" stroke-width="1.2"/>

          <!-- Truck on left -->
          <g class="truck-bob" transform="translate(12, 22)">
            <rect x="0" y="0" width="50" height="20" rx="2" fill="white" fill-opacity="0.18" stroke="white" stroke-opacity="0.6" stroke-width="1.2"/>
            <rect x="50" y="6" width="20" height="14" rx="1.5" fill="white" fill-opacity="0.22" stroke="white" stroke-opacity="0.6" stroke-width="1.2"/>
            <path d="M52 8 L64 8 L66 13 L52 13 Z" fill="#1e3a8a" fill-opacity="0.4" stroke="white" stroke-opacity="0.45" stroke-width="0.7"/>
            <rect x="5" y="4" width="42" height="6" rx="1" fill="#1e3a8a" fill-opacity="0.35" stroke="white" stroke-opacity="0.35" stroke-width="0.6"/>
            <circle cx="12" cy="22" r="4" fill="#1e3a8a" stroke="white" stroke-opacity="0.6" stroke-width="1.2"/>
            <circle cx="12" cy="22" r="1.5" fill="white" fill-opacity="0.5"/>
            <circle cx="58" cy="22" r="4" fill="#1e3a8a" stroke="white" stroke-opacity="0.6" stroke-width="1.2"/>
            <circle cx="58" cy="22" r="1.5" fill="white" fill-opacity="0.5"/>
            <circle cx="69" cy="16" r="1" fill="white" fill-opacity="0.85"/>
          </g>

          <!-- Vertical separator -->
          <line x1="100" y1="14" x2="100" y2="54" stroke="white" stroke-opacity="0.2" stroke-width="1"/>

          <!-- Calendar grid (compact, fits 235px wide between separator at x=100 and edge at x=340) -->
          <g transform="translate(112, 14)">
            <!-- Header row M T W T F SA SU - each cell 30px wide -->
            <text x="10" y="6" text-anchor="middle" fill="white" fill-opacity="0.5" font-size="7" font-weight="700" font-family="monospace">M</text>
            <text x="40" y="6" text-anchor="middle" fill="white" fill-opacity="0.5" font-size="7" font-weight="700" font-family="monospace">T</text>
            <text x="70" y="6" text-anchor="middle" fill="white" fill-opacity="0.5" font-size="7" font-weight="700" font-family="monospace">W</text>
            <text x="100" y="6" text-anchor="middle" fill="white" fill-opacity="0.5" font-size="7" font-weight="700" font-family="monospace">T</text>
            <text x="130" y="6" text-anchor="middle" fill="white" fill-opacity="0.5" font-size="7" font-weight="700" font-family="monospace">F</text>
            <text x="165" y="6" text-anchor="middle" fill="white" fill-opacity="0.95" font-size="7" font-weight="700" font-family="monospace">SA</text>
            <text x="200" y="6" text-anchor="middle" fill="white" fill-opacity="0.95" font-size="7" font-weight="700" font-family="monospace">SU</text>

            <!-- Day cells (weekdays muted) -->
            <rect x="2" y="12" width="16" height="14" rx="2" fill="white" fill-opacity="0.04" stroke="white" stroke-opacity="0.18" stroke-width="0.8"/>
            <rect x="32" y="12" width="16" height="14" rx="2" fill="white" fill-opacity="0.04" stroke="white" stroke-opacity="0.18" stroke-width="0.8"/>
            <rect x="62" y="12" width="16" height="14" rx="2" fill="white" fill-opacity="0.04" stroke="white" stroke-opacity="0.18" stroke-width="0.8"/>
            <rect x="92" y="12" width="16" height="14" rx="2" fill="white" fill-opacity="0.04" stroke="white" stroke-opacity="0.18" stroke-width="0.8"/>
            <rect x="122" y="12" width="16" height="14" rx="2" fill="white" fill-opacity="0.04" stroke="white" stroke-opacity="0.18" stroke-width="0.8"/>

            <!-- Highlighted Saturday and Sunday -->
            <g class="cal-day cal-sat">
              <rect x="153" y="12" width="22" height="14" rx="2" fill="white" fill-opacity="0.3" stroke="white" stroke-opacity="0.85" stroke-width="1"/>
              <path d="M158 19 L161 22 L170 14" stroke="white" stroke-opacity="0.95" stroke-width="1.3" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
            </g>
            <g class="cal-day cal-sun">
              <rect x="188" y="12" width="22" height="14" rx="2" fill="white" fill-opacity="0.3" stroke="white" stroke-opacity="0.85" stroke-width="1"/>
              <path d="M193 19 L196 22 L205 14" stroke="white" stroke-opacity="0.95" stroke-width="1.3" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
            </g>

            <!-- Hours strip -->
            <text x="106" y="42" text-anchor="middle" fill="white" fill-opacity="0.85" font-size="8" font-weight="700" font-family="monospace" letter-spacing="1.5">9 AM — 4 PM</text>
          </g>
        </g>
      </g>

      <g stroke="white" stroke-opacity="0.04" stroke-width="1">
        <line x1="0" y1="150" x2="400" y2="150"/>
        <line x1="0" y1="300" x2="400" y2="300"/>
        <line x1="0" y1="450" x2="400" y2="450"/>
        <line x1="133" y1="0" x2="133" y2="600"/>
        <line x1="266" y1="0" x2="266" y2="600"/>
      </g>
    </svg>

    <!-- Hero text overlay -->
    <div id="hero-content">
      <p class="hero-label">Weekend Pickup Service</p>
      <h1 id="hero-wordmark">Can't Drop It Off?<br/>I'll Come to You.</h1>
      <p id="hero-tagline">Weekday drop-off windows don't work for everyone. On Saturdays and Sundays from 9 AM to 4 PM, I'll come pick up your device, drop it back off when it's fixed, and you barely have to leave your couch.</p>
      <a href="#how-it-works" id="hero-cta">
        How It Works
        <svg style="height:1rem;width:1rem;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M12 5v14M5 12l7 7 7-7"/></svg>
      </a>
    </div>

  </section>

  <!-- How It Works -->
  <section id="how-it-works" style="background:white;padding:5rem 1.5rem;">
    <div style="max-width:56rem;margin:0 auto;">
      <div style="text-align:center;margin-bottom:3rem;">
        <p style="font-size:0.875rem;font-weight:600;text-transform:uppercase;letter-spacing:0.1em;color:#2563eb;">How It Works</p>
        <h2 style="font-size:2rem;font-weight:800;color:#111827;margin-top:0.5rem;">Four Steps. No Hassle.</h2>
        <p style="color:#6b7280;margin-top:0.75rem;max-width:40rem;margin-left:auto;margin-right:auto;line-height:1.75;">Designed for people who work weekdays, run businesses, raise kids, or just can't make it across town between 5 and 7:30 PM on a school night.</p>
      </div>

      <div class="steps-grid">
        <div class="step-card">
          <div class="step-number">1</div>
          <h3>Reach Out</h3>
          <p>Call, text or send a message. Describe what's going on with your device and roughly where you're located. I'll confirm pricing and a pickup window.</p>
        </div>
        <div class="step-card">
          <div class="step-number">2</div>
          <h3>Saturday or Sunday Pickup</h3>
          <p>I arrive in your pickup window between 9 AM and 4 PM. You hand off the device, pay the diagnostic fee plus any mileage, and we're done in about 5 minutes.</p>
        </div>
        <div class="step-card">
          <div class="step-number">3</div>
          <h3>I Fix It</h3>
          <p>I diagnose the issue, send you the full quote, and once you approve, I get it sorted. Most repairs are done in 1–3 business days.</p>
        </div>
