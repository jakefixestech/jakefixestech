---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Screen Repair | Jake Fixes Tech — Littleton, NH"
description="Laptop, Chromebook, all-in-one and handheld gaming console screen replacement. Free quote, honest advice, $100 labor plus parts. Serving Littleton NH and the North Country.">

  <!-- Animated SVG Hero -->
  <section id="hero-svg" aria-label="Screen Repair Service">

    <!-- DESKTOP SVG -->
    <svg class="hero-bg-desktop" viewBox="0 0 1440 520" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <defs>
        <linearGradient id="bgGrad" x1="0%" y1="0%" x2="100%" y2="100%">
          <stop offset="0%" style="stop-color:#1e3a8a;stop-opacity:1"/>
          <stop offset="100%" style="stop-color:#2563eb;stop-opacity:1"/>
        </linearGradient>
        <linearGradient id="glowGrad" x1="0%" y1="0%" x2="100%" y2="100%">
          <stop offset="0%" style="stop-color:#3b82f6;stop-opacity:0.25"/>
          <stop offset="100%" style="stop-color:#1d4ed8;stop-opacity:0"/>
        </linearGradient>
      </defs>
      <rect width="1440" height="520" fill="url(#bgGrad)"/>
      <ellipse cx="320" cy="200" rx="380" ry="260" fill="url(#glowGrad)" class="glow-orb-1"/>
      <ellipse cx="1180" cy="340" rx="320" ry="220" fill="url(#glowGrad)" class="glow-orb-2"/>

      <!-- Main laptop with cracking/repairing screen — translate(110, 130), 360x250 -->
      <g class="laptop-group" transform="translate(110, 130)">
        <!-- Laptop base/keyboard -->
        <path d="M-30 220 L390 220 L420 250 L-60 250 Z" stroke="white" stroke-opacity="0.25" stroke-width="2" fill="white" fill-opacity="0.06"/>
        <rect x="170" y="225" width="20" height="6" rx="1" fill="white" fill-opacity="0.2"/>
        <!-- Laptop screen frame -->
        <rect x="0" y="0" width="360" height="220" rx="6" stroke="white" stroke-opacity="0.3" stroke-width="2" fill="white" fill-opacity="0.05"/>
        <!-- Screen interior background -->
        <rect x="10" y="10" width="340" height="200" rx="3" fill="white" fill-opacity="0.05" class="screen-bg"/>
        <!-- Screen content that "draws in" during repaired phase -->
        <g class="screen-content">
          <!-- Title bar -->
          <rect x="22" y="22" width="316" height="14" rx="2" fill="white" fill-opacity="0.15" class="content-line cl-1"/>
          <!-- Content lines -->
          <line x1="22" y1="56" x2="280" y2="56" stroke="white" stroke-opacity="0.4" stroke-width="3" stroke-linecap="round" class="content-line cl-2"/>
          <line x1="22" y1="78" x2="320" y2="78" stroke="white" stroke-opacity="0.25" stroke-width="2" stroke-linecap="round" class="content-line cl-3"/>
          <line x1="22" y1="98" x2="240" y2="98" stroke="white" stroke-opacity="0.25" stroke-width="2" stroke-linecap="round" class="content-line cl-4"/>
          <!-- Image / card boxes -->
          <rect x="22" y="120" width="100" height="74" rx="3" stroke="white" stroke-opacity="0.25" stroke-width="1.5" fill="white" fill-opacity="0.06" class="content-line cl-5"/>
          <rect x="132" y="120" width="100" height="74" rx="3" stroke="white" stroke-opacity="0.25" stroke-width="1.5" fill="white" fill-opacity="0.06" class="content-line cl-6"/>
          <rect x="242" y="120" width="100" height="74" rx="3" stroke="white" stroke-opacity="0.25" stroke-width="1.5" fill="white" fill-opacity="0.06" class="content-line cl-7"/>
        </g>
        <!-- Crack pattern that fades during repair (covers screen area 10,10 to 350,210) -->
        <g class="crack-group" stroke="white" stroke-opacity="0.85" stroke-width="2" fill="none" stroke-linecap="round">
          <!-- Main impact point near upper-left -->
          <circle cx="120" cy="80" r="4" fill="white" fill-opacity="0.6" class="crack-impact"/>
          <!-- Radiating cracks -->
          <path d="M120 80 L60 30" class="crack crack-1"/>
          <path d="M120 80 L40 110" class="crack crack-2"/>
          <path d="M120 80 L80 180" class="crack crack-3"/>
          <path d="M120 80 L200 50" class="crack crack-4"/>
          <path d="M120 80 L240 120" class="crack crack-5"/>
          <path d="M120 80 L320 180" class="crack crack-6"/>
          <path d="M120 80 L180 200" class="crack crack-7"/>
          <!-- Branching cracks -->
          <path d="M180 130 L240 170" class="crack crack-8"/>
          <path d="M70 60 L100 30" class="crack crack-9"/>
          <path d="M280 150 L320 130" class="crack crack-10"/>
        </g>
        <!-- Screen camera dot -->
        <circle cx="180" cy="6" r="1.5" fill="white" fill-opacity="0.4"/>
      </g>

      <!-- Secondary device: handheld console (right side) — translate(990, 240), ~260x180 -->
      <g class="handheld-group" transform="translate(990, 240)">
        <!-- Console body -->
        <path d="M0 30 Q0 0 30 0 L230 0 Q260 0 260 30 L260 110 Q260 140 230 140 L30 140 Q0 140 0 110 Z" stroke="white" stroke-opacity="0.22" stroke-width="2" fill="white" fill-opacity="0.05"/>
        <!-- Screen -->
        <rect x="60" y="20" width="140" height="100" rx="4" stroke="white" stroke-opacity="0.3" stroke-width="1.5" fill="white" fill-opacity="0.08" class="handheld-screen"/>
        <!-- Screen pixels appearing -->
        <g class="handheld-pixels">
          <rect x="70" y="32" width="120" height="6" rx="1" fill="white" fill-opacity="0.3" class="hp-line hp-1"/>
          <rect x="70" y="46" width="80" height="4" rx="1" fill="white" fill-opacity="0.2" class="hp-line hp-2"/>
          <rect x="70" y="60" width="100" height="40" rx="2" stroke="white" stroke-opacity="0.25" stroke-width="1" fill="white" fill-opacity="0.05" class="hp-line hp-3"/>
        </g>
        <!-- D-pad -->
        <g transform="translate(28, 70)">
          <rect x="-3" y="-12" width="6" height="24" rx="1" stroke="white" stroke-opacity="0.25" stroke-width="1.5" fill="white" fill-opacity="0.05"/>
          <rect x="-12" y="-3" width="24" height="6" rx="1" stroke="white" stroke-opacity="0.25" stroke-width="1.5" fill="white" fill-opacity="0.05"/>
        </g>
        <!-- Buttons -->
        <g transform="translate(232, 70)">
          <circle cx="-10" cy="0" r="5" stroke="white" stroke-opacity="0.25" stroke-width="1.5" fill="white" fill-opacity="0.06"/>
          <circle cx="10" cy="0" r="5" stroke="white" stroke-opacity="0.25" stroke-width="1.5" fill="white" fill-opacity="0.06"/>
          <circle cx="0" cy="-10" r="5" stroke="white" stroke-opacity="0.25" stroke-width="1.5" fill="white" fill-opacity="0.06"/>
          <circle cx="0" cy="10" r="5" stroke="white" stroke-opacity="0.25" stroke-width="1.5" fill="white" fill-opacity="0.06"/>
        </g>
        <!-- Subtle crack on handheld screen -->
        <g class="handheld-crack" stroke="white" stroke-opacity="0.55" stroke-width="1.2" fill="none" stroke-linecap="round">
          <path d="M130 50 L100 30" class="crack-h crack-h-1"/>
          <path d="M130 50 L160 75" class="crack-h crack-h-2"/>
          <path d="M130 50 L110 100" class="crack-h crack-h-3"/>
          <circle cx="130" cy="50" r="2.5" fill="white" fill-opacity="0.5" class="crack-impact"/>
        </g>
      </g>

      <!-- Floating screwdriver tool — outer group positions, inner animates -->
      <g transform="translate(700, 80)">
        <g class="float-icon float-tool-1">
          <line x1="0" y1="0" x2="40" y2="40" stroke="white" stroke-opacity="0.18" stroke-width="3" stroke-linecap="round"/>
          <rect x="-8" y="-8" width="14" height="14" rx="2" fill="white" fill-opacity="0.12" stroke="white" stroke-opacity="0.25" stroke-width="1.5" transform="rotate(45)"/>
        </g>
      </g>

      <!-- Floating wrench -->
      <g transform="translate(140, 380)">
        <g class="float-icon float-tool-2" stroke="white" stroke-opacity="0.18" fill="none" stroke-width="2">
          <path d="M14 7l3-3a5 5 0 0 0-6.2 6.2L1 20.5a2.5 2.5 0 0 0 3.5 3.5l9.6-9.6A5 5 0 0 0 21 8l-3 3-4-4z" transform="scale(1.3)"/>
        </g>
      </g>

      <!-- Floating pixel grid icon -->
      <g transform="translate(1260, 110)">
        <g class="float-icon float-tool-3" stroke="white" stroke-opacity="0.16" fill="white" fill-opacity="0.08">
          <rect x="0" y="0" width="8" height="8" rx="1"/>
          <rect x="12" y="0" width="8" height="8" rx="1"/>
          <rect x="24" y="0" width="8" height="8" rx="1"/>
          <rect x="0" y="12" width="8" height="8" rx="1"/>
          <rect x="12" y="12" width="8" height="8" rx="1"/>
          <rect x="24" y="12" width="8" height="8" rx="1"/>
          <rect x="0" y="24" width="8" height="8" rx="1"/>
          <rect x="12" y="24" width="8" height="8" rx="1"/>
          <rect x="24" y="24" width="8" height="8" rx="1"/>
        </g>
      </g>

      <!-- Ambient labels -->
      <g font-family="ui-monospace, SFMono-Regular, Menlo, monospace" font-weight="700" fill="white">
        <text x="100" y="100" font-size="11" fill-opacity="0.1" class="code-tw ct-a">// diagnose</text>
        <text x="660" y="430" font-size="11" fill-opacity="0.1" class="code-tw ct-b">// repair</text>
        <text x="1180" y="450" font-size="11" fill-opacity="0.1" class="code-tw ct-c">// test</text>
        <text x="80" y="450" font-size="10" fill-opacity="0.09" class="code-tw ct-d">1080 × 1920</text>
      </g>

      <!-- Grid -->
      <g stroke="white" stroke-opacity="0.04" stroke-width="1">
        <line x1="0" y1="130" x2="1440" y2="130"/>
        <line x1="0" y1="260" x2="1440" y2="260"/>
        <line x1="0" y1="390" x2="1440" y2="390"/>
        <line x1="360" y1="0" x2="360" y2="520"/>
        <line x1="720" y1="0" x2="720" y2="520"/>
        <line x1="1080" y1="0" x2="1080" y2="520"/>
      </g>
    </svg>

    <!-- MOBILE SVG -->
    <svg class="hero-bg-mobile" viewBox="0 0 400 600" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <defs>
        <linearGradient id="bgGradM" x1="0%" y1="0%" x2="100%" y2="100%">
          <stop offset="0%" style="stop-color:#1e3a8a;stop-opacity:1"/>
          <stop offset="100%" style="stop-color:#2563eb;stop-opacity:1"/>
        </linearGradient>
        <linearGradient id="glowGradM" x1="0%" y1="0%" x2="100%" y2="100%">
          <stop offset="0%" style="stop-color:#3b82f6;stop-opacity:0.3"/>
          <stop offset="100%" style="stop-color:#1d4ed8;stop-opacity:0"/>
        </linearGradient>
      </defs>
      <rect width="400" height="600" fill="url(#bgGradM)"/>
      <ellipse cx="100" cy="160" rx="220" ry="180" fill="url(#glowGradM)" class="glow-orb-1"/>
      <ellipse cx="320" cy="500" rx="220" ry="180" fill="url(#glowGradM)" class="glow-orb-2"/>

      <!-- Laptop top center — translate(80, 60), 240x170 -->
      <g class="laptop-group" transform="translate(80, 60)">
        <path d="M-15 150 L255 150 L275 170 L-35 170 Z" stroke="white" stroke-opacity="0.25" stroke-width="1.5" fill="white" fill-opacity="0.06"/>
        <rect x="0" y="0" width="240" height="150" rx="5" stroke="white" stroke-opacity="0.3" stroke-width="1.5" fill="white" fill-opacity="0.05"/>
        <rect x="8" y="8" width="224" height="134" rx="3" fill="white" fill-opacity="0.05" class="screen-bg"/>
        <g class="screen-content">
          <rect x="18" y="18" width="204" height="10" rx="2" fill="white" fill-opacity="0.15" class="content-line cl-1"/>
          <line x1="18" y1="42" x2="180" y2="42" stroke="white" stroke-opacity="0.4" stroke-width="2.5" stroke-linecap="round" class="content-line cl-2"/>
          <line x1="18" y1="58" x2="210" y2="58" stroke="white" stroke-opacity="0.25" stroke-width="2" stroke-linecap="round" class="content-line cl-3"/>
          <rect x="18" y="78" width="60" height="50" rx="2" stroke="white" stroke-opacity="0.25" stroke-width="1.5" fill="white" fill-opacity="0.06" class="content-line cl-5"/>
          <rect x="86" y="78" width="60" height="50" rx="2" stroke="white" stroke-opacity="0.25" stroke-width="1.5" fill="white" fill-opacity="0.06" class="content-line cl-6"/>
          <rect x="154" y="78" width="60" height="50" rx="2" stroke="white" stroke-opacity="0.25" stroke-width="1.5" fill="white" fill-opacity="0.06" class="content-line cl-7"/>
        </g>
        <g class="crack-group" stroke="white" stroke-opacity="0.85" stroke-width="1.5" fill="none" stroke-linecap="round">
          <circle cx="80" cy="60" r="3" fill="white" fill-opacity="0.6" class="crack-impact"/>
          <path d="M80 60 L40 25" class="crack crack-1"/>
          <path d="M80 60 L25 80" class="crack crack-2"/>
          <path d="M80 60 L60 130" class="crack crack-3"/>
          <path d="M80 60 L140 35" class="crack crack-4"/>
          <path d="M80 60 L170 90" class="crack crack-5"/>
          <path d="M80 60 L210 130" class="crack crack-6"/>
          <path d="M120 90 L160 110" class="crack crack-7"/>
        </g>
        <circle cx="120" cy="4" r="1.2" fill="white" fill-opacity="0.4"/>
      </g>

      <!-- Handheld console — bottom — translate(60, 380), ~280x150 -->
      <g class="handheld-group" transform="translate(60, 380)">
        <path d="M0 25 Q0 0 25 0 L255 0 Q280 0 280 25 L280 95 Q280 120 255 120 L25 120 Q0 120 0 95 Z" stroke="white" stroke-opacity="0.22" stroke-width="1.5" fill="white" fill-opacity="0.05"/>
        <rect x="60" y="18" width="160" height="84" rx="4" stroke="white" stroke-opacity="0.3" stroke-width="1.5" fill="white" fill-opacity="0.08" class="handheld-screen"/>
        <g class="handheld-pixels">
          <rect x="70" y="28" width="140" height="5" rx="1" fill="white" fill-opacity="0.3" class="hp-line hp-1"/>
          <rect x="70" y="40" width="90" height="4" rx="1" fill="white" fill-opacity="0.2" class="hp-line hp-2"/>
          <rect x="70" y="52" width="120" height="42" rx="2" stroke="white" stroke-opacity="0.25" stroke-width="1" fill="white" fill-opacity="0.05" class="hp-line hp-3"/>
        </g>
        <g transform="translate(28, 60)">
          <rect x="-3" y="-10" width="6" height="20" rx="1" stroke="white" stroke-opacity="0.25" stroke-width="1.5" fill="white" fill-opacity="0.05"/>
          <rect x="-10" y="-3" width="20" height="6" rx="1" stroke="white" stroke-opacity="0.25" stroke-width="1.5" fill="white" fill-opacity="0.05"/>
        </g>
        <g transform="translate(252, 60)">
          <circle cx="-9" cy="0" r="4" stroke="white" stroke-opacity="0.25" stroke-width="1.5" fill="white" fill-opacity="0.06"/>
          <circle cx="9" cy="0" r="4" stroke="white" stroke-opacity="0.25" stroke-width="1.5" fill="white" fill-opacity="0.06"/>
          <circle cx="0" cy="-9" r="4" stroke="white" stroke-opacity="0.25" stroke-width="1.5" fill="white" fill-opacity="0.06"/>
          <circle cx="0" cy="9" r="4" stroke="white" stroke-opacity="0.25" stroke-width="1.5" fill="white" fill-opacity="0.06"/>
        </g>
        <g class="handheld-crack" stroke="white" stroke-opacity="0.55" stroke-width="1" fill="none" stroke-linecap="round">
          <path d="M140 50 L110 28" class="crack-h crack-h-1"/>
          <path d="M140 50 L175 70" class="crack-h crack-h-2"/>
          <circle cx="140" cy="50" r="2" fill="white" fill-opacity="0.5" class="crack-impact"/>
        </g>
      </g>

      <!-- Ambient label -->
      <g font-family="ui-monospace, SFMono-Regular, Menlo, monospace" font-weight="700" fill="white">
        <text x="20" y="290" font-size="10" fill-opacity="0.1" class="code-tw ct-a">// repair</text>
        <text x="290" y="290" font-size="10" fill-opacity="0.09" class="code-tw ct-b">1080p</text>
      </g>

      <!-- Grid -->
      <g stroke="white" stroke-opacity="0.04" stroke-width="1">
        <line x1="0" y1="150" x2="400" y2="150"/>
        <line x1="0" y1="300" x2="400" y2="300"/>
        <line x1="0" y1="450" x2="400" y2="450"/>
        <line x1="133" y1="0" x2="133" y2="600"/>
        <line x1="266" y1="0" x2="266" y2="600"/>
      </g>
    </svg>

    <!-- Hero text -->
    <div id="hero-content">
      <p class="hero-label">
        <a href="/services#screen-repair" style="color:#93c5fd;text-decoration:none;" aria-label="Back to all services">← Services</a>
      </p>
      <h1 id="hero-wordmark">Screen Repair</h1>
      <p id="hero-tagline">Cracked, flickering or completely dead screen? I replace screens on laptops, Chromebooks, all-in-one computers and handheld gaming consoles, including retro handhelds. Free quote, honest advice.</p>
      <div id="hero-cta-row">
        <a href="/contact" class="hero-cta-primary">
          Get a Free Quote
          <svg style="height:1rem;width:1rem;" aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
        <a href="/pricing" class="hero-cta-secondary">View Pricing</a>
      </div>
    </div>

    <div id="scroll-hint" aria-hidden="true" role="button" tabindex="-1" onclick="document.getElementById('what-i-replace').scrollIntoView({behavior:'smooth'})">
      <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" style="height:1.5rem;width:1.5rem;"><path d="M12 5v14M5 12l7 7 7-7"/></svg>
    </div>
  </section>

  <!-- Info Bar -->
  <section style="background:#1e40af;padding:1.25rem 1.5rem;">
    <div style="max-width:56rem;margin:0 auto;display:flex;flex-wrap:wrap;align-items:center;justify-content:center;gap:2rem;text-align:center;">
      <div>
        <div style="font-size:1.75rem;font-weight:800;color:white;">$100</div>
        <div style="font-size:0.8rem;color:#bfdbfe;font-weight:600;">Labor + Parts</div>
      </div>
      <div style="width:1px;height:2.5rem;background:rgba(255,255,255,0.2);flex-shrink:0;"></div>
      <div>
        <div style="font-size:1.75rem;font-weight:800;color:white;">Free Quote</div>
        <div style="font-size:0.8rem;color:#bfdbfe;font-weight:600;">Fast Turnaround</div>
      </div>
      <div style="width:1px;height:2.5rem;background:rgba(255,255,255,0.2);flex-shrink:0;"></div>
      <div>
        <div style="font-size:1.75rem;font-weight:800;color:white;">30 Day</div>
        <div style="font-size:0.8rem;color:#bfdbfe;font-weight:600;">Labor Warranty</div>
      </div>
    </div>
  </section>

  <!-- What I Replace -->
  <section id="what-i-replace" style="background:#f8fafc;padding:4rem 1.5rem;">
    <div style="max-width:56rem;margin:0 auto;">
      <div style="margin-bottom:2.5rem;">
        <p style="font-size:0.875rem;font-weight:600;text-transform:uppercase;letter-spacing:0.1em;color:#2563eb;">What I Work On</p>
        <h2 style="font-size:2rem;font-weight:800;color:#111827;margin-top:0.5rem;">Screens I Replace</h2>
        <p style="color:#6b7280;margin-top:0.75rem;line-height:1.75;">If your screen is cracked, dead, flickering, showing lines, or just not turning on, reach out and let me know what you have. Most screens I can source and replace quickly.</p>
      </div>

      <div style="display:flex;flex-direction:column;gap:1rem;">

        <div class="service-item" style="border-left:4px solid #2563eb;">
          <div class="service-num" style="background:#eff6ff;color:#1e40af;">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
          </div>
          <div>
            <h3 class="item-title">Laptops &amp; Chromebooks</h3>
            <p class="item-desc">Windows, Linux and Chrome OS laptops of all makes and models, including all Chromebooks. Cracked glass, dead backlights, flickering displays, lines across the screen. I source the correct replacement panel and swap it out. Note: MacBook screen replacements are not available as I do not work on Apple hardware.</p>
          </div>
        </div>

        <div class="service-item" style="border-left:4px solid #7c3aed;">
          <div class="service-num" style="background:#f5f3ff;color:#6d28d9;">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/><path d="M7 8h.01M12 8h.01"/><circle cx="17" cy="8" r="1"/></svg>
          </div>
          <div>
            <h3 class="item-title">All-in-One Computers</h3>
            <p class="item-desc">All-in-one desktops where the screen and computer are built into one unit. These can be trickier to disassemble than laptops but I have experience with the process. Windows and Linux only, no iMac repairs.</p>
          </div>
        </div>

        <div class="service-item" style="border-left:4px solid #15803d;">
          <div class="service-num" style="background:#f0fdf4;color:#15803d;">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><rect x="2" y="6" width="20" height="12" rx="2"/><path d="M6 12h.01M10 12h.01M7 9l-1 3 1 3M13 9l1 3-1 3"/></svg>
          </div>
          <div>
            <h3 class="item-title">Handheld Gaming Consoles</h3>
            <p class="item-desc">Nintendo Switch, Switch Lite, Steam Deck, Game Boy, older Nintendo handhelds and other retro handheld consoles. If it has a screen and fits in your hands, ask me. Chances are I can replace it.</p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- What I Don't Do -->
  <section style="background:white;padding:4rem 1.5rem;">
    <div style="max-width:56rem;margin:0 auto;">
      <div style="margin-bottom:2rem;">
        <p style="font-size:0.875rem;font-weight:600;text-transform:uppercase;letter-spacing:0.1em;color:#2563eb;">Honest Limitations</p>
        <h2 style="font-size:2rem;font-weight:800;color:#111827;margin-top:0.5rem;">What I Don't Replace</h2>
        <p style="color:#6b7280;margin-top:0.75rem;line-height:1.75;">I'd rather be upfront than have you bring something in that I can't help with. Here's what's outside my scope right now.</p>
      </div>
      <div style="display:flex;flex-direction:column;gap:1rem;">

        <div class="limit-item">
          <div class="limit-icon" aria-hidden="true">
