  */

  .scan-beam { animation: scanSweep 8s ease-in-out infinite; }
  .scan-beam-m { animation: scanSweepM 8s ease-in-out infinite; }
  @keyframes scanSweep {
    0%   { transform: translateY(-100px); opacity: 0; }
    5%   { opacity: 1; }
    45%  { transform: translateY(110px); opacity: 1; }
    50%  { transform: translateY(110px); opacity: 0; }
    100% { transform: translateY(110px); opacity: 0; }
  }
  @keyframes scanSweepM {
    0%   { transform: translateY(-65px); opacity: 0; }
    5%   { opacity: 1; }
    45%  { transform: translateY(70px); opacity: 1; }
    50%  { transform: translateY(70px); opacity: 0; }
    100% { transform: translateY(70px); opacity: 0; }
