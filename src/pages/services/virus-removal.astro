  @keyframes checkCycle {
    0%, 50%   { opacity: 0; transform: scale(0.7); }
    58%       { opacity: 1; transform: scale(1.15); }
    65%, 95%  { opacity: 1; transform: scale(1); }
    100%      { opacity: 0; transform: scale(0.7); }
  }

  /* Viruses + cleared checkmarks share the same cycle, opposite phase */
  .virus { animation: virusCycle 8s ease-in-out infinite; transform-origin: center; }
  .virus-1 { animation-delay: 0s; }
  .virus-2 { animation-delay: 0.2s; }
  .virus-3 { animation-delay: 0.4s; }
