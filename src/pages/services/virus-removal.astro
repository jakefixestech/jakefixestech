  /* Shield body entrance */
  .shield-body { animation: shieldAppear 0.9s cubic-bezier(0.34,1.56,0.64,1) 0.3s both; transform-origin: center; }
  @keyframes shieldAppear {
    from { opacity: 0; transform: scale(0.85); }
