---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Gaming Console Repair | Jake Fixes Tech — Littleton, NH"
description="PlayStation, Xbox, Nintendo Switch, retro consoles and more. Diagnosis, disc drive repair, overheating fixes, cleaning and retro odds and ends. Serving Littleton NH and the North Country.">

  <!-- Animated SVG Hero -->
  <section id="hero-svg" aria-label="Gaming Console Repair Service">

    <!-- DESKTOP SVG -->
    <svg class="hero-bg-desktop" viewBox="0 0 1440 520" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <defs>
        <linearGradient id="bgGrad" x1="0%" y1="0%" x2="100%" y2="100%">
          <stop offset="0%" style="stop-color:#1e3a8a;stop-opacity:1"/>
          <stop offset="100%" style="stop-color:#2563eb;stop-opacity:1"/>
        </linearGradient>
        <linearGradient id="glowGrad" x1="0%" y1="0%" x2="100%" y2="100%">
          <stop offset="0%" style="stop-color:#3b82f6;stop-opacity:0.25"/>
          <stop offset="100%" style="stop-color:#1d4ed8;stop-opacity:0"/>
        </linearGradient>
      </defs>
      <rect width="1440" height="520" fill="url(#bgGrad)"/>
      <ellipse cx="220" cy="200" rx="380" ry="260" fill="url(#glowGrad)" class="glow-orb-1"/>
      <ellipse cx="1220" cy="340" rx="320" ry="220" fill="url(#glowGrad)" class="glow-orb-2"/>

      <!-- LEFT: Game controller — translate(280, 240) -->
      <g class="controller-group" transform="translate(280, 240)">
        <!-- Controller body -->
        <path d="M-110 -10 Q-110 -45 -75 -45 L75 -45 Q110 -45 110 -10 L130 70 Q130 100 100 100 L65 100 L45 70 L-45 70 L-65 100 L-100 100 Q-130 100 -130 70 Z"
              stroke="white" stroke-opacity="0.4" stroke-width="2.5" fill="white" fill-opacity="0.08" class="controller-body"/>

        <!-- Top shoulder buttons -->
        <rect x="-90" y="-50" width="30" height="8" rx="3" stroke="white" stroke-opacity="0.3" stroke-width="1.2" fill="white" fill-opacity="0.1"/>
        <rect x="60" y="-50" width="30" height="8" rx="3" stroke="white" stroke-opacity="0.3" stroke-width="1.2" fill="white" fill-opacity="0.1"/>

        <!-- Left D-pad cross -->
        <g transform="translate(-70, 5)">
          <rect x="-5" y="-15" width="10" height="30" rx="1" stroke="white" stroke-opacity="0.35" stroke-width="1.5" fill="white" fill-opacity="0.12"/>
          <rect x="-15" y="-5" width="30" height="10" rx="1" stroke="white" stroke-opacity="0.35" stroke-width="1.5" fill="white" fill-opacity="0.12"/>
        </g>

        <!-- Right buttons (4 face buttons in diamond) — outer wrapper, inner animates -->
        <g transform="translate(70, 5)">
          <!-- Top button (Y/△) -->
          <g transform="translate(0, -16)">
            <g class="face-btn btn-1">
              <circle cx="0" cy="0" r="9" stroke="white" stroke-opacity="0.5" stroke-width="2" fill="white" fill-opacity="0.15"/>
              <text x="0" y="3.5" text-anchor="middle" fill="white" fill-opacity="0.7" font-size="11" font-family="ui-monospace, monospace" font-weight="700">Y</text>
            </g>
          </g>
          <!-- Right button (B/○) -->
          <g transform="translate(16, 0)">
            <g class="face-btn btn-2">
              <circle cx="0" cy="0" r="9" stroke="white" stroke-opacity="0.5" stroke-width="2" fill="white" fill-opacity="0.15"/>
              <text x="0" y="3.5" text-anchor="middle" fill="white" fill-opacity="0.7" font-size="11" font-family="ui-monospace, monospace" font-weight="700">B</text>
            </g>
          </g>
          <!-- Bottom button (A/×) -->
          <g transform="translate(0, 16)">
            <g class="face-btn btn-3">
              <circle cx="0" cy="0" r="9" stroke="white" stroke-opacity="0.5" stroke-width="2" fill="white" fill-opacity="0.15"/>
              <text x="0" y="3.5" text-anchor="middle" fill="white" fill-opacity="0.7" font-size="11" font-family="ui-monospace, monospace" font-weight="700">A</text>
            </g>
          </g>
          <!-- Left button (X/□) -->
          <g transform="translate(-16, 0)">
            <g class="face-btn btn-4">
              <circle cx="0" cy="0" r="9" stroke="white" stroke-opacity="0.5" stroke-width="2" fill="white" fill-opacity="0.15"/>
              <text x="0" y="3.5" text-anchor="middle" fill="white" fill-opacity="0.7" font-size="11" font-family="ui-monospace, monospace" font-weight="700">X</text>
            </g>
          </g>
        </g>

        <!-- Joystick (left, lower) — wiggles -->
        <g transform="translate(-30, 50)">
          <circle cx="0" cy="0" r="14" stroke="white" stroke-opacity="0.35" stroke-width="1.5" fill="white" fill-opacity="0.1"/>
          <g class="joystick">
            <circle cx="0" cy="0" r="9" stroke="white" stroke-opacity="0.5" stroke-width="1.5" fill="white" fill-opacity="0.2"/>
            <circle cx="0" cy="0" r="3" fill="white" fill-opacity="0.4"/>
          </g>
        </g>

        <!-- Joystick (right, lower) — wiggles opposite -->
        <g transform="translate(30, 50)">
          <circle cx="0" cy="0" r="14" stroke="white" stroke-opacity="0.35" stroke-width="1.5" fill="white" fill-opacity="0.1"/>
          <g class="joystick joystick-r">
            <circle cx="0" cy="0" r="9" stroke="white" stroke-opacity="0.5" stroke-width="1.5" fill="white" fill-opacity="0.2"/>
            <circle cx="0" cy="0" r="3" fill="white" fill-opacity="0.4"/>
          </g>
        </g>

        <!-- Center home button -->
        <circle cx="0" cy="0" r="4" stroke="white" stroke-opacity="0.3" stroke-width="1.2" fill="white" fill-opacity="0.1" class="home-btn"/>

        <!-- Connecting cable curling off to the left (just decorative) -->
        <path d="M-130 70 Q-160 80 -170 110" stroke="white" stroke-opacity="0.2" stroke-width="2" fill="none" stroke-linecap="round"/>
      </g>

      <!-- RIGHT: Console body with disc slot — translate(1180, 240) -->
      <g class="console-group" transform="translate(1180, 240)">
        <!-- Console body -->
        <rect x="-120" y="-50" width="240" height="100" rx="5" stroke="white" stroke-opacity="0.4" stroke-width="2.5" fill="white" fill-opacity="0.06" class="console-body"/>
        <!-- Top vent grille -->
        <g stroke="white" stroke-opacity="0.18" stroke-width="1">
          <line x1="-100" y1="-40" x2="-30" y2="-40"/>
          <line x1="-100" y1="-35" x2="-30" y2="-35"/>
          <line x1="-100" y1="-30" x2="-30" y2="-30"/>
          <line x1="30" y1="-40" x2="100" y2="-40"/>
          <line x1="30" y1="-35" x2="100" y2="-35"/>
          <line x1="30" y1="-30" x2="100" y2="-30"/>
        </g>
        <!-- Disc slot (horizontal opening) -->
        <rect x="-90" y="-15" width="180" height="3" rx="1.5" fill="#1e3a8a" stroke="white" stroke-opacity="0.4" stroke-width="1" class="disc-slot"/>
        <!-- Power button -->
        <circle cx="-95" cy="25" r="5" stroke="white" stroke-opacity="0.4" stroke-width="1.5" fill="white" fill-opacity="0.1"/>
        <line x1="-95" y1="22" x2="-95" y2="27" stroke="white" stroke-opacity="0.55" stroke-width="1.5" stroke-linecap="round"/>
        <!-- Eject button -->
        <circle cx="-78" cy="25" r="5" stroke="white" stroke-opacity="0.4" stroke-width="1.5" fill="white" fill-opacity="0.1"/>
        <polygon points="-78,22 -75,27 -81,27" fill="white" fill-opacity="0.55"/>
        <!-- USB ports -->
        <rect x="60" y="22" width="14" height="6" rx="0.5" stroke="white" stroke-opacity="0.4" stroke-width="1" fill="white" fill-opacity="0.1"/>
        <rect x="80" y="22" width="14" height="6" rx="0.5" stroke="white" stroke-opacity="0.4" stroke-width="1" fill="white" fill-opacity="0.1"/>

        <!-- Status LED (lights up when "ready") -->
        <circle cx="0" cy="35" r="3" fill="white" fill-opacity="0.25" class="status-led"/>
        <text x="0" y="48" text-anchor="middle" fill="white" fill-opacity="0.55" font-size="9" font-family="ui-monospace, monospace" letter-spacing="2" font-weight="700" class="status-text">READY</text>

        <!-- Disc — outer wrapper positions, inner animates the slide-in + spin -->
        <g transform="translate(0, -60)">
          <g class="disc">
            <!-- Disc body -->
            <circle cx="0" cy="0" r="32" stroke="white" stroke-opacity="0.5" stroke-width="2" fill="white" fill-opacity="0.12"/>
            <circle cx="0" cy="0" r="22" stroke="white" stroke-opacity="0.25" stroke-width="1" fill="none"/>
            <circle cx="0" cy="0" r="12" stroke="white" stroke-opacity="0.3" stroke-width="1.5" fill="white" fill-opacity="0.05"/>
            <!-- Center hole -->
            <circle cx="0" cy="0" r="5" fill="#1e3a8a"/>
            <!-- Iridescent tick marks for spin effect -->
            <g class="disc-spin">
              <line x1="0" y1="-30" x2="0" y2="-22" stroke="white" stroke-opacity="0.5" stroke-width="2" stroke-linecap="round"/>
              <line x1="21" y1="-21" x2="15.5" y2="-15.5" stroke="white" stroke-opacity="0.35" stroke-width="1.5" stroke-linecap="round"/>
              <line x1="30" y1="0" x2="22" y2="0" stroke="white" stroke-opacity="0.25" stroke-width="1.2" stroke-linecap="round"/>
            </g>
          </g>
        </g>
      </g>

      <!-- Floating D-pad — outer wrapper -->
      <g transform="translate(720, 90)">
        <g class="float-icon float-tool-1" stroke="white" stroke-opacity="0.18" fill="white" fill-opacity="0.06" stroke-width="1.5">
          <rect x="-4" y="-14" width="8" height="28" rx="1"/>
          <rect x="-14" y="-4" width="28" height="8" rx="1"/>
        </g>
      </g>

      <!-- Floating power icon -->
      <g transform="translate(160, 380)">
        <g class="float-icon float-tool-2" stroke="white" stroke-opacity="0.18" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M18.36 -5.36a9 9 0 1 1-12.73 0" transform="translate(-12, -2)"/>
          <line x1="0" y1="-12" x2="0" y2="0" />
        </g>
      </g>

      <!-- Floating retro cartridge -->
      <g transform="translate(1280, 110)">
        <g class="float-icon float-tool-3" stroke="white" stroke-opacity="0.18" fill="white" fill-opacity="0.08" stroke-width="1.5" stroke-linejoin="round">
          <path d="M-15 -18 L15 -18 L15 8 L18 12 L18 18 L-18 18 L-18 12 L-15 8 Z"/>
          <rect x="-10" y="-13" width="20" height="14" stroke-opacity="0.25" fill-opacity="0.05"/>
          <line x1="-12" y1="14" x2="12" y2="14" stroke-opacity="0.3"/>
        </g>
      </g>

      <!-- Ambient labels -->
      <g font-family="ui-monospace, SFMono-Regular, Menlo, monospace" font-weight="700" fill="white">
        <text x="100" y="100" font-size="11" fill-opacity="0.1" class="code-tw ct-a">// player 1</text>
        <text x="660" y="430" font-size="11" fill-opacity="0.1" class="code-tw ct-b">// press start</text>
        <text x="1180" y="450" font-size="11" fill-opacity="0.1" class="code-tw ct-c">// loading</text>
        <text x="80" y="450" font-size="10" fill-opacity="0.09" class="code-tw ct-d">P1 ready</text>
      </g>

      <!-- Grid -->
      <g stroke="white" stroke-opacity="0.04" stroke-width="1">
        <line x1="0" y1="130" x2="1440" y2="130"/>
        <line x1="0" y1="260" x2="1440" y2="260"/>
        <line x1="0" y1="390" x2="1440" y2="390"/>
        <line x1="360" y1="0" x2="360" y2="520"/>
        <line x1="720" y1="0" x2="720" y2="520"/>
        <line x1="1080" y1="0" x2="1080" y2="520"/>
      </g>
    </svg>

    <!-- MOBILE SVG -->
    <svg class="hero-bg-mobile" viewBox="0 0 400 600" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <defs>
        <linearGradient id="bgGradM" x1="0%" y1="0%" x2="100%" y2="100%">
          <stop offset="0%" style="stop-color:#1e3a8a;stop-opacity:1"/>
          <stop offset="100%" style="stop-color:#2563eb;stop-opacity:1"/>
        </linearGradient>
        <linearGradient id="glowGradM" x1="0%" y1="0%" x2="100%" y2="100%">
          <stop offset="0%" style="stop-color:#3b82f6;stop-opacity:0.3"/>
          <stop offset="100%" style="stop-color:#1d4ed8;stop-opacity:0"/>
        </linearGradient>
      </defs>
      <rect width="400" height="600" fill="url(#bgGradM)"/>
      <ellipse cx="80" cy="100" rx="180" ry="140" fill="url(#glowGradM)" class="glow-orb-1"/>
      <ellipse cx="340" cy="500" rx="180" ry="140" fill="url(#glowGradM)" class="glow-orb-2"/>

      <!-- Controller top-left — translate(80, 90) -->
      <g class="controller-group" transform="translate(80, 90)">
        <path d="M-70 -8 Q-70 -28 -48 -28 L48 -28 Q70 -28 70 -8 L82 45 Q82 62 64 62 L42 62 L28 45 L-28 45 L-42 62 L-64 62 Q-82 62 -82 45 Z"
              stroke="white" stroke-opacity="0.4" stroke-width="1.5" fill="white" fill-opacity="0.08" class="controller-body"/>
        <g transform="translate(-44, 4)">
          <rect x="-3" y="-9" width="6" height="18" rx="0.5" stroke="white" stroke-opacity="0.35" stroke-width="1" fill="white" fill-opacity="0.12"/>
          <rect x="-9" y="-3" width="18" height="6" rx="0.5" stroke="white" stroke-opacity="0.35" stroke-width="1" fill="white" fill-opacity="0.12"/>
        </g>
        <g transform="translate(44, 4)">
          <g transform="translate(0, -10)">
            <g class="face-btn btn-1">
              <circle cx="0" cy="0" r="5.5" stroke="white" stroke-opacity="0.5" stroke-width="1.2" fill="white" fill-opacity="0.15"/>
              <text x="0" y="2" text-anchor="middle" fill="white" fill-opacity="0.7" font-size="6.5" font-family="ui-monospace, monospace" font-weight="700">Y</text>
            </g>
          </g>
          <g transform="translate(10, 0)">
            <g class="face-btn btn-2">
              <circle cx="0" cy="0" r="5.5" stroke="white" stroke-opacity="0.5" stroke-width="1.2" fill="white" fill-opacity="0.15"/>
              <text x="0" y="2" text-anchor="middle" fill="white" fill-opacity="0.7" font-size="6.5" font-family="ui-monospace, monospace" font-weight="700">B</text>
            </g>
          </g>
          <g transform="translate(0, 10)">
            <g class="face-btn btn-3">
              <circle cx="0" cy="0" r="5.5" stroke="white" stroke-opacity="0.5" stroke-width="1.2" fill="white" fill-opacity="0.15"/>
              <text x="0" y="2" text-anchor="middle" fill="white" fill-opacity="0.7" font-size="6.5" font-family="ui-monospace, monospace" font-weight="700">A</text>
            </g>
          </g>
          <g transform="translate(-10, 0)">
            <g class="face-btn btn-4">
              <circle cx="0" cy="0" r="5.5" stroke="white" stroke-opacity="0.5" stroke-width="1.2" fill="white" fill-opacity="0.15"/>
              <text x="0" y="2" text-anchor="middle" fill="white" fill-opacity="0.7" font-size="6.5" font-family="ui-monospace, monospace" font-weight="700">X</text>
            </g>
          </g>
        </g>
        <g transform="translate(-18, 30)">
          <circle cx="0" cy="0" r="9" stroke="white" stroke-opacity="0.35" stroke-width="1" fill="white" fill-opacity="0.1"/>
          <g class="joystick">
            <circle cx="0" cy="0" r="6" stroke="white" stroke-opacity="0.5" stroke-width="1" fill="white" fill-opacity="0.2"/>
          </g>
        </g>
        <g transform="translate(18, 30)">
          <circle cx="0" cy="0" r="9" stroke="white" stroke-opacity="0.35" stroke-width="1" fill="white" fill-opacity="0.1"/>
          <g class="joystick joystick-r">
            <circle cx="0" cy="0" r="6" stroke="white" stroke-opacity="0.5" stroke-width="1" fill="white" fill-opacity="0.2"/>
          </g>
        </g>
      </g>

      <!-- Console + disc bottom-right — translate(310, 510) -->
      <g class="console-group" transform="translate(310, 510)">
        <rect x="-75" y="-30" width="150" height="60" rx="3" stroke="white" stroke-opacity="0.4" stroke-width="1.8" fill="white" fill-opacity="0.06" class="console-body"/>
        <g stroke="white" stroke-opacity="0.18" stroke-width="0.8">
          <line x1="-65" y1="-22" x2="-22" y2="-22"/>
          <line x1="-65" y1="-18" x2="-22" y2="-18"/>
          <line x1="22" y1="-22" x2="65" y2="-22"/>
          <line x1="22" y1="-18" x2="65" y2="-18"/>
        </g>
        <rect x="-55" y="-8" width="110" height="2" rx="1" fill="#1e3a8a" stroke="white" stroke-opacity="0.4" stroke-width="0.8"/>
        <circle cx="-58" cy="16" r="3" stroke="white" stroke-opacity="0.4" stroke-width="1" fill="white" fill-opacity="0.1"/>
        <circle cx="0" cy="20" r="2" fill="white" fill-opacity="0.25" class="status-led"/>
        <text x="0" y="29" text-anchor="middle" fill="white" fill-opacity="0.55" font-size="6" font-family="ui-monospace, monospace" letter-spacing="1.5" font-weight="700" class="status-text">READY</text>

        <g transform="translate(0, -38)">
          <g class="disc">
            <circle cx="0" cy="0" r="20" stroke="white" stroke-opacity="0.5" stroke-width="1.5" fill="white" fill-opacity="0.12"/>
            <circle cx="0" cy="0" r="13" stroke="white" stroke-opacity="0.25" stroke-width="0.8" fill="none"/>
            <circle cx="0" cy="0" r="7" stroke="white" stroke-opacity="0.3" stroke-width="1" fill="white" fill-opacity="0.05"/>
            <circle cx="0" cy="0" r="3" fill="#1e3a8a"/>
            <g class="disc-spin">
              <line x1="0" y1="-18" x2="0" y2="-13" stroke="white" stroke-opacity="0.5" stroke-width="1.5" stroke-linecap="round"/>
              <line x1="13" y1="-13" x2="9" y2="-9" stroke="white" stroke-opacity="0.35" stroke-width="1" stroke-linecap="round"/>
            </g>
          </g>
        </g>
      </g>

      <!-- Grid -->
      <g stroke="white" stroke-opacity="0.04" stroke-width="1">
        <line x1="0" y1="150" x2="400" y2="150"/>
        <line x1="0" y1="300" x2="400" y2="300"/>
        <line x1="0" y1="450" x2="400" y2="450"/>
        <line x1="133" y1="0" x2="133" y2="600"/>
        <line x1="266" y1="0" x2="266" y2="600"/>
      </g>
    </svg>

    <!-- Hero text -->
    <div id="hero-content">
      <p class="hero-label">
        <a href="/services#gaming-console-repair" style="color:#93c5fd;text-decoration:none;" aria-label="Back to all services">← Services</a>
      </p>
      <h1 id="hero-wordmark">Gaming Console Repair</h1>
      <p id="hero-tagline">PlayStation, Xbox, Nintendo Switch and more. I diagnose and repair common console issues including disc drives, overheating and general wear and tear. Modern and retro.</p>
      <div id="hero-cta-row">
        <a href="/contact" class="hero-cta-primary">
          Get a Free Quote
          <svg style="height:1rem;width:1rem;" aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
        <a href="/pricing" class="hero-cta-secondary">View Pricing</a>
      </div>
    </div>

    <div id="scroll-hint" aria-hidden="true" role="button" tabindex="-1" onclick="document.getElementById('what-i-work-on').scrollIntoView({behavior:'smooth'})">
      <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" style="height:1.5rem;width:1.5rem;"><path d="M12 5v14M5 12l7 7 7-7"/></svg>
    </div>
  </section>

  <!-- Info Bar -->
  <section style="background:#1e40af;padding:1.25rem 1.5rem;">
    <div style="max-width:56rem;margin:0 auto;display:flex;flex-wrap:wrap;align-items:center;justify-content:center;gap:2rem;text-align:center;">
      <div>
        <div style="font-size:1.75rem;font-weight:800;color:white;">From $60</div>
        <div style="font-size:0.8rem;color:#bfdbfe;font-weight:600;">Diagnostics &amp; Repair</div>
      </div>
      <div style="width:1px;height:2.5rem;background:rgba(255,255,255,0.2);flex-shrink:0;"></div>
      <div>
        <div style="font-size:1.75rem;font-weight:800;color:white;">Free Quote</div>
        <div style="font-size:0.8rem;color:#bfdbfe;font-weight:600;">Honest Assessment</div>
      </div>
      <div style="width:1px;height:2.5rem;background:rgba(255,255,255,0.2);flex-shrink:0;"></div>
      <div>
        <div style="font-size:1.75rem;font-weight:800;color:white;">30 Day</div>
        <div style="font-size:0.8rem;color:#bfdbfe;font-weight:600;">Labor Warranty</div>
      </div>
    </div>
  </section>

  <!-- What I Work On -->
  <section id="what-i-work-on" style="background:#f8fafc;padding:4rem 1.5rem;">
    <div style="max-width:56rem;margin:0 auto;">
      <div style="margin-bottom:2.5rem;">
        <p style="font-size:0.875rem;font-weight:600;text-transform:uppercase;letter-spacing:0.1em;color:#2563eb;">Consoles I Service</p>
        <h2 style="font-size:2rem;font-weight:800;color:#111827;margin-top:0.5rem;">What I Work On</h2>
        <p style="color:#6b7280;margin-top:0.75rem;line-height:1.75;">From current-gen consoles to retro classics, I can diagnose and repair a wide range of gaming hardware. If you're not sure whether I can help with yours, just ask.</p>
      </div>

      <div style="display:flex;flex-direction:column;gap:1rem;">
        <div class="service-item" style="border-left:4px solid #2563eb;">
          <div class="service-icon" style="background:#dbeafe;color:#2563eb;" aria-hidden="true">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><rect x="2" y="6" width="20" height="12" rx="2"/><path d="M6 12h.01M10 12h.01M7 9l-1 3 1 3M13 9l1 3-1 3"/></svg>
          </div>
          <div>
            <h3 class="item-title">PlayStation &amp; Xbox</h3>
            <p class="item-desc">PS4, PS5, Xbox One, Xbox Series X/S and earlier models. Common issues like disc drive failures, overheating, HDMI port issues where board-level soldering is not required, and general hardware faults. I have experience with optical drive repairs including the chip transfer process required on Xbox One X disc drive swaps.</p>
          </div>
        </div>

        <div class="service-item" style="border-left:4px solid #7c3aed;">
          <div class="service-icon" style="background:#ede9fe;color:#6d28d9;" aria-hidden="true">
