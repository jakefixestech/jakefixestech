---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Mac & Apple Software | Jake Fixes Tech — Littleton, NH"
description="macOS reinstalls, software troubleshooting, iCloud help and Linux installs on older Macs. Serving Littleton NH and the North Country. Software only, no Apple hardware repairs.">

  <!-- Animated SVG Hero -->
  <section id="hero-svg" aria-label="Mac and Apple Software Service">

    <!-- DESKTOP SVG -->
    <svg class="hero-bg-desktop" viewBox="0 0 1440 520" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <defs>
        <linearGradient id="bgGrad" x1="0%" y1="0%" x2="100%" y2="100%">
          <stop offset="0%" style="stop-color:#1e3a8a;stop-opacity:1"/>
          <stop offset="100%" style="stop-color:#2563eb;stop-opacity:1"/>
        </linearGradient>
        <linearGradient id="glowGrad" x1="0%" y1="0%" x2="100%" y2="100%">
          <stop offset="0%" style="stop-color:#3b82f6;stop-opacity:0.25"/>
          <stop offset="100%" style="stop-color:#1d4ed8;stop-opacity:0"/>
        </linearGradient>
        <linearGradient id="installFill" x1="0%" y1="0%" x2="100%" y2="0%">
          <stop offset="0%" style="stop-color:#86efac;stop-opacity:0.6"/>
          <stop offset="100%" style="stop-color:#86efac;stop-opacity:0.3"/>
        </linearGradient>
      </defs>
      <rect width="1440" height="520" fill="url(#bgGrad)"/>
      <ellipse cx="220" cy="200" rx="380" ry="260" fill="url(#glowGrad)" class="glow-orb-1"/>
      <ellipse cx="1220" cy="340" rx="320" ry="220" fill="url(#glowGrad)" class="glow-orb-2"/>

      <!-- LEFT: Laptop showing macOS install/update — translate(280, 240) -->
      <g class="laptop-1" transform="translate(280, 240)">
        <!-- Laptop base -->
        <path d="M-120 90 L120 90 L130 105 L-130 105 Z" stroke="white" stroke-opacity="0.35" stroke-width="2" fill="white" fill-opacity="0.06" class="laptop-base"/>
        <!-- Laptop screen frame -->
        <rect x="-110" y="-80" width="220" height="170" rx="4" stroke="white" stroke-opacity="0.4" stroke-width="2" fill="white" fill-opacity="0.05" class="laptop-frame"/>
        <!-- Screen bezel -->
        <rect x="-100" y="-72" width="200" height="155" rx="2" fill="white" fill-opacity="0.04"/>
        <!-- Camera dot -->
        <circle cx="0" cy="-76" r="1.2" fill="white" fill-opacity="0.4"/>

        <!-- Screen content: install in progress -->
        <g class="install-screen">
          <!-- Title text "macOS" (plain text, no logo) -->
          <text x="0" y="-30" text-anchor="middle" fill="white" fill-opacity="0.7" font-size="22" font-family="ui-sans-serif, system-ui, sans-serif" font-weight="600" letter-spacing="1">macOS</text>
          <text x="0" y="-12" text-anchor="middle" fill="white" fill-opacity="0.45" font-size="9" font-family="ui-monospace, monospace" letter-spacing="1.5" class="install-status">INSTALLING</text>
          <text x="0" y="0" text-anchor="middle" fill="white" fill-opacity="0.45" font-size="9" font-family="ui-monospace, monospace" letter-spacing="1.5" class="install-status-done">COMPLETE</text>

          <!-- Progress bar track -->
          <rect x="-70" y="14" width="140" height="8" rx="4" stroke="white" stroke-opacity="0.2" stroke-width="1" fill="white" fill-opacity="0.05"/>
          <!-- Progress fill (animates width) -->
          <rect x="-70" y="14" width="0" height="8" rx="4" fill="url(#installFill)" class="install-fill"/>

          <!-- Percentage text -->
          <text x="0" y="38" text-anchor="middle" fill="white" fill-opacity="0.4" font-size="8" font-family="ui-monospace, monospace" class="install-pct">0%</text>

          <!-- Final checkmark, fades in when install completes -->
          <g class="install-check">
            <circle cx="0" cy="55" r="14" stroke="#86efac" stroke-opacity="0.7" stroke-width="2" fill="white" fill-opacity="0.05"/>
            <polyline points="-6,55 -2,60 6,50" stroke="#86efac" stroke-opacity="0.85" stroke-width="2.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
          </g>
        </g>

        <!-- Hinge notch -->
        <rect x="-25" y="89" width="50" height="3" rx="1" fill="white" fill-opacity="0.2"/>
      </g>

      <!-- RIGHT: Laptop showing Linux Mint customization — translate(1180, 240) -->
      <g class="laptop-2" transform="translate(1180, 240)">
        <path d="M-120 90 L120 90 L130 105 L-130 105 Z" stroke="white" stroke-opacity="0.35" stroke-width="2" fill="white" fill-opacity="0.06" class="laptop-base"/>
        <rect x="-110" y="-80" width="220" height="170" rx="4" stroke="white" stroke-opacity="0.4" stroke-width="2" fill="white" fill-opacity="0.05" class="laptop-frame"/>
        <rect x="-100" y="-72" width="200" height="155" rx="2" fill="white" fill-opacity="0.04"/>
        <circle cx="0" cy="-76" r="1.2" fill="white" fill-opacity="0.4"/>

        <!-- Screen content: Linux desktop with cycling themes -->
        <g class="linux-screen">
          <!-- "Linux Mint" label across the top -->
          <text x="0" y="-55" text-anchor="middle" fill="white" fill-opacity="0.6" font-size="11" font-family="ui-sans-serif, system-ui, sans-serif" font-weight="700" letter-spacing="1">Linux Mint</text>

          <!-- Three theme preview tiles cycling -->
          <!-- Theme 1: Default dark -->
          <g transform="translate(-66, -36)">
            <g class="theme theme-1">
              <rect x="0" y="0" width="44" height="32" rx="3" stroke="white" stroke-opacity="0.35" stroke-width="1.2" fill="white" fill-opacity="0.08"/>
              <!-- Top bar -->
              <rect x="2" y="2" width="40" height="4" rx="0.5" fill="white" fill-opacity="0.25"/>
              <!-- Window -->
              <rect x="6" y="10" width="32" height="14" rx="1" stroke="white" stroke-opacity="0.3" stroke-width="0.8" fill="white" fill-opacity="0.06"/>
              <!-- Dock at bottom -->
              <rect x="10" y="26" width="24" height="3" rx="1.5" fill="white" fill-opacity="0.2"/>
            </g>
          </g>

          <!-- Theme 2: Mac-like -->
          <g transform="translate(-22, -36)">
            <g class="theme theme-2">
              <rect x="0" y="0" width="44" height="32" rx="3" stroke="white" stroke-opacity="0.35" stroke-width="1.2" fill="white" fill-opacity="0.1"/>
              <rect x="2" y="2" width="40" height="3" rx="0.3" fill="white" fill-opacity="0.18"/>
              <!-- Centered window -->
              <rect x="8" y="9" width="28" height="13" rx="1.5" stroke="white" stroke-opacity="0.3" stroke-width="0.8" fill="white" fill-opacity="0.07"/>
              <circle cx="11" cy="12" r="0.9" fill="white" fill-opacity="0.5"/>
              <circle cx="14" cy="12" r="0.9" fill="white" fill-opacity="0.5"/>
              <circle cx="17" cy="12" r="0.9" fill="white" fill-opacity="0.5"/>
              <!-- Bottom centered dock with rounded pills -->
              <rect x="10" y="26" width="24" height="3" rx="1.5" stroke="white" stroke-opacity="0.25" stroke-width="0.5" fill="white" fill-opacity="0.12"/>
            </g>
          </g>

          <!-- Theme 3: Tiling/custom -->
          <g transform="translate(22, -36)">
            <g class="theme theme-3">
              <rect x="0" y="0" width="44" height="32" rx="3" stroke="white" stroke-opacity="0.35" stroke-width="1.2" fill="white" fill-opacity="0.06"/>
              <!-- Tiled split -->
              <rect x="3" y="3" width="18" height="26" rx="1" stroke="white" stroke-opacity="0.3" stroke-width="0.8" fill="white" fill-opacity="0.08"/>
              <rect x="23" y="3" width="18" height="12" rx="1" stroke="white" stroke-opacity="0.3" stroke-width="0.8" fill="white" fill-opacity="0.08"/>
              <rect x="23" y="17" width="18" height="12" rx="1" stroke="white" stroke-opacity="0.3" stroke-width="0.8" fill="white" fill-opacity="0.08"/>
            </g>
          </g>

          <!-- "Customize" label below tiles -->
          <text x="0" y="6" text-anchor="middle" fill="white" fill-opacity="0.4" font-size="8" font-family="ui-monospace, monospace" letter-spacing="1.5">CUSTOMIZE</text>

          <!-- Speed indicator: lightning + label -->
          <g transform="translate(-50, 34)">
            <polygon points="0,-8 -4,2 -1,2 -3,8 4,-2 1,-2 3,-8" fill="#86efac" fill-opacity="0.7" stroke="#86efac" stroke-opacity="0.85" stroke-width="0.8" stroke-linejoin="round"/>
          </g>
          <text x="-30" y="36" fill="#86efac" fill-opacity="0.8" font-size="9" font-family="ui-monospace, monospace" font-weight="700">FAST</text>

          <!-- Free indicator -->
          <g transform="translate(20, 34)">
            <circle cx="0" cy="0" r="6" stroke="#86efac" stroke-opacity="0.7" stroke-width="1.2" fill="white" fill-opacity="0.05"/>
            <text x="0" y="2.5" text-anchor="middle" fill="#86efac" fill-opacity="0.85" font-size="6" font-family="ui-monospace, monospace" font-weight="700">$0</text>
          </g>
          <text x="40" y="36" fill="#86efac" fill-opacity="0.8" font-size="9" font-family="ui-monospace, monospace" font-weight="700">FREE</text>
        </g>

        <rect x="-25" y="89" width="50" height="3" rx="1" fill="white" fill-opacity="0.2"/>
      </g>

      <!-- Floating cloud (iCloud troubleshooting) — outer wrapper -->
      <g transform="translate(720, 90)">
        <g class="float-icon float-tool-1" stroke="white" stroke-opacity="0.18" fill="white" fill-opacity="0.06" stroke-width="1.5" stroke-linejoin="round">
          <path d="M -16 4 a 8 8 0 0 1 8 -8 a 10 10 0 0 1 19 3 a 7 7 0 0 1 -1 14 h -19 a 7 7 0 0 1 -7 -7 z"/>
        </g>
      </g>

      <!-- Floating terminal window (software troubleshooting) -->
      <g transform="translate(160, 380)">
        <g class="float-icon float-tool-2" stroke="white" stroke-opacity="0.18" fill="white" fill-opacity="0.05" stroke-width="1.5" stroke-linejoin="round">
          <rect x="-18" y="-14" width="36" height="28" rx="2"/>
          <line x1="-18" y1="-7" x2="18" y2="-7" stroke-opacity="0.25"/>
          <circle cx="-13" cy="-10.5" r="1.2" fill="white" fill-opacity="0.3" stroke="none"/>
          <circle cx="-9" cy="-10.5" r="1.2" fill="white" fill-opacity="0.3" stroke="none"/>
          <circle cx="-5" cy="-10.5" r="1.2" fill="white" fill-opacity="0.3" stroke="none"/>
          <line x1="-13" y1="-2" x2="-7" y2="-2" stroke-opacity="0.4"/>
          <line x1="-13" y1="3" x2="-1" y2="3" stroke-opacity="0.4"/>
          <line x1="-13" y1="8" x2="4" y2="8" stroke-opacity="0.4"/>
        </g>
      </g>

      <!-- Floating clock (time machine backup) -->
      <g transform="translate(1280, 110)">
        <g class="float-icon float-tool-3" stroke="white" stroke-opacity="0.18" fill="white" fill-opacity="0.05" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="0" cy="0" r="14"/>
          <polyline points="0,-8 0,0 6,4"/>
          <!-- Backward arrow accent (time goes back) -->
          <path d="M -14 -4 a 14 14 0 0 1 4 -10" fill="none" stroke-opacity="0.3"/>
          <polyline points="-14,-4 -16,-8 -10,-8" fill="none" stroke-opacity="0.3"/>
        </g>
      </g>

      <!-- Ambient labels -->
      <g font-family="ui-monospace, SFMono-Regular, Menlo, monospace" font-weight="700" fill="white">
        <text x="100" y="100" font-size="11" fill-opacity="0.1" class="code-tw ct-a">// macOS</text>
        <text x="660" y="430" font-size="11" fill-opacity="0.1" class="code-tw ct-b">// software</text>
        <text x="1180" y="450" font-size="11" fill-opacity="0.1" class="code-tw ct-c">// linux</text>
        <text x="80" y="450" font-size="10" fill-opacity="0.09" class="code-tw ct-d">2012-2018</text>
      </g>

      <!-- Grid -->
      <g stroke="white" stroke-opacity="0.04" stroke-width="1">
        <line x1="0" y1="130" x2="1440" y2="130"/>
        <line x1="0" y1="260" x2="1440" y2="260"/>
        <line x1="0" y1="390" x2="1440" y2="390"/>
        <line x1="360" y1="0" x2="360" y2="520"/>
        <line x1="720" y1="0" x2="720" y2="520"/>
        <line x1="1080" y1="0" x2="1080" y2="520"/>
      </g>
    </svg>

    <!-- MOBILE SVG -->
    <svg class="hero-bg-mobile" viewBox="0 0 400 600" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <defs>
        <linearGradient id="bgGradM" x1="0%" y1="0%" x2="100%" y2="100%">
          <stop offset="0%" style="stop-color:#1e3a8a;stop-opacity:1"/>
          <stop offset="100%" style="stop-color:#2563eb;stop-opacity:1"/>
        </linearGradient>
        <linearGradient id="glowGradM" x1="0%" y1="0%" x2="100%" y2="100%">
          <stop offset="0%" style="stop-color:#3b82f6;stop-opacity:0.3"/>
          <stop offset="100%" style="stop-color:#1d4ed8;stop-opacity:0"/>
        </linearGradient>
        <linearGradient id="installFillM" x1="0%" y1="0%" x2="100%" y2="0%">
          <stop offset="0%" style="stop-color:#86efac;stop-opacity:0.6"/>
          <stop offset="100%" style="stop-color:#86efac;stop-opacity:0.3"/>
        </linearGradient>
      </defs>
      <rect width="400" height="600" fill="url(#bgGradM)"/>
      <ellipse cx="80" cy="100" rx="180" ry="140" fill="url(#glowGradM)" class="glow-orb-1"/>
      <ellipse cx="340" cy="500" rx="180" ry="140" fill="url(#glowGradM)" class="glow-orb-2"/>

      <!-- macOS install laptop top-left — translate(80, 90) -->
      <g class="laptop-1" transform="translate(80, 90)">
        <path d="M-72 60 L72 60 L80 70 L-80 70 Z" stroke="white" stroke-opacity="0.35" stroke-width="1.5" fill="white" fill-opacity="0.06" class="laptop-base"/>
        <rect x="-66" y="-50" width="132" height="110" rx="3" stroke="white" stroke-opacity="0.4" stroke-width="1.5" fill="white" fill-opacity="0.05" class="laptop-frame"/>
        <rect x="-60" y="-44" width="120" height="100" rx="2" fill="white" fill-opacity="0.04"/>
        <circle cx="0" cy="-47" r="0.8" fill="white" fill-opacity="0.4"/>

        <g class="install-screen">
          <text x="0" y="-15" text-anchor="middle" fill="white" fill-opacity="0.7" font-size="14" font-family="ui-sans-serif, system-ui, sans-serif" font-weight="600">macOS</text>
          <text x="0" y="-2" text-anchor="middle" fill="white" fill-opacity="0.45" font-size="6" font-family="ui-monospace, monospace" letter-spacing="1" class="install-status">INSTALLING</text>
          <text x="0" y="-2" text-anchor="middle" fill="white" fill-opacity="0.45" font-size="6" font-family="ui-monospace, monospace" letter-spacing="1" class="install-status-done">COMPLETE</text>
          <rect x="-44" y="6" width="88" height="5" rx="2.5" stroke="white" stroke-opacity="0.2" stroke-width="0.8" fill="white" fill-opacity="0.05"/>
          <rect x="-44" y="6" width="0" height="5" rx="2.5" fill="url(#installFillM)" class="install-fill-m"/>
          <text x="0" y="22" text-anchor="middle" fill="white" fill-opacity="0.4" font-size="6" font-family="ui-monospace, monospace" class="install-pct-m">0%</text>
          <g class="install-check">
            <circle cx="0" cy="38" r="9" stroke="#86efac" stroke-opacity="0.7" stroke-width="1.5" fill="white" fill-opacity="0.05"/>
            <polyline points="-4,38 -1,42 4,33" stroke="#86efac" stroke-opacity="0.85" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
          </g>
        </g>
      </g>

      <!-- Linux laptop bottom-right — translate(310, 510) -->
      <g class="laptop-2" transform="translate(310, 510)">
        <path d="M-72 40 L72 40 L80 48 L-80 48 Z" stroke="white" stroke-opacity="0.35" stroke-width="1.5" fill="white" fill-opacity="0.06" class="laptop-base"/>
        <rect x="-66" y="-40" width="132" height="80" rx="3" stroke="white" stroke-opacity="0.4" stroke-width="1.5" fill="white" fill-opacity="0.05" class="laptop-frame"/>
        <rect x="-60" y="-34" width="120" height="70" rx="2" fill="white" fill-opacity="0.04"/>

        <g class="linux-screen">
          <text x="0" y="-22" text-anchor="middle" fill="white" fill-opacity="0.6" font-size="8" font-family="ui-sans-serif, system-ui, sans-serif" font-weight="700">Linux Mint</text>

          <g transform="translate(-40, -14)">
            <g class="theme theme-1">
              <rect x="0" y="0" width="26" height="20" rx="2" stroke="white" stroke-opacity="0.35" stroke-width="0.8" fill="white" fill-opacity="0.08"/>
              <rect x="1" y="1" width="24" height="2" rx="0.3" fill="white" fill-opacity="0.25"/>
              <rect x="3" y="6" width="20" height="8" rx="0.5" stroke="white" stroke-opacity="0.3" stroke-width="0.5" fill="white" fill-opacity="0.06"/>
              <rect x="6" y="16" width="14" height="2" rx="1" fill="white" fill-opacity="0.2"/>
            </g>
          </g>
          <g transform="translate(-13, -14)">
            <g class="theme theme-2">
              <rect x="0" y="0" width="26" height="20" rx="2" stroke="white" stroke-opacity="0.35" stroke-width="0.8" fill="white" fill-opacity="0.1"/>
              <rect x="1" y="1" width="24" height="2" rx="0.3" fill="white" fill-opacity="0.18"/>
              <rect x="4" y="6" width="18" height="8" rx="1" stroke="white" stroke-opacity="0.3" stroke-width="0.5" fill="white" fill-opacity="0.07"/>
              <rect x="6" y="16" width="14" height="2" rx="1" stroke="white" stroke-opacity="0.25" stroke-width="0.3" fill="white" fill-opacity="0.12"/>
            </g>
          </g>
          <g transform="translate(14, -14)">
            <g class="theme theme-3">
              <rect x="0" y="0" width="26" height="20" rx="2" stroke="white" stroke-opacity="0.35" stroke-width="0.8" fill="white" fill-opacity="0.06"/>
              <rect x="2" y="2" width="11" height="16" rx="0.5" stroke="white" stroke-opacity="0.3" stroke-width="0.5" fill="white" fill-opacity="0.08"/>
              <rect x="14" y="2" width="10" height="7" rx="0.5" stroke="white" stroke-opacity="0.3" stroke-width="0.5" fill="white" fill-opacity="0.08"/>
              <rect x="14" y="11" width="10" height="7" rx="0.5" stroke="white" stroke-opacity="0.3" stroke-width="0.5" fill="white" fill-opacity="0.08"/>
            </g>
          </g>

          <text x="0" y="14" text-anchor="middle" fill="white" fill-opacity="0.4" font-size="6" font-family="ui-monospace, monospace" letter-spacing="1">CUSTOMIZE</text>
          <text x="-22" y="28" fill="#86efac" fill-opacity="0.8" font-size="7" font-family="ui-monospace, monospace" font-weight="700">FAST</text>
          <text x="6" y="28" fill="#86efac" fill-opacity="0.8" font-size="7" font-family="ui-monospace, monospace" font-weight="700">FREE</text>
        </g>
      </g>

      <!-- Grid -->
      <g stroke="white" stroke-opacity="0.04" stroke-width="1">
        <line x1="0" y1="150" x2="400" y2="150"/>
        <line x1="0" y1="300" x2="400" y2="300"/>
        <line x1="0" y1="450" x2="400" y2="450"/>
        <line x1="133" y1="0" x2="133" y2="600"/>
        <line x1="266" y1="0" x2="266" y2="600"/>
      </g>
    </svg>

    <!-- Hero text -->
    <div id="hero-content">
      <p class="hero-label">
        <a href="/services#mac-software" style="color:#93c5fd;text-decoration:none;" aria-label="Back to all services">← Services</a>
      </p>
      <h1 id="hero-wordmark">Mac &amp; Apple Software</h1>
      <p id="hero-tagline">macOS reinstalls, software troubleshooting, iCloud help, and Linux installs on older Macs. Software support only. No Apple hardware repairs.</p>
      <div id="hero-cta-row">
        <a href="/contact" class="hero-cta-primary">
          Book a Repair
          <svg style="height:1rem;width:1rem;" aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
        <a href="/pricing" class="hero-cta-secondary">View Pricing</a>
      </div>
    </div>

    <div id="scroll-hint" aria-hidden="true" role="button" tabindex="-1" onclick="document.getElementById('mac-services').scrollIntoView({behavior:'smooth'})">
      <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" style="height:1.5rem;width:1.5rem;"><path d="M12 5v14M5 12l7 7 7-7"/></svg>
    </div>
  </section>

  <!-- Info Bar -->
  <section style="background:#1e40af;padding:1.25rem 1.5rem;">
    <div style="max-width:56rem;margin:0 auto;display:flex;flex-wrap:wrap;align-items:center;justify-content:center;gap:2rem;text-align:center;">
      <div>
        <div style="font-size:1.75rem;font-weight:800;color:white;">Software Only</div>
        <div style="font-size:0.8rem;color:#bfdbfe;font-weight:600;">No Apple Hardware Repairs</div>
      </div>
      <div style="width:1px;height:2.5rem;background:rgba(255,255,255,0.2);flex-shrink:0;"></div>
      <div>
        <div style="font-size:1.75rem;font-weight:800;color:white;">macOS + Linux</div>
        <div style="font-size:0.8rem;color:#bfdbfe;font-weight:600;">All Software Options Covered</div>
      </div>
      <div style="width:1px;height:2.5rem;background:rgba(255,255,255,0.2);flex-shrink:0;"></div>
      <div>
        <div style="font-size:1.75rem;font-weight:800;color:white;">2012 to 2018</div>
        <div style="font-size:0.8rem;color:#bfdbfe;font-weight:600;">Mac Models for Linux Installs</div>
      </div>
    </div>
  </section>

  <!-- What I Do -->
  <section id="mac-services" style="background:#f8fafc;padding:4rem 1.5rem;">
    <div style="max-width:56rem;margin:0 auto;">
      <div style="margin-bottom:2.5rem;">
        <p style="font-size:0.875rem;font-weight:600;text-transform:uppercase;letter-spacing:0.1em;color:#2563eb;">Mac Services</p>
        <h2 style="font-size:2rem;font-weight:800;color:#111827;margin-top:0.5rem;">What I Can Help With</h2>
        <p style="color:#6b7280;margin-top:0.75rem;line-height:1.75;">From a sluggish Mac that needs a fresh OS install to an older machine that Apple stopped supporting, there are more options than most people realize. Here's what I offer for Mac and Apple software support.</p>
      </div>

      <div style="display:flex;flex-direction:column;gap:1rem;">

        <div class="service-item" style="border-left:4px solid #2563eb;">
          <div class="service-num" style="background:#eff6ff;color:#1e40af;">
