<script>
  // Progressive enhancement: keep submit disabled until the terms box is checked.
  // Native `required` on the checkbox still enforces agreement if JS is off.
  (function () {
    const form = document.querySelector('.intake-form');
    if (!form) return;
    const agree = form.querySelector('#iagree');
    const btn = form.querySelector('#intake-submit');
    if (!agree || !btn) return;
    function sync() {
      if (agree instanceof HTMLInputElement && btn instanceof HTMLButtonElement) {
        btn.disabled = !agree.checked;
      }
    }
    agree.addEventListener('change', sync);
    sync();
  })();
</script>

