  /* Power glow ring fades in once RAM is seated */
  .power-glow { animation: powerGlow 6s ease-in-out infinite; }
  @keyframes powerGlow {
    0%, 22%   { stroke-opacity: 0; }
    30%       { stroke-opacity: 0.5; }
    50%       { stroke-opacity: 0.2; }
