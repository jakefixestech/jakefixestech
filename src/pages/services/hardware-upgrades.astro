  }

  /* RAM stick drop-in cycle, 6s loop:
     0-15%: above slot, falling
     15-25%: seated in slot
     25-90%: stays seated
     90-100%: lifts back out for loop reset
  */
  .ram-stick { animation: ramDrop 6s ease-in-out infinite; }
  @keyframes ramDrop {
    0%       { transform: translateY(-90px); opacity: 0; }
    8%       { opacity: 1; }
    18%      { transform: translateY(0); opacity: 1; }
    22%      { transform: translateY(-3px); }
    25%, 88% { transform: translateY(0); opacity: 1; }
    98%, 100% { transform: translateY(-90px); opacity: 0; }
