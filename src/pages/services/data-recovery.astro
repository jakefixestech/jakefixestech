---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Data Recovery | Jake Fixes Tech — Littleton, NH"
description="Professional data recovery for deleted, corrupted or lost files from hard drives, SSDs, USB drives and memory cards. $50 assessment fee, $100 if successful. Windows and Linux. Serving Littleton NH and the North Country.">

  <!-- Animated SVG Hero -->
  <section id="hero-svg" aria-label="Data Recovery Service">

    <!-- DESKTOP SVG -->
    <svg class="hero-bg-desktop" viewBox="0 0 1440 520" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <defs>
        <linearGradient id="bgGrad" x1="0%" y1="0%" x2="100%" y2="100%">
          <stop offset="0%" style="stop-color:#1e3a8a;stop-opacity:1"/>
          <stop offset="100%" style="stop-color:#2563eb;stop-opacity:1"/>
        </linearGradient>
        <linearGradient id="glowGrad" x1="0%" y1="0%" x2="100%" y2="100%">
          <stop offset="0%" style="stop-color:#3b82f6;stop-opacity:0.25"/>
          <stop offset="100%" style="stop-color:#1d4ed8;stop-opacity:0"/>
        </linearGradient>
      </defs>
      <rect width="1440" height="520" fill="url(#bgGrad)"/>
      <ellipse cx="220" cy="200" rx="380" ry="260" fill="url(#glowGrad)" class="glow-orb-1"/>
      <ellipse cx="1220" cy="340" rx="320" ry="220" fill="url(#glowGrad)" class="glow-orb-2"/>

      <!-- LEFT: Hard drive with spinning platter — translate(280, 240) -->
      <g class="drive-group" transform="translate(280, 240)">
        <!-- Drive enclosure -->
        <rect x="-110" y="-80" width="220" height="160" rx="6" stroke="white" stroke-opacity="0.35" stroke-width="2.5" fill="white" fill-opacity="0.06" class="drive-body"/>
        <!-- Inner frame -->
        <rect x="-100" y="-72" width="200" height="144" rx="3" stroke="white" stroke-opacity="0.15" stroke-width="1" fill="none"/>
        <!-- Mounting screws -->
        <circle cx="-100" cy="-70" r="3" fill="white" fill-opacity="0.3"/>
        <circle cx="100" cy="-70" r="3" fill="white" fill-opacity="0.3"/>
        <circle cx="-100" cy="70" r="3" fill="white" fill-opacity="0.3"/>
        <circle cx="100" cy="70" r="3" fill="white" fill-opacity="0.3"/>

        <!-- Spinning platter (outer ring + concentric circles) -->
        <g class="platter-group">
          <circle cx="-20" cy="0" r="58" stroke="white" stroke-opacity="0.3" stroke-width="2" fill="white" fill-opacity="0.05"/>
          <circle cx="-20" cy="0" r="44" stroke="white" stroke-opacity="0.18" stroke-width="1" fill="none"/>
          <circle cx="-20" cy="0" r="32" stroke="white" stroke-opacity="0.18" stroke-width="1" fill="none"/>
          <circle cx="-20" cy="0" r="20" stroke="white" stroke-opacity="0.18" stroke-width="1" fill="none"/>
          <!-- Spindle -->
          <circle cx="-20" cy="0" r="6" fill="white" fill-opacity="0.35"/>
          <circle cx="-20" cy="0" r="2" fill="white" fill-opacity="0.6"/>
          <!-- Read/write head arm -->
          <g class="rw-arm">
            <line x1="60" y1="-50" x2="-10" y2="-12" stroke="white" stroke-opacity="0.6" stroke-width="3" stroke-linecap="round"/>
            <circle cx="60" cy="-50" r="4" fill="white" fill-opacity="0.45"/>
            <rect x="-15" y="-16" width="10" height="6" rx="1" fill="white" fill-opacity="0.55" transform="rotate(-30 -10 -13)"/>
          </g>
          <!-- Tick marker rotating with platter to show spin -->
          <line x1="-20" y1="0" x2="-20" y2="-44" stroke="white" stroke-opacity="0.45" stroke-width="2" stroke-linecap="round" class="platter-tick"/>
        </g>

        <!-- Progress ring around the drive -->
        <circle cx="0" cy="0" r="100" stroke="white" stroke-opacity="0.08" stroke-width="3" fill="none"/>
        <circle cx="0" cy="0" r="100" stroke="#86efac" stroke-opacity="0.6" stroke-width="3" fill="none"
                stroke-dasharray="628" stroke-dashoffset="628" stroke-linecap="round"
                transform="rotate(-90 0 0)" class="progress-ring"/>

        <!-- Status label -->
        <text x="0" y="105" text-anchor="middle" fill="white" fill-opacity="0.6" font-size="11" font-family="ui-monospace, monospace" letter-spacing="2" font-weight="700" class="drive-label">SCANNING</text>
      </g>

      <!-- RIGHT: Recovered files folder — translate(1100, 240) -->
      <g class="folder-group" transform="translate(1180, 240)">
        <!-- Folder back -->
        <path d="M-90 -50 L-50 -50 L-30 -65 L90 -65 L90 70 L-90 70 Z" stroke="white" stroke-opacity="0.3" stroke-width="2" fill="white" fill-opacity="0.06" class="folder-back"/>
        <!-- Folder front pocket -->
        <path d="M-90 -30 L90 -30 L90 70 L-90 70 Z" stroke="white" stroke-opacity="0.4" stroke-width="2.5" fill="white" fill-opacity="0.1" class="folder-front"/>
        <!-- Folder label -->
        <text x="0" y="-40" text-anchor="middle" fill="white" fill-opacity="0.55" font-size="10" font-family="ui-monospace, monospace" letter-spacing="2" font-weight="700">RECOVERED</text>

        <!-- Files stacked inside the folder, fade in over time -->
        <g transform="translate(-58, 8)">
          <g class="stacked-file sf-1">
            <rect x="0" y="0" width="32" height="40" rx="2" stroke="white" stroke-opacity="0.35" stroke-width="1.5" fill="white" fill-opacity="0.12"/>
            <line x1="6" y1="10" x2="26" y2="10" stroke="white" stroke-opacity="0.4" stroke-width="1.2"/>
            <line x1="6" y1="18" x2="22" y2="18" stroke="white" stroke-opacity="0.3" stroke-width="1.2"/>
            <line x1="6" y1="26" x2="24" y2="26" stroke="white" stroke-opacity="0.3" stroke-width="1.2"/>
          </g>
        </g>
        <g transform="translate(-18, 8)">
          <g class="stacked-file sf-2">
            <rect x="0" y="0" width="32" height="40" rx="2" stroke="white" stroke-opacity="0.35" stroke-width="1.5" fill="white" fill-opacity="0.12"/>
            <circle cx="10" cy="14" r="3" fill="white" fill-opacity="0.45"/>
            <path d="M4 32 L12 22 L18 28 L26 16 L28 32 Z" fill="white" fill-opacity="0.35"/>
          </g>
        </g>
        <g transform="translate(22, 8)">
          <g class="stacked-file sf-3">
            <rect x="0" y="0" width="32" height="40" rx="2" stroke="white" stroke-opacity="0.35" stroke-width="1.5" fill="white" fill-opacity="0.12"/>
            <line x1="6" y1="10" x2="26" y2="10" stroke="white" stroke-opacity="0.4" stroke-width="1.2"/>
            <line x1="6" y1="18" x2="22" y2="18" stroke="white" stroke-opacity="0.3" stroke-width="1.2"/>
            <line x1="6" y1="26" x2="20" y2="26" stroke="white" stroke-opacity="0.3" stroke-width="1.2"/>
          </g>
        </g>
      </g>

      <!-- Curved dotted path from drive (390, 240) to folder (1090, 240) — for traveling files -->
      <path id="recover-path" d="M390 240 Q740 140 1090 240" stroke="white" stroke-opacity="0.12" stroke-width="1.5" fill="none" stroke-dasharray="6 5"/>

      <!-- Traveling files along the path (cx/cy at path start to prevent ghost) -->
      <g class="flying-file ff-1">
        <rect x="-8" y="-10" width="16" height="20" rx="1.5" stroke="white" stroke-opacity="0.55" stroke-width="1.5" fill="white" fill-opacity="0.18"/>
        <line x1="-4" y1="-4" x2="4" y2="-4" stroke="white" stroke-opacity="0.6" stroke-width="1"/>
        <line x1="-4" y1="0" x2="3" y2="0" stroke="white" stroke-opacity="0.5" stroke-width="1"/>
        <line x1="-4" y1="4" x2="4" y2="4" stroke="white" stroke-opacity="0.5" stroke-width="1"/>
        <animateMotion dur="4s" repeatCount="indefinite" begin="0.5s">
          <mpath href="#recover-path"/>
        </animateMotion>
      </g>
      <g class="flying-file ff-2">
        <rect x="-8" y="-10" width="16" height="20" rx="1.5" stroke="white" stroke-opacity="0.55" stroke-width="1.5" fill="white" fill-opacity="0.18"/>
        <line x1="-4" y1="-4" x2="4" y2="-4" stroke="white" stroke-opacity="0.6" stroke-width="1"/>
        <line x1="-4" y1="0" x2="3" y2="0" stroke="white" stroke-opacity="0.5" stroke-width="1"/>
        <line x1="-4" y1="4" x2="4" y2="4" stroke="white" stroke-opacity="0.5" stroke-width="1"/>
        <animateMotion dur="4s" repeatCount="indefinite" begin="1.5s">
          <mpath href="#recover-path"/>
        </animateMotion>
      </g>
      <g class="flying-file ff-3">
        <rect x="-8" y="-10" width="16" height="20" rx="1.5" stroke="white" stroke-opacity="0.55" stroke-width="1.5" fill="white" fill-opacity="0.18"/>
        <line x1="-4" y1="-4" x2="4" y2="-4" stroke="white" stroke-opacity="0.6" stroke-width="1"/>
        <line x1="-4" y1="0" x2="3" y2="0" stroke="white" stroke-opacity="0.5" stroke-width="1"/>
        <line x1="-4" y1="4" x2="4" y2="4" stroke="white" stroke-opacity="0.5" stroke-width="1"/>
        <animateMotion dur="4s" repeatCount="indefinite" begin="2.5s">
          <mpath href="#recover-path"/>
        </animateMotion>
      </g>

      <!-- Floating magnifying glass — outer wrapper -->
      <g transform="translate(720, 90)">
        <g class="float-icon float-tool-1" stroke="white" stroke-opacity="0.18" fill="none" stroke-width="2.5">
          <circle cx="0" cy="0" r="14"/>
          <line x1="10" y1="10" x2="20" y2="20" stroke-linecap="round"/>
        </g>
      </g>

      <!-- Floating SD card -->
      <g transform="translate(160, 380)">
        <g class="float-icon float-tool-2" stroke="white" stroke-opacity="0.18" fill="white" fill-opacity="0.06" stroke-width="1.5">
          <path d="M0 0 L18 0 L24 6 L24 30 L0 30 Z" stroke-linejoin="round"/>
          <line x1="4" y1="4" x2="4" y2="10" stroke-opacity="0.3"/>
          <line x1="9" y1="4" x2="9" y2="10" stroke-opacity="0.3"/>
          <line x1="14" y1="4" x2="14" y2="10" stroke-opacity="0.3"/>
          <line x1="19" y1="4" x2="19" y2="10" stroke-opacity="0.3"/>
        </g>
      </g>

      <!-- Floating USB stick -->
      <g transform="translate(1280, 110)">
        <g class="float-icon float-tool-3" stroke="white" stroke-opacity="0.16" fill="white" fill-opacity="0.06" stroke-width="1.5">
          <rect x="-15" y="-6" width="30" height="12" rx="1.5"/>
          <rect x="-22" y="-3" width="7" height="6" rx="0.5"/>
          <line x1="-8" y1="0" x2="8" y2="0" stroke-opacity="0.3"/>
        </g>
      </g>

      <!-- Ambient labels -->
      <g font-family="ui-monospace, SFMono-Regular, Menlo, monospace" font-weight="700" fill="white">
        <text x="100" y="100" font-size="11" fill-opacity="0.1" class="code-tw ct-a">// scan</text>
        <text x="660" y="430" font-size="11" fill-opacity="0.1" class="code-tw ct-b">// retrieve</text>
        <text x="1180" y="450" font-size="11" fill-opacity="0.1" class="code-tw ct-c">// restore</text>
        <text x="80" y="450" font-size="10" fill-opacity="0.09" class="code-tw ct-d">files: 2,847</text>
      </g>

      <!-- Grid -->
      <g stroke="white" stroke-opacity="0.04" stroke-width="1">
        <line x1="0" y1="130" x2="1440" y2="130"/>
        <line x1="0" y1="260" x2="1440" y2="260"/>
        <line x1="0" y1="390" x2="1440" y2="390"/>
        <line x1="360" y1="0" x2="360" y2="520"/>
        <line x1="720" y1="0" x2="720" y2="520"/>
        <line x1="1080" y1="0" x2="1080" y2="520"/>
      </g>
    </svg>

    <!-- MOBILE SVG -->
    <svg class="hero-bg-mobile" viewBox="0 0 400 600" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <defs>
        <linearGradient id="bgGradM" x1="0%" y1="0%" x2="100%" y2="100%">
          <stop offset="0%" style="stop-color:#1e3a8a;stop-opacity:1"/>
          <stop offset="100%" style="stop-color:#2563eb;stop-opacity:1"/>
        </linearGradient>
        <linearGradient id="glowGradM" x1="0%" y1="0%" x2="100%" y2="100%">
          <stop offset="0%" style="stop-color:#3b82f6;stop-opacity:0.3"/>
          <stop offset="100%" style="stop-color:#1d4ed8;stop-opacity:0"/>
        </linearGradient>
      </defs>
      <rect width="400" height="600" fill="url(#bgGradM)"/>
      <ellipse cx="80" cy="100" rx="180" ry="140" fill="url(#glowGradM)" class="glow-orb-1"/>
      <ellipse cx="340" cy="500" rx="180" ry="140" fill="url(#glowGradM)" class="glow-orb-2"/>

      <!-- Drive top-left corner — translate(80, 80) -->
      <g class="drive-group" transform="translate(80, 80)">
        <rect x="-65" y="-50" width="130" height="100" rx="4" stroke="white" stroke-opacity="0.35" stroke-width="2" fill="white" fill-opacity="0.06" class="drive-body"/>
        <rect x="-58" y="-44" width="116" height="88" rx="2" stroke="white" stroke-opacity="0.15" stroke-width="1" fill="none"/>
        <circle cx="-58" cy="-44" r="2" fill="white" fill-opacity="0.3"/>
        <circle cx="58" cy="-44" r="2" fill="white" fill-opacity="0.3"/>
        <circle cx="-58" cy="44" r="2" fill="white" fill-opacity="0.3"/>
        <circle cx="58" cy="44" r="2" fill="white" fill-opacity="0.3"/>
        <g class="platter-group">
          <circle cx="-12" cy="0" r="36" stroke="white" stroke-opacity="0.3" stroke-width="1.5" fill="white" fill-opacity="0.05"/>
          <circle cx="-12" cy="0" r="26" stroke="white" stroke-opacity="0.18" stroke-width="1" fill="none"/>
          <circle cx="-12" cy="0" r="16" stroke="white" stroke-opacity="0.18" stroke-width="1" fill="none"/>
          <circle cx="-12" cy="0" r="4" fill="white" fill-opacity="0.35"/>
          <circle cx="-12" cy="0" r="1.5" fill="white" fill-opacity="0.6"/>
          <line x1="-12" y1="0" x2="-12" y2="-26" stroke="white" stroke-opacity="0.45" stroke-width="1.5" stroke-linecap="round" class="platter-tick"/>
        </g>
        <circle cx="0" cy="0" r="60" stroke="white" stroke-opacity="0.08" stroke-width="2" fill="none"/>
        <circle cx="0" cy="0" r="60" stroke="#86efac" stroke-opacity="0.6" stroke-width="2" fill="none"
                stroke-dasharray="377" stroke-dashoffset="377" stroke-linecap="round"
                transform="rotate(-90 0 0)" class="progress-ring-m"/>
      </g>

      <!-- Folder bottom-right corner — translate(310, 470) -->
      <g class="folder-group" transform="translate(310, 470)">
        <path d="M-60 -32 L-32 -32 L-20 -42 L60 -42 L60 50 L-60 50 Z" stroke="white" stroke-opacity="0.3" stroke-width="2" fill="white" fill-opacity="0.06" class="folder-back"/>
        <path d="M-60 -20 L60 -20 L60 50 L-60 50 Z" stroke="white" stroke-opacity="0.4" stroke-width="2" fill="white" fill-opacity="0.1" class="folder-front"/>
        <text x="0" y="-26" text-anchor="middle" fill="white" fill-opacity="0.55" font-size="8" font-family="ui-monospace, monospace" letter-spacing="1.5" font-weight="700">RECOVERED</text>
        <g transform="translate(-40, 4)">
          <g class="stacked-file sf-1">
            <rect x="0" y="0" width="22" height="28" rx="1.5" stroke="white" stroke-opacity="0.35" stroke-width="1.2" fill="white" fill-opacity="0.12"/>
            <line x1="4" y1="7" x2="18" y2="7" stroke="white" stroke-opacity="0.4" stroke-width="1"/>
            <line x1="4" y1="14" x2="16" y2="14" stroke="white" stroke-opacity="0.3" stroke-width="1"/>
          </g>
        </g>
        <g transform="translate(-11, 4)">
          <g class="stacked-file sf-2">
            <rect x="0" y="0" width="22" height="28" rx="1.5" stroke="white" stroke-opacity="0.35" stroke-width="1.2" fill="white" fill-opacity="0.12"/>
            <circle cx="7" cy="10" r="2" fill="white" fill-opacity="0.45"/>
            <path d="M3 22 L8 16 L12 19 L18 11 L19 22 Z" fill="white" fill-opacity="0.35"/>
          </g>
        </g>
        <g transform="translate(18, 4)">
          <g class="stacked-file sf-3">
            <rect x="0" y="0" width="22" height="28" rx="1.5" stroke="white" stroke-opacity="0.35" stroke-width="1.2" fill="white" fill-opacity="0.12"/>
            <line x1="4" y1="7" x2="18" y2="7" stroke="white" stroke-opacity="0.4" stroke-width="1"/>
            <line x1="4" y1="14" x2="14" y2="14" stroke="white" stroke-opacity="0.3" stroke-width="1"/>
          </g>
        </g>
      </g>

      <!-- Mobile recover path -->
      <path id="recover-path-m" d="M140 80 Q220 280 270 470" stroke="white" stroke-opacity="0.1" stroke-width="1.2" fill="none" stroke-dasharray="5 4"/>

      <g class="flying-file ff-1">
        <rect x="-6" y="-8" width="12" height="16" rx="1.5" stroke="white" stroke-opacity="0.55" stroke-width="1.2" fill="white" fill-opacity="0.18"/>
        <line x1="-3" y1="-3" x2="3" y2="-3" stroke="white" stroke-opacity="0.6" stroke-width="0.8"/>
        <line x1="-3" y1="0" x2="2" y2="0" stroke="white" stroke-opacity="0.5" stroke-width="0.8"/>
        <line x1="-3" y1="3" x2="3" y2="3" stroke="white" stroke-opacity="0.5" stroke-width="0.8"/>
        <animateMotion dur="4s" repeatCount="indefinite" begin="0.5s">
          <mpath href="#recover-path-m"/>
        </animateMotion>
      </g>
      <g class="flying-file ff-2">
        <rect x="-6" y="-8" width="12" height="16" rx="1.5" stroke="white" stroke-opacity="0.55" stroke-width="1.2" fill="white" fill-opacity="0.18"/>
        <line x1="-3" y1="-3" x2="3" y2="-3" stroke="white" stroke-opacity="0.6" stroke-width="0.8"/>
        <line x1="-3" y1="0" x2="2" y2="0" stroke="white" stroke-opacity="0.5" stroke-width="0.8"/>
        <line x1="-3" y1="3" x2="3" y2="3" stroke="white" stroke-opacity="0.5" stroke-width="0.8"/>
        <animateMotion dur="4s" repeatCount="indefinite" begin="2s">
          <mpath href="#recover-path-m"/>
        </animateMotion>
      </g>

      <!-- Grid -->
      <g stroke="white" stroke-opacity="0.04" stroke-width="1">
        <line x1="0" y1="150" x2="400" y2="150"/>
        <line x1="0" y1="300" x2="400" y2="300"/>
        <line x1="0" y1="450" x2="400" y2="450"/>
        <line x1="133" y1="0" x2="133" y2="600"/>
        <line x1="266" y1="0" x2="266" y2="600"/>
      </g>
    </svg>

    <!-- Hero text -->
    <div id="hero-content">
      <p class="hero-label">
        <a href="/services#data-recovery" style="color:#93c5fd;text-decoration:none;" aria-label="Back to all services">← Services</a>
      </p>
      <h1 id="hero-wordmark">Data Recovery</h1>
      <p id="hero-tagline">Accidentally deleted something important? Drive not showing up? I use professional recovery software to retrieve lost, deleted or corrupted files from drives, USB drives and memory cards.</p>
      <div id="hero-cta-row">
        <a href="/contact" class="hero-cta-primary">
          Get in Touch
          <svg style="height:1rem;width:1rem;" aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
        <a href="/pricing" class="hero-cta-secondary">View Pricing</a>
      </div>
    </div>

    <div id="scroll-hint" aria-hidden="true" role="button" tabindex="-1" onclick="document.getElementById('how-pricing').scrollIntoView({behavior:'smooth'})">
      <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" style="height:1.5rem;width:1.5rem;"><path d="M12 5v14M5 12l7 7 7-7"/></svg>
    </div>
  </section>

  <!-- Info Bar -->
  <section style="background:#1e40af;padding:1.25rem 1.5rem;">
    <div style="max-width:56rem;margin:0 auto;display:flex;flex-wrap:wrap;align-items:center;justify-content:center;gap:2rem;text-align:center;">
      <div>
        <div style="font-size:1.75rem;font-weight:800;color:white;">$50</div>
        <div style="font-size:0.8rem;color:#bfdbfe;font-weight:600;">Assessment Fee</div>
      </div>
      <div style="width:1px;height:2.5rem;background:rgba(255,255,255,0.2);flex-shrink:0;"></div>
      <div>
        <div style="font-size:1.75rem;font-weight:800;color:white;">$100</div>
        <div style="font-size:0.8rem;color:#bfdbfe;font-weight:600;">If Successful</div>
      </div>
      <div style="width:1px;height:2.5rem;background:rgba(255,255,255,0.2);flex-shrink:0;"></div>
      <div>
        <div style="font-size:1.75rem;font-weight:800;color:white;">No Surprises</div>
        <div style="font-size:0.8rem;color:#bfdbfe;font-weight:600;">You Know Before You Pay</div>
      </div>
    </div>
  </section>

  <!-- How Pricing Works -->
  <section id="how-pricing" style="background:#f8fafc;padding:4rem 1.5rem;">
    <div style="max-width:56rem;margin:0 auto;">
      <div style="margin-bottom:2.5rem;">
        <p style="font-size:0.875rem;font-weight:600;text-transform:uppercase;letter-spacing:0.1em;color:#2563eb;">How It Works</p>
        <h2 style="font-size:2rem;font-weight:800;color:#111827;margin-top:0.5rem;">Honest Pricing, No Guarantees</h2>
        <p style="color:#6b7280;margin-top:0.75rem;line-height:1.75;">Data recovery isn't always possible. Before any work begins I'll assess the drive and tell you what looks recoverable. You decide whether to proceed from there.</p>
      </div>

      <div style="display:grid;gap:1rem;grid-template-columns:1fr 1fr;">
        <div style="background:white;border:1px solid #e5e7eb;border-radius:0.75rem;padding:1.5rem;border-left:4px solid #2563eb;">
          <div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:1rem;">
            <div style="display:flex;height:2.5rem;width:2.5rem;min-width:2.5rem;align-items:center;justify-content:center;border-radius:0.5rem;background:#dbeafe;color:#2563eb;flex-shrink:0;" aria-hidden="true">
              <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            </div>
            <h3 style="font-size:1rem;font-weight:700;color:#111827;margin:0;">Step 1: Assessment ($50)</h3>
          </div>
