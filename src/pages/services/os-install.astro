---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Operating System Install Service | Jake Fixes Tech — Littleton, NH"
description="Fresh OS installs for Linux ($50), Windows ($75), and macOS ($75). Includes all updates and basic user account setup. Bring me your computer, take it home ready to use.">

  <!-- Animated SVG Hero -->
  <section id="hero-svg" aria-label="Operating System Install Service">

    <!-- DESKTOP SVG -->
    <svg class="hero-bg-desktop" viewBox="0 0 1440 520" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <defs>
        <linearGradient id="bgGrad" x1="0%" y1="0%" x2="100%" y2="100%">
          <stop offset="0%" style="stop-color:#1e3a8a;stop-opacity:1"/>
          <stop offset="100%" style="stop-color:#2563eb;stop-opacity:1"/>
        </linearGradient>
        <linearGradient id="glowGrad" x1="0%" y1="0%" x2="100%" y2="100%">
          <stop offset="0%" style="stop-color:#3b82f6;stop-opacity:0.25"/>
          <stop offset="100%" style="stop-color:#1d4ed8;stop-opacity:0"/>
        </linearGradient>
      </defs>
      <rect width="1440" height="520" fill="url(#bgGrad)"/>
      <ellipse cx="280" cy="240" rx="360" ry="260" fill="url(#glowGrad)" class="glow-orb-1"/>
      <ellipse cx="1200" cy="300" rx="340" ry="240" fill="url(#glowGrad)" class="glow-orb-2"/>

      <!-- LEFT: Laptop with install progress -->
      <g class="laptop-group" transform="translate(140, 175)">
        <rect x="0" y="0" width="260" height="160" rx="4" stroke="white" stroke-opacity="0.5" stroke-width="2" fill="white" fill-opacity="0.1"/>
        <rect x="6" y="6" width="248" height="148" rx="2" stroke="white" stroke-opacity="0.2" stroke-width="1" fill="#0f172a" fill-opacity="0.4"/>

        <text x="130" y="35" text-anchor="middle" fill="white" fill-opacity="0.85" font-size="11" font-weight="700" font-family="monospace" letter-spacing="2" class="screen-text st-1">INSTALLING OS</text>
        <text x="130" y="50" text-anchor="middle" fill="white" fill-opacity="0.5" font-size="8" font-family="monospace" letter-spacing="1" class="screen-text st-2">PREPARING PACKAGES...</text>

        <rect x="30" y="65" width="200" height="10" rx="2" stroke="white" stroke-opacity="0.4" stroke-width="1" fill="white" fill-opacity="0.05"/>
        <rect x="32" y="67" width="0" height="6" rx="1" fill="white" fill-opacity="0.7" class="screen-progress"/>
        <text x="130" y="89" text-anchor="middle" fill="white" fill-opacity="0.6" font-size="8" font-family="monospace" class="screen-percent">0%</text>

        <line x1="30" y1="105" x2="180" y2="105" stroke="white" stroke-opacity="0.45" stroke-width="1.8" stroke-linecap="round" class="console-line cl-1"/>
        <line x1="30" y1="115" x2="210" y2="115" stroke="white" stroke-opacity="0.4" stroke-width="1.8" stroke-linecap="round" class="console-line cl-2"/>
        <line x1="40" y1="125" x2="195" y2="125" stroke="white" stroke-opacity="0.4" stroke-width="1.8" stroke-linecap="round" class="console-line cl-3"/>
        <line x1="40" y1="135" x2="170" y2="135" stroke="white" stroke-opacity="0.4" stroke-width="1.8" stroke-linecap="round" class="console-line cl-4"/>

        <path d="M-20 160 L280 160 L268 178 L-8 178 Z" stroke="white" stroke-opacity="0.5" stroke-width="2" fill="white" fill-opacity="0.12"/>
        <rect x="115" y="160" width="30" height="3" fill="white" fill-opacity="0.25"/>
      </g>

      <!-- RIGHT: Three OS logos stacked -->
      <g class="os-stack" transform="translate(1080, 110)">
        <text x="120" y="0" text-anchor="middle" fill="white" fill-opacity="0.5" font-size="10" font-weight="700" font-family="monospace" letter-spacing="2">CHOOSE YOUR OS</text>

        <g class="os-tile os-linux" transform="translate(0, 18)">
          <rect x="0" y="0" width="240" height="68" rx="6" stroke="white" stroke-opacity="0.4" stroke-width="1.5" fill="white" fill-opacity="0.08"/>
          <g transform="translate(22, 16)" stroke="white" stroke-opacity="0.85" fill="white" fill-opacity="0.1" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M18 6 C12 6 10 12 10 18 C10 22 8 25 6 28 C4 31 4 34 8 34 L28 34 C32 34 32 31 30 28 C28 25 26 22 26 18 C26 12 24 6 18 6 Z"/>
            <circle cx="14" cy="14" r="1.5" fill="white" stroke="none"/>
            <circle cx="22" cy="14" r="1.5" fill="white" stroke="none"/>
          </g>
          <text x="78" y="32" fill="white" fill-opacity="0.95" font-size="16" font-weight="800" font-family="sans-serif">Linux</text>
          <text x="78" y="50" fill="white" fill-opacity="0.55" font-size="9" font-family="monospace" letter-spacing="0.5">FREE · ANY DISTRO</text>
          <text x="220" y="32" text-anchor="end" fill="white" fill-opacity="0.95" font-size="20" font-weight="900" font-family="sans-serif">$50</text>
        </g>

        <g class="os-tile os-windows" transform="translate(0, 100)">
          <rect x="0" y="0" width="240" height="68" rx="6" stroke="white" stroke-opacity="0.4" stroke-width="1.5" fill="white" fill-opacity="0.08"/>
          <g transform="translate(22, 16)" stroke="white" stroke-opacity="0.85" fill="white" fill-opacity="0.1" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="4" y="6" width="13" height="13"/>
            <rect x="19" y="6" width="13" height="13"/>
            <rect x="4" y="21" width="13" height="13"/>
            <rect x="19" y="21" width="13" height="13"/>
          </g>
          <text x="78" y="32" fill="white" fill-opacity="0.95" font-size="16" font-weight="800" font-family="sans-serif">Windows</text>
          <text x="78" y="50" fill="white" fill-opacity="0.55" font-size="9" font-family="monospace" letter-spacing="0.5">WINDOWS 11</text>
          <text x="220" y="32" text-anchor="end" fill="white" fill-opacity="0.95" font-size="20" font-weight="900" font-family="sans-serif">$75</text>
        </g>

        <g class="os-tile os-mac" transform="translate(0, 182)">
          <rect x="0" y="0" width="240" height="68" rx="6" stroke="white" stroke-opacity="0.4" stroke-width="1.5" fill="white" fill-opacity="0.08"/>
          <g transform="translate(22, 14)" stroke="white" stroke-opacity="0.85" fill="white" fill-opacity="0.1" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M22 6 C19 4 15 4 12 6 C9 8 8 12 8 16 C8 22 12 28 16 32 C18 34 20 34 22 32 C26 28 30 22 30 16 C30 12 28 8 25 6 Z"/>
            <path d="M22 4 C22 6 21 8 19 9"/>
          </g>
          <text x="78" y="32" fill="white" fill-opacity="0.95" font-size="16" font-weight="800" font-family="sans-serif">macOS</text>
          <text x="78" y="50" fill="white" fill-opacity="0.55" font-size="9" font-family="monospace" letter-spacing="0.5">REINSTALL ONLY</text>
          <text x="220" y="32" text-anchor="end" fill="white" fill-opacity="0.95" font-size="20" font-weight="900" font-family="sans-serif">$75</text>
        </g>
      </g>

      <!-- Ambient code-like glyphs -->
      <g class="glyph-field" font-family="monospace" font-weight="700" fill="white">
        <text x="540" y="120" font-size="13" fill-opacity="0.1" class="glyph-tw gl-a">$</text>
        <text x="610" y="160" font-size="11" fill-opacity="0.1" class="glyph-tw gl-b">#</text>
        <text x="680" y="100" font-size="14" fill-opacity="0.12" class="glyph-tw gl-c">&gt;</text>
        <text x="750" y="170" font-size="13" fill-opacity="0.1" class="glyph-tw gl-d">$</text>
        <text x="820" y="130" font-size="11" fill-opacity="0.1" class="glyph-tw gl-a">#</text>
        <text x="900" y="170" font-size="13" fill-opacity="0.11" class="glyph-tw gl-b">&gt;</text>
        <text x="560" y="380" font-size="13" fill-opacity="0.1" class="glyph-tw gl-c">$</text>
        <text x="700" y="420" font-size="11" fill-opacity="0.1" class="glyph-tw gl-d">#</text>
        <text x="800" y="390" font-size="13" fill-opacity="0.11" class="glyph-tw gl-a">&gt;</text>
        <text x="900" y="430" font-size="11" fill-opacity="0.1" class="glyph-tw gl-b">$</text>
      </g>

      <g stroke="white" stroke-opacity="0.04" stroke-width="1">
        <line x1="0" y1="130" x2="1440" y2="130"/>
        <line x1="0" y1="260" x2="1440" y2="260"/>
        <line x1="0" y1="390" x2="1440" y2="390"/>
        <line x1="360" y1="0" x2="360" y2="520"/>
        <line x1="720" y1="0" x2="720" y2="520"/>
        <line x1="1080" y1="0" x2="1080" y2="520"/>
      </g>
    </svg>

    <!-- MOBILE SVG -->
    <svg class="hero-bg-mobile" viewBox="0 0 400 600" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <defs>
        <linearGradient id="bgGradM" x1="0%" y1="0%" x2="100%" y2="100%">
          <stop offset="0%" style="stop-color:#1e3a8a;stop-opacity:1"/>
          <stop offset="100%" style="stop-color:#2563eb;stop-opacity:1"/>
        </linearGradient>
        <linearGradient id="glowGradM" x1="0%" y1="0%" x2="100%" y2="100%">
          <stop offset="0%" style="stop-color:#3b82f6;stop-opacity:0.3"/>
          <stop offset="100%" style="stop-color:#1d4ed8;stop-opacity:0"/>
        </linearGradient>
      </defs>
      <rect width="400" height="600" fill="url(#bgGradM)"/>
      <ellipse cx="100" cy="180" rx="220" ry="180" fill="url(#glowGradM)" class="glow-orb-1"/>
      <ellipse cx="320" cy="500" rx="220" ry="180" fill="url(#glowGradM)" class="glow-orb-2"/>

      <!-- TOP: Laptop with install progress -->
      <g class="laptop-group" transform="translate(125, 25) scale(0.65)">
        <rect x="0" y="0" width="230" height="140" rx="3" stroke="white" stroke-opacity="0.5" stroke-width="1.5" fill="white" fill-opacity="0.1"/>
        <rect x="5" y="5" width="220" height="130" rx="2" stroke="white" stroke-opacity="0.2" stroke-width="0.8" fill="#0f172a" fill-opacity="0.4"/>

        <text x="115" y="30" text-anchor="middle" fill="white" fill-opacity="0.85" font-size="9" font-weight="700" font-family="monospace" letter-spacing="2" class="screen-text st-1">INSTALLING OS</text>
        <text x="115" y="42" text-anchor="middle" fill="white" fill-opacity="0.5" font-size="6.5" font-family="monospace" letter-spacing="1" class="screen-text st-2">PREPARING PACKAGES...</text>

        <rect x="25" y="55" width="180" height="8" rx="1.5" stroke="white" stroke-opacity="0.4" stroke-width="0.8" fill="white" fill-opacity="0.05"/>
        <rect x="27" y="57" width="0" height="4" rx="0.8" fill="white" fill-opacity="0.7" class="screen-progress-m"/>
        <text x="115" y="76" text-anchor="middle" fill="white" fill-opacity="0.6" font-size="6.5" font-family="monospace" class="screen-percent-m">0%</text>

        <line x1="25" y1="92" x2="160" y2="92" stroke="white" stroke-opacity="0.45" stroke-width="1.5" stroke-linecap="round" class="console-line cl-1"/>
        <line x1="25" y1="100" x2="185" y2="100" stroke="white" stroke-opacity="0.4" stroke-width="1.5" stroke-linecap="round" class="console-line cl-2"/>
        <line x1="35" y1="108" x2="170" y2="108" stroke="white" stroke-opacity="0.4" stroke-width="1.5" stroke-linecap="round" class="console-line cl-3"/>
        <line x1="35" y1="116" x2="150" y2="116" stroke="white" stroke-opacity="0.4" stroke-width="1.5" stroke-linecap="round" class="console-line cl-4"/>

        <path d="M-15 140 L245 140 L235 156 L-5 156 Z" stroke="white" stroke-opacity="0.5" stroke-width="1.5" fill="white" fill-opacity="0.12"/>
        <rect x="105" y="140" width="22" height="2.5" fill="white" fill-opacity="0.25"/>
      </g>

      <!-- BOTTOM: OS tiles -->
      <g class="os-stack" transform="translate(74, 425) scale(0.7)">
        <text x="180" y="0" text-anchor="middle" fill="white" fill-opacity="0.5" font-size="8" font-weight="700" font-family="monospace" letter-spacing="2">CHOOSE YOUR OS</text>

        <g class="os-tile os-linux" transform="translate(0, 12)">
          <rect x="0" y="0" width="360" height="48" rx="5" stroke="white" stroke-opacity="0.4" stroke-width="1.2" fill="white" fill-opacity="0.08"/>
          <g transform="translate(14, 11)" stroke="white" stroke-opacity="0.85" fill="white" fill-opacity="0.1" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
            <path d="M14 4 C9 4 8 9 8 14 C8 17 6 19 5 22 C3 24 3 26 6 26 L22 26 C25 26 25 24 23 22 C22 19 20 17 20 14 C20 9 18 4 14 4 Z"/>
            <circle cx="10" cy="11" r="1.2" fill="white" stroke="none"/>
            <circle cx="18" cy="11" r="1.2" fill="white" stroke="none"/>
          </g>
          <text x="60" y="22" fill="white" fill-opacity="0.95" font-size="13" font-weight="800" font-family="sans-serif">Linux</text>
          <text x="60" y="37" fill="white" fill-opacity="0.55" font-size="7" font-family="monospace" letter-spacing="0.5">FREE · ANY DISTRO</text>
          <text x="340" y="29" text-anchor="end" fill="white" fill-opacity="0.95" font-size="16" font-weight="900" font-family="sans-serif">$50</text>
        </g>

        <g class="os-tile os-windows" transform="translate(0, 70)">
          <rect x="0" y="0" width="360" height="48" rx="5" stroke="white" stroke-opacity="0.4" stroke-width="1.2" fill="white" fill-opacity="0.08"/>
          <g transform="translate(14, 11)" stroke="white" stroke-opacity="0.85" fill="white" fill-opacity="0.1" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="4" width="10" height="10"/>
            <rect x="15" y="4" width="10" height="10"/>
            <rect x="3" y="16" width="10" height="10"/>
            <rect x="15" y="16" width="10" height="10"/>
          </g>
          <text x="60" y="22" fill="white" fill-opacity="0.95" font-size="13" font-weight="800" font-family="sans-serif">Windows</text>
          <text x="60" y="37" fill="white" fill-opacity="0.55" font-size="7" font-family="monospace" letter-spacing="0.5">WINDOWS 11</text>
          <text x="340" y="29" text-anchor="end" fill="white" fill-opacity="0.95" font-size="16" font-weight="900" font-family="sans-serif">$75</text>
        </g>

        <g class="os-tile os-mac" transform="translate(0, 128)">
          <rect x="0" y="0" width="360" height="48" rx="5" stroke="white" stroke-opacity="0.4" stroke-width="1.2" fill="white" fill-opacity="0.08"/>
          <g transform="translate(14, 10)" stroke="white" stroke-opacity="0.85" fill="white" fill-opacity="0.1" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
            <path d="M17 4 C15 3 12 3 10 4 C7 6 6 9 6 12 C6 17 9 22 12 25 C14 26 16 26 17 25 C20 22 23 17 23 12 C23 9 22 6 19 4 Z"/>
            <path d="M17 3 C17 5 16 6 15 7"/>
          </g>
          <text x="60" y="22" fill="white" fill-opacity="0.95" font-size="13" font-weight="800" font-family="sans-serif">macOS</text>
          <text x="60" y="37" fill="white" fill-opacity="0.55" font-size="7" font-family="monospace" letter-spacing="0.5">REINSTALL ONLY</text>
          <text x="340" y="29" text-anchor="end" fill="white" fill-opacity="0.95" font-size="16" font-weight="900" font-family="sans-serif">$75</text>
        </g>
      </g>

      <g stroke="white" stroke-opacity="0.04" stroke-width="1">
        <line x1="0" y1="150" x2="400" y2="150"/>
        <line x1="0" y1="300" x2="400" y2="300"/>
        <line x1="0" y1="450" x2="400" y2="450"/>
        <line x1="133" y1="0" x2="133" y2="600"/>
        <line x1="266" y1="0" x2="266" y2="600"/>
      </g>
    </svg>

    <!-- Hero text overlay -->
    <div id="hero-content">
      <p class="hero-label">Operating System Install Service</p>
      <h1 id="hero-wordmark">Fresh Install. Fully Updated.<br/>Ready to Use.</h1>
      <p id="hero-tagline">Linux, Windows, or macOS. I install your operating system from scratch, apply all updates, and set up a basic user account so your computer is genuinely ready to use the moment you take it home.</p>
      <a href="#os-options" id="hero-cta">
        See OS Options
        <svg style="height:1rem;width:1rem;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M12 5v14M5 12l7 7 7-7"/></svg>
      </a>
    </div>

  </section>

  <!-- What's Included -->
  <section style="background:white;padding:5rem 1.5rem;">
    <div style="max-width:56rem;margin:0 auto;">
      <div style="text-align:center;margin-bottom:3rem;">
        <p style="font-size:0.875rem;font-weight:600;text-transform:uppercase;letter-spacing:0.1em;color:#2563eb;">What's Included</p>
        <h2 style="font-size:2rem;font-weight:800;color:#111827;margin-top:0.5rem;">Done Right, Not Just Done.</h2>
        <p style="color:#6b7280;margin-top:0.75rem;max-width:40rem;margin-left:auto;margin-right:auto;line-height:1.75;">A fresh OS install isn't just running an installer and handing it back. Every install includes the steps most shops skip, so your computer is genuinely ready to use, not stuck on a login screen demanding a hundred updates.</p>
      </div>

      <div class="incl-grid">
        <div class="incl-card">
          <div class="incl-icon" aria-hidden="true">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/></svg>
          </div>
          <h3>Clean OS Install</h3>
          <p>Fresh installation from official media. No bloatware, no random preinstalled junk. Just the operating system as it was meant to be.</p>
        </div>
        <div class="incl-card">
          <div class="incl-icon" aria-hidden="true">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M21 12a9 9 0 1 1-6.219-8.56"/><polyline points="23 4 23 10 17 10"/></svg>
          </div>
          <h3>All Updates Applied</h3>
          <p>Every available system update, security patch, and driver update applied before handoff. Your machine boots ready, not stuck downloading for 4 hours.</p>
        </div>
        <div class="incl-card">
          <div class="incl-icon" aria-hidden="true">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="10" r="3"/><path d="M6.34 17.66a8 8 0 0 1 11.32 0"/></svg>
          </div>
          <h3>Basic User Account Setup</h3>
          <p>I set up your user account with your name, password (yours, never mine), basic settings, and confirm everything's working. You log in, you're ready.</p>
        </div>
        <div class="incl-card">
          <div class="incl-icon" aria-hidden="true">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          </div>
          <h3>Working &amp; Tested</h3>
          <p>I verify networking, audio, video, and basic functionality before you pick up. If anything's flaky, you know about it, not a week later.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- OS Options -->
  <section id="os-options" style="background:#f8fafc;padding:5rem 1.5rem;">
    <div style="max-width:60rem;margin:0 auto;">
      <div style="text-align:center;margin-bottom:3rem;">
        <p style="font-size:0.875rem;font-weight:600;text-transform:uppercase;letter-spacing:0.1em;color:#2563eb;">Three OS Options</p>
        <h2 style="font-size:2rem;font-weight:800;color:#111827;margin-top:0.5rem;">Pick Your Operating System.</h2>
      </div>

      <div class="os-grid">
        <!-- LINUX -->
        <div class="os-card os-card-linux">
          <div class="os-card-header">
            <div class="os-card-icon" aria-hidden="true">
              <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M12 2 C8 2 7 7 7 11 C7 13 6 15 5 17 C3 19 3 21 6 21 L18 21 C21 21 21 19 19 17 C18 15 17 13 17 11 C17 7 16 2 12 2 Z"/><circle cx="10" cy="9" r="1" fill="currentColor"/><circle cx="14" cy="9" r="1" fill="currentColor"/></svg>
            </div>
            <div>
              <div class="os-card-label">Linux</div>
              <div class="os-card-price">$50</div>
            </div>
          </div>
          <p class="os-card-tagline">Free, fast, and a great way to give older hardware new life.</p>
          <ul class="os-card-features">
            <li>Any major distribution: Ubuntu, Linux Mint, Fedora, Pop!_OS, etc.</li>
            <li>Free operating system, no license fees</li>
            <li>Works great on older or low-spec machines</li>
            <li>Ideal life-extension option for pre-2016 laptops/desktops</li>
            <li>Also installable on older Macs that no longer get macOS updates</li>
          </ul>
          <p class="os-card-note">Not sure which distribution? I'll recommend one based on what you'll use the computer for. Linux Mint is the most beginner-friendly, Ubuntu is the most popular.</p>
        </div>

        <!-- WINDOWS -->
        <div class="os-card os-card-windows">
          <div class="os-card-header">
            <div class="os-card-icon" aria-hidden="true">
              <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="9" height="9"/><rect x="13" y="3" width="9" height="9"/><rect x="2" y="14" width="9" height="9"/><rect x="13" y="14" width="9" height="9"/></svg>
            </div>
            <div>
              <div class="os-card-label">Windows</div>
              <div class="os-card-price">$75</div>
            </div>
          </div>
          <p class="os-card-tagline">Fresh Windows 11 install with all updates applied.</p>
          <ul class="os-card-features">
            <li>Windows 11 (the current supported version)</li>
            <li>All Windows Updates applied through completion</li>
            <li>Drivers installed and verified working</li>
            <li>Bloatware removed where possible</li>
            <li>Microsoft account or local account, your choice</li>
          </ul>
          <p class="os-card-note"><strong>About licensing:</strong> Most modern PCs (2016 and newer) have the Windows license stored in the BIOS/UEFI firmware, and Windows will activate automatically with no key needed. For older machines, custom builds, or machines that didn't ship with Windows, you'll need to provide a valid Windows license key.</p>
        </div>

        <!-- macOS -->
