<style>
  /* Hero */
  #hero-svg {
    position: relative;
    width: 100%;
    height: 72vh;
    min-height: 460px;
    max-height: 720px;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #1e3a8a;
  }
  .hero-bg-desktop, .hero-bg-mobile {
    position: absolute; inset: 0;
    width: 100%; height: 100%;
  }
  .hero-bg-desktop { display: block; }
  .hero-bg-mobile  { display: none; }

  /* Pieces fade in */
  .house-body, .van-start { animation: pieceAppear 0.8s ease 0.3s both; }
  @keyframes pieceAppear {
    from { opacity: 0; }
    to   { opacity: 1; }
  }

  /* 9s loop matching the van travel:
     0-10%:  van parked at start (broken WiFi visible)
     10-50%: van travels right → left along road
     50%:    van arrives at house, broken → fixed
     50-100%: van parked at house, fixed WiFi held
  */
  .house-wifi-broken { animation: brokenSignal 9s ease-in-out infinite; }
  .house-wifi-fixed  { opacity: 0; animation: fixedSignal 9s ease-in-out infinite; transform-origin: center; transform-box: fill-box; }
  @keyframes brokenSignal {
    0%, 48%  { opacity: 1; }
    52%      { opacity: 0; }
    100%     { opacity: 0; }
  }
  @keyframes fixedSignal {
    0%, 48%  { opacity: 0; transform: scale(0.85); }
    54%      { opacity: 1; transform: scale(1.15); }
    60%, 96% { opacity: 1; transform: scale(1); }
    100%     { opacity: 0; transform: scale(0.85); }
  }

  /* Van fades in/out — visible only during travel phase */
  .service-van { animation: vanVisible 9s ease-in-out infinite; }
  @keyframes vanVisible {
    0%, 6%   { opacity: 0; }
    12%      { opacity: 1; }
    48%      { opacity: 1; }
    54%, 100% { opacity: 0; }
  }

  /* Road dashed line scrolls subtly to feel like motion */
  .road-line { animation: roadScroll 2s linear infinite; }
  @keyframes roadScroll {
    from { stroke-dashoffset: 0; }
    to   { stroke-dashoffset: -32; }
  }

  /* Float icons */
  .float-tool-1 { animation: floatA 6s ease-in-out infinite; }
  .float-tool-2 { animation: floatB 7s ease-in-out infinite; }
  .float-tool-3 { animation: floatC 5.5s ease-in-out infinite; }
  @keyframes floatA { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-10px)} }
  @keyframes floatB { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-8px)} }
  @keyframes floatC { 0%,100%{transform:translateY(0) rotate(0deg)} 50%{transform:translateY(-12px) rotate(15deg)} }

  /* Ambient code labels */
  .code-tw { animation-fill-mode: both; opacity: 0; }
  .ct-a { animation: codeBlink 5s ease-in-out infinite 0.5s; }
  .ct-b { animation: codeBlink 6s ease-in-out infinite 0.8s; }
  .ct-c { animation: codeBlink 4.5s ease-in-out infinite 1.0s; }
  .ct-d { animation: codeBlink 5.5s ease-in-out infinite 1.3s; }
  @keyframes codeBlink {
    0%   { opacity: 0; }
    20%  { opacity: 0.9; }
    60%  { opacity: 0.4; }
    100% { opacity: 0.85; }
  }

  /* Glow orbs */
  .glow-orb-1 { animation: glowPulse 4s ease-in-out infinite; }
  .glow-orb-2 { animation: glowPulse 5s ease-in-out infinite reverse; }
