---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="On-Site Tech Support | Jake Fixes Tech — Littleton, NH"
description="On-site tech support for homes and small businesses across the North Country. WiFi, printers, device setup, troubleshooting and more. $65/hr, weekends 9am–4pm.">

  <!-- Header Banner -->
  <section style="position:relative;overflow:hidden;background-color:rgb(30,64,175);">
    <img src="/hero.jpg" alt="Professional tech workspace with dual monitors" fetchpriority="high" decoding="async" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;z-index:0;" />
    <div style="position:absolute;inset:0;background:linear-gradient(135deg,rgba(30,64,175,0.88),rgba(37,99,235,0.88));z-index:1;"></div>
    <div style="max-width:56rem;margin:0 auto;padding:4rem 1.5rem;text-align:center;position:relative;z-index:2;">
      <p style="font-size:0.875rem;font-weight:600;text-transform:uppercase;letter-spacing:0.1em;color:#93c5fd;">
        <a href="/services#on-site-tech-support" style="color:#93c5fd;text-decoration:none;" aria-label="Back to all services">← Services</a>
      </p>
      <h1 style="margin-top:0.75rem;font-size:2.5rem;font-weight:800;color:white;line-height:1.2;">On-Site Tech Support</h1>
      <p style="margin-top:1rem;color:#bfdbfe;line-height:1.75;font-size:1.1rem;max-width:42rem;margin-left:auto;margin-right:auto;">
        I come to you. Whether it's a WiFi problem, a printer that won't cooperate, a new device to set up, or general tech troubleshooting, I'll handle it at your home or business across the North Country.
      </p>
      <div style="margin-top:1.5rem;display:flex;flex-wrap:wrap;justify-content:center;gap:1rem;">
        <a href="/contact" style="display:inline-flex;align-items:center;gap:0.5rem;background:white;color:#1e40af;font-weight:700;padding:0.75rem 1.75rem;border-radius:0.5rem;text-decoration:none;font-size:1rem;">
          Book a Visit
          <svg style="height:1rem;width:1rem;" aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
        <a href="/pricing" style="display:inline-flex;align-items:center;gap:0.5rem;background:rgba(255,255,255,0.15);color:white;font-weight:600;padding:0.75rem 1.75rem;border-radius:0.5rem;text-decoration:none;font-size:1rem;border:1px solid rgba(255,255,255,0.3);">
          View Pricing
        </a>
      </div>
    </div>
  </section>

  <!-- Info Bar -->
  <section style="background:#1e40af;padding:1.25rem 1.5rem;">
    <div style="max-width:56rem;margin:0 auto;display:flex;flex-wrap:wrap;align-items:center;justify-content:center;gap:2rem;text-align:center;">
      <div>
        <div style="font-size:1.75rem;font-weight:800;color:white;">$65/hr</div>
        <div style="font-size:0.8rem;color:#bfdbfe;font-weight:600;">1 Hour Minimum</div>
      </div>
      <div style="width:1px;height:2.5rem;background:rgba(255,255,255,0.2);flex-shrink:0;"></div>
      <div>
        <div style="font-size:1.75rem;font-weight:800;color:white;">Weekends</div>
        <div style="font-size:0.8rem;color:#bfdbfe;font-weight:600;">9am to 4pm</div>
      </div>
      <div style="width:1px;height:2.5rem;background:rgba(255,255,255,0.2);flex-shrink:0;"></div>
      <div>
        <div style="font-size:1.75rem;font-weight:800;color:white;">North Country</div>
        <div style="font-size:0.8rem;color:#bfdbfe;font-weight:600;">~30 Min from Littleton</div>
      </div>
    </div>
  </section>

  <!-- Hours & Availability -->
  <section style="background:#f8fafc;padding:4rem 1.5rem;">
    <div style="max-width:56rem;margin:0 auto;">
      <div style="margin-bottom:2.5rem;">
        <p style="font-size:0.875rem;font-weight:600;text-transform:uppercase;letter-spacing:0.1em;color:#2563eb;">Availability</p>
        <h2 style="font-size:2rem;font-weight:800;color:#111827;margin-top:0.5rem;">When I'm Available</h2>
        <p style="color:#6b7280;margin-top:0.75rem;line-height:1.75;">On-site visits and drop-offs run on different schedules. Here's what's available and when.</p>
      </div>

      <div style="display:grid;gap:1rem;grid-template-columns:1fr 1fr;">
        <div style="background:white;border:1px solid #e5e7eb;border-radius:0.75rem;padding:1.5rem;border-left:4px solid #2563eb;">
          <div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:1rem;">
            <div style="display:flex;height:2.5rem;width:2.5rem;min-width:2.5rem;align-items:center;justify-content:center;border-radius:0.5rem;background:#dbeafe;color:#2563eb;flex-shrink:0;" aria-hidden="true">
              <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            </div>
            <h3 style="font-size:1rem;font-weight:700;color:#111827;margin:0;">On-Site Visits</h3>
          </div>
          <p style="font-size:0.875rem;color:#4b5563;line-height:1.7;margin:0;">Available <strong>weekends only, 9am to 4pm.</strong> I come to your home or business anywhere in the North Country, roughly within 30 minutes of Littleton. Reach out to schedule and I'll confirm availability.</p>
        </div>

        <div style="background:white;border:1px solid #e5e7eb;border-radius:0.75rem;padding:1.5rem;border-left:4px solid #6d28d9;">
          <div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:1rem;">
            <div style="display:flex;height:2.5rem;width:2.5rem;min-width:2.5rem;align-items:center;justify-content:center;border-radius:0.5rem;background:#ede9fe;color:#6d28d9;flex-shrink:0;" aria-hidden="true">
              <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
            </div>
            <h3 style="font-size:1rem;font-weight:700;color:#111827;margin:0;">Drop-Off Repairs</h3>
          </div>
          <p style="font-size:0.875rem;color:#4b5563;line-height:1.7;margin:0;">Prefer to drop your device off? Drop-offs are accepted <strong>weekdays 5pm to 7:30pm</strong> at my Littleton location. Great for repairs that don't require an on-site visit.</p>
        </div>
      </div>

      <div style="margin-top:1rem;background:#eff6ff;border:2px solid #bfdbfe;border-radius:0.75rem;padding:1.25rem 1.5rem;display:flex;align-items:flex-start;gap:0.75rem;">
        <div style="flex-shrink:0;color:#2563eb;margin-top:0.1rem;" aria-hidden="true">
          <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" style="height:1.25rem;width:1.25rem;"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><circle cx="12" cy="16" r="1" fill="currentColor" stroke="none"/></svg>
        </div>
        <p style="font-size:0.875rem;color:#1e40af;line-height:1.7;margin:0;">Hours are subject to change. If you're unsure whether I'm available for your area or timeframe, just reach out and I'll let you know quickly.</p>
      </div>
    </div>
  </section>

  <!-- What I Can Do On-Site -->
  <section style="background:white;padding:4rem 1.5rem;">
    <div style="max-width:56rem;margin:0 auto;">
      <div style="margin-bottom:2.5rem;">
        <p style="font-size:0.875rem;font-weight:600;text-transform:uppercase;letter-spacing:0.1em;color:#2563eb;">What's Included</p>
        <h2 style="font-size:2rem;font-weight:800;color:#111827;margin-top:0.5rem;">What I Can Help With On-Site</h2>
        <p style="color:#6b7280;margin-top:0.75rem;line-height:1.75;">Anything I can do in my shop, I can generally do at your location too. Here are the most common on-site requests. This isn't an exhaustive list.</p>
      </div>

      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(15rem,1fr));gap:1rem;">
        <div class="onsite-card">
          <div class="onsite-icon" aria-hidden="true">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M5 12.55a11 11 0 0 1 14.08 0"/><path d="M1.42 9a16 16 0 0 1 21.16 0"/><path d="M8.53 16.11a6 6 0 0 1 6.95 0"/><circle cx="12" cy="20" r="1" fill="currentColor" stroke="none"/></svg>
          </div>
          <h3>WiFi &amp; Networking</h3>
          <p>Router setup, WiFi dead zones, slow speeds, devices that won't connect, network security. I've set up and maintained networks for schools and businesses. Homes are no problem.</p>
        </div>

        <div class="onsite-card">
          <div class="onsite-icon" aria-hidden="true">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect x="6" y="14" width="12" height="8"/></svg>
          </div>
          <h3>Printer Setup &amp; Repair</h3>
          <p>Won't print, won't connect, paper jams, dead power boards. I can set up a new printer or troubleshoot one that's stopped cooperating at your desk, not mine.</p>
        </div>

        <div class="onsite-card">
          <div class="onsite-icon" aria-hidden="true">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
          </div>
          <h3>Device Setup &amp; Configuration</h3>
          <p>New computer, new TV, new smart home device. I'll get it set up, connected, and configured the way you want it. No reading manuals required on your end.</p>
        </div>

        <div class="onsite-card">
          <div class="onsite-icon" aria-hidden="true">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          </div>
          <h3>Virus &amp; Malware Removal</h3>
          <p>Slow computer, pop-ups, strange behavior. I can clean and secure your machine on-site without you having to leave it somewhere.</p>
        </div>

        <div class="onsite-card">
          <div class="onsite-icon" aria-hidden="true">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="2" y1="20" x2="22" y2="20"/></svg>
          </div>
          <h3>Monitor &amp; Display Setup</h3>
          <p>Multi-monitor setups, TV-as-monitor connections, display scaling and resolution issues. I'll get everything looking and working right.</p>
        </div>

        <div class="onsite-card">
          <div class="onsite-icon" aria-hidden="true">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>
          </div>
          <h3>Software Troubleshooting</h3>
          <p>Applications crashing, updates breaking things, software conflicts. Diagnosed and resolved on-site across Windows, macOS, Linux and ChromeOS.</p>
        </div>

        <div class="onsite-card">
          <div class="onsite-icon" aria-hidden="true">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          </div>
          <h3>Small Business IT Support</h3>
          <p>Workstation setup, network troubleshooting, printer and peripheral configuration, basic IT infrastructure for small offices. I've supported IT across multiple school districts and businesses and I'm happy to bring that experience to a local business.</p>
        </div>

        <div class="onsite-card">
          <div class="onsite-icon" aria-hidden="true">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><ellipse cx="12" cy="12" rx="10" ry="3"/><path d="M2 12c0 1.66 4.48 3 10 3s10-1.34 10-3"/><path d="M2 12v6c0 1.66 4.48 3 10 3s10-1.34 10-3v-6"/></svg>
          </div>
          <h3>Data Backup &amp; Transfer</h3>
          <p>Setting up a backup system, transferring files to a new computer, or recovering data from an old drive. Done at your location so your files never have to leave your hands.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Travel Fee -->
  <section style="background:#f8fafc;padding:4rem 1.5rem;">
    <div style="max-width:56rem;margin:0 auto;">
      <div style="margin-bottom:2rem;">
        <p style="font-size:0.875rem;font-weight:600;text-transform:uppercase;letter-spacing:0.1em;color:#2563eb;">Travel &amp; Pricing</p>
        <h2 style="font-size:2rem;font-weight:800;color:#111827;margin-top:0.5rem;">Rate &amp; Travel Fee</h2>
        <p style="color:#6b7280;margin-top:0.75rem;line-height:1.75;">On-site support is billed at $65/hr with a one hour minimum. A flat travel fee applies based on distance from Littleton.</p>
      </div>

      <div style="display:flex;flex-direction:column;gap:0.75rem;">
        <div class="travel-row">
          <div style="display:flex;align-items:center;gap:0.75rem;">
            <div style="display:flex;height:2.25rem;width:2.25rem;min-width:2.25rem;align-items:center;justify-content:center;border-radius:0.5rem;background:#dbeafe;color:#2563eb;flex-shrink:0;" aria-hidden="true">
              <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            </div>
            <div>
              <div style="font-size:0.95rem;font-weight:700;color:#111827;">Within 10 miles of Littleton</div>
              <div style="font-size:0.8rem;color:#6b7280;">Littleton, Bethlehem, Sugar Hill, Franconia and nearby</div>
            </div>
          </div>
          <div style="font-size:1rem;font-weight:800;color:#2563eb;white-space:nowrap;">No travel fee</div>
        </div>

        <div class="travel-row">
          <div style="display:flex;align-items:center;gap:0.75rem;">
            <div style="display:flex;height:2.25rem;width:2.25rem;min-width:2.25rem;align-items:center;justify-content:center;border-radius:0.5rem;background:#dbeafe;color:#2563eb;flex-shrink:0;" aria-hidden="true">
              <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            </div>
            <div>
              <div style="font-size:0.95rem;font-weight:700;color:#111827;">10 to 20 miles from Littleton</div>
              <div style="font-size:0.8rem;color:#6b7280;">Lisbon, Woodsville, Lincoln, Easton and surrounding areas</div>
            </div>
          </div>
          <div style="font-size:1rem;font-weight:800;color:#2563eb;white-space:nowrap;">+$15</div>
        </div>

        <div class="travel-row">
          <div style="display:flex;align-items:center;gap:0.75rem;">
            <div style="display:flex;height:2.25rem;width:2.25rem;min-width:2.25rem;align-items:center;justify-content:center;border-radius:0.5rem;background:#dbeafe;color:#2563eb;flex-shrink:0;" aria-hidden="true">
              <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            </div>
            <div>
              <div style="font-size:0.95rem;font-weight:700;color:#111827;">20 to 30 miles from Littleton</div>
              <div style="font-size:0.8rem;color:#6b7280;">Lancaster, Plymouth, and the wider North Country region</div>
            </div>
          </div>
          <div style="font-size:1rem;font-weight:800;color:#2563eb;white-space:nowrap;">+$25</div>
        </div>
      </div>

      <div style="margin-top:1rem;background:#eff6ff;border:2px solid #bfdbfe;border-radius:0.75rem;padding:1.25rem 1.5rem;display:flex;align-items:flex-start;gap:0.75rem;">
        <div style="flex-shrink:0;color:#2563eb;margin-top:0.1rem;" aria-hidden="true">
          <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" style="height:1.25rem;width:1.25rem;"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><circle cx="12" cy="16" r="1" fill="currentColor" stroke="none"/></svg>
        </div>
        <p style="font-size:0.875rem;color:#1e40af;line-height:1.7;margin:0;">Not sure if you're in range? Just ask. If you're outside the 30 mile radius I'll let you know. <a href="/services/remote-support" style="color:#1e40af;font-weight:700;text-decoration:underline;">Remote support</a> may be an option depending on what you need.</p>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section style="background:linear-gradient(135deg,#1e40af,#2563eb);padding:4rem 1.5rem;text-align:center;">
    <div style="max-width:40rem;margin:0 auto;">
      <h2 style="font-size:2rem;font-weight:800;color:white;margin-bottom:1rem;">Need Someone to Come to You?</h2>
      <p style="color:#bfdbfe;font-size:1.1rem;line-height:1.75;margin-bottom:2rem;">Reach out and describe what's going on. I'll let you know if an on-site visit makes sense, confirm availability, and get something scheduled.</p>
      <div style="display:flex;flex-wrap:wrap;justify-content:center;gap:1rem;">
        <a href="/contact" style="display:inline-flex;align-items:center;gap:0.5rem;background:white;color:#2563eb;font-weight:700;padding:0.875rem 2rem;border-radius:0.5rem;text-decoration:none;font-size:1rem;">
          <svg style="height:1.25rem;width:1.25rem;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          Get in Touch
        </a>
        <a href="tel:+18022341552" style="display:inline-flex;align-items:center;gap:0.5rem;background:rgba(255,255,255,0.15);color:white;font-weight:600;padding:0.875rem 2rem;border-radius:0.5rem;text-decoration:none;font-size:1rem;border:1px solid rgba(255,255,255,0.3);">
          <svg style="height:1.25rem;width:1.25rem;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.28h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.96a16 16 0 0 0 6.29 6.29l.54-.54a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21.28 17z"/></svg>
          (802) 234-1552
        </a>
      </div>
      <p style="color:#bfdbfe;font-size:0.875rem;margin-top:1.5rem;">
        <a href="/services#on-site-tech-support" style="color:#bfdbfe;text-decoration:underline;" aria-label="Back to all services">Back to All Services</a>
      </p>
    </div>
  </section>

</Layout>

<style>
  .onsite-card { background: #f8fafc; border: 1px solid #e5e7eb; border-radius: 0.75rem; padding: 1.25rem; }
  .onsite-icon { display: flex; height: 2.5rem; width: 2.5rem; align-items: center; justify-content: center; border-radius: 0.5rem; background: #dbeafe; color: #2563eb; margin-bottom: 0.75rem; }
  .onsite-icon svg { height: 1.25rem; width: 1.25rem; }
  .onsite-card h3 { font-size: 0.95rem; font-weight: 700; color: #111827; margin-bottom: 0.375rem; }
  .onsite-card p { font-size: 0.875rem; color: #6b7280; line-height: 1.6; margin: 0; }
  .travel-row { background: white; border: 1px solid #e5e7eb; border-radius: 0.75rem; padding: 1rem 1.25rem; display: flex; align-items: center; justify-content: space-between; gap: 1rem; }

  @media (max-width: 640px) {
    div[style*="grid-template-columns:1fr 1fr"] { grid-template-columns: 1fr !important; }
    .travel-row { flex-direction: column; align-items: flex-start; }
  }
</style>