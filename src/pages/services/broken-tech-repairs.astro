  /* Devices/toolbox entrance */
  .device, .tb-body, .tb-handle, .tb-lid { animation: pieceAppear 0.8s ease 0.3s both; }
  @keyframes pieceAppear {
    from { opacity: 0; }
    to   { opacity: 1; }
  }

  /* 9s loop, 3 devices each get a "broken → fixed" beat (3s each).
     During each beat:  0-66% broken visible, 66-100% fixed visible
     Devices are staggered so only one is "fixing" at a time.
     Default state: broken visible, fixed hidden. Then they swap. */

  .broken-state { opacity: 1; }
  .fixed-state  { opacity: 0; transform-origin: center; transform-box: fill-box; }

  /* Device 1 cycle 0-3s of 9s */
  .d1-broken { animation: brokenBeat1 9s ease-in-out infinite; }
  .d1-fixed  { animation: fixedBeat1 9s ease-in-out infinite; }
  @keyframes brokenBeat1 {
    0%, 22%      { opacity: 1; }
    25%          { opacity: 0; }
    100%         { opacity: 0; }
  }
  @keyframes fixedBeat1 {
    0%, 22%      { opacity: 0; transform: scale(0.7); }
    28%          { opacity: 1; transform: scale(1.15); }
    33%, 100%    { opacity: 1; transform: scale(1); }
  }

  /* Device 2 cycle 3-6s of 9s */
  .d2-broken { animation: brokenBeat2 9s ease-in-out infinite; }
  .d2-fixed  { animation: fixedBeat2 9s ease-in-out infinite; }
  @keyframes brokenBeat2 {
    0%, 55%      { opacity: 1; }
    58%          { opacity: 0; }
    100%         { opacity: 0; }
  }
  @keyframes fixedBeat2 {
    0%, 55%      { opacity: 0; transform: scale(0.7); }
    61%          { opacity: 1; transform: scale(1.15); }
    66%, 100%    { opacity: 1; transform: scale(1); }
  }

  /* Device 3 cycle 6-9s of 9s */
  .d3-broken { animation: brokenBeat3 9s ease-in-out infinite; }
  .d3-fixed  { animation: fixedBeat3 9s ease-in-out infinite; }
  @keyframes brokenBeat3 {
    0%, 88%      { opacity: 1; }
    91%          { opacity: 0; }
    100%         { opacity: 0; }
  }
  @keyframes fixedBeat3 {
    0%, 88%      { opacity: 0; transform: scale(0.7); }
    94%          { opacity: 1; transform: scale(1.15); }
    99%, 100%    { opacity: 1; transform: scale(1); }
  }

  /* Tools peek up out of toolbox (staggered) */
  .tool { transform-origin: bottom center; transform-box: fill-box; }
  .tool-1 { animation: toolPeek 5s ease-in-out infinite 0s; }
  .tool-2 { animation: toolPeek 5s ease-in-out infinite 0.5s; }
  .tool-3 { animation: toolPeek 5s ease-in-out infinite 1s; }
  .tool-4 { animation: toolPeek 5s ease-in-out infinite 1.5s; }
  @keyframes toolPeek {
    0%, 100% { transform: translateY(0); }
    50%      { transform: translateY(-6px); }
  }

  /* Float icons */
  .float-tool-1 { animation: floatA 6s ease-in-out infinite; }
  .float-tool-2 { animation: floatB 7s ease-in-out infinite; }
  .float-tool-3 { animation: floatC 5.5s ease-in-out infinite; }
  @keyframes floatA { 0%,100%{transform:translateY(0) rotate(0deg)} 50%{transform:translateY(-10px) rotate(-8deg)} }
  @keyframes floatB { 0%,100%{transform:translateY(0) rotate(0deg)} 50%{transform:translateY(-8px) rotate(20deg)} }
  @keyframes floatC { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-12px)} }

  /* Ambient code labels */
