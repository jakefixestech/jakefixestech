<style>
  /* Hero */
  #hero-svg {
    position: relative;
    width: 100%;
    height: 72vh;
    min-height: 460px;
    max-height: 720px;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #1e3a8a;
  }
  .hero-bg-desktop, .hero-bg-mobile {
    position: absolute; inset: 0;
    width: 100%; height: 100%;
  }
  .hero-bg-desktop { display: block; }
  .hero-bg-mobile  { display: none; }

  /* Pieces fade in */
  .device-body, .device-frame { animation: pieceAppear 0.8s ease 0.3s both; }
  @keyframes pieceAppear {
    from { opacity: 0; }
    to   { opacity: 1; }
  }

  /* 10s loop matching the cursor travel:
     0-15%:  cursor parked on Jake's side (error visible)
     15-40%: cursor travels Jake → Client (error still visible)
     40%:    cursor lands, click ripple, error → fixed
     40-92%: long pause on FIXED state (the satisfying "done" beat)
     92-100%: cursor fades out, brief reset for loop */
  .screen-state-error  { animation: errorState 10s ease-in-out infinite; }
  .screen-state-fixed  { opacity: 0; animation: fixedState 10s ease-in-out infinite; transform-origin: center; transform-box: fill-box; }
  @keyframes errorState {
    0%, 38%  { opacity: 1; }
    44%      { opacity: 0; }
    100%     { opacity: 0; }
  }
  @keyframes fixedState {
    0%, 38%  { opacity: 0; transform: scale(0.85); }
    46%      { opacity: 1; transform: scale(1.1); }
    52%, 92% { opacity: 1; transform: scale(1); }
    100%     { opacity: 0; transform: scale(0.85); }
  }

  /* Cursor fades in when about to move, fades out near end of cycle before reset */
  .cursor-traveler { animation: cursorFade 10s ease-in-out infinite; }
  @keyframes cursorFade {
    0%, 8%    { opacity: 0; }
    13%       { opacity: 1; }
    88%       { opacity: 1; }
    96%, 100% { opacity: 0; }
  }

  /* Connection line shimmer (dash offset animation) */
  .conn-line { animation: dashFlow 3s linear infinite; }
  @keyframes dashFlow {
    from { stroke-dashoffset: 0; }
    to   { stroke-dashoffset: -22; }
  }

  /* Secure badge gentle pulse */
  .secure-badge { animation: securePulse 3s ease-in-out infinite; transform-origin: center; transform-box: fill-box; }
  @keyframes securePulse {
    0%, 100% { transform: scale(1); }
    50%      { transform: scale(1.06); }
  }

  /* Connection LED pulse */
  .connection-pulse { animation: connDot 1.5s ease-in-out infinite; }
  @keyframes connDot {
    0%, 100% { fill-opacity: 0.5; }
    50%      { fill-opacity: 1; }
  }

  /* Click ripple at cursor destination — fires when cursor lands at 40% */
  .click-ripple { animation: clickAt 10s ease-in-out infinite; transform-origin: center; transform-box: fill-box; opacity: 0; }
  @keyframes clickAt {
    0%, 38% { opacity: 0; transform: scale(0.5); }
    42%     { opacity: 1; transform: scale(1); }
    50%     { opacity: 0; transform: scale(2.2); }
    100%    { opacity: 0; transform: scale(2.2); }
  }

  /* Float icons */
  .float-tool-1 { animation: floatA 6s ease-in-out infinite; }
  .float-tool-2 { animation: floatB 7s ease-in-out infinite; }
  .float-tool-3 { animation: floatC 5.5s ease-in-out infinite; }
  @keyframes floatA { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-10px)} }
  @keyframes floatB { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-8px)} }
  @keyframes floatC { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-12px)} }

  /* Ambient code labels */
  .code-tw { animation-fill-mode: both; opacity: 0; }
  .ct-a { animation: codeBlink 5s ease-in-out infinite 0.5s; }
  .ct-b { animation: codeBlink 6s ease-in-out infinite 0.8s; }
  .ct-c { animation: codeBlink 4.5s ease-in-out infinite 1.0s; }
  .ct-d { animation: codeBlink 5.5s ease-in-out infinite 1.3s; }
  @keyframes codeBlink {
    0%   { opacity: 0; }
    20%  { opacity: 0.9; }
    60%  { opacity: 0.4; }
    100% { opacity: 0.85; }
  }

  /* Glow orbs */
  .glow-orb-1 { animation: glowPulse 4s ease-in-out infinite; }
  .glow-orb-2 { animation: glowPulse 5s ease-in-out infinite reverse; }
  @keyframes glowPulse { 0%,100%{opacity:0.6} 50%{opacity:1} }

