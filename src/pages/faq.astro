      <div style="margin-top:1rem;background:#eff6ff;border:2px solid #bfdbfe;border-radius:0.75rem;padding:2rem;display:flex;align-items:flex-start;gap:1.5rem;flex-wrap:wrap;">
        <div style="display:flex;height:3rem;width:3rem;min-width:3rem;align-items:center;justify-content:center;border-radius:0.5rem;background:#dbeafe;color:#2563eb;flex-shrink:0;" aria-hidden="true">
          <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M8 9a4 4 0 1 1 4 4v2"/><circle cx="12" cy="19" r="1" fill="currentColor"/></svg>
        </div>
        <div style="flex:1;min-width:200px;">
          <h3 style="font-size:1.1rem;font-weight:700;color:#1e40af;margin-bottom:0.5rem;">Still Have a Question?</h3>
          <p style="color:#1e40af;font-size:0.9rem;line-height:1.75;margin:0;">If your question isn't covered here, reach out. I respond fast and there's no such thing as a question too small.</p>
          <div style="margin-top:1rem;display:flex;flex-wrap:wrap;gap:0.75rem;">
            <a href="/contact" class="cta-btn-primary">Send a Message</a>
            <a href="tel:+18022341552" class="cta-btn-secondary">(802) 234-1552</a>
          </div>
        </div>
      </div>

    </div>
  </section>

