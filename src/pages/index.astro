---
import Layout from '../layouts/Layout.astro';
import content from '../content/home.yml';
---

<Layout title="Jake Fixes Tech — Computer Repair & Website Design in Littleton, NH"
description="Your friendly neighborhood tech expert. Affordable computer repair, tech support and website design serving Littleton, NH and the North Country. Call or text (802) 234-1552.">

  <!-- SVG Animated Hero -->
  <section id="hero-svg" aria-label="Jake Fixes Tech hero">

    <!-- DESKTOP SVG — circuit traces span the full canvas decoratively (already safe), wordmark centered via flexbox -->
    <svg id="hero-bg" class="hero-bg-desktop" viewBox="0 0 1440 600" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <defs>
        <linearGradient id="bgGrad" x1="0%" y1="0%" x2="100%" y2="100%">
          <stop offset="0%" style="stop-color:#1e3a8a;stop-opacity:1" />
          <stop offset="100%" style="stop-color:#2563eb;stop-opacity:1" />
        </linearGradient>
        <linearGradient id="glowGrad" x1="0%" y1="0%" x2="100%" y2="100%">
          <stop offset="0%" style="stop-color:#3b82f6;stop-opacity:0.3" />
          <stop offset="100%" style="stop-color:#1d4ed8;stop-opacity:0" />
        </linearGradient>
      </defs>
      <rect width="1440" height="600" fill="url(#bgGrad)"/>
      <ellipse cx="300" cy="200" rx="350" ry="250" fill="url(#glowGrad)" class="glow-orb-1"/>
      <ellipse cx="1100" cy="400" rx="300" ry="200" fill="url(#glowGrad)" class="glow-orb-2"/>
      <g class="circuit-group" stroke="white" stroke-opacity="0.12" fill="none">
        <path d="M0 150 L200 150 L220 170 L400 170" stroke-width="1.5" class="trace trace-1"/>
        <path d="M0 280 L100 280 L130 310 L350 310 L380 280 L600 280" stroke-width="1.5" class="trace trace-2"/>
        <path d="M800 130 L1000 130 L1020 150 L1200 150 L1220 130 L1440 130" stroke-width="1.5" class="trace trace-3"/>
        <path d="M600 400 L800 400 L830 430 L1100 430 L1130 400 L1440 400" stroke-width="1.5" class="trace trace-4"/>
        <path d="M0 480 L300 480 L330 510 L550 510" stroke-width="1.5" class="trace trace-5"/>
        <path d="M900 250 L1100 250 L1130 220 L1300 220" stroke-width="1.5" class="trace trace-6"/>
        <path d="M200 350 L350 350 L380 320 L500 320" stroke-width="1.5" class="trace trace-7"/>
        <path d="M1000 500 L1200 500 L1220 480 L1440 480" stroke-width="1.5" class="trace trace-8"/>
      </g>
      <g class="nodes-group" fill="white">
        <circle cx="200" cy="150" r="3" fill-opacity="0" class="node node-1"/>
        <circle cx="400" cy="170" r="3" fill-opacity="0" class="node node-2"/>
        <circle cx="100" cy="280" r="3" fill-opacity="0" class="node node-3"/>
        <circle cx="380" cy="280" r="3" fill-opacity="0" class="node node-4"/>
        <circle cx="600" cy="280" r="3" fill-opacity="0" class="node node-5"/>
        <circle cx="1000" cy="130" r="3" fill-opacity="0" class="node node-6"/>
        <circle cx="1220" cy="130" r="3" fill-opacity="0" class="node node-7"/>
        <circle cx="800" cy="400" r="3" fill-opacity="0" class="node node-8"/>
        <circle cx="1130" cy="400" r="3" fill-opacity="0" class="node node-9"/>
        <circle cx="300" cy="480" r="3" fill-opacity="0" class="node node-10"/>
        <circle cx="1100" cy="250" r="4" fill-opacity="0" class="node node-11"/>
        <circle cx="350" cy="350" r="3" fill-opacity="0" class="node node-12"/>
        <circle cx="1200" cy="500" r="3" fill-opacity="0" class="node node-13"/>
        <circle cx="550" cy="510" r="5" fill-opacity="0" class="node node-accent-1"/>
        <circle cx="1300" cy="220" r="5" fill-opacity="0" class="node node-accent-2"/>
        <circle cx="500" cy="320" r="5" fill-opacity="0" class="node node-accent-3"/>
      </g>
      <g fill="none" stroke="white">
        <circle cx="550" cy="510" r="5" stroke-opacity="0" class="pulse-ring pulse-ring-1"/>
        <circle cx="1300" cy="220" r="5" stroke-opacity="0" class="pulse-ring pulse-ring-2"/>
        <circle cx="500" cy="320" r="5" stroke-opacity="0" class="pulse-ring pulse-ring-3"/>
      </g>
      <circle r="3" fill="white" fill-opacity="0.7">
        <animateMotion dur="4s" repeatCount="indefinite" begin="0.5s"><mpath href="#trace-path-1"/></animateMotion>
      </circle>
      <circle r="2.5" fill="white" fill-opacity="0.6">
        <animateMotion dur="5s" repeatCount="indefinite" begin="1.5s"><mpath href="#trace-path-2"/></animateMotion>
      </circle>
      <circle r="2" fill="white" fill-opacity="0.5">
        <animateMotion dur="3.5s" repeatCount="indefinite" begin="2s"><mpath href="#trace-path-3"/></animateMotion>
      </circle>
      <defs>
        <path id="trace-path-1" d="M0 150 L200 150 L220 170 L400 170"/>
        <path id="trace-path-2" d="M600 280 L380 280 L350 310 L130 310 L100 280 L0 280"/>
        <path id="trace-path-3" d="M800 130 L1000 130 L1020 150 L1200 150 L1220 130 L1440 130"/>
      </defs>
    </svg>

    <!-- MOBILE SVG -->
    <svg id="hero-bg-mobile" class="hero-bg-mobile" viewBox="0 0 400 700" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <defs>
        <linearGradient id="bgGradM" x1="0%" y1="0%" x2="100%" y2="100%">
          <stop offset="0%" style="stop-color:#1e3a8a;stop-opacity:1" />
          <stop offset="100%" style="stop-color:#2563eb;stop-opacity:1" />
        </linearGradient>
        <linearGradient id="glowGradM" x1="0%" y1="0%" x2="100%" y2="100%">
          <stop offset="0%" style="stop-color:#3b82f6;stop-opacity:0.4" />
          <stop offset="100%" style="stop-color:#1d4ed8;stop-opacity:0" />
        </linearGradient>
      </defs>

      <rect width="400" height="700" fill="url(#bgGradM)"/>

      <ellipse cx="200" cy="180" rx="220" ry="180" fill="url(#glowGradM)" class="glow-orb-1"/>
      <ellipse cx="200" cy="520" rx="200" ry="160" fill="url(#glowGradM)" class="glow-orb-2"/>

      <!-- Vertical-friendly circuit traces; pulled away from extreme top/bottom edges -->
      <g stroke="white" stroke-opacity="0.15" fill="none">
        <path d="M60 90 L60 140 L80 160 L80 220" stroke-width="1.5" class="trace trace-1"/>
        <path d="M340 90 L340 130 L320 150 L320 220" stroke-width="1.5" class="trace trace-2"/>
        <path d="M0 200 L80 200 L100 220 L300 220 L320 200 L400 200" stroke-width="1.5" class="trace trace-3"/>
        <path d="M80 320 L160 320 L180 340 L220 340 L240 320 L320 320" stroke-width="1.5" class="trace trace-4"/>
        <path d="M0 440 L100 440 L120 460 L280 460 L300 440 L400 440" stroke-width="1.5" class="trace trace-5"/>
        <path d="M60 520 L60 600 L80 620 L80 660" stroke-width="1.5" class="trace trace-6"/>
        <path d="M340 520 L340 580 L320 600 L320 660" stroke-width="1.5" class="trace trace-7"/>
        <path d="M0 580 L120 580 L140 600 L260 600 L280 580 L400 580" stroke-width="1.5" class="trace trace-8"/>
      </g>

      <g fill="white">
        <circle cx="60" cy="140" r="3" fill-opacity="0" class="node node-1"/>
        <circle cx="80" cy="220" r="3" fill-opacity="0" class="node node-2"/>
        <circle cx="340" cy="130" r="3" fill-opacity="0" class="node node-3"/>
        <circle cx="320" cy="220" r="3" fill-opacity="0" class="node node-4"/>
        <circle cx="80" cy="200" r="3" fill-opacity="0" class="node node-5"/>
        <circle cx="320" cy="200" r="3" fill-opacity="0" class="node node-6"/>
        <circle cx="160" cy="320" r="3" fill-opacity="0" class="node node-7"/>
        <circle cx="240" cy="320" r="3" fill-opacity="0" class="node node-8"/>
        <circle cx="100" cy="440" r="3" fill-opacity="0" class="node node-9"/>
        <circle cx="300" cy="440" r="3" fill-opacity="0" class="node node-10"/>
        <circle cx="60" cy="600" r="3" fill-opacity="0" class="node node-11"/>
        <circle cx="340" cy="580" r="3" fill-opacity="0" class="node node-12"/>
        <circle cx="120" cy="580" r="3" fill-opacity="0" class="node node-13"/>
        <circle cx="200" cy="220" r="5" fill-opacity="0" class="node node-accent-1"/>
        <circle cx="200" cy="460" r="5" fill-opacity="0" class="node node-accent-2"/>
        <circle cx="200" cy="600" r="5" fill-opacity="0" class="node node-accent-3"/>
      </g>

      <g fill="none" stroke="white">
        <circle cx="200" cy="220" r="5" stroke-opacity="0" class="pulse-ring pulse-ring-1"/>
        <circle cx="200" cy="460" r="5" stroke-opacity="0" class="pulse-ring pulse-ring-2"/>
        <circle cx="200" cy="600" r="5" stroke-opacity="0" class="pulse-ring pulse-ring-3"/>
      </g>

      <circle r="3" fill="white" fill-opacity="0.7">
        <animateMotion dur="3s" repeatCount="indefinite" begin="0.5s">
          <mpath href="#mob-trace-1"/>
        </animateMotion>
      </circle>
      <circle r="2.5" fill="white" fill-opacity="0.6">
        <animateMotion dur="4s" repeatCount="indefinite" begin="1.2s">
          <mpath href="#mob-trace-2"/>
        </animateMotion>
      </circle>
      <defs>
        <path id="mob-trace-1" d="M60 90 L60 140 L80 160 L80 220"/>
        <path id="mob-trace-2" d="M0 440 L100 440 L120 460 L280 460 L300 440 L400 440"/>
      </defs>
    </svg>

    <!-- Hero text content -->
    <div id="hero-content">
      <div id="hero-wordmark" aria-label="Jake Fixes Tech">
        <span class="wordmark-jake">Jake</span>
        <span class="wordmark-fixes">Fixes</span>
        <span class="wordmark-tech">Tech</span>
      </div>
      <p id="hero-tagline">Computer Repair & Website Design — Littleton, NH</p>
      <a href="/location" id="hero-cta">
        Hours & Location
        <svg style="height:1rem;width:1rem;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>

    <div id="scroll-hint" aria-hidden="true" role="button" tabindex="-1" onclick="document.getElementById('hero-content-band').scrollIntoView({behavior:'smooth'})">
      <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" style="height:1.5rem;width:1.5rem;"><path d="M12 5v14M5 12l7 7 7-7"/></svg>
    </div>
  </section>

  <!-- Hero Content Section -->
  <section id="hero-content-band" style="background:#1e40af;padding:4rem 1.5rem 5rem 1.5rem;">
    <div style="max-width:80rem;margin:0 auto;">
      <div style="max-width:48rem;">
        <h1 style="font-size:clamp(2rem,5vw,3rem);font-weight:900;color:white;line-height:1.1;margin-bottom:1.25rem;">
          {content.heroTitle}
        </h1>
        <p style="font-size:1.1rem;color:#bfdbfe;line-height:1.8;max-width:38rem;margin-bottom:2.25rem;">
          {content.heroSubtitle}
        </p>
        <div style="display:flex;flex-wrap:wrap;gap:1rem;margin-bottom:3rem;">
          <a href="/services" style="display:inline-flex;align-items:center;gap:0.5rem;background:white;color:#2563eb;font-weight:700;padding:0.875rem 1.75rem;border-radius:0.5rem;text-decoration:none;font-size:1rem;">
            {content.heroBtnPrimary}
            <svg style="height:1rem;width:1rem;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
          <a href="/contact" style="display:inline-flex;align-items:center;background:rgba(255,255,255,0.15);color:white;font-weight:600;padding:0.875rem 1.75rem;border-radius:0.5rem;text-decoration:none;font-size:1rem;border:1px solid rgba(255,255,255,0.3);">
            {content.heroBtnSecondary}
          </a>
        </div>
        <div style="display:flex;flex-wrap:wrap;gap:1.5rem;">
          <span style="display:flex;align-items:center;gap:0.5rem;color:white;font-size:0.875rem;font-weight:500;"><span style="height:0.5rem;width:0.5rem;border-radius:50%;background:#4ade80;display:inline-block;flex-shrink:0;"></span>{content.heroBadge1}</span>
          <span style="display:flex;align-items:center;gap:0.5rem;color:white;font-size:0.875rem;font-weight:500;"><span style="height:0.5rem;width:0.5rem;border-radius:50%;background:#4ade80;display:inline-block;flex-shrink:0;"></span>{content.heroBadge2}</span>
          <span style="display:flex;align-items:center;gap:0.5rem;color:white;font-size:0.875rem;font-weight:500;"><span style="height:0.5rem;width:0.5rem;border-radius:50%;background:#4ade80;display:inline-block;flex-shrink:0;"></span>{content.heroBadge3}</span>
          <span style="display:flex;align-items:center;gap:0.5rem;color:white;font-size:0.875rem;font-weight:500;"><span style="height:0.5rem;width:0.5rem;border-radius:50%;background:#4ade80;display:inline-block;flex-shrink:0;"></span>{content.heroBadge4}</span>
          <span style="display:flex;align-items:center;gap:0.5rem;color:white;font-size:0.875rem;font-weight:500;"><span style="height:0.5rem;width:0.5rem;border-radius:50%;background:#4ade80;display:inline-block;flex-shrink:0;"></span>{content.heroBadge5}</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Services Preview Section -->
  <section style="background:#f8fafc;padding:5rem 1.5rem;">
    <div style="max-width:80rem;margin:0 auto;">
      <div style="text-align:center;margin-bottom:3rem;">
        <p style="font-size:0.875rem;font-weight:600;text-transform:uppercase;letter-spacing:0.1em;color:#2563eb;">{content.servicesLabel}</p>
        <h2 style="font-size:2rem;font-weight:800;color:#111827;margin-top:0.5rem;">{content.servicesTitle}</h2>
        <p style="color:#6b7280;margin-top:0.75rem;max-width:36rem;margin-left:auto;margin-right:auto;line-height:1.75;">{content.servicesSubtitle}</p>
      </div>
      <div id="preview-grid">
        <a href="/services/screen-repair" class="preview-card" style="text-decoration:none;display:block;color:inherit;" aria-label="Screen Repair — learn about screen replacement services">
          <div class="preview-icon" aria-hidden="true"><svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg></div>
          <h3>{content.service1Title}</h3>
          <p>{content.service1Desc}</p>
        </a>
        <a href="/services/virus-removal" class="preview-card" style="text-decoration:none;display:block;color:inherit;" aria-label="Virus and Malware Removal — learn about computer cleaning and protection">
          <div class="preview-icon" aria-hidden="true"><svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg></div>
          <h3>{content.service2Title}</h3>
          <p>{content.service2Desc}</p>
        </a>
        <a href="/services/hardware-upgrades" class="preview-card" style="text-decoration:none;display:block;color:inherit;" aria-label="Hardware Upgrades — learn about RAM, SSD and other upgrades">
          <div class="preview-icon" aria-hidden="true"><svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><rect x="4" y="4" width="16" height="16" rx="2"/><rect x="9" y="9" width="6" height="6"/><line x1="9" y1="2" x2="9" y2="4"/><line x1="15" y1="2" x2="15" y2="4"/><line x1="9" y1="20" x2="9" y2="22"/><line x1="15" y1="20" x2="15" y2="22"/><line x1="2" y1="9" x2="4" y2="9"/><line x1="2" y1="15" x2="4" y2="15"/><line x1="20" y1="9" x2="22" y2="9"/><line x1="20" y1="15" x2="22" y2="15"/></svg></div>
          <h3>{content.service3Title}</h3>
          <p>{content.service3Desc}</p>
        </a>
        <a href="/services/data-recovery" class="preview-card" style="text-decoration:none;display:block;color:inherit;" aria-label="Data Recovery — learn about recovering lost or deleted files">
          <div class="preview-icon" aria-hidden="true"><svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><ellipse cx="12" cy="12" rx="10" ry="3"/><path d="M2 12c0 1.66 4.48 3 10 3s10-1.34 10-3"/><path d="M2 12v6c0 1.66 4.48 3 10 3s10-1.34 10-3v-6"/></svg></div>
          <h3>{content.service4Title}</h3>
          <p>{content.service4Desc}</p>
        </a>
        <a href="/services/broken-tech-repairs" class="preview-card" style="text-decoration:none;display:block;color:inherit;" aria-label="Broken Tech Repairs — learn about diagnosing and fixing damaged devices">
          <div class="preview-icon" aria-hidden="true"><svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg></div>
          <h3>{content.service5Title}</h3>
          <p>{content.service5Desc}</p>
        </a>
        <a href="/services/on-site-tech-support" class="preview-card" style="text-decoration:none;display:block;color:inherit;" aria-label="On-Site Tech Support — learn about in-home and business visits">
          <div class="preview-icon" aria-hidden="true"><svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg></div>
          <h3>{content.service6Title}</h3>
          <p>{content.service6Desc}</p>
        </a>
      </div>
      <div style="text-align:center;margin-top:3rem;">
        <a href="/services" style="display:inline-flex;align-items:center;gap:0.5rem;background:#2563eb;color:white;font-weight:600;padding:0.875rem 2rem;border-radius:0.5rem;text-decoration:none;font-size:1rem;">
          View All Services
          <svg style="height:1rem;width:1rem;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Web Services Teaser -->
  <section style="background:white;padding:5rem 1.5rem;">
    <div style="max-width:80rem;margin:0 auto;">
      <div id="web-teaser-grid">
        <div>
          <p style="font-size:0.875rem;font-weight:600;text-transform:uppercase;letter-spacing:0.1em;color:#2563eb;">{content.webLabel}</p>
          <h2 style="font-size:2rem;font-weight:800;color:#111827;margin-top:0.5rem;margin-bottom:1rem;">{content.webTitle}</h2>
          <p style="color:#6b7280;line-height:1.75;margin-bottom:1rem;">{content.webDesc1}</p>
          <p style="color:#6b7280;line-height:1.75;margin-bottom:2rem;" set:html={content.webDesc2.replace('$750', '<strong style="color:#111827;">$750</strong>')}></p>
          <div style="display:flex;flex-wrap:wrap;gap:1rem;">
            <a href="/web-services" style="display:inline-flex;align-items:center;gap:0.5rem;background:#2563eb;color:white;font-weight:600;padding:0.875rem 2rem;border-radius:0.5rem;text-decoration:none;font-size:1rem;">
              {content.webBtnText}
              <svg style="height:1rem;width:1rem;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
          </div>
        </div>
        <div id="web-teaser-cards">
          <div class="teaser-card">
            <div class="teaser-icon" aria-hidden="true"><svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg></div>
            <h3>Starter</h3>
            <p style="color:#374151;">1-3 page site</p>
            <div style="font-size:1.5rem;font-weight:800;color:#2563eb;margin-top:0.5rem;">$750</div>
          </div>
          <div class="teaser-card teaser-featured">
            <div class="teaser-icon" style="background:#dbeafe;color:#2563eb;" aria-hidden="true"><svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg></div>
            <h3>Professional</h3>
            <p style="color:#374151;">5-15 page site</p>
            <div style="font-size:1.5rem;font-weight:800;color:#2563eb;margin-top:0.5rem;">$2,000</div>
          </div>
          <div class="teaser-card">
            <div class="teaser-icon" aria-hidden="true"><svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg></div>
            <h3>Premium</h3>
            <p style="color:#374151;">30+ pages, custom scope</p>
            <div style="font-size:1.5rem;font-weight:800;color:#2563eb;margin-top:0.5rem;">$3,500+</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Why Choose Jake Section -->
  <section style="background:#f8fafc;padding:5rem 1.5rem;">
    <div style="max-width:80rem;margin:0 auto;">
      <div style="text-align:center;margin-bottom:3rem;">
        <p style="font-size:0.875rem;font-weight:600;text-transform:uppercase;letter-spacing:0.1em;color:#2563eb;">{content.whyLabel}</p>
        <h2 style="font-size:2rem;font-weight:800;color:#111827;margin-top:0.5rem;">{content.whyTitle}</h2>
      </div>
      <div id="why-grid">
        <div class="why-card">
          <div class="why-icon" aria-hidden="true"><svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg></div>
          <h3>{content.why1Title}</h3>
          <p>{content.why1Desc}</p>
        </div>
        <div class="why-card">
          <div class="why-icon" aria-hidden="true"><svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg></div>
          <h3>{content.why2Title}</h3>
