  .security-icon { display: flex; height: 3rem; width: 3rem; align-items: center; justify-content: center; border-radius: 0.5rem; background: #dbeafe; color: #2563eb; margin: 0 auto 0.75rem auto; }
  .security-icon svg { height: 1.5rem; width: 1.5rem; }
  .security-card h3 { font-size: 0.95rem; font-weight: 700; color: #111827; margin-bottom: 0.375rem; }
