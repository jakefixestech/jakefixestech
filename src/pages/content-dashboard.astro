---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Website Content Dashboard | Jake Fixes Tech — Littleton, NH"
description="Update your own website without calling a developer. Jake Fixes Tech offers a secure content dashboard add-on for all website packages. Edit text, swap images and go live in 60 seconds.">

  <!-- Animated SVG Hero -->
  <section id="hero-svg" aria-label="Content Dashboard">

    <!-- DESKTOP SVG -->
    <svg class="hero-bg-desktop" viewBox="0 0 1440 520" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <defs>
        <linearGradient id="bgGrad" x1="0%" y1="0%" x2="100%" y2="100%">
          <stop offset="0%" style="stop-color:#1e3a8a;stop-opacity:1"/>
          <stop offset="100%" style="stop-color:#2563eb;stop-opacity:1"/>
        </linearGradient>
        <linearGradient id="glowGrad" x1="0%" y1="0%" x2="100%" y2="100%">
          <stop offset="0%" style="stop-color:#3b82f6;stop-opacity:0.3"/>
          <stop offset="100%" style="stop-color:#1d4ed8;stop-opacity:0"/>
        </linearGradient>
      </defs>
      <rect width="1440" height="520" fill="url(#bgGrad)"/>
      <ellipse cx="320" cy="260" rx="380" ry="280" fill="url(#glowGrad)" class="glow-orb-1"/>
      <ellipse cx="1150" cy="260" rx="340" ry="260" fill="url(#glowGrad)" class="glow-orb-2"/>

      <!-- ============================================
           LEFT: Editor panel — typing + publishing demo.
           Anchored x:200 y:130 (extends to x:480, y:390).
           Inside x:200-1240 ultrawide safe zone.
           ============================================ -->
      <g class="editor-panel" transform="translate(200, 110)">
        <!-- Window frame -->
        <rect x="0" y="0" width="220" height="310" rx="10" fill="white" fill-opacity="0.08" stroke="white" stroke-opacity="0.4" stroke-width="1.5"/>
        <!-- Title bar -->
        <rect x="0" y="0" width="220" height="32" rx="10" fill="white" fill-opacity="0.06"/>
        <rect x="0" y="22" width="220" height="10" fill="white" fill-opacity="0.06"/>
        <!-- Traffic lights -->
        <circle cx="14" cy="16" r="3.5" fill="white" fill-opacity="0.35"/>
        <circle cx="26" cy="16" r="3.5" fill="white" fill-opacity="0.35"/>
        <circle cx="38" cy="16" r="3.5" fill="white" fill-opacity="0.35"/>
        <text x="110" y="20" text-anchor="middle" fill="white" fill-opacity="0.55" font-size="9" font-weight="600" font-family="monospace" letter-spacing="1.5">YOUR DASHBOARD</text>

        <!-- Field label -->
        <text x="20" y="60" fill="white" fill-opacity="0.55" font-size="9" font-weight="700" font-family="monospace" letter-spacing="1.5">BUSINESS HOURS</text>

        <!-- Input field -->
        <rect x="20" y="70" width="180" height="36" rx="6" fill="white" fill-opacity="0.1" stroke="white" stroke-opacity="0.4" stroke-width="1.5"/>
        <text x="32" y="93" fill="white" font-size="13" font-weight="600" font-family="monospace" class="typed-text">Mon-Fri 9-5</text>
        <rect x="32" y="80" width="1.5" height="16" fill="white" class="caret"/>

        <!-- Second field -->
        <text x="20" y="130" fill="white" fill-opacity="0.55" font-size="9" font-weight="700" font-family="monospace" letter-spacing="1.5">PHONE NUMBER</text>
        <rect x="20" y="140" width="180" height="36" rx="6" fill="white" fill-opacity="0.06" stroke="white" stroke-opacity="0.25" stroke-width="1.2"/>
        <text x="32" y="163" fill="white" fill-opacity="0.7" font-size="13" font-weight="600" font-family="monospace">(802) 234-1552</text>

        <!-- Third field -->
        <text x="20" y="200" fill="white" fill-opacity="0.55" font-size="9" font-weight="700" font-family="monospace" letter-spacing="1.5">HEADLINE</text>
        <rect x="20" y="210" width="180" height="36" rx="6" fill="white" fill-opacity="0.06" stroke="white" stroke-opacity="0.25" stroke-width="1.2"/>
        <text x="32" y="233" fill="white" fill-opacity="0.7" font-size="13" font-weight="600" font-family="monospace">Fast Local Tech Repair</text>

        <!-- Publish button — INSIDE the window now, at y:266 -->
        <g class="publish-btn">
          <rect x="120" y="266" width="80" height="32" rx="6" fill="white" fill-opacity="0.95"/>
          <text x="160" y="287" text-anchor="middle" fill="#1e40af" font-size="11" font-weight="800" font-family="monospace" letter-spacing="1">PUBLISH ✓</text>
        </g>

        <!-- Toast — visible at top of window where there's space -->
        <g class="publish-toast">
          <rect x="20" y="266" width="92" height="32" rx="6" fill="#10b981" fill-opacity="0.2" stroke="#34d399" stroke-opacity="0.7" stroke-width="1.5"/>
          <circle cx="33" cy="282" r="5" fill="#34d399"/>
          <path d="M30 282 L32 284 L36 280" stroke="white" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
          <text x="44" y="286" fill="white" fill-opacity="0.95" font-size="9" font-weight="700" font-family="monospace">Published ✓</text>
        </g>
      </g>

      <!-- ============================================
           RIGHT: Stack of editable field cards (legend).
           Each shows a field name + sample value.
           Anchored x:960 y:120 (extends to x:1240, y:400).
           ============================================ -->
      <g class="field-stack" transform="translate(1020, 120)">
        <!-- Section label -->
        <text x="110" y="0" text-anchor="middle" fill="white" fill-opacity="0.5" font-size="10" font-weight="700" font-family="monospace" letter-spacing="2">EDITABLE FIELDS</text>

        <!-- Card 1: Hero Headline -->
        <g transform="translate(0, 20)">
          <g class="field-card fc-1">
            <rect width="220" height="48" rx="8" fill="white" fill-opacity="0.1" stroke="white" stroke-opacity="0.35" stroke-width="1.2"/>
            <g transform="translate(14, 14)">
              <rect width="20" height="20" rx="4" fill="white" fill-opacity="0.2"/>
              <path d="M5 8 L15 8 M5 12 L13 12" stroke="white" stroke-opacity="0.85" stroke-width="1.5" stroke-linecap="round"/>
            </g>
            <text x="46" y="22" fill="white" fill-opacity="0.85" font-size="11" font-weight="700" font-family="monospace">HERO HEADLINE</text>
            <text x="46" y="36" fill="white" fill-opacity="0.55" font-size="10" font-family="monospace">Fast Local Tech Repair</text>
          </g>
        </g>

        <!-- Card 2: Hours -->
        <g transform="translate(0, 80)">
          <g class="field-card fc-2">
            <rect width="220" height="48" rx="8" fill="white" fill-opacity="0.1" stroke="white" stroke-opacity="0.35" stroke-width="1.2"/>
            <g transform="translate(14, 14)">
              <rect width="20" height="20" rx="4" fill="white" fill-opacity="0.2"/>
              <circle cx="10" cy="10" r="6" stroke="white" stroke-opacity="0.85" stroke-width="1.5" fill="none"/>
              <path d="M10 6 L10 10 L13 12" stroke="white" stroke-opacity="0.85" stroke-width="1.5" stroke-linecap="round" fill="none"/>
            </g>
            <text x="46" y="22" fill="white" fill-opacity="0.85" font-size="11" font-weight="700" font-family="monospace">BUSINESS HOURS</text>
            <text x="46" y="36" fill="white" fill-opacity="0.55" font-size="10" font-family="monospace">Mon-Fri 9-5</text>
          </g>
        </g>

        <!-- Card 3: Phone -->
        <g transform="translate(0, 140)">
          <g class="field-card fc-3">
            <rect width="220" height="48" rx="8" fill="white" fill-opacity="0.1" stroke="white" stroke-opacity="0.35" stroke-width="1.2"/>
            <g transform="translate(14, 14)">
              <rect width="20" height="20" rx="4" fill="white" fill-opacity="0.2"/>
              <path d="M6 5 L9 5 L11 9 L9 11 C10 13 11 14 13 15 L15 13 L19 15 L19 18 C19 19 18 19 17 19 C12 19 5 12 5 7 C5 6 5 5 6 5 Z" stroke="white" stroke-opacity="0.85" stroke-width="1.2" fill="none"/>
            </g>
            <text x="46" y="22" fill="white" fill-opacity="0.85" font-size="11" font-weight="700" font-family="monospace">PHONE NUMBER</text>
            <text x="46" y="36" fill="white" fill-opacity="0.55" font-size="10" font-family="monospace">(802) 234-1552</text>
          </g>
        </g>

        <!-- Card 4: Pricing -->
        <g transform="translate(0, 200)">
          <g class="field-card fc-4">
            <rect width="220" height="48" rx="8" fill="white" fill-opacity="0.1" stroke="white" stroke-opacity="0.35" stroke-width="1.2"/>
            <g transform="translate(14, 14)">
              <rect width="20" height="20" rx="4" fill="white" fill-opacity="0.2"/>
              <line x1="10" y1="3" x2="10" y2="17" stroke="white" stroke-opacity="0.85" stroke-width="1.5"/>
              <path d="M14 6 L8 6 C7 6 6 7 6 8 C6 9 7 10 8 10 L12 10 C13 10 14 11 14 12 C14 13 13 14 12 14 L5 14" stroke="white" stroke-opacity="0.85" stroke-width="1.2" fill="none" stroke-linecap="round"/>
            </g>
            <text x="46" y="22" fill="white" fill-opacity="0.85" font-size="11" font-weight="700" font-family="monospace">PRICING TABLE</text>
            <text x="46" y="36" fill="white" fill-opacity="0.55" font-size="10" font-family="monospace">Starter · Pro · Premium</text>
          </g>
        </g>

        <!-- Card 5: Photo -->
        <g transform="translate(0, 260)">
          <g class="field-card fc-5">
            <rect width="220" height="48" rx="8" fill="white" fill-opacity="0.1" stroke="white" stroke-opacity="0.35" stroke-width="1.2"/>
            <g transform="translate(14, 14)">
              <rect width="20" height="20" rx="4" fill="white" fill-opacity="0.2"/>
              <rect x="3" y="5" width="14" height="10" rx="1" stroke="white" stroke-opacity="0.85" stroke-width="1.2" fill="none"/>
              <circle cx="7" cy="9" r="1" fill="white" fill-opacity="0.85"/>
              <path d="M3 13 L7 10 L12 13 L17 10" stroke="white" stroke-opacity="0.85" stroke-width="1.2" fill="none"/>
            </g>
            <text x="46" y="22" fill="white" fill-opacity="0.85" font-size="11" font-weight="700" font-family="monospace">HERO PHOTO</text>
            <text x="46" y="36" fill="white" fill-opacity="0.55" font-size="10" font-family="monospace">workshop.jpg</text>
          </g>
        </g>
      </g>

      <!-- Ambient floating dots -->
      <g class="ambient-dots">
        <circle cx="540" cy="100" r="2" fill="white" fill-opacity="0.25" class="float-dot d1"/>
        <circle cx="900" cy="80" r="2.5" fill="white" fill-opacity="0.3" class="float-dot d2"/>
        <circle cx="540" cy="430" r="2" fill="white" fill-opacity="0.25" class="float-dot d3"/>
        <circle cx="900" cy="450" r="2" fill="white" fill-opacity="0.3" class="float-dot d4"/>
      </g>

      <!-- Subtle grid -->
      <g stroke="white" stroke-opacity="0.04" stroke-width="1">
        <line x1="0" y1="130" x2="1440" y2="130"/>
        <line x1="0" y1="260" x2="1440" y2="260"/>
        <line x1="0" y1="390" x2="1440" y2="390"/>
        <line x1="360" y1="0" x2="360" y2="520"/>
        <line x1="720" y1="0" x2="720" y2="520"/>
        <line x1="1080" y1="0" x2="1080" y2="520"/>
      </g>
    </svg>

    <!-- MOBILE SVG -->
    <svg class="hero-bg-mobile" viewBox="0 0 400 600" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <defs>
        <linearGradient id="bgGradM" x1="0%" y1="0%" x2="100%" y2="100%">
          <stop offset="0%" style="stop-color:#1e3a8a;stop-opacity:1"/>
          <stop offset="100%" style="stop-color:#2563eb;stop-opacity:1"/>
        </linearGradient>
        <linearGradient id="glowGradM" x1="0%" y1="0%" x2="100%" y2="100%">
          <stop offset="0%" style="stop-color:#3b82f6;stop-opacity:0.3"/>
          <stop offset="100%" style="stop-color:#1d4ed8;stop-opacity:0"/>
        </linearGradient>
      </defs>
      <rect width="400" height="600" fill="url(#bgGradM)"/>
      <ellipse cx="100" cy="180" rx="220" ry="180" fill="url(#glowGradM)" class="glow-orb-1"/>
      <ellipse cx="320" cy="500" rx="220" ry="180" fill="url(#glowGradM)" class="glow-orb-2"/>

      <!-- TOP: Compact editor demo — y:60 to y:148 (just the active field, no button inside) -->
      <g class="editor-panel" transform="translate(50, 60)">
        <rect x="0" y="0" width="300" height="88" rx="8" fill="white" fill-opacity="0.08" stroke="white" stroke-opacity="0.4" stroke-width="1.2"/>
        <rect x="0" y="0" width="300" height="22" rx="8" fill="white" fill-opacity="0.06"/>
        <rect x="0" y="14" width="300" height="8" fill="white" fill-opacity="0.06"/>
        <circle cx="10" cy="11" r="2.5" fill="white" fill-opacity="0.35"/>
        <circle cx="19" cy="11" r="2.5" fill="white" fill-opacity="0.35"/>
        <circle cx="28" cy="11" r="2.5" fill="white" fill-opacity="0.35"/>
        <text x="150" y="14" text-anchor="middle" fill="white" fill-opacity="0.55" font-size="7" font-weight="600" font-family="monospace" letter-spacing="1.2">YOUR DASHBOARD</text>

        <text x="14" y="40" fill="white" fill-opacity="0.55" font-size="7" font-weight="700" font-family="monospace" letter-spacing="1.2">BUSINESS HOURS</text>
        <rect x="14" y="46" width="272" height="28" rx="5" fill="white" fill-opacity="0.1" stroke="white" stroke-opacity="0.4" stroke-width="1.2"/>
        <text x="22" y="64" fill="white" font-size="11" font-weight="600" font-family="monospace" class="typed-text">Mon-Fri 9-5</text>
        <rect x="22" y="52" width="1.2" height="14" fill="white" class="caret"/>
      </g>

      <!-- "Published" toast floating BELOW editor — y:155 -->
      <g class="publish-toast" transform="translate(120, 155)">
        <rect x="0" y="0" width="160" height="22" rx="11" fill="#10b981" fill-opacity="0.25" stroke="#34d399" stroke-opacity="0.8" stroke-width="1.2"/>
        <circle cx="14" cy="11" r="4" fill="#34d399"/>
        <path d="M11.5 11 L13.5 13 L16.5 9" stroke="white" stroke-width="1.2" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
        <text x="24" y="14" fill="white" fill-opacity="0.95" font-size="8" font-weight="700" font-family="monospace">Published — Live now</text>
      </g>

      <!-- Field stack removed on mobile — was overlapping with hero button.
           Mobile users see the editor demo + toast at top, and the full grid
           of editable fields lower in the page. -->

      <g stroke="white" stroke-opacity="0.04" stroke-width="1">
        <line x1="0" y1="150" x2="400" y2="150"/>
        <line x1="0" y1="300" x2="400" y2="300"/>
        <line x1="0" y1="450" x2="400" y2="450"/>
        <line x1="133" y1="0" x2="133" y2="600"/>
        <line x1="266" y1="0" x2="266" y2="600"/>
      </g>
    </svg>

    <!-- Hero text overlay -->
    <div id="hero-content">
      <p class="hero-label">Optional Add-On</p>
      <h1 id="hero-wordmark">Your Website. Your Dashboard.</h1>
      <p id="hero-tagline">Update your own website from any browser without touching a single line of code. Change your hours, swap a photo, update your prices — done in minutes from your phone, tablet or computer.</p>
      <a href="#what-section" id="hero-cta">
        See How It Works
        <svg style="height:1rem;width:1rem;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M12 5v14M5 12l7 7 7-7"/></svg>
      </a>
    </div>

    <div id="scroll-hint" aria-hidden="true" role="button" tabindex="-1" onclick="document.getElementById('what-section').scrollIntoView({behavior:'smooth'})">
      <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" style="height:1.5rem;width:1.5rem;"><path d="M12 5v14M5 12l7 7 7-7"/></svg>
    </div>
  </section>

  <!-- What Is It -->
  <section id="what-section" style="background:white;padding:5rem 1.5rem;">
    <div style="max-width:56rem;margin:0 auto;">
      <p style="font-size:0.875rem;font-weight:600;text-transform:uppercase;letter-spacing:0.1em;color:#2563eb;">What Is It?</p>
      <h2 style="font-size:2rem;font-weight:800;color:#111827;margin-top:0.5rem;margin-bottom:1.5rem;">A Private Dashboard Built Into Your Website</h2>
      <p style="color:#4b5563;font-size:1.05rem;line-height:1.85;margin-bottom:1rem;">When I build your website, every word and image is carefully crafted. But things change. Your hours shift, you add a new service, prices go up, you get a better photo. Without a dashboard, every one of those changes means contacting me and waiting.</p>
      <p style="color:#4b5563;font-size:1.05rem;line-height:1.85;margin-bottom:1rem;">With the Content Dashboard add-on, I build a private editing interface directly into your website. When your site is ready I send you a private login link that only you have. Log in securely with your account and you see a clean dashboard with every editable section of your site laid out in simple form fields.</p>
      <p style="color:#4b5563;font-size:1.05rem;line-height:1.85;">Change what you need, click Publish, and your website updates automatically — usually within about 60 seconds. No developer. No waiting. No extra charge for the update itself.</p>
    </div>
  </section>

  <!-- How It Works Steps -->
  <section style="background:#f8fafc;padding:4rem 1.5rem;">
    <div style="max-width:56rem;margin:0 auto;">
      <div style="text-align:center;margin-bottom:3rem;">
        <p style="font-size:0.875rem;font-weight:600;text-transform:uppercase;letter-spacing:0.1em;color:#2563eb;">How It Works</p>
        <h2 style="font-size:2rem;font-weight:800;color:#111827;margin-top:0.5rem;">Three Steps. No Tech Knowledge Required.</h2>
      </div>
      <div style="display:flex;flex-direction:column;gap:1.5rem;">
        <div style="background:white;border:1px solid #e5e7eb;border-radius:0.75rem;padding:1.5rem;display:flex;align-items:flex-start;gap:1.25rem;">
          <div style="display:flex;height:3rem;width:3rem;min-width:3rem;align-items:center;justify-content:center;border-radius:50%;background:#2563eb;color:white;font-size:1.25rem;font-weight:800;flex-shrink:0;">1</div>
          <div>
            <h3 style="font-size:1.05rem;font-weight:700;color:#111827;margin-bottom:0.375rem;">Open Your Private Login Link</h3>
            <p style="font-size:0.9rem;color:#4b5563;line-height:1.7;margin:0;">When your site launches I send you a private link to your dashboard. Bookmark it and use it any time from any device — phone, tablet or computer.</p>
          </div>
        </div>
        <div style="background:white;border:1px solid #e5e7eb;border-radius:0.75rem;padding:1.5rem;display:flex;align-items:flex-start;gap:1.25rem;">
          <div style="display:flex;height:3rem;width:3rem;min-width:3rem;align-items:center;justify-content:center;border-radius:50%;background:#2563eb;color:white;font-size:1.25rem;font-weight:800;flex-shrink:0;">2</div>
          <div>
            <h3 style="font-size:1.05rem;font-weight:700;color:#111827;margin-bottom:0.375rem;">Log In Securely</h3>
            <p style="font-size:0.9rem;color:#4b5563;line-height:1.7;margin:0;">Your dashboard is protected by secure authentication. Nobody else can access it. One click to log in and you're inside your website's editing interface.</p>
          </div>
        </div>
        <div style="background:white;border:1px solid #e5e7eb;border-radius:0.75rem;padding:1.5rem;display:flex;align-items:flex-start;gap:1.25rem;">
          <div style="display:flex;height:3rem;width:3rem;min-width:3rem;align-items:center;justify-content:center;border-radius:50%;background:#2563eb;color:white;font-size:1.25rem;font-weight:800;flex-shrink:0;">3</div>
          <div>
            <h3 style="font-size:1.05rem;font-weight:700;color:#111827;margin-bottom:0.375rem;">Make Changes & Publish</h3>
            <p style="font-size:0.9rem;color:#4b5563;line-height:1.7;margin:0;">Every editable section of your site appears as a simple text field or image uploader. Click the field, type your update, click Publish. Your website updates automatically in about 60 seconds.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- What You Can Edit -->
  <section style="background:white;padding:4rem 1.5rem;">
    <div style="max-width:56rem;margin:0 auto;">
      <div style="text-align:center;margin-bottom:3rem;">
        <p style="font-size:0.875rem;font-weight:600;text-transform:uppercase;letter-spacing:0.1em;color:#2563eb;">What You Can Change</p>
        <h2 style="font-size:2rem;font-weight:800;color:#111827;margin-top:0.5rem;">Edit Anything on Your Pages</h2>
        <p style="color:#6b7280;margin-top:0.75rem;max-width:38rem;margin-left:auto;margin-right:auto;line-height:1.75;">I define exactly which parts of your site are editable when I build it. Here's what's typically included.</p>
      </div>
      <div id="edit-grid">
        <div class="edit-card">
          <div class="edit-icon" aria-hidden="true">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
          </div>
          <div>
            <div style="font-size:0.9rem;font-weight:700;color:#111827;">All Text & Copy</div>
            <div style="font-size:0.8rem;color:#6b7280;margin-top:0.1rem;">Headlines, descriptions, paragraphs, button labels</div>
          </div>
        </div>
        <div class="edit-card">
          <div class="edit-icon" aria-hidden="true">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>
          </div>
          <div>
            <div style="font-size:0.9rem;font-weight:700;color:#111827;">Photos & Images</div>
            <div style="font-size:0.8rem;color:#6b7280;margin-top:0.1rem;">Upload new images directly from your device</div>
          </div>
        </div>
        <div class="edit-card">
          <div class="edit-icon" aria-hidden="true">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
          </div>
          <div>
            <div style="font-size:0.9rem;font-weight:700;color:#111827;">Prices & Services</div>
            <div style="font-size:0.8rem;color:#6b7280;margin-top:0.1rem;">Update pricing, add or edit service descriptions</div>
          </div>
        </div>
        <div class="edit-card">
          <div class="edit-icon" aria-hidden="true">
