<style>
  /* ===== HERO ===== */
  #hero-svg {
    position: relative;
    width: 100%;
    height: 72vh;
    min-height: 460px;
    max-height: 720px;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #1e3a8a;
  }
  .hero-bg-desktop, .hero-bg-mobile {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }
  .hero-bg-desktop { display: block; }
  .hero-bg-mobile  { display: none; }

  /* === EDITOR PANEL === */
  .editor-panel {
    opacity: 0;
    animation: panelFadeIn 0.6s ease 0.6s forwards;
  }
  @keyframes panelFadeIn { from { opacity: 0 } to { opacity: 1 } }

  /* Live-typing effect using clip-path:
     The text element has a max-width revealed via inset clip.
     We use width animation on text via stroke-dasharray trick
     OR simpler: just do a length-based reveal with animation.
     Best for SVG <text>: wrap in <clipPath>, OR use opacity per character... 
     Simplest reliable: animate the text's textLength + opacity stagger.
     For this we'll do a 2-phase typing: shows "Mon-Fri 9-5" for a beat,
     then erases (caret backspaces) and types "Mon-Sat 9-6". */
  .typed-text {
    /* CSS @keyframes can't actually animate textContent — we fake the effect
       by overlaying a clip rect that "wipes" across the text on a loop. */
    animation: textCycle 10s steps(24, end) infinite 1.4s;
  }
  @keyframes textCycle {
    /* No actual content change here, just opacity/visibility ticks for caret sync */
    0%, 100% { opacity: 1; }
  }

  /* Caret blink */
  .caret {
    animation: caretBlink 0.8s step-end infinite, caretMove 10s ease-in-out infinite 1.4s;
  }
  @keyframes caretBlink {
    0%, 50% { opacity: 1; }
    51%, 100% { opacity: 0; }
  }
  /* Move caret along the text width as if typing.
     The text "Mon-Fri 9-5" is roughly 88px wide at 13px monospace.
     The text starts at x:32 in field. End of text at ~x:120. */
  @keyframes caretMove {
    0%   { transform: translateX(0); }
    20%  { transform: translateX(88px); }   /* end of "Mon-Fri 9-5" */
    35%  { transform: translateX(88px); }   /* hold */
    45%  { transform: translateX(40px); }   /* "backspace" to "Mon-" */
    55%  { transform: translateX(40px); }
    70%  { transform: translateX(96px); }   /* re-type to "Mon-Sat 9-6" */
    85%  { transform: translateX(96px); }
    100% { transform: translateX(0); }      /* reset */
  }
  /* Mobile caret has shorter movement (smaller font) */
  .hero-bg-mobile .caret {
    animation: caretBlink 0.8s step-end infinite, caretMoveMob 10s ease-in-out infinite 1.4s;
  }
  @keyframes caretMoveMob {
    0%   { transform: translateX(0); }
    20%  { transform: translateX(72px); }
    35%  { transform: translateX(72px); }
    45%  { transform: translateX(32px); }
    55%  { transform: translateX(32px); }
    70%  { transform: translateX(80px); }
    85%  { transform: translateX(80px); }
    100% { transform: translateX(0); }
  }

  /* Publish button: visible most of the time, hides when toast shows */
  .publish-btn {
    animation: publishBtnCycle 10s ease-in-out infinite 1.4s;
    transform-origin: center;
  }
  @keyframes publishBtnCycle {
    0%, 22%   { opacity: 1; transform: scale(1); }
    25%       { opacity: 1; transform: scale(0.92); } /* "click" press */
    28%       { opacity: 0; transform: scale(0.85); }
    32%       { opacity: 0; }
    72%       { opacity: 0; }
    78%       { opacity: 1; transform: scale(1); }
    100%      { opacity: 1; transform: scale(1); }
  }

  /* Toast appears right after publish click, holds, then fades */
  .publish-toast {
    opacity: 0;
    animation: toastCycle 10s ease-in-out infinite 1.4s;
  }
  @keyframes toastCycle {
    0%, 28%  { opacity: 0; transform: translateY(8px); }
    32%      { opacity: 1; transform: translateY(0); }
    70%      { opacity: 1; transform: translateY(0); }
    74%      { opacity: 0; transform: translateY(-4px); }
    100%     { opacity: 0; }
  }

  /* === FIELD STACK === */
  .field-stack {
    opacity: 0;
    animation: panelFadeIn 0.6s ease 1s forwards;
  }
  /* Each card pops in staggered, then highlights one at a time on a slow loop */
  .field-card {
    opacity: 0;
    transform-origin: center;
  }
  .fc-1 { animation: cardPopIn 0.5s ease 1.2s forwards, cardHighlight 10s ease-in-out infinite 2s; }
  .fc-2 { animation: cardPopIn 0.5s ease 1.4s forwards, cardHighlight 10s ease-in-out infinite 4s; }
  .fc-3 { animation: cardPopIn 0.5s ease 1.6s forwards, cardHighlight 10s ease-in-out infinite 6s; }
  .fc-4 { animation: cardPopIn 0.5s ease 1.8s forwards, cardHighlight 10s ease-in-out infinite 8s; }
  .fc-5 { animation: cardPopIn 0.5s ease 2.0s forwards, cardHighlight 10s ease-in-out infinite 10s; }
  @keyframes cardPopIn {
    0%   { opacity: 0; }
    100% { opacity: 1; }
  }
  /* Highlight = brief brightness flash so it feels like it's "the active field" */
  @keyframes cardHighlight {
    0%, 100% { filter: brightness(1); }
    5%       { filter: brightness(1.4); }
    10%      { filter: brightness(1); }
  }

  /* === AMBIENT === */
  .float-dot { animation: dotFloat 4s ease-in-out infinite; }
  .float-dot.d1 { animation-delay: 0s; }
  .float-dot.d2 { animation-delay: 1s; }
  .float-dot.d3 { animation-delay: 2s; }
  .float-dot.d4 { animation-delay: 3s; }
  @keyframes dotFloat {
    0%, 100% { opacity: 0.2; }
