      .pos-1e { top:  72%; left: 12%; animation: drift-b 26s ease-in-out infinite; }
      .pos-1f { top:  85%; left: 84%; animation: drift-c 34s ease-in-out infinite; }

      .pos-2a { top:   8%; left: 22%; animation: drift-c 30s ease-in-out infinite; }
      .pos-2b { top:  20%; left: 70%; animation: drift-a 32s ease-in-out infinite; }
      .pos-2c { top:  38%; left:  6%; animation: drift-b 28s ease-in-out infinite; }
      .pos-2d { top:  55%; left: 88%; animation: drift-a 34s ease-in-out infinite; }
      .pos-2e { top:  72%; left: 36%; animation: drift-c 30s ease-in-out infinite; }
      .pos-2f { top:  88%; left: 76%; animation: drift-b 32s ease-in-out infinite; }

      .pos-3a { top:  12%; left: 80%; animation: drift-b 32s ease-in-out infinite; }
