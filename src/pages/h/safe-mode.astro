      .pos-3d { top:  60%; left: 24%; animation: drift-a 36s ease-in-out infinite; }
      .pos-3e { top:  78%; left: 72%; animation: drift-b 26s ease-in-out infinite; }
      .pos-3f { top:  90%; left:  8%; animation: drift-c 34s ease-in-out infinite; }

      .pos-4a { top:   6%; left: 44%; animation: drift-a 30s ease-in-out infinite; }
      .pos-4b { top:  22%; left: 84%; animation: drift-c 32s ease-in-out infinite; }
      .pos-4c { top:  38%; left: 18%; animation: drift-b 28s ease-in-out infinite; }
      .pos-4d { top:  54%; left: 66%; animation: drift-a 34s ease-in-out infinite; }
      .pos-4e { top:  74%; left: 32%; animation: drift-c 30s ease-in-out infinite; }
      .pos-4f { top:  88%; left: 80%; animation: drift-b 32s ease-in-out infinite; }

      .pos-5a { top:  10%; left: 14%; animation: drift-b 30s ease-in-out infinite; }
      .pos-5b { top:  18%; left: 76%; animation: drift-c 32s ease-in-out infinite; }
      .pos-5c { top:  38%; left:  6%; animation: drift-a 28s ease-in-out infinite; }
      .pos-5d { top:  42%; left: 88%; animation: drift-b 34s ease-in-out infinite; }
      .pos-5e { top:  76%; left: 22%; animation: drift-c 30s ease-in-out infinite; }
      .pos-5f { top:  84%; left: 72%; animation: drift-a 32s ease-in-out infinite; }

      @keyframes drift-a {
        0%, 100% { transform: translate(0, 0) rotate(0deg); }
        25%      { transform: translate(20px, -15px) rotate(8deg); }
        50%      { transform: translate(-10px, 20px) rotate(-6deg); }
        75%      { transform: translate(-25px, -10px) rotate(4deg); }
      }
      @keyframes drift-b {
        0%, 100% { transform: translate(0, 0) rotate(0deg); }
        33%      { transform: translate(-18px, 12px) rotate(-5deg); }
        66%      { transform: translate(15px, -22px) rotate(7deg); }
      }
      @keyframes drift-c {
        0%, 100% { transform: translate(0, 0) rotate(0deg); }
        20%      { transform: translate(12px, 18px) rotate(3deg); }
        50%      { transform: translate(22px, -12px) rotate(-8deg); }
        80%      { transform: translate(-15px, 15px) rotate(5deg); }
      }

      .milestone-content {
        position: relative;
        z-index: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1.5rem;
      }

      .typewriter {
        font-family: 'Inter Tight', system-ui, sans-serif;
        font-weight: 900;
        font-size: clamp(2rem, 7vw, 4.5rem);
        line-height: 1.1;
        letter-spacing: -0.02em;
        color: #ffffff;
        text-shadow: 0 2px 30px rgba(0, 0, 0, 0.3);
        max-width: 90vw;
        word-break: break-word;
        position: relative;
        min-height: 1.2em;
      }

      .typewriter::after {
        content: '|';
        display: inline-block;
        margin-left: 0.05em;
        font-weight: 400;
        color: rgba(255, 255, 255, 0.7);
        animation: caret-blink 1s steps(2) infinite;
      }

      .typewriter--done::after {
        animation: caret-blink 1s steps(2) infinite;
      }

      @keyframes caret-blink {
        0%, 50% { opacity: 1; }
        51%, 100% { opacity: 0; }
      }

      .scroll-arrow {
        margin-top: 1rem;
        width: 40px;
        height: 40px;
        color: rgba(255, 255, 255, 0.7);
        animation: scroll-bounce 1.8s ease-in-out infinite;
      }

      .scroll-arrow svg { width: 100%; height: 100%; }

      @keyframes scroll-bounce {
        0%, 100% { transform: translateY(0); opacity: 0.7; }
        50%      { transform: translateY(8px); opacity: 1; }
      }

      .start-btn {
        display: inline-flex;
        align-items: center;
        gap: 0.75rem;
        padding: 1.25rem 2.5rem;
        background: #ffffff;
        color: #1e3a8a;
        font-family: 'Inter Tight', system-ui, sans-serif;
        font-weight: 900;
        font-size: clamp(1rem, 3vw, 1.5rem);
        letter-spacing: 0.05em;
        text-decoration: none;
        border-radius: 0.75rem;
        box-shadow:
          0 0 0 0 rgba(255, 255, 255, 0.5),
          0 12px 40px rgba(0, 0, 0, 0.25);
        transition: transform 0.2s ease, box-shadow 0.2s ease;
        animation: cta-pulse 2.2s ease-in-out infinite;
      }

      .start-btn:hover,
      .start-btn:focus-visible {
        transform: translateY(-3px) scale(1.02);
        box-shadow:
          0 0 0 6px rgba(255, 255, 255, 0.25),
          0 16px 50px rgba(0, 0, 0, 0.35);
        outline: none;
        animation-play-state: paused;
      }

      .start-btn-arrow {
        width: 1.25em;
        height: 1.25em;
        transition: transform 0.2s ease;
      }

      .start-btn:hover .start-btn-arrow {
        transform: translateX(4px);
      }

      @keyframes cta-pulse {
        0%, 100% {
          box-shadow:
            0 0 0 0 rgba(255, 255, 255, 0.4),
            0 12px 40px rgba(0, 0, 0, 0.25);
        }
        50% {
          box-shadow:
            0 0 0 12px rgba(255, 255, 255, 0),
            0 14px 45px rgba(0, 0, 0, 0.3);
        }
      }

      .cta-sub {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.875rem;
        font-weight: 400;
        color: rgba(255, 255, 255, 0.6);
        letter-spacing: 0.1em;
        text-transform: uppercase;
      }

      @media (prefers-reduced-motion: reduce) {
        .floater { animation: none; }
        .scroll-arrow { animation: none; }
        .start-btn { animation: none; }
        .typewriter::after { animation: none; opacity: 0.6; }
      }

      @media (max-width: 768px) {
        .floater { width: 40px; height: 40px; }
      }
    </style>
  </body>
</html>