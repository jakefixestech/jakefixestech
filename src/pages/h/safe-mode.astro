        -moz-osx-font-smoothing: grayscale;
      }

      .page { position: relative; min-height: 100vh; }

      /* Visually-hidden utility — keeps text accessible to screen readers
         and accessibility tools (like WAVE) without showing it on screen */
      .sr-only {
        position: absolute;
        width: 1px;
        height: 1px;
        padding: 0;
        margin: -1px;
        overflow: hidden;
        clip: rect(0, 0, 0, 0);
        white-space: nowrap;
        border: 0;
      }

      .milestone {
        position: relative;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 2rem 1.5rem;
        text-align: center;
        overflow: hidden;
      }

      .floaters {
        position: absolute;
        inset: 0;
        pointer-events: none;
        z-index: 0;
      }

      .floater {
