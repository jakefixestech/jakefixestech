    </noscript>
  </head>

  <body data-pagefind-ignore>
    <main class="page">
      <h1 class="sr-only">Scavenger Hunt — Clue Four</h1>

      <!-- ============================================ -->
      <!-- Floating ambient SVG icons                   -->
      <!-- ============================================ -->
      <div class="floaters" aria-hidden="true">
        <svg class="floater pos-a" viewBox="0 0 40 40" xmlns="http://www.w3.org/2000/svg">
          <rect x="6" y="10" width="28" height="22" rx="2" fill="none" stroke="currentColor" stroke-width="2" />
          <path d="M 6 14 L 14 14 L 16 10 L 26 10" fill="none" stroke="currentColor" stroke-width="2" stroke-linejoin="round" />
        </svg>
        <svg class="floater pos-b" viewBox="0 0 40 40" xmlns="http://www.w3.org/2000/svg">
          <rect x="8" y="6" width="20" height="28" rx="2" fill="none" stroke="currentColor" stroke-width="2" />
          <line x1="13" y1="14" x2="23" y2="14" stroke="currentColor" stroke-width="1.5" />
          <line x1="13" y1="20" x2="23" y2="20" stroke="currentColor" stroke-width="1.5" />
          <line x1="13" y1="26" x2="20" y2="26" stroke="currentColor" stroke-width="1.5" />
        </svg>
        <svg class="floater pos-c" viewBox="0 0 40 40" xmlns="http://www.w3.org/2000/svg">
          <circle cx="14" cy="20" r="6" fill="none" stroke="currentColor" stroke-width="2" />
          <line x1="20" y1="20" x2="34" y2="20" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
          <line x1="28" y1="20" x2="28" y2="25" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
          <line x1="32" y1="20" x2="32" y2="24" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
        </svg>
        <svg class="floater pos-d" viewBox="0 0 40 40" xmlns="http://www.w3.org/2000/svg">
          <path d="M 14 8 L 6 20 L 14 32" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" />
          <path d="M 26 8 L 34 20 L 26 32" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" />
          <line x1="22" y1="8" x2="18" y2="32" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" />
        </svg>
        <svg class="floater pos-e" viewBox="0 0 40 40" xmlns="http://www.w3.org/2000/svg">
