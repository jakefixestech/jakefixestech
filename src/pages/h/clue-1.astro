    <script>
      // @ts-nocheck

      const lines = [
        { text: '> initializing scavenger.exe ...',     class: 't-dim',   delay: 300 },
        { text: '> connection established. welcome.',   class: 't-ok',    delay: 1400 },
        { text: '',                                     class: 't-blank', delay: 2400 },
        { text: 'So you actually scrolled down. Respect.',          class: 't-line', delay: 2700 },
        { text: 'Most people would have given up by now.',          class: 't-line', delay: 4000 },
        { text: '',                                     class: 't-blank', delay: 5400 },
        { text: '⚙ loading first clue ...',             class: 't-dim',   delay: 5700 },
        { text: '✓ first clue ready',                   class: 't-ok',    delay: 7000 },
        { text: '',                                     class: 't-blank', delay: 7800 },
        { text: 'You\u2019ve made it past the door, no question why,', class: 't-rhyme', delay: 8100 },
        { text: 'the next clue waits, but it\u2019s a little shy.',     class: 't-rhyme', delay: 10500 },
        { text: 'No URL to type, no link to chase \u2014',              class: 't-rhyme', delay: 13000 },
        { text: 'a search bar holds the secret place.',                 class: 't-rhyme', delay: 15400 },
        { text: 'Run the command shown below this line,',               class: 't-rhyme', delay: 17800 },
        { text: 'then type "let\u2019s go" and you\u2019ll be fine.',   class: 't-rhyme', delay: 20200 },
        { text: '',                                     class: 't-blank', delay: 22600 },
        { text: '> SEARCH BAR PHRASE: "let\u2019s go"', class: 't-prompt', delay: 22900 },
      ];

      const output = document.getElementById('terminal-output');
      const cursor = document.getElementById('terminal-cursor');
      const proceedLink = document.getElementById('proceed-link');
      const CHAR_SPEED = 35;

      // === Reveal the command chip (called multiple times safely) ===
      let chipRevealed = false;
      function revealChip() {
        if (chipRevealed) return;
        chipRevealed = true;
        if (cursor) cursor.style.display = 'none';
        // Wait one animation frame so the browser has a paint cycle
        // ready before we toggle the visibility class
        requestAnimationFrame(() => {
          proceedLink.classList.add('cmd-chip--visible');
        });
      }

      function typeLine(text, className, onDone) {
        const line = document.createElement('div');
        line.className = className;

        if (className === 't-blank') {
          line.style.height = '0.6rem';
          output.appendChild(line);
          if (onDone) onDone();
          return;
        }

        output.appendChild(line);

        let i = 0;
        function typeChar() {
          if (i < text.length) {
            line.textContent += text[i];
            i++;
            setTimeout(typeChar, CHAR_SPEED);
          } else {
            if (onDone) onDone();
          }
        }
        typeChar();
      }

      function runTerminal() {
        lines.forEach((line, index) => {
          setTimeout(() => {
            typeLine(line.text, line.class, () => {
              if (index === lines.length - 1) {
                // After last line types, reveal the chip after a small pause
                setTimeout(revealChip, 700);
              }
            });
          }, line.delay);
        });

        // === Safety net: regardless of timing/throttling, force-reveal the chip
        // 28 seconds after the script starts. This guarantees the chip will
        // appear no matter what — protects against tab throttling, JS errors,
        // or any future timing issue.
        setTimeout(revealChip, 28000);
      }

      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        // Reduced motion: dump all lines instantly + show chip immediately
        lines.forEach((line) => {
          const el = document.createElement('div');
          el.className = line.class;
          if (line.class === 't-blank') {
            el.style.height = '0.6rem';
          } else {
            el.textContent = line.text;
          }
          output.appendChild(el);
        });
        cursor.style.display = 'none';
        revealChip();
      } else {
        setTimeout(runTerminal, 200);
      }
    </script>

    <style>
      *, *::before, *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      html { scroll-behavior: smooth; }
      @media (prefers-reduced-motion: reduce) { html { scroll-behavior: auto; } }

      body {
        background: linear-gradient(135deg, #1e3a8a 0%, #2563eb 100%);
        color: #ffffff;
        font-family: 'Inter Tight', system-ui, -apple-system, sans-serif;
        min-height: 100vh;
        overflow-x: hidden;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
      }

      .page { position: relative; min-height: 100vh; }

      /* Visually hidden h1 for SEO/a11y heading structure */
      .sr-only {
        position: absolute;
        width: 1px; height: 1px;
        padding: 0; margin: -1px;
        overflow: hidden;
        clip: rect(0, 0, 0, 0);
        white-space: nowrap;
        border: 0;
      }

      /* ============================================================ */
      /* Ambient floaters                                              */
      /* ============================================================ */
      .floaters {
        position: fixed;
        inset: 0;
        pointer-events: none;
        z-index: 0;
        overflow: hidden;
      }

      .floater {
        position: absolute;
        width: 56px;
        height: 56px;
        color: rgba(255, 255, 255, 0.10);
        will-change: transform;
      }

      .pos-a { top:  6%; left:  8%; animation: drift-a 28s ease-in-out infinite; }
      .pos-b { top: 14%; left: 78%; animation: drift-b 32s ease-in-out infinite; }
      .pos-c { top: 22%; left: 18%; animation: drift-c 30s ease-in-out infinite; }
      .pos-d { top: 28%; left: 88%; animation: drift-a 36s ease-in-out infinite; }
      .pos-e { top: 42%; left:  6%; animation: drift-b 26s ease-in-out infinite; }
      .pos-f { top: 50%; left: 92%; animation: drift-c 34s ease-in-out infinite; }
      .pos-g { top: 62%; left: 14%; animation: drift-a 30s ease-in-out infinite; }
      .pos-h { top: 70%; left: 82%; animation: drift-b 32s ease-in-out infinite; }
      .pos-i { top: 80%; left:  8%; animation: drift-c 28s ease-in-out infinite; }
      .pos-j { top: 88%; left: 76%; animation: drift-a 30s ease-in-out infinite; }
      .pos-k { top: 36%; left: 50%; animation: drift-b 38s ease-in-out infinite; }
      .pos-l { top: 92%; left: 44%; animation: drift-c 32s ease-in-out infinite; }

      @keyframes drift-a {
        0%, 100% { transform: translate(0, 0) rotate(0deg); }
        25%      { transform: translate(20px, -15px) rotate(8deg); }
        50%      { transform: translate(-10px, 20px) rotate(-6deg); }
        75%      { transform: translate(-25px, -10px) rotate(4deg); }
      }
      @keyframes drift-b {
        0%, 100% { transform: translate(0, 0) rotate(0deg); }
        33%      { transform: translate(-18px, 12px) rotate(-5deg); }
        66%      { transform: translate(15px, -22px) rotate(7deg); }
      }
      @keyframes drift-c {
        0%, 100% { transform: translate(0, 0) rotate(0deg); }
        20%      { transform: translate(12px, 18px) rotate(3deg); }
        50%      { transform: translate(22px, -12px) rotate(-8deg); }
        80%      { transform: translate(-15px, 15px) rotate(5deg); }
      }

      /* ============================================================ */
      /* Terminal section                                              */
      /* ============================================================ */
      .terminal-section {
        position: relative;
        z-index: 1;
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 5rem 1.5rem;
      }

      .terminal-wrap {
        width: 100%;
        max-width: 56rem;
        background: #0a0e1a;
        border: 1px solid rgba(96, 165, 250, 0.4);
        border-radius: 0.875rem;
        overflow: hidden;
        box-shadow:
          0 0 0 1px rgba(96, 165, 250, 0.15),
          0 0 40px rgba(96, 165, 250, 0.35),
          0 0 90px rgba(37, 99, 235, 0.4),
          0 25px 60px rgba(0, 0, 0, 0.4);
        animation: terminal-glow 3.5s ease-in-out infinite;
      }

      @keyframes terminal-glow {
        0%, 100% {
          box-shadow:
            0 0 0 1px rgba(96, 165, 250, 0.15),
            0 0 40px rgba(96, 165, 250, 0.35),
            0 0 90px rgba(37, 99, 235, 0.4),
            0 25px 60px rgba(0, 0, 0, 0.4);
        }
        50% {
          box-shadow:
            0 0 0 1px rgba(96, 165, 250, 0.3),
            0 0 60px rgba(96, 165, 250, 0.5),
            0 0 120px rgba(37, 99, 235, 0.55),
            0 25px 60px rgba(0, 0, 0, 0.4);
        }
      }

      .terminal-header {
        background: #11172a;
        border-bottom: 1px solid rgba(96, 165, 250, 0.2);
        padding: 0.625rem 1rem;
        display: flex;
        align-items: center;
        gap: 1rem;
      }

      .terminal-dots { display: flex; gap: 0.4rem; }

      .dot {
        width: 0.7rem;
        height: 0.7rem;
        border-radius: 50%;
        display: inline-block;
      }

      .dot-red    { background: #ef4444; }
      .dot-yellow { background: #f59e0b; }
      .dot-green  { background: #10b981; }

      .terminal-title {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.8rem;
        color: rgba(255, 255, 255, 0.55);
        letter-spacing: 0.02em;
      }

      .terminal-body {
        padding: 1.75rem 1.75rem 2rem 1.75rem;
        font-family: 'JetBrains Mono', monospace;
        font-size: 1rem;
        line-height: 1.85;
        color: #e5e7eb;
        min-height: 28rem;
      }

      #terminal-output .t-dim    { color: #94a3b8; }
      #terminal-output .t-ok     { color: #4ade80; }
      #terminal-output .t-line   { color: #f8fafc; }
      #terminal-output .t-rhyme  { color: #93c5fd; font-style: italic; }
      #terminal-output .t-prompt { color: #fbbf24; font-weight: 700; margin-top: 0.4rem; }

      /* ============================================================ */
      /* Cursor — animates COLOR (not opacity) so WAVE can't false-flag */
      /* ============================================================ */
      .cursor {
        display: inline-block;
        font-family: 'JetBrains Mono', monospace;
        font-size: 1rem;
        vertical-align: baseline;
        color: #60a5fa;
        animation: cursor-color-blink 0.8s steps(2) infinite;
      }

      @keyframes cursor-color-blink {
        0%, 49%   { color: #60a5fa; }
        50%, 100% { color: #0a0e1a; } /* same as terminal bg → invisible but opaque */
      }

      /* ============================================================ */
      /* The command chip                                              */
      /* CHANGED: uses inline-flex + opacity/visibility for reliable   */
      /* reveal across browsers. (The old display:none → display:flex */
      /* swap was causing browser repaint issues that required a click */
      /* to "unstick".)                                                */
      /* ============================================================ */
      .cmd-chip {
        display: inline-flex;
        align-items: center;
        gap: 0.65rem;
        margin-top: 1.75rem;
        padding: 0.875rem 1.25rem;
        background: linear-gradient(135deg, rgba(96, 165, 250, 0.15), rgba(37, 99, 235, 0.12));
        border: 1px solid rgba(96, 165, 250, 0.5);
        border-radius: 0.5rem;
        font-family: 'JetBrains Mono', monospace;
        font-size: 1rem;
        font-weight: 600;
        color: #93c5fd;
        text-decoration: none;
        cursor: pointer;
        transition: all 0.2s ease;
        width: fit-content;
        box-shadow:
          0 0 20px rgba(96, 165, 250, 0.15),
          inset 0 1px 0 rgba(255, 255, 255, 0.05);

        /* Hidden by default — visible-but-invisible (browser still lays it out, just doesn't paint) */
        opacity: 0;
        visibility: hidden;
        transform: translateY(8px);
        pointer-events: none;
      }

      .cmd-chip--visible {
        opacity: 1;
        visibility: visible;
        transform: translateY(0);
        pointer-events: auto;
        transition:
          opacity 0.5s ease,
          visibility 0s linear 0s,
          transform 0.5s ease;
        animation: chip-pulse 2.4s ease-in-out 0.6s infinite;
      }

      .cmd-chip:hover,
      .cmd-chip:focus-visible {
        background: linear-gradient(135deg, rgba(96, 165, 250, 0.3), rgba(37, 99, 235, 0.25));
        border-color: rgba(147, 197, 253, 0.9);
        color: #ffffff;
        outline: none;
        transform: translateX(3px);
        animation-play-state: paused;
        box-shadow:
          0 0 35px rgba(96, 165, 250, 0.45),
          inset 0 1px 0 rgba(255, 255, 255, 0.1);
      }

      .cmd-prefix {
        color: #4ade80;
        font-weight: 700;
      }

      .cmd-text {
        letter-spacing: 0.02em;
      }

      .cmd-arrow {
        margin-left: 0.25rem;
        font-size: 1.1em;
        transition: transform 0.2s ease;
      }

      .cmd-chip:hover .cmd-arrow {
        transform: translateX(2px);
      }

      @keyframes chip-pulse {
        0%, 100% {
          box-shadow:
            0 0 20px rgba(96, 165, 250, 0.15),
            inset 0 1px 0 rgba(255, 255, 255, 0.05);
        }
        50% {
          box-shadow:
            0 0 35px rgba(96, 165, 250, 0.4),
            inset 0 1px 0 rgba(255, 255, 255, 0.1);
        }
      }

      /* ============================================================ */
      /* Mobile                                                        */
      /* ============================================================ */
      @media (max-width: 768px) {
        .floater {
          width: 38px;
          height: 38px;
        }

        .terminal-section {
          padding: 3rem 1rem;
        }

        .terminal-body {
          padding: 1.25rem 1rem 1.5rem 1rem;
          font-size: 0.85rem;
          line-height: 1.7;
          min-height: 24rem;
        }

        .terminal-title {
          font-size: 0.7rem;
        }

        .cmd-chip {
          font-size: 0.85rem;
          padding: 0.75rem 1rem;
          margin-top: 1.5rem;
        }
      }

      /* ============================================================ */
      /* Reduced motion                                                */
      /* ============================================================ */
      @media (prefers-reduced-motion: reduce) {
        .floater { animation: none; }
        .terminal-wrap { animation: none; }
        .cursor { animation: none; color: #60a5fa; }
        .cmd-chip--visible {
          animation: none;
          transition: opacity 0.2s ease;
        }
      }
    </style>
  </body>
</html>