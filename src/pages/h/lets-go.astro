---
// /h/lets-go.astro
// Place at: src/pages/h/lets-go.astro
//
// The minigame clue! Whack-a-virus on a 3x3 grid.
// Score 10 in 30 seconds to unlock the next clue page (/h/clue-4).
//
// Custom SVG virus characters with eyes, teeth, and personality.
// Vanilla JS, no libraries. Mobile + desktop + curved screens all supported.
//
// noindex/nofollow.
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <title>...</title>
    <meta name="description" content="" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Inter+Tight:wght@400;600;800;900&family=JetBrains+Mono:wght@400;500;600;700&display=optional"
    />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter+Tight:wght@400;600;800;900&family=JetBrains+Mono:wght@400;500;600;700&display=optional"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link
        rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Inter+Tight:wght@400;600;800;900&family=JetBrains+Mono:wght@400;500;600;700&display=swap"
      />
    </noscript>
  </head>

  <body data-pagefind-ignore>
    <main class="page">
      <h1 class="sr-only">Scavenger Hunt — Whack-a-Virus Minigame</h1>

      <!-- ============================================ -->
      <!-- Floating ambient SVG icons                   -->
      <!-- ============================================ -->
      <div class="floaters" aria-hidden="true">
        <svg class="floater pos-a" viewBox="0 0 40 40" xmlns="http://www.w3.org/2000/svg">
          <circle cx="16" cy="16" r="9" fill="none" stroke="currentColor" stroke-width="2" />
          <line x1="23" y1="23" x2="33" y2="33" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" />
        </svg>
        <svg class="floater pos-b" viewBox="0 0 40 40" xmlns="http://www.w3.org/2000/svg">
          <rect x="10" y="18" width="20" height="16" rx="2" fill="none" stroke="currentColor" stroke-width="2" />
          <path d="M 14 18 V 13 a 6 6 0 0 1 12 0 V 18" fill="none" stroke="currentColor" stroke-width="2" />
          <circle cx="20" cy="25" r="1.5" fill="currentColor" />
        </svg>
        <svg class="floater pos-c" viewBox="0 0 40 40" xmlns="http://www.w3.org/2000/svg">
          <circle cx="14" cy="20" r="6" fill="none" stroke="currentColor" stroke-width="2" />
          <line x1="20" y1="20" x2="34" y2="20" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
          <line x1="28" y1="20" x2="28" y2="25" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
          <line x1="32" y1="20" x2="32" y2="24" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
        </svg>
        <svg class="floater pos-d" viewBox="0 0 40 40" xmlns="http://www.w3.org/2000/svg">
          <path d="M 14 8 L 6 20 L 14 32" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" />
          <path d="M 26 8 L 34 20 L 26 32" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" />
          <line x1="22" y1="8" x2="18" y2="32" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" />
        </svg>
        <svg class="floater pos-e" viewBox="0 0 40 40" xmlns="http://www.w3.org/2000/svg">
          <path d="M 4 20 Q 20 8 36 20 Q 20 32 4 20 Z" fill="none" stroke="currentColor" stroke-width="2" stroke-linejoin="round" />
          <circle cx="20" cy="20" r="4" fill="currentColor" />
        </svg>
        <svg class="floater pos-f" viewBox="0 0 40 40" xmlns="http://www.w3.org/2000/svg">
          <path d="M 12 14 Q 12 6 20 6 Q 28 6 28 14 Q 28 19 22 22 Q 20 23 20 28 M 20 33 L 20 35" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
        <svg class="floater pos-g" viewBox="0 0 40 40" xmlns="http://www.w3.org/2000/svg">
          <text x="6" y="26" font-family="JetBrains Mono, monospace" font-size="20" font-weight="700" fill="currentColor">&gt;_</text>
        </svg>
        <svg class="floater pos-h" viewBox="0 0 40 40" xmlns="http://www.w3.org/2000/svg">
          <path d="M 20 6 Q 12 6 12 16 Q 12 22 16 25 L 16 30 L 24 30 L 24 25 Q 28 22 28 16 Q 28 6 20 6 Z" fill="none" stroke="currentColor" stroke-width="2" stroke-linejoin="round" />
          <line x1="16" y1="33" x2="24" y2="33" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
          <line x1="17" y1="36" x2="23" y2="36" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
        </svg>
        <svg class="floater pos-i" viewBox="0 0 40 40" xmlns="http://www.w3.org/2000/svg">
          <circle cx="20" cy="20" r="14" fill="none" stroke="currentColor" stroke-width="2" />
          <path d="M 20 10 L 23 20 L 20 30 L 17 20 Z" fill="currentColor" opacity="0.6" />
          <circle cx="20" cy="20" r="1.5" fill="currentColor" />
        </svg>
        <svg class="floater pos-j" viewBox="0 0 40 40" xmlns="http://www.w3.org/2000/svg">
          <path d="M 20 5 L 22 9 L 26 8 L 27 12 L 31 13 L 30 17 L 34 19 L 33 23 L 35 27 L 31 28 L 30 32 L 26 31 L 24 35 L 20 33 L 16 35 L 14 31 L 10 32 L 9 28 L 5 27 L 7 23 L 6 19 L 10 17 L 9 13 L 13 12 L 14 8 L 18 9 Z" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round" />
          <circle cx="20" cy="20" r="4" fill="none" stroke="currentColor" stroke-width="1.5" />
        </svg>
      </div>

      <!-- ============================================ -->
      <!-- The game container                           -->
      <!-- ============================================ -->
      <section class="game-section">
        <div class="game-wrap">
          <!-- Header (terminal-style title bar) -->
          <div class="game-header" aria-hidden="true">
            <div class="game-dots">
              <span class="dot dot-red"></span>
              <span class="dot dot-yellow"></span>
              <span class="dot dot-green"></span>
            </div>
            <div class="game-title">jake@hunt: ~/whack-a-virus</div>
          </div>

          <!-- Body — switches between three states: intro / playing / result -->
          <div class="game-body">

            <!-- INTRO STATE -->
            <div id="state-intro" class="state state--active">
              <div class="intro-icon" aria-hidden="true">
                <svg viewBox="0 0 80 80" xmlns="http://www.w3.org/2000/svg">
                  <ellipse cx="40" cy="44" rx="20" ry="24" fill="#ef4444" />
                  <line x1="40" y1="20" x2="40" y2="44" stroke="#ef4444" stroke-width="3" stroke-linecap="round" />
                  <line x1="10" y1="28" x2="22" y2="36" stroke="#ef4444" stroke-width="3" stroke-linecap="round" />
                  <line x1="70" y1="28" x2="58" y2="36" stroke="#ef4444" stroke-width="3" stroke-linecap="round" />
                  <line x1="6" y1="46" x2="20" y2="46" stroke="#ef4444" stroke-width="3" stroke-linecap="round" />
                  <line x1="74" y1="46" x2="60" y2="46" stroke="#ef4444" stroke-width="3" stroke-linecap="round" />
                  <line x1="10" y1="64" x2="22" y2="56" stroke="#ef4444" stroke-width="3" stroke-linecap="round" />
                  <line x1="70" y1="64" x2="58" y2="56" stroke="#ef4444" stroke-width="3" stroke-linecap="round" />
                  <circle cx="33" cy="40" r="3" fill="#fff" />
                  <circle cx="47" cy="40" r="3" fill="#fff" />
                  <circle cx="33" cy="40" r="1.5" fill="#000" />
                  <circle cx="47" cy="40" r="1.5" fill="#000" />
                  <path d="M 30 54 L 33 50 L 36 54 L 39 50 L 42 54 L 45 50 L 48 54" fill="none" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              </div>

              <h2 class="intro-title">Your tech got infected.</h2>
              <p class="intro-text">
                Smash <strong>20 viruses</strong> in <strong>30 seconds</strong> to clean the system and unlock the next clue.
              </p>
              <p class="intro-hint">
                Tap or click each virus before it disappears. Don't let them spread.
              </p>

              <button id="start-btn" class="primary-btn" type="button">
                <span>RUN ANTIVIRUS</span>
                <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                  <path d="M 5 12 L 19 12 M 13 6 L 19 12 L 13 18" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              </button>
            </div>

            <!-- PLAYING STATE -->
            <div id="state-playing" class="state">
              <!-- HUD -->
              <div class="hud">
                <div class="hud-item">
                  <span class="hud-label">SCORE</span>
                  <span class="hud-value" id="score-display" aria-live="polite" aria-atomic="true">0</span>
                </div>
                <div class="hud-item hud-timer-wrap">
                  <span class="hud-label">TIME</span>
                  <span class="hud-value" id="timer-display">30</span>
                  <div class="timer-bar" aria-hidden="true">
                    <div class="timer-fill" id="timer-fill"></div>
                  </div>
                </div>
                <div class="hud-item">
                  <span class="hud-label">GOAL</span>
                  <span class="hud-value">20</span>
                </div>
              </div>

              <!-- The 3x3 grid -->
              <div class="grid" role="application" aria-label="Whack-a-virus game grid. Click on viruses to remove them.">
                <button type="button" class="cell" data-cell="0" aria-label="Cell 1"></button>
                <button type="button" class="cell" data-cell="1" aria-label="Cell 2"></button>
                <button type="button" class="cell" data-cell="2" aria-label="Cell 3"></button>
                <button type="button" class="cell" data-cell="3" aria-label="Cell 4"></button>
                <button type="button" class="cell" data-cell="4" aria-label="Cell 5"></button>
                <button type="button" class="cell" data-cell="5" aria-label="Cell 6"></button>
                <button type="button" class="cell" data-cell="6" aria-label="Cell 7"></button>
                <button type="button" class="cell" data-cell="7" aria-label="Cell 8"></button>
                <button type="button" class="cell" data-cell="8" aria-label="Cell 9"></button>
              </div>

              <p class="play-hint" aria-hidden="true">Tap viruses fast. Score 20 to win.</p>
            </div>

            <!-- RESULT STATE (win OR lose) -->
            <div id="state-result" class="state">
              <div id="result-content"></div>
            </div>

          </div>
        </div>
      </section>
    </main>

    <!-- ============================================ -->
    <!-- VIRUS SVG TEMPLATE                           -->
    <!-- Used as a JS template, hidden from layout    -->
    <!-- Three virus variants for personality variety -->
    <!-- ============================================ -->
    <template id="virus-template-1">
      <svg class="virus virus-1" viewBox="0 0 80 80" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <ellipse cx="40" cy="44" rx="22" ry="26" fill="#ef4444" />
        <ellipse cx="40" cy="40" rx="20" ry="22" fill="#dc2626" />
        <line x1="40" y1="14" x2="40" y2="22" stroke="#dc2626" stroke-width="4" stroke-linecap="round" />
        <circle cx="40" cy="11" r="3" fill="#dc2626" />
        <line x1="6" y1="22" x2="20" y2="32" stroke="#dc2626" stroke-width="3" stroke-linecap="round" />
        <circle cx="6" cy="22" r="2.5" fill="#dc2626" />
        <line x1="74" y1="22" x2="60" y2="32" stroke="#dc2626" stroke-width="3" stroke-linecap="round" />
        <circle cx="74" cy="22" r="2.5" fill="#dc2626" />
        <line x1="2" y1="44" x2="18" y2="44" stroke="#dc2626" stroke-width="3" stroke-linecap="round" />
        <circle cx="2" cy="44" r="2.5" fill="#dc2626" />
        <line x1="78" y1="44" x2="62" y2="44" stroke="#dc2626" stroke-width="3" stroke-linecap="round" />
        <circle cx="78" cy="44" r="2.5" fill="#dc2626" />
        <line x1="6" y1="66" x2="20" y2="56" stroke="#dc2626" stroke-width="3" stroke-linecap="round" />
        <circle cx="6" cy="66" r="2.5" fill="#dc2626" />
        <line x1="74" y1="66" x2="60" y2="56" stroke="#dc2626" stroke-width="3" stroke-linecap="round" />
        <circle cx="74" cy="66" r="2.5" fill="#dc2626" />
        <ellipse cx="32" cy="38" rx="5" ry="6" fill="#fff" />
        <ellipse cx="48" cy="38" rx="5" ry="6" fill="#fff" />
        <circle cx="32" cy="40" r="2.5" fill="#000" />
        <circle cx="48" cy="40" r="2.5" fill="#000" />
        <circle cx="33" cy="38" r="0.8" fill="#fff" />
        <circle cx="49" cy="38" r="0.8" fill="#fff" />
        <path d="M 28 54 L 31 50 L 34 54 L 37 50 L 40 54 L 43 50 L 46 54 L 49 50 L 52 54" fill="none" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
    </template>

    <template id="virus-template-2">
      <svg class="virus virus-2" viewBox="0 0 80 80" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <circle cx="40" cy="40" r="26" fill="#a855f7" />
        <circle cx="40" cy="40" r="23" fill="#9333ea" />
        <line x1="40" y1="8" x2="40" y2="17" stroke="#9333ea" stroke-width="3.5" stroke-linecap="round" />
        <line x1="14" y1="14" x2="20" y2="22" stroke="#9333ea" stroke-width="3.5" stroke-linecap="round" />
        <line x1="66" y1="14" x2="60" y2="22" stroke="#9333ea" stroke-width="3.5" stroke-linecap="round" />
        <line x1="6" y1="40" x2="14" y2="40" stroke="#9333ea" stroke-width="3.5" stroke-linecap="round" />
        <line x1="74" y1="40" x2="66" y2="40" stroke="#9333ea" stroke-width="3.5" stroke-linecap="round" />
        <line x1="14" y1="66" x2="20" y2="58" stroke="#9333ea" stroke-width="3.5" stroke-linecap="round" />
        <line x1="66" y1="66" x2="60" y2="58" stroke="#9333ea" stroke-width="3.5" stroke-linecap="round" />
        <line x1="40" y1="72" x2="40" y2="64" stroke="#9333ea" stroke-width="3.5" stroke-linecap="round" />
        <ellipse cx="30" cy="36" rx="6" ry="7" fill="#fff" />
        <ellipse cx="50" cy="36" rx="6" ry="7" fill="#fff" />
        <circle cx="30" cy="38" r="3" fill="#000" />
        <circle cx="50" cy="38" r="3" fill="#000" />
        <path d="M 26 52 Q 40 60 54 52" fill="none" stroke="#fff" stroke-width="2.5" stroke-linecap="round" />
        <path d="M 30 52 L 30 56 M 35 53 L 35 57 M 40 54 L 40 58 M 45 53 L 45 57 M 50 52 L 50 56" stroke="#fff" stroke-width="1.5" stroke-linecap="round" />
      </svg>
    </template>

    <template id="virus-template-3">
      <svg class="virus virus-3" viewBox="0 0 80 80" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <path d="M 40 14 L 60 22 L 64 44 L 56 64 L 40 70 L 24 64 L 16 44 L 20 22 Z" fill="#f59e0b" />
        <path d="M 40 18 L 56 24 L 60 44 L 53 60 L 40 65 L 27 60 L 20 44 L 24 24 Z" fill="#d97706" />
        <line x1="40" y1="6" x2="40" y2="14" stroke="#d97706" stroke-width="3" stroke-linecap="round" />
        <line x1="68" y1="22" x2="60" y2="22" stroke="#d97706" stroke-width="3" stroke-linecap="round" />
        <line x1="12" y1="22" x2="20" y2="22" stroke="#d97706" stroke-width="3" stroke-linecap="round" />
        <line x1="72" y1="44" x2="64" y2="44" stroke="#d97706" stroke-width="3" stroke-linecap="round" />
        <line x1="8" y1="44" x2="16" y2="44" stroke="#d97706" stroke-width="3" stroke-linecap="round" />
        <line x1="64" y1="68" x2="58" y2="62" stroke="#d97706" stroke-width="3" stroke-linecap="round" />
        <line x1="16" y1="68" x2="22" y2="62" stroke="#d97706" stroke-width="3" stroke-linecap="round" />
        <ellipse cx="33" cy="38" rx="5" ry="6" fill="#fff" />
        <ellipse cx="47" cy="38" rx="5" ry="6" fill="#fff" />
        <circle cx="33" cy="40" r="2.5" fill="#000" />
        <circle cx="47" cy="40" r="2.5" fill="#000" />
        <path d="M 30 54 L 50 54 L 47 58 L 43 54 L 40 58 L 37 54 L 33 58 Z" fill="#fff" stroke="#fff" stroke-width="0.5" stroke-linejoin="round" />
      </svg>
    </template>

    <script>
      // @ts-nocheck

      // === DOM refs ===
      const stateIntro = document.getElementById('state-intro');
      const statePlaying = document.getElementById('state-playing');
      const stateResult = document.getElementById('state-result');
      const resultContent = document.getElementById('result-content');
      const startBtn = document.getElementById('start-btn');
      const scoreDisplay = document.getElementById('score-display');
      const timerDisplay = document.getElementById('timer-display');
      const timerFill = document.getElementById('timer-fill');
      const cells = Array.from(document.querySelectorAll('.cell'));
      const virusTemplates = [
        document.getElementById('virus-template-1'),
        document.getElementById('virus-template-2'),
        document.getElementById('virus-template-3'),
      ];

      // === Game config ===
      const GAME_DURATION = 30;        // seconds
      const SCORE_TO_WIN = 20;
      const VIRUS_LIFETIME = 950;      // ms a virus stays before disappearing
      const SPAWN_INTERVAL = 600;      // ms between spawn attempts
      const NEXT_CLUE_URL = '/h/clue-4';

      // === Game state ===
      let score = 0;
      let timeLeft = GAME_DURATION;
      let gameRunning = false;
      let timerHandle = null;
      let spawnHandle = null;
      let activeViruses = new Map(); // cellIndex → { element, hideTimeout }

      // === State switching ===
      function showState(stateName) {
        [stateIntro, statePlaying, stateResult].forEach(s => s.classList.remove('state--active'));
        if (stateName === 'intro') stateIntro.classList.add('state--active');
        if (stateName === 'playing') statePlaying.classList.add('state--active');
        if (stateName === 'result') stateResult.classList.add('state--active');
      }

      // === Start game ===
      function startGame() {
        score = 0;
        timeLeft = GAME_DURATION;
        gameRunning = true;
        activeViruses.clear();

        scoreDisplay.textContent = '0';
        timerDisplay.textContent = String(GAME_DURATION);
        timerFill.style.width = '100%';

        // Clear any leftover virus elements in cells
        cells.forEach(cell => { cell.innerHTML = ''; cell.classList.remove('cell--smashed'); });

        showState('playing');

        // Start countdown
        timerHandle = setInterval(tickTimer, 1000);

        // Start spawning viruses
        spawnHandle = setInterval(spawnVirus, SPAWN_INTERVAL);

        // Spawn one immediately so the player sees something instantly
        spawnVirus();
      }

      // === Timer tick ===
      function tickTimer() {
        timeLeft--;
        timerDisplay.textContent = String(timeLeft);
        timerFill.style.width = (timeLeft / GAME_DURATION * 100) + '%';

        if (timeLeft <= 5) {
          timerDisplay.classList.add('timer-urgent');
        }

        if (timeLeft <= 0) {
          endGame();
        }
      }

      // === Spawn a virus in a random empty cell ===
      function spawnVirus() {
        if (!gameRunning) return;

        // Find an empty cell
        const emptyCells = cells.filter((_, i) => !activeViruses.has(i));
        if (emptyCells.length === 0) return;

        const targetCell = emptyCells[Math.floor(Math.random() * emptyCells.length)];
        const cellIndex = parseInt(targetCell.dataset.cell);

        // Pick a random virus variant
        const template = virusTemplates[Math.floor(Math.random() * virusTemplates.length)];
        const virusClone = template.content.cloneNode(true);
        targetCell.appendChild(virusClone);

        const virusEl = targetCell.querySelector('.virus');
        if (!virusEl) return;
        virusEl.classList.add('virus--popping');

        // Auto-disappear after lifetime
        const hideTimeout = setTimeout(() => {
          if (gameRunning && activeViruses.has(cellIndex)) {
            removeVirus(cellIndex, false);
          }
        }, VIRUS_LIFETIME);

        activeViruses.set(cellIndex, { element: virusEl, hideTimeout, smashed: false });
      }

      // === Remove virus from cell ===
      function removeVirus(cellIndex, wasSmashed) {
        const data = activeViruses.get(cellIndex);
        if (!data) return;

        clearTimeout(data.hideTimeout);
        const cell = cells[cellIndex];
        const virus = data.element;

        if (wasSmashed && virus) {
          // Smash animation
          virus.classList.remove('virus--popping');
          virus.classList.add('virus--smashed');
          cell.classList.add('cell--smashed');

          setTimeout(() => {
            cell.innerHTML = '';
            cell.classList.remove('cell--smashed');
          }, 350);
        } else {
          // Just disappear
          if (virus) virus.classList.add('virus--escaping');
          setTimeout(() => {
            cell.innerHTML = '';
          }, 250);
        }

        activeViruses.delete(cellIndex);
      }

      // === Cell click handler ===
      cells.forEach(cell => {
        cell.addEventListener('click', () => {
          if (!gameRunning) return;
          const cellIndex = parseInt(cell.dataset.cell);
          if (!activeViruses.has(cellIndex)) return;

          const data = activeViruses.get(cellIndex);
          if (data.smashed) return; // already smashed, prevent double-counting
          data.smashed = true;

          score++;
          scoreDisplay.textContent = String(score);

          // Bounce animation on score
          scoreDisplay.classList.remove('score-bump');
          // Force reflow so we can re-trigger animation
          void scoreDisplay.offsetWidth;
          scoreDisplay.classList.add('score-bump');

          removeVirus(cellIndex, true);

          // Win check (don't end immediately — let timer run out, but mark a win)
          // Actually — immediate win is more satisfying when you hit the goal
          if (score >= SCORE_TO_WIN) {
            endGame();
          }
        });
      });

      // === End game ===
      function endGame() {
        if (!gameRunning) return;
        gameRunning = false;

        clearInterval(timerHandle);
        clearInterval(spawnHandle);

        // Clear all active viruses
        activeViruses.forEach((data, idx) => {
          clearTimeout(data.hideTimeout);
          cells[idx].innerHTML = '';
        });
        activeViruses.clear();

        timerDisplay.classList.remove('timer-urgent');

        // Show result
        const won = score >= SCORE_TO_WIN;
        renderResult(won);
        showState('result');
      }

      // === Render result state ===
      function renderResult(won) {
        if (won) {
          resultContent.innerHTML = `
            <div class="result-icon result-icon--win" aria-hidden="true">
              <svg viewBox="0 0 80 80" xmlns="http://www.w3.org/2000/svg">
                <circle cx="40" cy="40" r="36" fill="#10b981" />
                <path d="M 22 40 L 36 54 L 58 28" fill="none" stroke="#fff" stroke-width="6" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </div>
            <h2 class="result-title">System cleaned!</h2>
            <p class="result-text">You smashed <strong>${score}</strong> viruses in time. Nice reflexes.</p>

            <div class="win-status" aria-live="polite">
              <span class="status-dot"></span>
              <span class="status-text">CLUE UNLOCKED</span>
            </div>

            <a href="${NEXT_CLUE_URL}" class="win-chip" aria-label="Continue to the next clue">
              <span class="win-chip-prefix">$</span>
              <span class="win-chip-text">./next_clue.sh</span>
              <span class="win-chip-arrow" aria-hidden="true">→</span>
            </a>
          `;
        } else {
          resultContent.innerHTML = `
            <div class="result-icon result-icon--lose" aria-hidden="true">
              <svg viewBox="0 0 80 80" xmlns="http://www.w3.org/2000/svg">
                <circle cx="40" cy="40" r="36" fill="#f59e0b" />
                <path d="M 28 28 L 52 52 M 52 28 L 28 52" fill="none" stroke="#fff" stroke-width="6" stroke-linecap="round" />
              </svg>
            </div>
            <h2 class="result-title">The viruses won this round.</h2>
            <p class="result-text">You smashed <strong>${score}</strong> out of <strong>${SCORE_TO_WIN}</strong>. Almost — try again!</p>
            <button type="button" id="retry-btn" class="primary-btn">
              <span>TRY AGAIN</span>
              <svg class="btn-icon" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path d="M 4 12 a 8 8 0 1 1 2.5 5.7 M 4 12 V 6 M 4 12 H 10" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </button>
          `;
          // Wire up retry button after innerHTML
          requestAnimationFrame(() => {
            const retryBtn = document.getElementById('retry-btn');
            if (retryBtn) retryBtn.addEventListener('click', startGame);
          });
        }
      }

      // === Wire up start button ===
      startBtn.addEventListener('click', startGame);

      // === Reduced motion: skip pop animations, just show/hide ===
      // CSS handles this via @media query, no JS changes needed.
    </script>

    <style>
      *, *::before, *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      html { scroll-behavior: smooth; }
      @media (prefers-reduced-motion: reduce) { html { scroll-behavior: auto; } }

      body {
        background: linear-gradient(135deg, #1e3a8a 0%, #2563eb 100%);
        color: #ffffff;
        font-family: 'Inter Tight', system-ui, -apple-system, sans-serif;
        min-height: 100vh;
        overflow-x: hidden;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
      }

      .page { position: relative; min-height: 100vh; }

      .sr-only {
        position: absolute;
        width: 1px; height: 1px;
        padding: 0; margin: -1px;
        overflow: hidden;
        clip: rect(0, 0, 0, 0);
        white-space: nowrap;
        border: 0;
      }

      /* ============================================================ */
      /* Floaters (same system as other hunt pages)                    */
      /* ============================================================ */
      .floaters {
        position: fixed;
        inset: 0;
        pointer-events: none;
        z-index: 0;
        overflow: hidden;
      }

      .floater {
        position: absolute;
        width: 56px;
        height: 56px;
        color: rgba(255, 255, 255, 0.10);
        will-change: transform;
      }

      .pos-a { top:  6%; left:  8%; animation: drift-a 28s ease-in-out infinite; }
      .pos-b { top: 14%; left: 78%; animation: drift-b 32s ease-in-out infinite; }
      .pos-c { top: 22%; left: 18%; animation: drift-c 30s ease-in-out infinite; }
      .pos-d { top: 28%; left: 88%; animation: drift-a 36s ease-in-out infinite; }
      .pos-e { top: 42%; left:  6%; animation: drift-b 26s ease-in-out infinite; }
      .pos-f { top: 50%; left: 92%; animation: drift-c 34s ease-in-out infinite; }
      .pos-g { top: 62%; left: 14%; animation: drift-a 30s ease-in-out infinite; }
      .pos-h { top: 70%; left: 82%; animation: drift-b 32s ease-in-out infinite; }
      .pos-i { top: 80%; left:  8%; animation: drift-c 28s ease-in-out infinite; }
      .pos-j { top: 88%; left: 76%; animation: drift-a 30s ease-in-out infinite; }

      @keyframes drift-a {
        0%, 100% { transform: translate(0, 0) rotate(0deg); }
        25%      { transform: translate(20px, -15px) rotate(8deg); }
        50%      { transform: translate(-10px, 20px) rotate(-6deg); }
        75%      { transform: translate(-25px, -10px) rotate(4deg); }
      }
      @keyframes drift-b {
        0%, 100% { transform: translate(0, 0) rotate(0deg); }
        33%      { transform: translate(-18px, 12px) rotate(-5deg); }
        66%      { transform: translate(15px, -22px) rotate(7deg); }
      }
      @keyframes drift-c {
        0%, 100% { transform: translate(0, 0) rotate(0deg); }
        20%      { transform: translate(12px, 18px) rotate(3deg); }
        50%      { transform: translate(22px, -12px) rotate(-8deg); }
        80%      { transform: translate(-15px, 15px) rotate(5deg); }
      }

      /* ============================================================ */
      /* Game container                                                */
      /* ============================================================ */
      .game-section {
        position: relative;
        z-index: 1;
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 5rem 1.5rem;
      }

      .game-wrap {
        width: 100%;
        max-width: 38rem;
        background: #0a0e1a;
        border: 1px solid rgba(96, 165, 250, 0.4);
        border-radius: 0.875rem;
        overflow: hidden;
        box-shadow:
          0 0 0 1px rgba(96, 165, 250, 0.15),
          0 0 40px rgba(96, 165, 250, 0.35),
          0 0 90px rgba(37, 99, 235, 0.4),
          0 25px 60px rgba(0, 0, 0, 0.4);
        animation: terminal-glow 3.5s ease-in-out infinite;
      }

      @keyframes terminal-glow {
        0%, 100% {
          box-shadow:
            0 0 0 1px rgba(96, 165, 250, 0.15),
            0 0 40px rgba(96, 165, 250, 0.35),
            0 0 90px rgba(37, 99, 235, 0.4),
            0 25px 60px rgba(0, 0, 0, 0.4);
        }
        50% {
          box-shadow:
            0 0 0 1px rgba(96, 165, 250, 0.3),
            0 0 60px rgba(96, 165, 250, 0.5),
            0 0 120px rgba(37, 99, 235, 0.55),
            0 25px 60px rgba(0, 0, 0, 0.4);
        }
      }

      .game-header {
        background: #11172a;
        border-bottom: 1px solid rgba(96, 165, 250, 0.2);
        padding: 0.625rem 1rem;
        display: flex;
        align-items: center;
        gap: 1rem;
      }

      .game-dots { display: flex; gap: 0.4rem; }

      .dot {
        width: 0.7rem;
        height: 0.7rem;
        border-radius: 50%;
        display: inline-block;
      }

      .dot-red    { background: #ef4444; }
      .dot-yellow { background: #f59e0b; }
      .dot-green  { background: #10b981; }

      .game-title {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.8rem;
        color: rgba(255, 255, 255, 0.55);
        letter-spacing: 0.02em;
      }

      .game-body {
        padding: 2rem 1.5rem;
        min-height: 32rem;
        display: flex;
        align-items: center;
        justify-content: center;
      }

      /* States — only one visible at a time */
      .state {
        display: none;
        width: 100%;
        text-align: center;
      }

      .state--active {
        display: block;
        animation: state-fade-in 0.3s ease;
      }

      @keyframes state-fade-in {
        from { opacity: 0; transform: translateY(8px); }
        to   { opacity: 1; transform: translateY(0); }
      }

      /* ============================================================ */
      /* Intro state                                                   */
      /* ============================================================ */
      .intro-icon {
        width: 96px;
        height: 96px;
        margin: 0 auto 1.5rem auto;
        animation: intro-wiggle 2s ease-in-out infinite;
      }

      @keyframes intro-wiggle {
        0%, 100% { transform: rotate(0deg); }
        25%      { transform: rotate(-6deg); }
        75%      { transform: rotate(6deg); }
      }

      .intro-icon svg { width: 100%; height: 100%; display: block; }

      .intro-title {
        font-family: 'Inter Tight', system-ui, sans-serif;
        font-size: clamp(1.5rem, 4vw, 2rem);
        font-weight: 900;
        color: #fff;
        line-height: 1.15;
        margin-bottom: 1rem;
        letter-spacing: -0.01em;
      }

      .intro-text {
        font-size: 1rem;
        color: #d1d5db;
        margin-bottom: 0.5rem;
        line-height: 1.6;
      }

      .intro-text strong {
        color: #93c5fd;
        font-weight: 700;
      }

      .intro-hint {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.85rem;
        color: #94a3b8;
        margin-bottom: 2rem;
      }

      /* ============================================================ */
      /* Primary button                                                */
      /* ============================================================ */
      .primary-btn {
        display: inline-flex;
        align-items: center;
        gap: 0.6rem;
        padding: 1rem 2rem;
        background: #fff;
        color: #1e3a8a;
        font-family: 'Inter Tight', system-ui, sans-serif;
        font-weight: 900;
        font-size: 1rem;
        letter-spacing: 0.05em;
        border: none;
        border-radius: 0.625rem;
        cursor: pointer;
        text-decoration: none;
        transition: transform 0.2s, box-shadow 0.2s;
        box-shadow: 0 8px 30px rgba(0, 0, 0, 0.25);
        animation: btn-pulse 2.4s ease-in-out infinite;
      }

      .primary-btn:hover,
      .primary-btn:focus-visible {
        transform: translateY(-2px) scale(1.02);
        box-shadow: 0 0 0 6px rgba(255, 255, 255, 0.2), 0 12px 40px rgba(0, 0, 0, 0.35);
        outline: none;
        animation-play-state: paused;
      }

      /* Specifically size SVGs INSIDE primary-btn — the .btn-icon class makes
         this rule beat the broader .result-icon svg { width: 100% } rule */
      .primary-btn svg,
      .primary-btn .btn-icon {
        width: 1.1rem !important;
        height: 1.1rem !important;
        flex-shrink: 0;
      }

      .primary-btn--win {
        background: #10b981;
        color: #fff;
      }

      @keyframes btn-pulse {
        0%, 100% { box-shadow: 0 0 0 0 rgba(255,255,255,0.4), 0 8px 30px rgba(0,0,0,0.25); }
        50%      { box-shadow: 0 0 0 10px rgba(255,255,255,0), 0 10px 35px rgba(0,0,0,0.3); }
      }

      /* ============================================================ */
      /* WIN STATUS — green LED indicator above the chip               */
      /* ============================================================ */
      .win-status {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.4rem 0.85rem;
        margin: 0.5rem auto 1.5rem auto;
        background: rgba(16, 185, 129, 0.12);
        border: 1px solid rgba(16, 185, 129, 0.45);
        border-radius: 999px;
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.7rem;
        font-weight: 700;
        color: #4ade80;
        letter-spacing: 0.15em;
      }

      .status-dot {
        width: 0.55rem;
        height: 0.55rem;
        border-radius: 50%;
        background: #10b981;
        box-shadow: 0 0 8px #10b981;
        animation: status-pulse 1.4s ease-in-out infinite;
      }

      @keyframes status-pulse {
        0%, 100% { opacity: 1; box-shadow: 0 0 8px #10b981; }
        50%      { opacity: 0.5; box-shadow: 0 0 14px #10b981; }
      }

      /* ============================================================ */
      /* WIN CHIP — terminal-style victory chip → continue link        */
      /* Same DNA as the cmd-chip on /h/clue-1 for visual consistency  */
      /* ============================================================ */
      .win-chip {
        display: inline-flex;
        align-items: center;
        gap: 0.65rem;
        padding: 1rem 1.5rem;
        background: linear-gradient(135deg, rgba(16, 185, 129, 0.18), rgba(5, 150, 105, 0.14));
        border: 1px solid rgba(16, 185, 129, 0.55);
        border-radius: 0.5rem;
        font-family: 'JetBrains Mono', monospace;
        font-size: 1rem;
        font-weight: 600;
        color: #4ade80;
        text-decoration: none;
        cursor: pointer;
        transition: all 0.2s ease;
        box-shadow:
          0 0 25px rgba(16, 185, 129, 0.25),
          inset 0 1px 0 rgba(255, 255, 255, 0.05);
        animation: win-chip-pulse 2.4s ease-in-out infinite;
      }

      .win-chip:hover,
      .win-chip:focus-visible {
        background: linear-gradient(135deg, rgba(16, 185, 129, 0.32), rgba(5, 150, 105, 0.25));
        border-color: rgba(74, 222, 128, 0.95);
        color: #fff;
        outline: none;
        transform: translateX(3px);
        animation-play-state: paused;
        box-shadow:
          0 0 40px rgba(16, 185, 129, 0.5),
          inset 0 1px 0 rgba(255, 255, 255, 0.1);
      }

      .win-chip-prefix {
        color: #fbbf24;
        font-weight: 700;
      }

      .win-chip-text {
        letter-spacing: 0.02em;
      }

      .win-chip-arrow {
        margin-left: 0.25rem;
        font-size: 1.1em;
        transition: transform 0.2s ease;
      }

      .win-chip:hover .win-chip-arrow {
        transform: translateX(2px);
      }

      @keyframes win-chip-pulse {
        0%, 100% {
          box-shadow:
            0 0 25px rgba(16, 185, 129, 0.25),
            inset 0 1px 0 rgba(255, 255, 255, 0.05);
        }
        50% {
          box-shadow:
            0 0 45px rgba(16, 185, 129, 0.55),
            inset 0 1px 0 rgba(255, 255, 255, 0.1);
        }
      }


      /* ============================================================ */
      /* Playing state — HUD + Grid                                    */
      /* ============================================================ */
      .hud {
        display: grid;
        grid-template-columns: 1fr 1.5fr 1fr;
        gap: 1rem;
        margin-bottom: 1.5rem;
        padding: 0.75rem 1rem;
        background: rgba(15, 23, 42, 0.7);
        border: 1px solid rgba(96, 165, 250, 0.25);
        border-radius: 0.5rem;
      }

      .hud-item {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.15rem;
        position: relative;
      }

      .hud-label {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.65rem;
        font-weight: 600;
        color: #64748b;
        letter-spacing: 0.15em;
        text-transform: uppercase;
      }

      .hud-value {
        font-family: 'JetBrains Mono', monospace;
        font-size: 1.6rem;
        font-weight: 700;
        color: #f8fafc;
        line-height: 1;
        font-variant-numeric: tabular-nums;
      }

      .timer-bar {
        position: absolute;
        bottom: -0.5rem;
        left: 0;
        right: 0;
        height: 3px;
        background: rgba(255, 255, 255, 0.1);
        border-radius: 2px;
        overflow: hidden;
      }

      .timer-fill {
        height: 100%;
        background: linear-gradient(90deg, #10b981, #60a5fa);
        width: 100%;
        transition: width 1s linear;
      }

      .timer-urgent {
        color: #ef4444 !important;
        animation: timer-pulse 0.5s ease-in-out infinite;
      }

      @keyframes timer-pulse {
        0%, 100% { transform: scale(1); }
        50%      { transform: scale(1.15); }
      }

      .score-bump {
        animation: score-bump 0.3s ease;
      }

      @keyframes score-bump {
        0%   { transform: scale(1); color: #f8fafc; }
        50%  { transform: scale(1.4); color: #4ade80; }
        100% { transform: scale(1); color: #f8fafc; }
      }

      /* The 3x3 grid */
      .grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 0.6rem;
        max-width: 100%;
        aspect-ratio: 1;
        margin-bottom: 1rem;
      }

      .cell {
        position: relative;
        aspect-ratio: 1;
        background: rgba(30, 41, 59, 0.6);
        border: 2px solid rgba(96, 165, 250, 0.2);
        border-radius: 0.625rem;
        cursor: pointer;
        padding: 0;
        overflow: hidden;
        transition: background 0.15s, border-color 0.15s;
      }

      .cell:hover {
        background: rgba(30, 41, 59, 0.85);
        border-color: rgba(96, 165, 250, 0.45);
      }

      .cell:focus-visible {
        outline: 2px solid #60a5fa;
        outline-offset: 2px;
      }

      .cell--smashed {
        background: rgba(74, 222, 128, 0.18);
        border-color: rgba(74, 222, 128, 0.6);
      }

      /* Virus inside cell */
      .virus {
        position: absolute;
        inset: 12%;
        width: 76%;
        height: 76%;
        pointer-events: none;
      }

      .virus--popping {
        animation: virus-pop-in 0.18s ease-out forwards, virus-wiggle 0.6s ease-in-out 0.18s infinite;
      }

      @keyframes virus-pop-in {
        from { transform: scale(0.3); opacity: 0; }
        to   { transform: scale(1); opacity: 1; }
      }

      @keyframes virus-wiggle {
        0%, 100% { transform: scale(1) rotate(0deg); }
        25%      { transform: scale(1.04) rotate(-4deg); }
        75%      { transform: scale(1.04) rotate(4deg); }
      }

      .virus--smashed {
        animation: virus-smash 0.35s ease-out forwards !important;
      }

      @keyframes virus-smash {
        0%   { transform: scale(1); opacity: 1; }
        40%  { transform: scale(1.4); opacity: 1; filter: brightness(2); }
        100% { transform: scale(0); opacity: 0; }
      }

      .virus--escaping {
        animation: virus-escape 0.25s ease-in forwards !important;
      }

      @keyframes virus-escape {
        from { transform: scale(1); opacity: 1; }
        to   { transform: scale(0.5); opacity: 0; }
      }

      .play-hint {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.75rem;
        color: #64748b;
        letter-spacing: 0.05em;
        margin-top: 1rem;
      }

      /* ============================================================ */
      /* Result state                                                  */
      /* ============================================================ */
      .result-icon {
        width: 96px;
        height: 96px;
        margin: 0 auto 1.5rem auto;
        animation: result-pop 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
      }

      @keyframes result-pop {
        0%   { transform: scale(0); }
        70%  { transform: scale(1.15); }
        100% { transform: scale(1); }
      }

      .result-icon svg { width: 100%; height: 100%; display: block; }

      .result-title {
        font-family: 'Inter Tight', system-ui, sans-serif;
        font-size: clamp(1.5rem, 4vw, 2rem);
        font-weight: 900;
        color: #fff;
        margin-bottom: 1rem;
        line-height: 1.15;
      }

      .result-text {
        font-size: 1rem;
        color: #d1d5db;
        margin-bottom: 1rem;
        line-height: 1.6;
      }

      .result-text strong {
        color: #93c5fd;
        font-weight: 700;
      }

      .result-sub {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.8rem;
        color: #4ade80;
        margin-bottom: 1.5rem;
        letter-spacing: 0.05em;
      }

      /* ============================================================ */
      /* Mobile                                                        */
      /* ============================================================ */
      @media (max-width: 768px) {
        .floater { width: 38px; height: 38px; }
        .game-section { padding: 3rem 1rem; }
        .game-body { padding: 1.5rem 1rem; min-height: 28rem; }
        .game-title { font-size: 0.7rem; }

        .hud { padding: 0.5rem 0.75rem; gap: 0.75rem; }
        .hud-value { font-size: 1.3rem; }
        .hud-label { font-size: 0.6rem; }

        .grid { gap: 0.4rem; }

        .intro-title { font-size: 1.25rem; }
        .intro-text { font-size: 0.9rem; }

        .primary-btn { font-size: 0.9rem; padding: 0.85rem 1.5rem; }
      }

      /* ============================================================ */
      /* Reduced motion                                                */
      /* ============================================================ */
      @media (prefers-reduced-motion: reduce) {
        .floater { animation: none; }
        .game-wrap { animation: none; }
        .intro-icon { animation: none; }
        .primary-btn { animation: none; }
        .timer-urgent { animation: none; }
        .virus--popping { animation: virus-pop-in 0.1s ease forwards; }
        .virus--smashed { animation: virus-smash 0.2s ease forwards !important; }
        .result-icon { animation: none; }
        .state--active { animation: none; }
        .status-dot { animation: none; }
        .win-chip { animation: none; }
      }
    </style>
  </body>
</html>