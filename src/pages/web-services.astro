---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <section style="background:linear-gradient(135deg,#1e40af,#2563eb);padding:5rem 1.5rem;text-align:center;">
    <div style="max-width:42rem;margin:0 auto;">
      <div style="font-size:4rem;margin-bottom:1rem;">🚧</div>
      <h1 style="font-size:2.5rem;font-weight:800;color:white;margin-bottom:1rem;">Web Services Coming Soon</h1>
      <p style="color:#bfdbfe;font-size:1.1rem;line-height:1.75;margin-bottom:2rem;">
        We're working on something great! Professional website design, hosting and management packages for small businesses will be available soon.
      </p>
      <a href="/" style="display:inline-flex;align-items:center;justify-content:center;background:white;color:#2563eb;font-weight:600;padding:0.75rem 2rem;border-radius:0.5rem;text-decoration:none;">
        Back to Home
      </a>
    </div>
  </section>
</Layout>