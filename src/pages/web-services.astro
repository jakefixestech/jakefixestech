---
import Layout from '../layouts/Layout.astro';
import content from '../content/web-services.yml';
---

<Layout title="Website Design & Management | Jake Fixes Tech — Littleton, NH"
description="Professional website design, hosting and management for small businesses. Packages starting at $750. Serving Littleton NH and the North Country.">

  <!-- Animated SVG Hero -->
  <section id="hero-svg" aria-label="Web Services">

    <!-- DESKTOP SVG -->
    <svg class="hero-bg-desktop" viewBox="0 0 1440 520" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <defs>
        <linearGradient id="bgGrad" x1="0%" y1="0%" x2="100%" y2="100%">
          <stop offset="0%" style="stop-color:#1e3a8a;stop-opacity:1"/>
          <stop offset="100%" style="stop-color:#2563eb;stop-opacity:1"/>
        </linearGradient>
        <linearGradient id="glowGrad" x1="0%" y1="0%" x2="100%" y2="100%">
          <stop offset="0%" style="stop-color:#3b82f6;stop-opacity:0.25"/>
          <stop offset="100%" style="stop-color:#1d4ed8;stop-opacity:0"/>
        </linearGradient>
      </defs>
      <rect width="1440" height="520" fill="url(#bgGrad)"/>
      <ellipse cx="350" cy="180" rx="380" ry="260" fill="url(#glowGrad)" class="glow-orb-1"/>
      <ellipse cx="1150" cy="360" rx="320" ry="220" fill="url(#glowGrad)" class="glow-orb-2"/>

      <!-- Large browser window - left side -->
      <g class="browser-group" transform="translate(60, 60)">
        <!-- Browser chrome -->
        <rect x="0" y="0" width="420" height="280" rx="8" stroke="white" stroke-opacity="0.2" stroke-width="1.5" fill="white" fill-opacity="0.04" class="browser-frame"/>
        <!-- Title bar -->
        <rect x="0" y="0" width="420" height="32" rx="8" fill="white" fill-opacity="0.08"/>
        <rect x="0" y="24" width="420" height="8" fill="white" fill-opacity="0.04"/>
        <!-- Traffic lights -->
        <circle cx="16" cy="16" r="5" fill="white" fill-opacity="0.2"/>
        <circle cx="30" cy="16" r="5" fill="white" fill-opacity="0.15"/>
        <circle cx="44" cy="16" r="5" fill="white" fill-opacity="0.1"/>
        <!-- URL bar -->
        <rect x="60" y="8" width="300" height="16" rx="8" fill="white" fill-opacity="0.1"/>
        <text x="75" y="20" fill="white" fill-opacity="0.3" font-size="8" font-family="monospace">jakefixestech.com</text>
        <!-- Content area - code lines drawing in -->
        <line x1="16" y1="52" x2="180" y2="52" stroke="white" stroke-opacity="0" stroke-width="2" stroke-linecap="round" class="code-line code-line-1"/>
        <line x1="16" y1="68" x2="240" y2="68" stroke="white" stroke-opacity="0" stroke-width="2" stroke-linecap="round" class="code-line code-line-2"/>
        <line x1="16" y1="84" x2="140" y2="84" stroke="white" stroke-opacity="0" stroke-width="2" stroke-linecap="round" class="code-line code-line-3"/>
        <line x1="32" y1="100" x2="200" y2="100" stroke="white" stroke-opacity="0" stroke-width="2" stroke-linecap="round" class="code-line code-line-4"/>
        <line x1="32" y1="116" x2="280" y2="116" stroke="white" stroke-opacity="0" stroke-width="2" stroke-linecap="round" class="code-line code-line-5"/>
        <line x1="32" y1="132" x2="160" y2="132" stroke="white" stroke-opacity="0" stroke-width="2" stroke-linecap="round" class="code-line code-line-6"/>
        <line x1="16" y1="148" x2="220" y2="148" stroke="white" stroke-opacity="0" stroke-width="2" stroke-linecap="round" class="code-line code-line-7"/>
        <line x1="16" y1="164" x2="190" y2="164" stroke="white" stroke-opacity="0" stroke-width="2" stroke-linecap="round" class="code-line code-line-8"/>
        <!-- Blinking cursor -->
        <rect x="190" y="157" width="2" height="12" fill="white" fill-opacity="0.6" class="cursor-blink"/>
        <!-- Score bars at bottom of browser -->
        <text x="16" y="206" fill="white" fill-opacity="0.25" font-size="7" font-family="monospace">PERFORMANCE</text>
        <rect x="16" y="210" width="380" height="6" rx="3" fill="white" fill-opacity="0.08"/>
        <rect x="16" y="210" width="0" height="6" rx="3" fill="white" fill-opacity="0.4" class="score-bar score-bar-1"/>
        <text x="16" y="228" fill="white" fill-opacity="0.25" font-size="7" font-family="monospace">ACCESSIBILITY</text>
        <rect x="16" y="232" width="380" height="6" rx="3" fill="white" fill-opacity="0.08"/>
        <rect x="16" y="232" width="0" height="6" rx="3" fill="white" fill-opacity="0.35" class="score-bar score-bar-2"/>
        <text x="16" y="250" fill="white" fill-opacity="0.25" font-size="7" font-family="monospace">SEO</text>
        <rect x="16" y="254" width="380" height="6" rx="3" fill="white" fill-opacity="0.08"/>
        <rect x="16" y="254" width="0" height="6" rx="3" fill="white" fill-opacity="0.3" class="score-bar score-bar-3"/>
      </g>

      <!-- Lightning bolt cluster - top right -->
      <g class="lightning-group" transform="translate(1180, 40)">
        <path d="M30 0 L10 50 L28 50 L0 100 L20 100 L-10 160" stroke="white" stroke-opacity="0.25" stroke-width="3" fill="none" stroke-linecap="round" stroke-linejoin="round" class="bolt bolt-main"/>
        <path d="M80 20 L65 60 L78 60 L55 110" stroke="white" stroke-opacity="0.15" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round" class="bolt bolt-2"/>
        <path d="M140 10 L128 45 L138 45 L120 85" stroke="white" stroke-opacity="0.1" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round" class="bolt bolt-3"/>
      </g>

      <!-- Circular score meter - bottom right -->
      <g class="score-meter" transform="translate(1200, 300)">
        <circle cx="0" cy="0" r="80" stroke="white" stroke-opacity="0.08" stroke-width="8" fill="none"/>
        <circle cx="0" cy="0" r="80" stroke="white" stroke-opacity="0.25" stroke-width="8" fill="none"
          stroke-dasharray="502" stroke-dashoffset="502" stroke-linecap="round"
          transform="rotate(-90)" class="score-ring"/>
        <text x="0" y="0" text-anchor="middle" dominant-baseline="middle" fill="white" fill-opacity="0.5" font-size="28" font-weight="800" font-family="monospace" class="score-text">100</text>
        <text x="0" y="24" text-anchor="middle" fill="white" fill-opacity="0.25" font-size="8" font-family="monospace">/100</text>
      </g>

      <!-- Floating tech stack icons -->
      <!-- Mobile phone -->
      <g class="float-icon float-icon-1" transform="translate(560, 40)" stroke="white" stroke-opacity="0.15" fill="none" stroke-width="1.5">
        <rect x="0" y="0" width="28" height="46" rx="4"/>
        <line x1="10" y1="40" x2="18" y2="40"/>
        <line x1="8" y1="6" x2="20" y2="6"/>
      </g>
      <!-- Shield / security -->
      <g class="float-icon float-icon-2" transform="translate(640, 380)" stroke="white" stroke-opacity="0.12" fill="none" stroke-width="1.5">
        <path d="M20 2 L2 9 L2 22 C2 31 20 38 20 38 C20 38 38 31 38 22 L38 9 Z"/>
        <polyline points="12,19 17,24 28,13"/>
      </g>
      <!-- Globe/web -->
      <g class="float-icon float-icon-3" transform="translate(780, 420)" stroke="white" stroke-opacity="0.12" fill="none" stroke-width="1.5">
        <circle cx="20" cy="20" r="18"/>
        <line x1="2" y1="20" x2="38" y2="20"/>
        <path d="M20 2 C12 8 12 32 20 38"/>
        <path d="M20 2 C28 8 28 32 20 38"/>
      </g>
      <!-- Star / quality -->
      <g class="float-icon float-icon-4" transform="translate(520, 420)" stroke="white" stroke-opacity="0.1" fill="none" stroke-width="1.5">
        <polygon points="20,2 24,14 38,14 27,22 31,34 20,26 9,34 13,22 2,14 16,14"/>
      </g>

      <!-- Grid background -->
      <g stroke="white" stroke-opacity="0.04" stroke-width="1">
        <line x1="0" y1="130" x2="1440" y2="130"/>
        <line x1="0" y1="260" x2="1440" y2="260"/>
        <line x1="0" y1="390" x2="1440" y2="390"/>
        <line x1="360" y1="0" x2="360" y2="520"/>
        <line x1="720" y1="0" x2="720" y2="520"/>
        <line x1="1080" y1="0" x2="1080" y2="520"/>
      </g>

      <!-- Data flow dots -->
      <circle r="3" fill="white" fill-opacity="0.6" class="data-dot">
        <animateMotion dur="3s" repeatCount="indefinite" begin="1s">
          <mpath href="#flow-path-1"/>
        </animateMotion>
      </circle>
      <circle r="2" fill="white" fill-opacity="0.4" class="data-dot">
        <animateMotion dur="4s" repeatCount="indefinite" begin="2s">
          <mpath href="#flow-path-2"/>
        </animateMotion>
      </circle>
      <defs>
        <path id="flow-path-1" d="M500 260 L720 200 L900 260 L1100 220"/>
        <path id="flow-path-2" d="M1100 300 L900 350 L700 300 L500 340 L300 300"/>
      </defs>
    </svg>

    <!-- MOBILE SVG -->
    <svg class="hero-bg-mobile" viewBox="0 0 400 600" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <defs>
        <linearGradient id="bgGradM" x1="0%" y1="0%" x2="100%" y2="100%">
          <stop offset="0%" style="stop-color:#1e3a8a;stop-opacity:1"/>
          <stop offset="100%" style="stop-color:#2563eb;stop-opacity:1"/>
        </linearGradient>
        <linearGradient id="glowGradM" x1="0%" y1="0%" x2="100%" y2="100%">
          <stop offset="0%" style="stop-color:#3b82f6;stop-opacity:0.3"/>
          <stop offset="100%" style="stop-color:#1d4ed8;stop-opacity:0"/>
        </linearGradient>
      </defs>
      <rect width="400" height="600" fill="url(#bgGradM)"/>
      <ellipse cx="200" cy="180" rx="260" ry="200" fill="url(#glowGradM)" class="glow-orb-1"/>
      <ellipse cx="200" cy="500" rx="220" ry="160" fill="url(#glowGradM)" class="glow-orb-2"/>

      <!-- Mini browser - top left -->
      <g class="browser-group" transform="translate(16, 30)">
        <rect x="0" y="0" width="200" height="140" rx="6" stroke="white" stroke-opacity="0.2" stroke-width="1.5" fill="white" fill-opacity="0.04" class="browser-frame"/>
        <rect x="0" y="0" width="200" height="22" rx="6" fill="white" fill-opacity="0.08"/>
        <rect x="0" y="16" width="200" height="6" fill="white" fill-opacity="0.04"/>
        <circle cx="10" cy="11" r="3.5" fill="white" fill-opacity="0.2"/>
        <circle cx="20" cy="11" r="3.5" fill="white" fill-opacity="0.15"/>
        <circle cx="30" cy="11" r="3.5" fill="white" fill-opacity="0.1"/>
        <rect x="40" y="5" width="140" height="12" rx="6" fill="white" fill-opacity="0.1"/>
        <line x1="10" y1="36" x2="100" y2="36" stroke="white" stroke-opacity="0" stroke-width="1.5" stroke-linecap="round" class="code-line code-line-1"/>
        <line x1="10" y1="48" x2="130" y2="48" stroke="white" stroke-opacity="0" stroke-width="1.5" stroke-linecap="round" class="code-line code-line-2"/>
        <line x1="10" y1="60" x2="80" y2="60" stroke="white" stroke-opacity="0" stroke-width="1.5" stroke-linecap="round" class="code-line code-line-3"/>
        <line x1="20" y1="72" x2="110" y2="72" stroke="white" stroke-opacity="0" stroke-width="1.5" stroke-linecap="round" class="code-line code-line-4"/>
        <line x1="20" y1="84" x2="150" y2="84" stroke="white" stroke-opacity="0" stroke-width="1.5" stroke-linecap="round" class="code-line code-line-5"/>
        <rect x="110" y="79" width="1.5" height="9" fill="white" fill-opacity="0.5" class="cursor-blink"/>
        <!-- Score bars -->
        <rect x="10" y="104" width="180" height="4" rx="2" fill="white" fill-opacity="0.08"/>
        <rect x="10" y="104" width="0" height="4" rx="2" fill="white" fill-opacity="0.4" class="score-bar score-bar-1"/>
        <rect x="10" y="116" width="180" height="4" rx="2" fill="white" fill-opacity="0.08"/>
        <rect x="10" y="116" width="0" height="4" rx="2" fill="white" fill-opacity="0.35" class="score-bar score-bar-2"/>
        <rect x="10" y="128" width="180" height="4" rx="2" fill="white" fill-opacity="0.08"/>
        <rect x="10" y="128" width="0" height="4" rx="2" fill="white" fill-opacity="0.3" class="score-bar score-bar-3"/>
      </g>

      <!-- Score meter - top right -->
      <g class="score-meter" transform="translate(330, 100)">
        <circle cx="0" cy="0" r="48" stroke="white" stroke-opacity="0.08" stroke-width="6" fill="none"/>
        <circle cx="0" cy="0" r="48" stroke="white" stroke-opacity="0.25" stroke-width="6" fill="none"
          stroke-dasharray="301" stroke-dashoffset="301" stroke-linecap="round"
          transform="rotate(-90)" class="score-ring"/>
        <text x="0" y="0" text-anchor="middle" dominant-baseline="middle" fill="white" fill-opacity="0.5" font-size="16" font-weight="800" font-family="monospace" class="score-text">100</text>
      </g>

      <!-- Lightning bolt - bottom right -->
      <g class="lightning-group" transform="translate(320, 380)">
        <path d="M20 0 L6 34 L18 34 L0 70" stroke="white" stroke-opacity="0.2" stroke-width="2.5" fill="none" stroke-linecap="round" stroke-linejoin="round" class="bolt bolt-main"/>
        <path d="M55 10 L44 38 L54 38 L38 70" stroke="white" stroke-opacity="0.12" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round" class="bolt bolt-2"/>
      </g>

      <!-- Floating icons -->
      <g class="float-icon float-icon-2" transform="translate(20, 490)" stroke="white" stroke-opacity="0.12" fill="none" stroke-width="1.5">
        <path d="M16 2 L2 8 L2 18 C2 25 16 30 16 30 C16 30 30 25 30 18 L30 8 Z"/>
        <polyline points="10,15 14,19 22,11"/>
      </g>
      <g class="float-icon float-icon-3" transform="translate(180, 490)" stroke="white" stroke-opacity="0.1" fill="none" stroke-width="1.5">
        <circle cx="16" cy="16" r="14"/>
        <line x1="2" y1="16" x2="30" y2="16"/>
        <path d="M16 2 C10 7 10 25 16 30"/>
        <path d="M16 2 C22 7 22 25 16 30"/>
      </g>

      <!-- Grid -->
      <g stroke="white" stroke-opacity="0.04" stroke-width="1">
        <line x1="0" y1="150" x2="400" y2="150"/>
        <line x1="0" y1="300" x2="400" y2="300"/>
        <line x1="0" y1="450" x2="400" y2="450"/>
        <line x1="133" y1="0" x2="133" y2="600"/>
        <line x1="266" y1="0" x2="266" y2="600"/>
      </g>
    </svg>

    <!-- Hero text -->
    <div id="hero-content">
      <p class="hero-label">{content.headerLabel}</p>
      <h1 id="hero-wordmark">{content.headerTitle}</h1>
      <p id="hero-tagline">{content.headerSubtitle}</p>
      <div style="display:flex;flex-wrap:wrap;gap:1rem;justify-content:center;" id="hero-btns">
        <a href="#packages-section" class="hero-cta-primary">
          View Packages
          <svg style="height:1rem;width:1rem;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M12 5v14M5 12l7 7 7-7"/></svg>
        </a>
        <a href="/why-different" class="hero-cta-secondary">Why My Sites Are Different →</a>
      </div>
    </div>

    <div id="scroll-hint" aria-hidden="true" role="button" tabindex="-1" onclick="document.getElementById('why-section').scrollIntoView({behavior:'smooth'})">
      <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" style="height:1.5rem;width:1.5rem;"><path d="M12 5v14M5 12l7 7 7-7"/></svg>
    </div>
  </section>

  <!-- Why Choose Jake for Web Design -->
  <section id="why-section" style="background:#f8fafc;padding:4rem 1.5rem;">
    <div style="max-width:72rem;margin:0 auto;">
      <div style="text-align:left;margin-bottom:3rem;max-width:56rem;">
        <h2 style="font-size:2rem;font-weight:800;color:#111827;margin-top:0.5rem;">{content.whyTitle}</h2>
        <p style="color:#6b7280;margin-top:0.75rem;max-width:36rem;line-height:1.75;">{content.whyDesc}</p>
      </div>
      <div id="why-grid">
        <div class="why-card">
          <div class="why-icon" aria-hidden="true"><svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg></div>
          <h3>{content.why1Title}</h3>
          <p>{content.why1Desc}</p>
        </div>
        <div class="why-card">
          <div class="why-icon" aria-hidden="true"><svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><rect x="5" y="2" width="14" height="20" rx="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg></div>
          <h3>{content.why2Title}</h3>
          <p>{content.why2Desc}</p>
        </div>
        <div class="why-card">
          <div class="why-icon" aria-hidden="true"><svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg></div>
          <h3>{content.why3Title}</h3>
          <p>{content.why3Desc}</p>
        </div>
        <div class="why-card">
          <div class="why-icon" aria-hidden="true"><svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg></div>
          <h3>{content.why4Title}</h3>
          <p>{content.why4Desc}</p>
        </div>
      </div>
      <div class="ada-card">
        <div style="display:flex;align-items:center;gap:1rem;flex-wrap:wrap;margin-bottom:1.5rem;">
          <div style="background:#16a34a;border-radius:50%;height:3rem;width:3rem;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
            <svg style="height:1.5rem;width:1.5rem;color:white;" aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 8v4M12 16h.01"/><path d="M9 12a3 3 0 1 1 6 0"/></svg>
          </div>
          <div style="flex:1;min-width:200px;">
            <h3 style="font-size:1.1rem;font-weight:700;color:#15803d;margin-bottom:0.25rem;">{content.adaTitle}</h3>
            <p style="color:#166534;font-size:0.9rem;line-height:1.6;">{content.adaDesc}</p>
          </div>
        </div>
        <div style="display:flex;flex-wrap:wrap;gap:1rem;justify-content:center;">
          <div style="text-align:center;background:white;border-radius:0.75rem;padding:1rem 1.5rem;border:2px solid #16a34a;flex:1;min-width:120px;"><div style="font-size:clamp(1.25rem, 4vw, 2rem);font-weight:800;color:#16a34a;">10/10</div><div style="font-size:0.75rem;color:#166534;font-weight:600;">WAVE Accessibility</div><div style="font-size:0.7rem;color:#14532d;margin-top:0.1rem;">Every Page</div></div>
          <div style="text-align:center;background:white;border-radius:0.75rem;padding:1rem 1.5rem;border:2px solid #16a34a;flex:1;min-width:120px;"><div style="font-size:clamp(1.25rem, 4vw, 2rem);font-weight:800;color:#16a34a;">100/100</div><div style="font-size:0.75rem;color:#166534;font-weight:600;">Lighthouse Desktop</div><div style="font-size:0.7rem;color:#14532d;margin-top:0.1rem;">Every Page</div></div>
          <div style="text-align:center;background:white;border-radius:0.75rem;padding:1rem 1.5rem;border:2px solid #16a34a;flex:1;min-width:120px;"><div style="font-size:clamp(1.25rem, 4vw, 2rem);font-weight:800;color:#16a34a;">398–400</div><div style="font-size:0.75rem;color:#166534;font-weight:600;">Lighthouse Mobile</div><div style="font-size:0.7rem;color:#14532d;margin-top:0.1rem;">Out of 400</div></div>
          <div style="text-align:center;background:white;border-radius:0.75rem;padding:1rem 1.5rem;border:2px solid #16a34a;flex:1;min-width:120px;"><div style="font-size:clamp(1.25rem, 4vw, 2rem);font-weight:800;color:#16a34a;">&lt;2s</div><div style="font-size:0.75rem;color:#166534;font-weight:600;">Load Time</div><div style="font-size:0.7rem;color:#14532d;margin-top:0.1rem;">Globally</div></div>
        </div>
      </div>
    </div>
  </section>

  <!-- Build Packages -->
  <section id="packages-section" style="background:white;padding:4rem 1.5rem;">
    <div style="max-width:72rem;margin:0 auto;">
      <div style="text-align:left;margin-bottom:2rem;">
        <p style="font-size:0.875rem;font-weight:600;text-transform:uppercase;letter-spacing:0.1em;color:#2563eb;">{content.packagesLabel}</p>
        <h2 style="font-size:2rem;font-weight:800;color:#111827;margin-top:0.5rem;">{content.packagesTitle}</h2>
        <p style="color:#6b7280;margin-top:0.75rem;max-width:36rem;line-height:1.75;">{content.packagesDesc}</p>
      </div>
      <div id="packages-grid">
        <div class="package-card">
          <div class="package-header"><h3>Starter</h3><div class="package-price">{content.starterPrice}</div><p class="package-label">one-time build fee</p></div>
          <ul class="package-features">
            <li>✅ 1-3 page website</li><li>✅ Mobile responsive design</li><li>✅ Contact info & hours</li><li>✅ Contact form</li><li>✅ Domain setup & configuration</li><li>✅ SSL certificate (free)</li><li>✅ Google-ready (basic SEO)</li><li>✅ 2 rounds of revisions</li><li>✅ 30 day post-launch support</li><li>✅ WCAG AA accessible</li>
            <li class="not-included">Google Analytics</li><li class="not-included">Google Business Profile setup</li><li class="not-included">Search Bar</li><li class="not-included">Blog or news section</li><li class="not-included">Booking system</li>
          </ul>
          <p class="package-best">Best for: Local businesses, tradespeople, simple landing pages</p>
          <a href="mailto:jake@jakefixestech.com?subject=Starter Website Package Inquiry" class="package-btn">Get Started</a>
        </div>
        <div class="package-card package-featured">
          <div class="package-popular">Most Popular</div>
