---
import Layout from '../layouts/Layout.astro';
import content from '../content/web-services.yml';
---

<Layout title="Website Design & Management | Jake Fixes Tech — Littleton, NH"
description="Professional website design, hosting and management for small businesses. Packages starting at $750. Serving Littleton NH and the North Country.">

  <!-- Header Banner -->
  <section style="position:relative;overflow:hidden;background-color:rgb(30,64,175);">
    <img src="/hero.jpg" alt="Professional tech workspace with dual monitors" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;z-index:0;" />
    <div style="position:absolute;inset:0;background:linear-gradient(135deg,rgba(30,64,175,0.88),rgba(37,99,235,0.88));z-index:1;"></div>
    <div style="max-width:56rem;margin:0 auto;padding:5rem 1.5rem 4rem 1.5rem;text-align:center;position:relative;z-index:2;">
      <p style="font-size:0.875rem;font-weight:600;text-transform:uppercase;letter-spacing:0.1em;color:#93c5fd;">{content.headerLabel}</p>
      <h1 style="font-size:2.5rem;font-weight:800;color:white;margin-top:0.5rem;margin-bottom:1rem;">{content.headerTitle}</h1>
      <p style="color:#bfdbfe;font-size:1.1rem;line-height:1.75;max-width:42rem;margin:0 auto;">{content.headerSubtitle}</p>
    </div>
  </section>

  <!-- Why Choose Jake for Web Design -->
  <section style="background:#f8fafc;padding:4rem 1.5rem;">
    <div style="max-width:72rem;margin:0 auto;">
      <div style="text-align:left;margin-bottom:3rem;max-width:56rem;">
        <p style="font-size:0.875rem;font-weight:600;text-transform:uppercase;letter-spacing:0.1em;color:#2563eb;">{content.whyLabel}</p>
        <a href="/why-different" style="display:inline-flex;align-items:center;gap:0.5rem;color:#2563eb;font-weight:600;font-size:0.9rem;text-decoration:underline;">See why my sites beat old school web agencies →</a>
        <h2 style="font-size:2rem;font-weight:800;color:#111827;margin-top:0.5rem;">{content.whyTitle}</h2>
        <p style="color:#6b7280;margin-top:0.75rem;max-width:36rem;line-height:1.75;">{content.whyDesc}</p>
      </div>
      <div id="why-grid">
        <div class="why-card">
          <div class="why-icon" aria-hidden="true"><svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg></div>
          <h3>{content.why1Title}</h3>
          <p>{content.why1Desc}</p>
        </div>
        <div class="why-card">
          <div class="why-icon" aria-hidden="true"><svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><rect x="5" y="2" width="14" height="20" rx="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg></div>
          <h3>{content.why2Title}</h3>
          <p>{content.why2Desc}</p>
        </div>
        <div class="why-card">
          <div class="why-icon" aria-hidden="true"><svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg></div>
          <h3>{content.why3Title}</h3>
          <p>{content.why3Desc}</p>
        </div>
        <div class="why-card">
          <div class="why-icon" aria-hidden="true"><svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg></div>
          <h3>{content.why4Title}</h3>
          <p>{content.why4Desc}</p>
        </div>
      </div>

      <!-- ADA Card -->
      <div class="ada-card">
        <div style="display:flex;align-items:center;gap:1rem;flex-wrap:wrap;margin-bottom:1.5rem;">
          <div style="background:#16a34a;border-radius:50%;height:3rem;width:3rem;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
            <svg style="height:1.5rem;width:1.5rem;color:white;" aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 8v4M12 16h.01"/><path d="M9 12a3 3 0 1 1 6 0"/></svg>
          </div>
          <div style="flex:1;min-width:200px;">
            <h3 style="font-size:1.1rem;font-weight:700;color:#15803d;margin-bottom:0.25rem;">{content.adaTitle}</h3>
            <p style="color:#166534;font-size:0.9rem;line-height:1.6;">{content.adaDesc}</p>
          </div>
        </div>
        <div style="display:flex;flex-wrap:wrap;gap:1rem;justify-content:center;">
          <div style="text-align:center;background:white;border-radius:0.75rem;padding:1rem 1.5rem;border:2px solid #16a34a;flex:1;min-width:120px;">
            <div style="font-size:clamp(1.25rem, 4vw, 2rem);font-weight:800;color:#16a34a;">10/10</div>
            <div style="font-size:0.75rem;color:#166534;font-weight:600;">WAVE Accessibility</div>
            <div style="font-size:0.7rem;color:#14532d;margin-top:0.1rem;">Every Page</div>
          </div>
          <div style="text-align:center;background:white;border-radius:0.75rem;padding:1rem 1.5rem;border:2px solid #16a34a;flex:1;min-width:120px;">
            <div style="font-size:clamp(1.25rem, 4vw, 2rem);font-weight:800;color:#16a34a;">100/100</div>
            <div style="font-size:0.75rem;color:#166534;font-weight:600;">Lighthouse Desktop</div>
            <div style="font-size:0.7rem;color:#14532d;margin-top:0.1rem;">Every Page</div>
          </div>
          <div style="text-align:center;background:white;border-radius:0.75rem;padding:1rem 1.5rem;border:2px solid #16a34a;flex:1;min-width:120px;">
            <div style="font-size:clamp(1.25rem, 4vw, 2rem);font-weight:800;color:#16a34a;">398–400</div>
            <div style="font-size:0.75rem;color:#166534;font-weight:600;">Lighthouse Mobile</div>
            <div style="font-size:0.7rem;color:#14532d;margin-top:0.1rem;">Out of 400</div>
          </div>
          <div style="text-align:center;background:white;border-radius:0.75rem;padding:1rem 1.5rem;border:2px solid #16a34a;flex:1;min-width:120px;">
            <div style="font-size:clamp(1.25rem, 4vw, 2rem);font-weight:800;color:#16a34a;">&lt;2s</div>
            <div style="font-size:0.75rem;color:#166534;font-weight:600;">Load Time</div>
            <div style="font-size:0.7rem;color:#14532d;margin-top:0.1rem;">Globally</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Build Packages -->
  <section style="background:white;padding:4rem 1.5rem;">
    <div style="max-width:72rem;margin:0 auto;">
      <div style="text-align:left;margin-bottom:2rem;">
        <p style="font-size:0.875rem;font-weight:600;text-transform:uppercase;letter-spacing:0.1em;color:#2563eb;">{content.packagesLabel}</p>
        <h2 style="font-size:2rem;font-weight:800;color:#111827;margin-top:0.5rem;">{content.packagesTitle}</h2>
        <p style="color:#6b7280;margin-top:0.75rem;max-width:36rem;line-height:1.75;">{content.packagesDesc}</p>
      </div>
      <div id="packages-grid">
        <div class="package-card">
          <div class="package-header">
            <h3>Starter</h3>
            <div class="package-price">{content.starterPrice}</div>
            <p class="package-label">one-time build fee</p>
          </div>
          <ul class="package-features">
            <li>✅ 1-3 page website</li>
            <li>✅ Mobile responsive design</li>
            <li>✅ Contact info & hours</li>
            <li>✅ Contact form</li>
            <li>✅ Domain setup & configuration</li>
            <li>✅ SSL certificate (free)</li>
            <li>✅ Google-ready (basic SEO)</li>
            <li>✅ 2 rounds of revisions</li>
            <li>✅ 30 day post-launch support</li>
            <li>✅ WCAG AA accessible</li>
            <li class="not-included">Google Analytics</li>
            <li class="not-included">Google Business Profile setup</li>
            <li class="not-included">Search Bar</li>
            <li class="not-included">Blog or news section</li>
            <li class="not-included">Booking system</li>
          </ul>
          <p class="package-best">Best for: Local businesses, tradespeople, simple landing pages</p>
          <a href="mailto:jake@jakefixestech.com?subject=Starter Website Package Inquiry" class="package-btn">Get Started</a>
        </div>
        <div class="package-card package-featured">
          <div class="package-popular">Most Popular</div>
          <div class="package-header">
            <h3>Professional</h3>
            <div class="package-price">{content.professionalPrice}</div>
            <p class="package-label">one-time build fee</p>
          </div>
          <ul class="package-features">
            <li>✅ 5-15 page website</li>
            <li>✅ Mobile responsive design</li>
            <li>✅ Contact form</li>
            <li>✅ Search Bar</li>
            <li>✅ Domain setup & configuration</li>
            <li>✅ SSL certificate (free)</li>
            <li>✅ SEO optimization</li>
            <li>✅ Google Analytics setup</li>
            <li>✅ Google Business Profile setup</li>
            <li>✅ Social media links</li>
            <li>✅ 3 rounds of revisions</li>
            <li>✅ 30 day post-launch support</li>
            <li>✅ WCAG AA accessible</li>
            <li>✅ WAVE accessibility report included</li>
            <li class="not-included">Booking system</li>
          </ul>
          <p class="package-best">Best for: Small businesses, restaurants, service companies</p>
          <a href="mailto:jake@jakefixestech.com?subject=Professional Website Package Inquiry" class="package-btn">Get Started</a>
        </div>
        <div class="package-card">
          <div class="package-header">
            <h3>Premium</h3>
            <div class="package-price">{content.premiumPrice}</div>
            <p class="package-label">starting price — quoted by scope</p>
          </div>
          <ul class="package-features">
            <li>✅ 30+ pages, custom scope</li>
            <li>✅ Mobile responsive design</li>
            <li>✅ Contact form & booking system</li>
            <li>✅ Domain setup & configuration</li>
            <li>✅ SSL certificate (free)</li>
            <li>✅ Full SEO optimization</li>
            <li>✅ Google Analytics setup</li>
            <li>✅ Google Business Profile setup</li>
            <li>✅ Custom features & integrations</li>
            <li>✅ 5 rounds of revisions</li>
            <li>✅ Priority support</li>
            <li>✅ 60 day post-launch support</li>
            <li>✅ WCAG AA accessible</li>
            <li>✅ Full WAVE accessibility report included</li>
          </ul>
          <p class="package-best">Best for: Schools, municipalities, large businesses and organizations needing a full custom build</p>
          <a href="mailto:jake@jakefixestech.com?subject=Premium Website Package Inquiry" class="package-btn">Get a Free Quote</a>
        </div>
      </div>
      <div style="margin-top:2rem;background:#eff6ff;border:2px solid #bfdbfe;border-radius:0.75rem;padding:1.25rem 1.5rem;display:flex;align-items:flex-start;gap:0.75rem;">
        <div style="flex-shrink:0;color:#2563eb;margin-top:0.1rem;" aria-hidden="true">
          <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" style="height:1.25rem;width:1.25rem;"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><circle cx="12" cy="16" r="1" fill="currentColor" stroke="none"/></svg>
        </div>
        <p style="font-size:0.875rem;color:#1e40af;line-height:1.6;margin:0;"><strong style="color:#1e3a8a;">Premium projects are quoted by scope.</strong> {content.premiumNotice} <a href="mailto:jake@jakefixestech.com?subject=Premium Website Quote Request" style="color:#1e40af;font-weight:700;text-decoration:underline;">Request a free quote</a> and I'll have a number for you fast.</p>
      </div>
    </div>
  </section>

  <!-- Portfolio Examples -->
  <section style="background:#f8fafc;padding:4rem 1.5rem;">
    <div style="max-width:72rem;margin:0 auto;">
      <div style="display:flex;align-items:flex-end;justify-content:space-between;flex-wrap:wrap;gap:1rem;margin-bottom:2rem;">
        <div>
          <p style="font-size:0.875rem;font-weight:600;text-transform:uppercase;letter-spacing:0.1em;color:#2563eb;">Portfolio</p>
          <h2 style="font-size:2rem;font-weight:800;color:#111827;margin-top:0.5rem;">Example Websites</h2>
          <p style="color:#6b7280;margin-top:0.5rem;max-width:36rem;line-height:1.75;">Every example site is mobile responsive, ADA compliant and scores 10/10 on WAVE. One from each package tier below.</p>
        </div>
        <a href="/portfolio" style="display:inline-flex;align-items:center;gap:0.5rem;background:#2563eb;color:white;font-weight:700;padding:0.75rem 1.5rem;border-radius:0.5rem;text-decoration:none;font-size:0.9rem;white-space:nowrap;flex-shrink:0;">View All Examples →</a>
      </div>
      <div id="portfolio-grid">
        <a href="https://starter1.jakefixestech.com" target="_blank" rel="noopener noreferrer" class="portfolio-card">
          <div class="portfolio-tier-badge" style="background:#dbeafe;color:#1e40af;">Starter — $750</div>
          <div class="portfolio-preview" style="background:linear-gradient(135deg,#0f2942,#1e4976);">
            <div style="color:white;font-weight:700;font-size:1rem;text-align:center;padding:1rem;">Granite State Plumbing & Drain</div>
            <div style="color:#93c5fd;font-size:0.75rem;text-align:center;">Plumbing & Drain Services</div>
          </div>
          <div class="portfolio-info">
            <div style="font-weight:600;color:#111827;font-size:0.95rem;">Granite State Plumbing & Drain</div>
            <div style="color:#4b5563;font-size:0.8rem;margin-top:0.25rem;">Littleton, NH · 3 pages</div>
            <div class="portfolio-link">View Example →</div>
          </div>
        </a>
        <a href="https://pro1.jakefixestech.com" target="_blank" rel="noopener noreferrer" class="portfolio-card">
          <div class="portfolio-tier-badge" style="background:#dbeafe;color:#1e40af;">Professional — $2,000</div>
          <div class="portfolio-preview" style="background:linear-gradient(135deg,#0369a1,#0284c7);">
            <div style="color:white;font-weight:700;font-size:1rem;text-align:center;padding:1rem;">Franconia Family Dental</div>
            <div style="color:#bae6fd;font-size:0.75rem;text-align:center;">Family Dental Practice</div>
          </div>
          <div class="portfolio-info">
            <div style="font-weight:600;color:#111827;font-size:0.95rem;">Franconia Family Dental</div>
            <div style="color:#4b5563;font-size:0.8rem;margin-top:0.25rem;">Franconia, NH · 15 pages</div>
            <div class="portfolio-link">View Example →</div>
          </div>
        </a>
        <a href="https://premium1.jakefixestech.com" target="_blank" rel="noopener noreferrer" class="portfolio-card">
          <div class="portfolio-tier-badge" style="background:#dbeafe;color:#1e40af;">Premium — $3,500+</div>
          <div class="portfolio-preview" style="background:linear-gradient(135deg,#1B2E4B,#2C4A7C);">
            <div style="color:white;font-weight:700;font-size:1rem;text-align:center;padding:1rem;">Town of Littleton, NH</div>
            <div style="color:#C8973A;font-size:0.75rem;text-align:center;">Official Municipal Website</div>
          </div>
          <div class="portfolio-info">
            <div style="font-weight:600;color:#111827;font-size:0.95rem;">Town of Littleton, NH</div>
            <div style="color:#4b5563;font-size:0.8rem;margin-top:0.25rem;">Littleton, NH · 34 pages</div>
            <div class="portfolio-link">View Example →</div>
          </div>
        </a>
      </div>
      <div style="text-align:center;margin-top:2rem;">
        <a href="/portfolio" style="display:inline-flex;align-items:center;gap:0.5rem;color:#2563eb;font-weight:600;font-size:0.95rem;text-decoration:none;">See all 12 example sites →</a>
      </div>
    </div>
  </section>

  <!-- Management Plans -->
  <section style="background:#f8fafc;padding:4rem 1.5rem;">
    <div style="max-width:72rem;margin:0 auto;">
      <div style="text-align:left;margin-bottom:3rem;">
        <p style="font-size:0.875rem;font-weight:600;text-transform:uppercase;letter-spacing:0.1em;color:#2563eb;">{content.mgmtLabel}</p>
        <h2 style="font-size:2rem;font-weight:800;color:#111827;margin-top:0.5rem;">{content.mgmtTitle}</h2>
        <p style="color:#6b7280;margin-top:0.75rem;max-width:40rem;line-height:1.75;">{content.mgmtDesc}</p>
      </div>
      <div id="management-grid">
        <div class="mgmt-card">
          <h3>Basic</h3>
          <div class="mgmt-price">{content.basicPrice}<span>/month</span></div>
          <ul class="mgmt-features">
            <li>Site uptime monitoring</li>
            <li>Domain renewal management</li>
            <li>Up to 1 hr/month included</li>
            <li>Minor text & content edits</li>
            <li>Email support</li>
          </ul>
          <a href="mailto:jake@jakefixestech.com?subject=Basic Management Plan Inquiry" class="mgmt-btn">Get Started</a>
        </div>
        <div class="mgmt-card mgmt-featured">
          <div class="mgmt-popular">Most Popular</div>
          <h3>Standard</h3>
          <div class="mgmt-price">{content.standardPrice}<span>/month</span></div>
          <ul class="mgmt-features">
            <li>Everything in Basic</li>
            <li>Up to 3 hrs/month included</li>
            <li>SEO monitoring</li>
            <li>Monthly Google Analytics report</li>
            <li>Monthly check-in call</li>
            <li>Priority email support</li>
          </ul>
          <a href="mailto:jake@jakefixestech.com?subject=Standard Management Plan Inquiry" class="mgmt-btn">Get Started</a>
        </div>
        <div class="mgmt-card">
          <h3>Premium</h3>
          <div class="mgmt-price">{content.premiumMgmtPrice}<span>/month</span></div>
          <ul class="mgmt-features">
            <li>Everything in Standard</li>
            <li>Regular content updates</li>
            <li>Same-day priority support</li>
            <li>Monthly Analytics & performance report</li>
            <li>Quarterly WAVE accessibility check</li>
            <li>Up to 8 hrs/month included</li>
          </ul>
          <a href="mailto:jake@jakefixestech.com?subject=Premium Management Plan Inquiry" class="mgmt-btn">Get Started</a>
        </div>
      </div>
      <div style="margin-top:2rem;background:#eff6ff;border:2px solid #2563eb;border-radius:0.75rem;padding:1.5rem;">
        <div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:1rem;">
          <div style="flex-shrink:0;height:1.5rem;width:1.5rem;color:#1e40af;" aria-hidden="true"><svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg></div>
          <p style="font-weight:700;color:#1e40af;font-size:1rem;margin:0;">Flexible Payment Options. Pay Less Upfront or Save More Annually!</p>
        </div>
        <div style="overflow-x:auto;">
          <table style="width:100%;border-collapse:collapse;font-size:0.875rem;min-width:320px;">
            <thead>
              <tr style="background:#dbeafe;">
                <th style="padding:0.625rem 1rem;text-align:left;color:#1e40af;font-weight:700;border:1px solid #bfdbfe;">Plan</th>
                <th style="padding:0.625rem 1rem;text-align:center;color:#1e40af;font-weight:700;border:1px solid #bfdbfe;">Monthly</th>
                <th style="padding:0.625rem 1rem;text-align:center;color:#1e40af;font-weight:700;border:1px solid #bfdbfe;">Quarterly<br/><span style="font-size:0.7rem;font-weight:400;">save 5%</span></th>
                <th style="padding:0.625rem 1rem;text-align:center;color:#1e40af;font-weight:700;border:1px solid #bfdbfe;background:#dbeafe;">Annual<br/><span style="font-size:0.7rem;font-weight:400;">2 months free!</span></th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td style="padding:0.625rem 1rem;border:1px solid #e5e7eb;font-weight:600;color:#374151;">Basic</td>
                <td style="padding:0.625rem 1rem;border:1px solid #e5e7eb;text-align:center;color:#374151;">$75/mo</td>
                <td style="padding:0.625rem 1rem;border:1px solid #e5e7eb;text-align:center;color:#374151;">$213/qtr</td>
                <td style="padding:0.625rem 1rem;border:1px solid #e5e7eb;text-align:center;color:#2563eb;font-weight:700;background:#f0f9ff;">$750/yr</td>
              </tr>
              <tr style="background:#f9fafb;">
                <td style="padding:0.625rem 1rem;border:1px solid #e5e7eb;font-weight:600;color:#374151;">Standard</td>
                <td style="padding:0.625rem 1rem;border:1px solid #e5e7eb;text-align:center;color:#374151;">$150/mo</td>
                <td style="padding:0.625rem 1rem;border:1px solid #e5e7eb;text-align:center;color:#374151;">$427/qtr</td>
                <td style="padding:0.625rem 1rem;border:1px solid #e5e7eb;text-align:center;color:#2563eb;font-weight:700;background:#f0f9ff;">$1,500/yr</td>
              </tr>
              <tr>
                <td style="padding:0.625rem 1rem;border:1px solid #e5e7eb;font-weight:600;color:#374151;">Premium</td>
                <td style="padding:0.625rem 1rem;border:1px solid #e5e7eb;text-align:center;color:#374151;">$300/mo</td>
                <td style="padding:0.625rem 1rem;border:1px solid #e5e7eb;text-align:center;color:#374151;">$855/qtr</td>
                <td style="padding:0.625rem 1rem;border:1px solid #e5e7eb;text-align:center;color:#2563eb;font-weight:700;background:#f0f9ff;">$3,000/yr</td>
              </tr>
            </tbody>
          </table>
        </div>
        <p style="color:#1e40af;font-size:0.8rem;margin-top:1rem;text-align:center;">Full payment terms and cancellation policy available in our <a href="/terms#web-services-terms" style="color:#1e40af;font-weight:600;text-decoration:underline;">Terms & Conditions</a>.</p>
      </div>
    </div>
  </section>

  <!-- On Demand -->
  <section style="background:white;padding:4rem 1.5rem;border-top:1px solid #e5e7eb;">
    <div style="max-width:72rem;margin:0 auto;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:2rem;">
      <div style="flex:1;min-width:260px;">
