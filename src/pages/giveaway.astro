---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Win a Free $2,000 Website — NH Local Business Giveaway | Jake Fixes Tech"
  description="Enter to win a free $2,000 professional website build. Open to New Hampshire local businesses only. 10-day entry window, May 15-25, 2026. No purchase necessary. All entrants get 20% off any future website build.">

  <!-- =====================================================
       Animated SVG Hero
       ===================================================== -->
  <section id="hero-svg" aria-label="Free Website Giveaway for NH Local Businesses">

    <!-- DESKTOP SVG -->
    <svg class="hero-bg-desktop" viewBox="0 0 1440 580" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <defs>
        <linearGradient id="bgGrad" x1="0%" y1="0%" x2="100%" y2="100%">
          <stop offset="0%" style="stop-color:#1e3a8a;stop-opacity:1"/>
          <stop offset="100%" style="stop-color:#2563eb;stop-opacity:1"/>
        </linearGradient>
        <linearGradient id="glowGrad" x1="0%" y1="0%" x2="100%" y2="100%">
          <stop offset="0%" style="stop-color:#3b82f6;stop-opacity:0.3"/>
          <stop offset="100%" style="stop-color:#1d4ed8;stop-opacity:0"/>
        </linearGradient>
        <linearGradient id="trophyGrad" x1="0%" y1="0%" x2="100%" y2="100%">
          <stop offset="0%" style="stop-color:#fde68a;stop-opacity:0.95"/>
          <stop offset="100%" style="stop-color:#fbbf24;stop-opacity:0.95"/>
        </linearGradient>
        <radialGradient id="trophyGlow" cx="50%" cy="50%" r="50%">
          <stop offset="0%" style="stop-color:#fde68a;stop-opacity:0.4"/>
          <stop offset="60%" style="stop-color:#fbbf24;stop-opacity:0.15"/>
          <stop offset="100%" style="stop-color:#fbbf24;stop-opacity:0"/>
        </radialGradient>
      </defs>

      <rect width="1440" height="580" fill="url(#bgGrad)"/>

      <!-- Glow orbs -->
      <ellipse cx="350" cy="260" rx="380" ry="280" fill="url(#glowGrad)" class="glow-orb-1"/>
      <ellipse cx="1100" cy="280" rx="340" ry="240" fill="url(#glowGrad)" class="glow-orb-2"/>

      <!-- LEFT: Big golden trophy with glow halo behind -->
      <g class="trophy-bob">
        <!-- Soft golden glow halo behind trophy -->
        <ellipse cx="220" cy="260" rx="200" ry="180" fill="url(#trophyGlow)" class="trophy-halo"/>

        <g class="trophy-group" transform="translate(80, 130)">
        <!-- Trophy body -->
        <path d="M50 30 Q50 10 70 10 L210 10 Q230 10 230 30 L230 90 Q230 150 180 165 L180 200 L210 200 L210 240 L70 240 L70 200 L100 200 L100 165 Q50 150 50 90 Z"
              fill="url(#trophyGrad)" stroke="#fde68a" stroke-opacity="0.6" stroke-width="1.5" class="trophy-cup"/>
        <!-- Trophy handles -->
        <path d="M50 50 Q15 50 15 80 Q15 110 50 110" stroke="#fde68a" stroke-opacity="0.8" stroke-width="3" fill="none" class="trophy-handle"/>
        <path d="M230 50 Q265 50 265 80 Q265 110 230 110" stroke="#fde68a" stroke-opacity="0.8" stroke-width="3" fill="none" class="trophy-handle"/>
        <!-- Trophy base -->
        <rect x="60" y="240" width="160" height="20" rx="3" fill="#fbbf24" fill-opacity="0.85" class="trophy-base"/>
        <!-- Star on the cup -->
        <path d="M140 70 L150 95 L177 95 L155 110 L163 137 L140 121 L117 137 L125 110 L103 95 L130 95 Z"
              fill="white" fill-opacity="0.9" class="trophy-star"/>
      </g>
      </g>
      <!-- /trophy-bob -->

      <!-- RIGHT: Stack of "FREE" floating badges suggesting prize value
           NOTE: Each pill is positioned via x/y attributes on its rect+text rather
           than transform="translate()" because the CSS animation also uses transform
           and would override the SVG positioning.
           Hero text max-width: 38rem ≈ 608px in a 1440 viewport, so text spans
           roughly x=416-1024. Pills sit at x=1060-1300 with a ~36px buffer.
           Trophy sits at translate(80,130), spans x=80-380, also ~36px buffer. -->
      <g class="badge-stack">
        <!-- $2,000 prize value -->
        <g class="prize-pill p1">
          <rect x="1060" y="110" width="240" height="56" rx="14" fill="white" fill-opacity="0.12" stroke="#fde68a" stroke-opacity="0.6" stroke-width="1.5"/>
          <text x="1180" y="146" text-anchor="middle" fill="#fde68a" font-size="22" font-weight="900" font-family="ui-sans-serif, system-ui">$2,000 PRIZE</text>
        </g>
        <!-- 100% FREE -->
        <g class="prize-pill p2">
          <rect x="1060" y="180" width="240" height="56" rx="14" fill="white" fill-opacity="0.12" stroke="white" stroke-opacity="0.5" stroke-width="1.5"/>
          <text x="1180" y="216" text-anchor="middle" fill="white" font-size="22" font-weight="900" font-family="ui-sans-serif, system-ui">100% FREE ENTRY</text>
        </g>
        <!-- NH local only -->
        <g class="prize-pill p3">
          <rect x="1060" y="250" width="240" height="56" rx="14" fill="white" fill-opacity="0.12" stroke="#34d399" stroke-opacity="0.6" stroke-width="1.5"/>
          <text x="1180" y="286" text-anchor="middle" fill="#34d399" font-size="18" font-weight="900" font-family="ui-sans-serif, system-ui">NH BUSINESSES ONLY</text>
        </g>
        <!-- 20% off all entrants -->
        <g class="prize-pill p4">
          <rect x="1060" y="320" width="240" height="56" rx="14" fill="white" fill-opacity="0.12" stroke="#bfdbfe" stroke-opacity="0.5" stroke-width="1.5"/>
          <text x="1180" y="356" text-anchor="middle" fill="#bfdbfe" font-size="17" font-weight="900" font-family="ui-sans-serif, system-ui">20% OFF FOR EVERYONE</text>
        </g>
      </g>

      <!-- Ambient floating dots -->
      <g class="ambient-dots">
        <circle cx="540" cy="100" r="2" fill="white" fill-opacity="0.25" class="float-dot d1"/>
        <circle cx="900" cy="80" r="2.5" fill="white" fill-opacity="0.3" class="float-dot d2"/>
        <circle cx="540" cy="450" r="2" fill="white" fill-opacity="0.25" class="float-dot d3"/>
        <circle cx="900" cy="500" r="2" fill="white" fill-opacity="0.3" class="float-dot d4"/>
        <circle cx="700" cy="40" r="2" fill="white" fill-opacity="0.25" class="float-dot d5"/>
      </g>

      <!-- Decorative grid -->
      <g stroke="white" stroke-opacity="0.04" stroke-width="1">
        <line x1="0" y1="145" x2="1440" y2="145"/>
        <line x1="0" y1="290" x2="1440" y2="290"/>
        <line x1="0" y1="435" x2="1440" y2="435"/>
        <line x1="360" y1="0" x2="360" y2="580"/>
        <line x1="720" y1="0" x2="720" y2="580"/>
        <line x1="1080" y1="0" x2="1080" y2="580"/>
      </g>
    </svg>

    <!-- MOBILE SVG -->
    <svg class="hero-bg-mobile" viewBox="0 0 400 700" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <defs>
        <linearGradient id="bgGradM" x1="0%" y1="0%" x2="100%" y2="100%">
          <stop offset="0%" style="stop-color:#1e3a8a;stop-opacity:1"/>
          <stop offset="100%" style="stop-color:#2563eb;stop-opacity:1"/>
        </linearGradient>
        <linearGradient id="glowGradM" x1="0%" y1="0%" x2="100%" y2="100%">
          <stop offset="0%" style="stop-color:#3b82f6;stop-opacity:0.4"/>
          <stop offset="100%" style="stop-color:#1d4ed8;stop-opacity:0"/>
        </linearGradient>
        <linearGradient id="trophyGradM" x1="0%" y1="0%" x2="100%" y2="100%">
          <stop offset="0%" style="stop-color:#fde68a;stop-opacity:0.95"/>
          <stop offset="100%" style="stop-color:#fbbf24;stop-opacity:0.95"/>
        </linearGradient>
        <radialGradient id="trophyGlowM" cx="50%" cy="50%" r="50%">
          <stop offset="0%" style="stop-color:#fde68a;stop-opacity:0.4"/>
          <stop offset="60%" style="stop-color:#fbbf24;stop-opacity:0.15"/>
          <stop offset="100%" style="stop-color:#fbbf24;stop-opacity:0"/>
        </radialGradient>
      </defs>

      <rect width="400" height="700" fill="url(#bgGradM)"/>

      <ellipse cx="200" cy="180" rx="240" ry="200" fill="url(#glowGradM)" class="glow-orb-1"/>
      <ellipse cx="200" cy="600" rx="220" ry="160" fill="url(#glowGradM)" class="glow-orb-2"/>

      <!-- Trophy at top with glow halo -->
      <g class="trophy-bob">
        <ellipse cx="220" cy="130" rx="120" ry="110" fill="url(#trophyGlowM)" class="trophy-halo"/>

        <g class="trophy-group" transform="translate(150, 50)">
        <path d="M30 18 Q30 6 42 6 L126 6 Q138 6 138 18 L138 54 Q138 90 108 99 L108 120 L126 120 L126 144 L42 144 L42 120 L60 120 L60 99 Q30 90 30 54 Z"
              fill="url(#trophyGradM)" stroke="#fde68a" stroke-opacity="0.6" stroke-width="1" class="trophy-cup"/>
        <path d="M30 30 Q9 30 9 48 Q9 66 30 66" stroke="#fde68a" stroke-opacity="0.8" stroke-width="2" fill="none" class="trophy-handle"/>
        <path d="M138 30 Q159 30 159 48 Q159 66 138 66" stroke="#fde68a" stroke-opacity="0.8" stroke-width="2" fill="none" class="trophy-handle"/>
        <rect x="36" y="144" width="96" height="12" rx="2" fill="#fbbf24" fill-opacity="0.85" class="trophy-base"/>
        <path d="M84 42 L90 57 L106 57 L93 66 L98 82 L84 72 L70 82 L75 66 L62 57 L78 57 Z"
              fill="white" fill-opacity="0.9" class="trophy-star"/>
      </g>
      </g>
      <!-- /trophy-bob mobile -->

      <!-- Prize pills stacked -->
      <g class="badge-stack">
        <g class="prize-pill p1">
          <rect x="60" y="410" width="280" height="48" rx="12" fill="white" fill-opacity="0.12" stroke="#fde68a" stroke-opacity="0.6" stroke-width="1.5"/>
          <text x="200" y="442" text-anchor="middle" fill="#fde68a" font-size="20" font-weight="900" font-family="ui-sans-serif, system-ui">$2,000 PRIZE</text>
        </g>
        <g class="prize-pill p2">
          <rect x="60" y="470" width="280" height="48" rx="12" fill="white" fill-opacity="0.12" stroke="white" stroke-opacity="0.5" stroke-width="1.5"/>
          <text x="200" y="502" text-anchor="middle" fill="white" font-size="20" font-weight="900" font-family="ui-sans-serif, system-ui">100% FREE ENTRY</text>
        </g>
        <g class="prize-pill p3">
          <rect x="60" y="530" width="280" height="48" rx="12" fill="white" fill-opacity="0.12" stroke="#34d399" stroke-opacity="0.6" stroke-width="1.5"/>
          <text x="200" y="562" text-anchor="middle" fill="#34d399" font-size="17" font-weight="900" font-family="ui-sans-serif, system-ui">NH BUSINESSES ONLY</text>
        </g>
        <g class="prize-pill p4">
          <rect x="60" y="590" width="280" height="48" rx="12" fill="white" fill-opacity="0.12" stroke="#bfdbfe" stroke-opacity="0.5" stroke-width="1.5"/>
          <text x="200" y="622" text-anchor="middle" fill="#bfdbfe" font-size="16" font-weight="900" font-family="ui-sans-serif, system-ui">20% OFF FOR EVERYONE</text>
        </g>
      </g>

      <g stroke="white" stroke-opacity="0.04" stroke-width="1">
        <line x1="0" y1="170" x2="400" y2="170"/>
        <line x1="0" y1="340" x2="400" y2="340"/>
        <line x1="0" y1="510" x2="400" y2="510"/>
      </g>
    </svg>

    <!-- Hero text -->
    <div id="hero-content">
      <p class="hero-label">NH Local Business Giveaway · May 15–25, 2026</p>
      <h1 id="hero-wordmark">Win a Free<br/>$2,000 Website</h1>
      <p id="hero-tagline">A free professional 5-15 page website build for one lucky New Hampshire local business. Every other entrant gets 20% off any future website build. No purchase necessary. Just enter.</p>
      <div class="hero-cta-row">
        <a href="#giveaway-state" id="hero-cta">
          <span id="hero-cta-text">See Status &amp; Enter</span>
          <svg style="height:1rem;width:1rem;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M12 5v14M5 12l7 7 7-7"/></svg>
        </a>
      </div>
      <p class="hero-meta">Free entry. No purchase. NH-based businesses only.</p>
    </div>

    <div id="scroll-hint" aria-hidden="true" role="button" tabindex="-1" onclick="document.getElementById('giveaway-state').scrollIntoView({behavior:'smooth'})">
      <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" style="height:1.5rem;width:1.5rem;"><path d="M12 5v14M5 12l7 7 7-7"/></svg>
    </div>
  </section>

  <!-- =====================================================
       State-aware Giveaway Section
       Has 4 states: pre-launch, active, closed, announced.
       JS picks the right one on page load based on date.
       Default visible: PRE-LAUNCH (so WAVE/no-JS sees a valid page).
       ===================================================== -->
  <section id="giveaway-state" style="background:#f8fafc;padding:5rem 1.5rem;">
    <div style="max-width:64rem;margin:0 auto;">

      <!-- ============ STATE: PRE-LAUNCH (default visible) ============ -->
      <div id="state-prelaunch" class="state-block">
        <div style="text-align:center;margin-bottom:3rem;">
          <p class="section-eyebrow">Coming Soon</p>
          <h2 class="section-title">Entries open in...</h2>
          <p style="color:#6b7280;margin-top:0.75rem;max-width:36rem;margin-left:auto;margin-right:auto;line-height:1.75;">
            The giveaway officially opens on <strong style="color:#111827;">May 15, 2026 at 12:00 AM EST</strong>. The form will go live the moment the timer hits zero. Bookmark this page or come back then.
          </p>
        </div>

        <!-- Countdown timer -->
        <div class="countdown" aria-live="polite" aria-atomic="true">
          <div class="countdown-cell">
            <div class="countdown-num" id="cd-days">--</div>
            <div class="countdown-label">Days</div>
          </div>
          <div class="countdown-sep" aria-hidden="true">:</div>
          <div class="countdown-cell">
            <div class="countdown-num" id="cd-hours">--</div>
            <div class="countdown-label">Hours</div>
          </div>
          <div class="countdown-sep" aria-hidden="true">:</div>
          <div class="countdown-cell">
            <div class="countdown-num" id="cd-mins">--</div>
            <div class="countdown-label">Mins</div>
          </div>
          <div class="countdown-sep" aria-hidden="true">:</div>
          <div class="countdown-cell">
            <div class="countdown-num" id="cd-secs">--</div>
            <div class="countdown-label">Secs</div>
          </div>
        </div>

        <!-- Disabled full form preview -->
        <div class="form-disabled-wrap">
          <div class="form-disabled-overlay" aria-hidden="true">
            <div class="form-disabled-badge">
              <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" style="height:1.5rem;width:1.5rem;display:inline-block;vertical-align:-0.4rem;margin-right:0.5rem;"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
              Form Locked Until May 15
            </div>
          </div>
          <div class="form-disabled-content">
            <h3 style="font-size:1.25rem;font-weight:800;color:#111827;margin-bottom:0.5rem;text-align:center;">Entry Form Preview</h3>
            <p style="color:#6b7280;text-align:center;margin-bottom:2rem;font-size:0.9rem;">Here's exactly what the form will look like when entries open. You won't be able to submit until May 15 at midnight.</p>

            <p class="form-required-note">Fields marked * are required.</p>

            <div class="form-row">
              <label>Business Name *</label>
              <input type="text" disabled placeholder="e.g. Mountain View Bakery" aria-label="Business Name (preview, disabled)" />
            </div>

            <div class="form-row">
              <label>Owner / Contact Name *</label>
              <input type="text" disabled placeholder="Your full name" aria-label="Owner Name (preview, disabled)" />
            </div>

            <div class="form-row form-row-split">
              <div>
                <label>Email *</label>
                <input type="email" disabled placeholder="you@yourbusiness.com" aria-label="Email (preview, disabled)" />
              </div>
              <div>
                <label>Phone Number *</label>
                <input type="tel" disabled placeholder="(603) 555-1234" aria-label="Phone (preview, disabled)" />
              </div>
            </div>

            <div class="form-row">
              <label>NH Business Address *</label>
              <input type="text" disabled placeholder="Street, City, NH ZIP" aria-label="Business Address (preview, disabled)" />
              <p class="form-help">Must be a verified NH business address. Eligibility verified before prize is awarded.</p>
            </div>

            <div class="form-row">
              <label>State *</label>
              <select disabled aria-label="State (preview, disabled)">
                <option>Select state...</option>
              </select>
              <p class="form-help">Only NH-based businesses are eligible. Out-of-state entries are automatically disqualified.</p>
            </div>

            <div class="form-row">
              <label>Type of Business *</label>
              <select disabled aria-label="Business type (preview, disabled)">
                <option>Select type...</option>
              </select>
            </div>

            <div class="form-row">
              <label>Brief Description of Your Business *</label>
              <textarea disabled rows="3" placeholder="What does your business do? Where are you located in NH?" aria-label="Business description (preview, disabled)"></textarea>
              <p class="form-help">2-3 sentences is plenty.</p>
            </div>

            <div class="form-row">
              <label>What Would You Want From a Website? *</label>
              <textarea disabled rows="4" placeholder="e.g. Show our menu, get more bookings, make it easier for customers to find us, sell products online, etc." aria-label="Website goals (preview, disabled)"></textarea>
              <p class="form-help">Don't overthink it. Even 1 sentence is fine.</p>
            </div>

            <div class="form-row form-row-checkbox">
              <input type="checkbox" disabled aria-label="Rules agreement (preview, disabled)" />
              <label>
                I have read and agree to the <a href="#sweepstakes-rules">Official Sweepstakes Rules</a> and confirm my business is located in New Hampshire. *
              </label>
            </div>

            <div class="form-row form-row-checkbox">
              <input type="checkbox" disabled aria-label="Discount opt-in (preview, disabled)" />
              <label>
                I'd like to receive a 20% off discount on any future website build (automatically given to all verified entrants who don't win).
              </label>
            </div>

            <button type="button" disabled class="btn-primary" style="width:100%;justify-content:center;opacity:0.5;cursor:not-allowed;">
              <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" style="height:1rem;width:1rem;"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
              Locked — Opens May 15
            </button>
          </div>
        </div>
      </div>

      <!-- ============ STATE: ACTIVE (hidden by default, JS shows) ============ -->
      <div id="state-active" class="state-block" hidden>
        <div style="text-align:center;margin-bottom:2.5rem;">
          <p class="section-eyebrow" style="color:#16a34a;">Entries Open Now</p>
          <h2 class="section-title">Enter the Giveaway</h2>
          <p style="color:#6b7280;margin-top:0.75rem;max-width:36rem;margin-left:auto;margin-right:auto;line-height:1.75;">
            <span id="active-countdown-text">Entries close on May 25, 2026 at 12:00 AM EST.</span> Free to enter. NH businesses only.
          </p>
          <!-- Mini countdown showing time remaining -->
          <div class="countdown countdown-mini" aria-live="polite">
            <div class="countdown-cell"><div class="countdown-num" id="cd-active-days">--</div><div class="countdown-label">Days</div></div>
            <div class="countdown-cell"><div class="countdown-num" id="cd-active-hours">--</div><div class="countdown-label">Hours</div></div>
            <div class="countdown-cell"><div class="countdown-num" id="cd-active-mins">--</div><div class="countdown-label">Mins</div></div>
          </div>
        </div>

        <!-- Real Web3Forms entry form -->
        <form id="giveaway-form" action="https://api.web3forms.com/submit" method="POST" class="giveaway-form" novalidate>
          <!-- Web3Forms config -->
          <input type="hidden" name="access_key" value="REPLACE_WITH_YOUR_WEB3FORMS_ACCESS_KEY" />
          <input type="hidden" name="subject" value="🎉 New Giveaway Entry — NH Website Giveaway" />
          <input type="hidden" name="from_name" value="Jake Fixes Tech Giveaway" />
          <input type="hidden" name="redirect" value="false" />
          <!-- Honeypot anti-spam (must stay empty) -->
          <input type="checkbox" name="botcheck" id="botcheck" style="display:none !important" tabindex="-1" autocomplete="off" />

          <p class="form-required-note">Fields marked * are required.</p>

          <div class="form-row">
            <label for="biz-name">Business Name *</label>
            <input type="text" id="biz-name" name="business_name" required maxlength="120" placeholder="e.g. Mountain View Bakery" autocomplete="organization" />
          </div>

          <div class="form-row">
            <label for="owner-name">Owner / Contact Name *</label>
            <input type="text" id="owner-name" name="owner_name" required maxlength="120" placeholder="Your full name" autocomplete="name" />
          </div>

          <div class="form-row form-row-split">
            <div>
              <label for="email">Email *</label>
              <input type="email" id="email" name="email" required maxlength="200" placeholder="you@yourbusiness.com" autocomplete="email" />
            </div>
            <div>
              <label for="phone">Phone Number *</label>
              <input type="tel" id="phone" name="phone" required maxlength="30" placeholder="(603) 555-1234" autocomplete="tel" />
            </div>
          </div>

          <div class="form-row">
            <label for="biz-address">NH Business Address *</label>
            <input type="text" id="biz-address" name="business_address" required maxlength="200" placeholder="Street, City, NH ZIP" autocomplete="street-address" />
            <p class="form-help">Must be a verified NH business address. Eligibility verified before prize is awarded.</p>
          </div>

          <div class="form-row">
            <label for="state-confirm">State *</label>
            <select id="state-confirm" name="state" required>
              <option value="">Select state...</option>
              <option value="NH">New Hampshire (NH)</option>
              <option value="OTHER">Outside NH (not eligible)</option>
            </select>
            <p class="form-help">Only NH-based businesses are eligible. Out-of-state entries are automatically disqualified.</p>
          </div>

          <div class="form-row">
            <label for="biz-type">Type of Business *</label>
            <select id="biz-type" name="business_type" required>
              <option value="">Select type...</option>
              <option>Restaurant / Food Service</option>
              <option>Retail / Shop</option>
              <option>Service-Based (Plumber, Electrician, Contractor, etc.)</option>
              <option>Professional Services (Legal, Accounting, Consulting)</option>
              <option>Health / Wellness</option>
              <option>Trades / Construction</option>
              <option>Salon / Spa / Personal Care</option>
              <option>Auto Services</option>
              <option>Nonprofit / Community Org</option>
              <option>Real Estate</option>
              <option>Tech / Creative</option>
              <option>Other</option>
            </select>
          </div>

          <div class="form-row">
            <label for="biz-desc">Brief Description of Your Business *</label>
            <textarea id="biz-desc" name="business_description" required maxlength="500" rows="3" placeholder="What does your business do? Where are you located in NH?"></textarea>
            <p class="form-help">2-3 sentences is plenty.</p>
          </div>

          <div class="form-row">
            <label for="goals">What Would You Want From a Website? *</label>
            <textarea id="goals" name="website_goals" required maxlength="800" rows="4" placeholder="e.g. Show our menu, get more bookings, make it easier for customers to find us, sell products online, etc."></textarea>
