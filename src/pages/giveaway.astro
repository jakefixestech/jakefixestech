<!-- ============================================================
     Auto-state-transitioning JavaScript
     ============================================================ -->
<script is:inline>
  (function() {
    // Date constants — Eastern Time
    // May 15, 2026 00:00:00 EDT = 2026-05-15T00:00:00-04:00 (DST is in effect)
    // May 25, 2026 00:00:00 EDT = 2026-05-25T00:00:00-04:00
    // May 25, 2026 09:00:00 EDT = 2026-05-25T09:00:00-04:00
    var ENTRY_OPEN  = new Date('2026-05-15T00:00:00-04:00');
    var ENTRY_CLOSE = new Date('2026-05-25T00:00:00-04:00');
    var DRAWING     = new Date('2026-05-25T09:00:00-04:00');

    var states = {
      prelaunch: document.getElementById('state-prelaunch'),
      active:    document.getElementById('state-active'),
      closed:    document.getElementById('state-closed'),
      announced: document.getElementById('state-announced')
    };

    function showState(name) {
      Object.keys(states).forEach(function(key) {
        if (!states[key]) return;
        if (key === name) {
          states[key].hidden = false;
        } else {
          states[key].hidden = true;
        }
      });
    }

    function pad(n) { return n < 10 ? '0' + n : '' + n; }

    function pickState(now) {
      if (now < ENTRY_OPEN) return 'prelaunch';
      if (now < ENTRY_CLOSE) return 'active';
      if (now < DRAWING) return 'closed';
      return 'announced';
    }

    function updateCountdown() {
      var now = new Date();
      var state = pickState(now);
      showState(state);

      // Update CTA button text based on state
      var ctaText = document.getElementById('hero-cta-text');
      if (ctaText) {
        if (state === 'prelaunch') ctaText.textContent = 'See Countdown';
        else if (state === 'active') ctaText.textContent = 'Enter Now';
        else if (state === 'closed') ctaText.textContent = 'See Status';
        else if (state === 'announced') ctaText.textContent = 'See Winner';
      }

      if (state === 'prelaunch') {
        var diff = Math.max(0, ENTRY_OPEN - now);
        var d = Math.floor(diff / 86400000);
        var h = Math.floor((diff % 86400000) / 3600000);
        var m = Math.floor((diff % 3600000) / 60000);
        var s = Math.floor((diff % 60000) / 1000);
        var dd = document.getElementById('cd-days');
        var hh = document.getElementById('cd-hours');
        var mm = document.getElementById('cd-mins');
        var ss = document.getElementById('cd-secs');
        if (dd) dd.textContent = pad(d);
        if (hh) hh.textContent = pad(h);
        if (mm) mm.textContent = pad(m);
        if (ss) ss.textContent = pad(s);
      } else if (state === 'active') {
        var diff = Math.max(0, ENTRY_CLOSE - now);
        var d = Math.floor(diff / 86400000);
        var h = Math.floor((diff % 86400000) / 3600000);
        var m = Math.floor((diff % 3600000) / 60000);
        var dd = document.getElementById('cd-active-days');
        var hh = document.getElementById('cd-active-hours');
        var mm = document.getElementById('cd-active-mins');
        if (dd) dd.textContent = pad(d);
        if (hh) hh.textContent = pad(h);
        if (mm) mm.textContent = pad(m);
      }
    }

    updateCountdown();
    setInterval(updateCountdown, 1000);
  })();
</script>

<!-- ============================================================
     Form submission handler — AJAX to Web3Forms
     ============================================================ -->
<script is:inline>
  (function() {
    var form = document.getElementById('giveaway-form');
    if (!form) return;

    form.addEventListener('submit', function(e) {
      e.preventDefault();

      var btn = document.getElementById('submit-btn');
      var btnText = document.getElementById('submit-btn-text');
      var errorEl = document.getElementById('form-error');
      var successEl = document.getElementById('form-success');

      if (errorEl) errorEl.hidden = true;

      // Validate state field — must be NH
      var state = form.querySelector('#state-confirm');
      if (state && state.value !== 'NH') {
        if (errorEl) {
          errorEl.textContent = 'This giveaway is open to New Hampshire businesses only. If your business is located in NH, please select "New Hampshire (NH)" from the dropdown.';
          errorEl.hidden = false;
        }
        state.focus();
        return;
      }

      btn.disabled = true;
      if (btnText) btnText.textContent = 'Submitting...';

      var formData = new FormData(form);
      var json = {};
      formData.forEach(function(value, key) { json[key] = value; });

      fetch('https://api.web3forms.com/submit', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'Accept': 'application/json'
        },
        body: JSON.stringify(json)
      })
      .then(function(response) { return response.json(); })
      .then(function(data) {
        if (data.success) {
          form.hidden = true;
          if (successEl) successEl.hidden = false;
          // Scroll the success message into view
          if (successEl) successEl.scrollIntoView({ behavior: 'smooth', block: 'center' });
        } else {
          throw new Error(data.message || 'Submission failed');
        }
      })
      .catch(function(err) {
        btn.disabled = false;
        if (btnText) btnText.textContent = 'Submit My Entry';
        if (errorEl) {
          errorEl.textContent = 'Something went wrong submitting your entry. Please try again or email jake@jakefixestech.com.';
          errorEl.hidden = false;
        }
      });
    });
  })();
</script>

