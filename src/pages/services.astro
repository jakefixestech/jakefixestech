---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Computer Repair Services | Jake Fixes Tech — Littleton, NH"
description="Screen repair, virus removal, data recovery, hardware upgrades, gaming console repair and more. Flat rate pricing, no hidden fees. Serving Littleton NH.">

  <!-- Animated SVG Hero -->
  <section id="hero-svg" aria-label="Computer repair services">

    <!-- DESKTOP SVG -->
    <svg class="hero-bg-desktop" viewBox="0 0 1440 520" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <defs>
        <linearGradient id="bgGrad" x1="0%" y1="0%" x2="100%" y2="100%">
          <stop offset="0%" style="stop-color:#1e3a8a;stop-opacity:1"/>
          <stop offset="100%" style="stop-color:#2563eb;stop-opacity:1"/>
        </linearGradient>
        <linearGradient id="glowGrad" x1="0%" y1="0%" x2="100%" y2="100%">
          <stop offset="0%" style="stop-color:#3b82f6;stop-opacity:0.25"/>
          <stop offset="100%" style="stop-color:#1d4ed8;stop-opacity:0"/>
        </linearGradient>
        <radialGradient id="tileGlow" cx="50%" cy="50%" r="50%">
          <stop offset="0%" style="stop-color:white;stop-opacity:0.12"/>
          <stop offset="100%" style="stop-color:white;stop-opacity:0"/>
        </radialGradient>
      </defs>
      <rect width="1440" height="520" fill="url(#bgGrad)"/>
      <ellipse cx="280" cy="240" rx="360" ry="260" fill="url(#glowGrad)" class="glow-orb-1"/>
      <ellipse cx="1200" cy="300" rx="340" ry="240" fill="url(#glowGrad)" class="glow-orb-2"/>

      <!-- PERSON AT DESK — left side, side-profile working at computer -->
      <g class="desk-scene" transform="translate(100, 180)">
        <!-- Floor line -->
        <line x1="-20" y1="240" x2="380" y2="240" stroke="white" stroke-opacity="0.2" stroke-width="1.5" class="ds-floor"/>

        <!-- DESK -->
        <!-- Desk surface -->
        <rect x="120" y="150" width="240" height="8" rx="1" stroke="white" stroke-opacity="0.35" stroke-width="1.5" fill="white" fill-opacity="0.12" class="ds-desk"/>
        <!-- Desk front edge / apron -->
        <rect x="120" y="158" width="240" height="6" stroke="white" stroke-opacity="0.2" stroke-width="1" fill="white" fill-opacity="0.06" class="ds-desk"/>
        <!-- Desk legs -->
        <line x1="135" y1="164" x2="135" y2="240" stroke="white" stroke-opacity="0.3" stroke-width="2" class="ds-desk"/>
        <line x1="345" y1="164" x2="345" y2="240" stroke="white" stroke-opacity="0.3" stroke-width="2" class="ds-desk"/>

        <!-- MONITOR — on desk -->
        <g class="ds-monitor">
          <!-- Monitor bezel -->
          <rect x="230" y="60" width="120" height="80" rx="3" stroke="white" stroke-opacity="0.4" stroke-width="2" fill="white" fill-opacity="0.08"/>
          <!-- Screen content area (inner rect) -->
          <rect x="236" y="66" width="108" height="68" rx="1.5" stroke="white" stroke-opacity="0.2" stroke-width="1" fill="white" fill-opacity="0.04"/>
          <!-- Stand neck -->
          <rect x="282" y="140" width="16" height="6" fill="white" fill-opacity="0.25"/>
          <!-- Stand base -->
          <path d="M268 150 L312 150 L308 146 L272 146 Z" stroke="white" stroke-opacity="0.3" stroke-width="1.5" fill="white" fill-opacity="0.12"/>

          <!-- Screen content — code/text lines that pulse-update -->
          <g class="ds-screen-content">
            <line class="ds-code ds-code-1" x1="242" y1="74" x2="282" y2="74" stroke="white" stroke-opacity="0.55" stroke-width="2" stroke-linecap="round"/>
            <line class="ds-code ds-code-2" x1="242" y1="82" x2="312" y2="82" stroke="white" stroke-opacity="0.5" stroke-width="2" stroke-linecap="round"/>
            <line class="ds-code ds-code-3" x1="250" y1="90" x2="296" y2="90" stroke="white" stroke-opacity="0.5" stroke-width="2" stroke-linecap="round"/>
            <line class="ds-code ds-code-4" x1="250" y1="98" x2="326" y2="98" stroke="white" stroke-opacity="0.5" stroke-width="2" stroke-linecap="round"/>
            <line class="ds-code ds-code-5" x1="242" y1="106" x2="288" y2="106" stroke="white" stroke-opacity="0.5" stroke-width="2" stroke-linecap="round"/>
            <line class="ds-code ds-code-6" x1="258" y1="114" x2="318" y2="114" stroke="white" stroke-opacity="0.5" stroke-width="2" stroke-linecap="round"/>
            <!-- Blinking cursor at end of current line -->
            <rect class="ds-cursor" x="320" y="110" width="6" height="8" fill="white" fill-opacity="0.8"/>
          </g>
        </g>

        <!-- KEYBOARD on desk -->
        <g class="ds-keyboard">
          <rect x="150" y="142" width="70" height="8" rx="1" stroke="white" stroke-opacity="0.35" stroke-width="1.2" fill="white" fill-opacity="0.1"/>
          <!-- Key details -->
          <line x1="156" y1="146" x2="214" y2="146" stroke="white" stroke-opacity="0.2" stroke-width="0.8"/>
        </g>

        <!-- CHAIR — behind person -->
        <g class="ds-chair">
          <!-- Chair back (tall) -->
          <rect x="46" y="110" width="10" height="70" rx="2" stroke="white" stroke-opacity="0.3" stroke-width="1.5" fill="white" fill-opacity="0.08"/>
          <!-- Chair seat -->
          <rect x="40" y="178" width="60" height="8" rx="1.5" stroke="white" stroke-opacity="0.3" stroke-width="1.5" fill="white" fill-opacity="0.1"/>
          <!-- Seat post -->
          <line x1="70" y1="186" x2="70" y2="220" stroke="white" stroke-opacity="0.3" stroke-width="2"/>
          <!-- 5-star chair base (two visible legs in side view) -->
          <line x1="70" y1="220" x2="52" y2="238" stroke="white" stroke-opacity="0.3" stroke-width="2" stroke-linecap="round"/>
          <line x1="70" y1="220" x2="88" y2="238" stroke="white" stroke-opacity="0.3" stroke-width="2" stroke-linecap="round"/>
          <!-- Wheels -->
          <circle cx="50" cy="238" r="2.5" stroke="white" stroke-opacity="0.35" stroke-width="1" fill="white" fill-opacity="0.15"/>
          <circle cx="90" cy="238" r="2.5" stroke="white" stroke-opacity="0.35" stroke-width="1" fill="white" fill-opacity="0.15"/>
        </g>

        <!-- PERSON — side profile, seated, arm extended to keyboard -->
        <g class="ds-person">
          <!-- Torso (trapezoid shoulder-to-hip, leaning slightly forward) -->
          <path d="M72 128 L112 120 L122 178 L74 180 Z"
            stroke="white" stroke-opacity="0.5" stroke-width="2" fill="white" fill-opacity="0.12" stroke-linejoin="round"/>
          <!-- Neck -->
          <line x1="106" y1="118" x2="108" y2="108" stroke="white" stroke-opacity="0.5" stroke-width="3.5" stroke-linecap="round"/>
          <!-- Head (with slight nod) -->
          <g class="ds-head" transform-origin="108 100">
            <circle cx="108" cy="96" r="14" stroke="white" stroke-opacity="0.55" stroke-width="2" fill="white" fill-opacity="0.12"/>
            <!-- Hair suggestion (small cap on top) -->
            <path d="M96 92 Q108 80 120 92" stroke="white" stroke-opacity="0.55" stroke-width="2" fill="none" stroke-linecap="round"/>
            <!-- Ear dot -->
            <circle cx="100" cy="98" r="1.5" fill="white" fill-opacity="0.5"/>
          </g>

          <!-- Upper arm (shoulder to elbow, reaching forward toward keyboard) -->
          <line x1="114" y1="128" x2="150" y2="138" stroke="white" stroke-opacity="0.5" stroke-width="4" stroke-linecap="round"/>
          <!-- Forearm + hand (elbow to keyboard) — this is the animated piece -->
          <g class="ds-arm" transform-origin="150 138">
            <line x1="150" y1="138" x2="180" y2="142" stroke="white" stroke-opacity="0.5" stroke-width="4" stroke-linecap="round"/>
            <!-- Hand -->
            <ellipse cx="186" cy="142" rx="7" ry="4" stroke="white" stroke-opacity="0.5" stroke-width="1.5" fill="white" fill-opacity="0.15"/>
          </g>

          <!-- Leg (seated, knee bent, foot on floor) -->
          <path d="M100 180 L120 210 L140 230" stroke="white" stroke-opacity="0.45" stroke-width="4" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
          <!-- Shoe -->
          <ellipse cx="144" cy="234" rx="8" ry="3" stroke="white" stroke-opacity="0.5" stroke-width="1.5" fill="white" fill-opacity="0.15"/>
        </g>
      </g>

      <!-- SERVICE TILES GRID — right side, 3x2 tiles -->
      <g class="tile-grid" transform="translate(1060, 160)">
        <!-- Tile 1: Laptop/screen -->
        <g class="tile tile-1" transform="translate(0, 0)">
          <rect x="0" y="0" width="80" height="80" rx="8" stroke="white" stroke-opacity="0.25" stroke-width="1.5" fill="white" fill-opacity="0.08"/>
          <circle cx="40" cy="40" r="35" fill="url(#tileGlow)" class="tile-glow"/>
          <g transform="translate(24, 24)" stroke="white" stroke-opacity="0.9" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="6" width="28" height="18" rx="1.5"/>
            <line x1="8" y1="30" x2="24" y2="30"/>
            <line x1="14" y1="26" x2="18" y2="26"/>
          </g>
        </g>
        <!-- Tile 2: Virus/shield with check -->
        <g class="tile tile-2" transform="translate(100, 0)">
          <rect x="0" y="0" width="80" height="80" rx="8" stroke="white" stroke-opacity="0.25" stroke-width="1.5" fill="white" fill-opacity="0.08"/>
          <circle cx="40" cy="40" r="35" fill="url(#tileGlow)" class="tile-glow"/>
          <g transform="translate(24, 22)" stroke="white" stroke-opacity="0.9" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M16 2 L2 8 L2 20 C2 28 16 34 16 34 C16 34 30 28 30 20 L30 8 Z"/>
            <path d="M10 18 L14 22 L22 12"/>
          </g>
        </g>
        <!-- Tile 3: Hardware/chip (simplified — 4 tick marks instead of 8) -->
        <g class="tile tile-3" transform="translate(200, 0)">
          <rect x="0" y="0" width="80" height="80" rx="8" stroke="white" stroke-opacity="0.25" stroke-width="1.5" fill="white" fill-opacity="0.08"/>
          <circle cx="40" cy="40" r="35" fill="url(#tileGlow)" class="tile-glow"/>
          <g transform="translate(22, 22)" stroke="white" stroke-opacity="0.9" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="6" y="6" width="24" height="24" rx="2"/>
            <rect x="13" y="13" width="10" height="10"/>
            <line x1="18" y1="2" x2="18" y2="6"/>
            <line x1="18" y1="30" x2="18" y2="34"/>
            <line x1="2" y1="18" x2="6" y2="18"/>
            <line x1="30" y1="18" x2="34" y2="18"/>
          </g>
        </g>
        <!-- Tile 4: Data/disk -->
        <g class="tile tile-4" transform="translate(0, 100)">
          <rect x="0" y="0" width="80" height="80" rx="8" stroke="white" stroke-opacity="0.25" stroke-width="1.5" fill="white" fill-opacity="0.08"/>
          <circle cx="40" cy="40" r="35" fill="url(#tileGlow)" class="tile-glow"/>
          <g transform="translate(22, 22)" stroke="white" stroke-opacity="0.9" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <ellipse cx="18" cy="10" rx="16" ry="4"/>
            <path d="M2 10 C2 12.5 9 15 18 15 S34 12.5 34 10"/>
            <path d="M2 10 L2 26 C2 28.5 9 31 18 31 S34 28.5 34 26 L34 10"/>
          </g>
        </g>
        <!-- Tile 5: Tools/wrench -->
        <g class="tile tile-5" transform="translate(100, 100)">
          <rect x="0" y="0" width="80" height="80" rx="8" stroke="white" stroke-opacity="0.25" stroke-width="1.5" fill="white" fill-opacity="0.08"/>
          <circle cx="40" cy="40" r="35" fill="url(#tileGlow)" class="tile-glow"/>
          <g transform="translate(22, 22)" stroke="white" stroke-opacity="0.9" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M22 6 L28 12 L14 26 L8 20 Z"/>
            <line x1="14" y1="26" x2="6" y2="34"/>
            <circle cx="26" cy="10" r="3"/>
          </g>
        </g>
        <!-- Tile 6: Gaming/controller -->
        <g class="tile tile-6" transform="translate(200, 100)">
          <rect x="0" y="0" width="80" height="80" rx="8" stroke="white" stroke-opacity="0.25" stroke-width="1.5" fill="white" fill-opacity="0.08"/>
          <circle cx="40" cy="40" r="35" fill="url(#tileGlow)" class="tile-glow"/>
          <g transform="translate(20, 26)" stroke="white" stroke-opacity="0.9" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="4" width="36" height="22" rx="3"/>
            <line x1="10" y1="15" x2="14" y2="15"/>
            <line x1="12" y1="13" x2="12" y2="17"/>
            <circle cx="28" cy="13" r="1.5" fill="white"/>
            <circle cx="32" cy="17" r="1.5" fill="white"/>
          </g>
        </g>
      </g>

      <!-- AMBIENT REPAIR ICONS — checkmarks, plus signs, small wrenches, gently drifting -->
      <g class="icon-field">
        <!-- Checkmark in circle, top left -->
        <g class="ambient-icon ai-1" transform="translate(80, 60)">
          <g stroke="white" stroke-opacity="0.1" fill="none" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="0" cy="0" r="12"/>
            <path d="M-5 0 L-1 4 L5 -4"/>
          </g>
        </g>
        <!-- Plus/medical cross, top center -->
        <g class="ambient-icon ai-2" transform="translate(560, 50)">
          <g stroke="white" stroke-opacity="0.11" fill="none" stroke-width="2" stroke-linecap="round">
            <line x1="0" y1="-10" x2="0" y2="10"/>
            <line x1="-10" y1="0" x2="10" y2="0"/>
          </g>
        </g>
        <!-- Small wrench, upper right -->
        <g class="ambient-icon ai-3" transform="translate(880, 90)">
          <g stroke="white" stroke-opacity="0.1" fill="none" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <!-- Wrench shape: head + handle, drawn tilted -->
            <path d="M-12 12 L2 -2 M-12 12 L-16 8 L-18 14 L-14 16 Z" transform="rotate(25)"/>
            <circle cx="4" cy="-4" r="3" transform="rotate(25)"/>
          </g>
        </g>
        <!-- Checkmark in circle, lower left -->
        <g class="ambient-icon ai-4" transform="translate(480, 440)">
          <g stroke="white" stroke-opacity="0.1" fill="none" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="0" cy="0" r="14"/>
            <path d="M-6 0 L-1 5 L6 -5"/>
          </g>
        </g>
        <!-- Plus sign, lower right -->
        <g class="ambient-icon ai-5" transform="translate(1340, 450)">
          <g stroke="white" stroke-opacity="0.1" fill="none" stroke-width="2" stroke-linecap="round">
            <line x1="0" y1="-9" x2="0" y2="9"/>
            <line x1="-9" y1="0" x2="9" y2="0"/>
          </g>
        </g>
        <!-- Small wrench, mid left -->
        <g class="ambient-icon ai-6" transform="translate(60, 420)">
          <g stroke="white" stroke-opacity="0.11" fill="none" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M-10 10 L2 -2 M-10 10 L-14 6 L-16 12 L-12 14 Z" transform="rotate(-15)"/>
            <circle cx="4" cy="-4" r="2.5" transform="rotate(-15)"/>
          </g>
        </g>
        <!-- Checkmark circle, far right top -->
        <g class="ambient-icon ai-7" transform="translate(1380, 80)">
          <g stroke="white" stroke-opacity="0.1" fill="none" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="0" cy="0" r="11"/>
            <path d="M-5 0 L-1 4 L5 -4"/>
          </g>
        </g>
      </g>

      <!-- Grid -->
      <g stroke="white" stroke-opacity="0.04" stroke-width="1">
        <line x1="0" y1="130" x2="1440" y2="130"/>
        <line x1="0" y1="260" x2="1440" y2="260"/>
        <line x1="360" y1="0" x2="360" y2="520"/>
        <line x1="720" y1="0" x2="720" y2="520"/>
        <line x1="1080" y1="0" x2="1080" y2="520"/>
      </g>
    </svg>

    <!-- MOBILE SVG -->
    <svg class="hero-bg-mobile" viewBox="0 0 400 600" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <defs>
        <linearGradient id="bgGradM" x1="0%" y1="0%" x2="100%" y2="100%">
          <stop offset="0%" style="stop-color:#1e3a8a;stop-opacity:1"/>
          <stop offset="100%" style="stop-color:#2563eb;stop-opacity:1"/>
        </linearGradient>
        <linearGradient id="glowGradM" x1="0%" y1="0%" x2="100%" y2="100%">
          <stop offset="0%" style="stop-color:#3b82f6;stop-opacity:0.3"/>
          <stop offset="100%" style="stop-color:#1d4ed8;stop-opacity:0"/>
        </linearGradient>
        <radialGradient id="tileGlowM" cx="50%" cy="50%" r="50%">
          <stop offset="0%" style="stop-color:white;stop-opacity:0.12"/>
          <stop offset="100%" style="stop-color:white;stop-opacity:0"/>
        </radialGradient>
      </defs>
      <rect width="400" height="600" fill="url(#bgGradM)"/>
      <ellipse cx="100" cy="160" rx="220" ry="180" fill="url(#glowGradM)" class="glow-orb-1"/>
      <ellipse cx="320" cy="480" rx="220" ry="180" fill="url(#glowGradM)" class="glow-orb-2"/>

      <!-- PERSON AT DESK — mobile, top, scaled for small canvas -->
      <g class="desk-scene" transform="translate(80, 20) scale(0.75)">
        <!-- Floor line -->
        <line x1="-20" y1="200" x2="340" y2="200" stroke="white" stroke-opacity="0.2" stroke-width="1.2" class="ds-floor"/>

        <!-- Desk -->
        <rect x="100" y="125" width="200" height="6" rx="1" stroke="white" stroke-opacity="0.35" stroke-width="1.2" fill="white" fill-opacity="0.12" class="ds-desk"/>
        <rect x="100" y="131" width="200" height="5" stroke="white" stroke-opacity="0.2" stroke-width="0.8" fill="white" fill-opacity="0.06" class="ds-desk"/>
        <line x1="115" y1="136" x2="115" y2="200" stroke="white" stroke-opacity="0.3" stroke-width="1.5" class="ds-desk"/>
        <line x1="285" y1="136" x2="285" y2="200" stroke="white" stroke-opacity="0.3" stroke-width="1.5" class="ds-desk"/>

        <!-- Monitor -->
        <g class="ds-monitor">
          <rect x="190" y="50" width="100" height="66" rx="2.5" stroke="white" stroke-opacity="0.4" stroke-width="1.5" fill="white" fill-opacity="0.08"/>
          <rect x="195" y="55" width="90" height="56" rx="1" stroke="white" stroke-opacity="0.2" stroke-width="0.8" fill="white" fill-opacity="0.04"/>
          <rect x="234" y="116" width="12" height="5" fill="white" fill-opacity="0.25"/>
          <path d="M222 125 L258 125 L255 121 L225 121 Z" stroke="white" stroke-opacity="0.3" stroke-width="1.2" fill="white" fill-opacity="0.12"/>

          <g class="ds-screen-content">
            <line class="ds-code ds-code-1" x1="200" y1="62" x2="232" y2="62" stroke="white" stroke-opacity="0.55" stroke-width="1.8" stroke-linecap="round"/>
            <line class="ds-code ds-code-2" x1="200" y1="70" x2="258" y2="70" stroke="white" stroke-opacity="0.5" stroke-width="1.8" stroke-linecap="round"/>
            <line class="ds-code ds-code-3" x1="206" y1="78" x2="244" y2="78" stroke="white" stroke-opacity="0.5" stroke-width="1.8" stroke-linecap="round"/>
            <line class="ds-code ds-code-4" x1="206" y1="86" x2="270" y2="86" stroke="white" stroke-opacity="0.5" stroke-width="1.8" stroke-linecap="round"/>
            <line class="ds-code ds-code-5" x1="200" y1="94" x2="238" y2="94" stroke="white" stroke-opacity="0.5" stroke-width="1.8" stroke-linecap="round"/>
            <line class="ds-code ds-code-6" x1="214" y1="102" x2="262" y2="102" stroke="white" stroke-opacity="0.5" stroke-width="1.8" stroke-linecap="round"/>
            <rect class="ds-cursor" x="264" y="98" width="5" height="7" fill="white" fill-opacity="0.8"/>
          </g>
        </g>

        <!-- Keyboard -->
        <g class="ds-keyboard">
          <rect x="128" y="118" width="56" height="6" rx="1" stroke="white" stroke-opacity="0.35" stroke-width="1" fill="white" fill-opacity="0.1"/>
        </g>

        <!-- Chair -->
        <g class="ds-chair">
          <rect x="40" y="92" width="8" height="58" rx="1.5" stroke="white" stroke-opacity="0.3" stroke-width="1.2" fill="white" fill-opacity="0.08"/>
          <rect x="34" y="148" width="50" height="6" rx="1.2" stroke="white" stroke-opacity="0.3" stroke-width="1.2" fill="white" fill-opacity="0.1"/>
          <line x1="58" y1="154" x2="58" y2="182" stroke="white" stroke-opacity="0.3" stroke-width="1.5"/>
          <line x1="58" y1="182" x2="42" y2="198" stroke="white" stroke-opacity="0.3" stroke-width="1.5" stroke-linecap="round"/>
          <line x1="58" y1="182" x2="74" y2="198" stroke="white" stroke-opacity="0.3" stroke-width="1.5" stroke-linecap="round"/>
          <circle cx="40" cy="198" r="2" stroke="white" stroke-opacity="0.35" stroke-width="0.8" fill="white" fill-opacity="0.15"/>
          <circle cx="76" cy="198" r="2" stroke="white" stroke-opacity="0.35" stroke-width="0.8" fill="white" fill-opacity="0.15"/>
        </g>

        <!-- Person -->
        <g class="ds-person">
          <path d="M60 108 L94 102 L102 150 L62 152 Z"
            stroke="white" stroke-opacity="0.5" stroke-width="1.5" fill="white" fill-opacity="0.12" stroke-linejoin="round"/>
          <line x1="89" y1="100" x2="91" y2="92" stroke="white" stroke-opacity="0.5" stroke-width="3" stroke-linecap="round"/>
          <g class="ds-head" transform-origin="91 86">
            <circle cx="91" cy="82" r="12" stroke="white" stroke-opacity="0.55" stroke-width="1.5" fill="white" fill-opacity="0.12"/>
            <path d="M81 78 Q91 68 101 78" stroke="white" stroke-opacity="0.55" stroke-width="1.5" fill="none" stroke-linecap="round"/>
            <circle cx="84" cy="84" r="1.2" fill="white" fill-opacity="0.5"/>
          </g>
          <line x1="96" y1="108" x2="126" y2="116" stroke="white" stroke-opacity="0.5" stroke-width="3" stroke-linecap="round"/>
          <g class="ds-arm" transform-origin="126 116">
            <line x1="126" y1="116" x2="152" y2="118" stroke="white" stroke-opacity="0.5" stroke-width="3" stroke-linecap="round"/>
