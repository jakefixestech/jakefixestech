---
import Layout from '../layouts/Layout.astro';
import content from '../content/about.yml';
---

<Layout title="About Jake | Jake Fixes Tech in Littleton, NH"
description="Meet Jake Charland, Computer Information Systems graduate, former college instructor and 10+ year IT veteran. Serving Littleton NH and the North Country.">

  <!-- Animated SVG Hero -->
  <section id="hero-svg" aria-label="About Jake">

    <!-- DESKTOP SVG -->
    <svg class="hero-bg-desktop" viewBox="0 0 1440 520" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <defs>
        <linearGradient id="bgGrad" x1="0%" y1="0%" x2="100%" y2="100%">
          <stop offset="0%" style="stop-color:#1e3a8a;stop-opacity:1"/>
          <stop offset="100%" style="stop-color:#2563eb;stop-opacity:1"/>
        </linearGradient>
        <linearGradient id="glowGrad" x1="0%" y1="0%" x2="100%" y2="100%">
          <stop offset="0%" style="stop-color:#3b82f6;stop-opacity:0.25"/>
          <stop offset="100%" style="stop-color:#1d4ed8;stop-opacity:0"/>
        </linearGradient>
      </defs>
      <rect width="1440" height="520" fill="url(#bgGrad)"/>
      <ellipse cx="280" cy="240" rx="360" ry="260" fill="url(#glowGrad)" class="glow-orb-1"/>
      <ellipse cx="1200" cy="300" rx="340" ry="240" fill="url(#glowGrad)" class="glow-orb-2"/>

      <!-- Mountains stay anchored to bottom — they ARE the bottom. Bottom of polygons at y:520 is the gradient floor, no harm if cropped on ultrawide -->
      <g class="mountains">
        <polygon points="0,520 100,350 220,450 380,280 520,410 660,300 780,420 900,310 1040,440 1180,300 1320,420 1440,350 1440,520"
          fill="white" fill-opacity="0.05" stroke="white" stroke-opacity="0.08" stroke-width="1" class="mountain-back"/>
        <polygon points="0,520 60,430 160,490 280,370 420,470 540,360 680,470 800,380 940,480 1080,370 1220,470 1360,400 1440,440 1440,520"
          fill="white" fill-opacity="0.08" stroke="white" stroke-opacity="0.14" stroke-width="1.5" class="mountain-front"/>
        <polygon points="380,280 398,256 416,280" fill="white" fill-opacity="0.22" class="snow snow-1"/>
        <polygon points="660,300 676,278 692,300" fill="white" fill-opacity="0.2" class="snow snow-2"/>
        <polygon points="900,310 916,288 932,310" fill="white" fill-opacity="0.22" class="snow snow-3"/>
        <polygon points="1180,300 1196,278 1212,300" fill="white" fill-opacity="0.18" class="snow snow-4"/>
      </g>

      <!-- DIPLOMA SCROLL — y:180 stays. Diploma extends from y:210 (top curl) to y:390 (bottom of seal/ribbon) — fits inside safe zone (75-445). -->
      <g class="diploma-group" transform="translate(100, 180)">
        <rect x="0" y="30" width="240" height="180" rx="4"
          stroke="white" stroke-opacity="0.22" stroke-width="2"
          fill="white" fill-opacity="0.07" class="diploma-body"/>
        <ellipse cx="120" cy="30" rx="120" ry="16"
          stroke="white" stroke-opacity="0.2" stroke-width="1.5"
          fill="white" fill-opacity="0.08" class="diploma-curl-top"/>
        <ellipse cx="120" cy="210" rx="120" ry="16"
          stroke="white" stroke-opacity="0.2" stroke-width="1.5"
          fill="white" fill-opacity="0.08" class="diploma-curl-bot"/>
        <ellipse cx="120" cy="30" rx="100" ry="11" stroke="white" stroke-opacity="0.08" stroke-width="1" fill="none"/>
        <ellipse cx="120" cy="210" rx="100" ry="11" stroke="white" stroke-opacity="0.08" stroke-width="1" fill="none"/>

        <text x="120" y="70" text-anchor="middle" fill="white" fill-opacity="0.5" font-size="11" font-family="serif" font-style="italic" class="diploma-text dip-t1">Certificate of Achievement</text>
        <line x1="20" y1="78" x2="220" y2="78" stroke="white" stroke-opacity="0.15" stroke-width="1" class="diploma-rule"/>

        <text x="120" y="108" text-anchor="middle" fill="white" fill-opacity="0.6" font-size="18" font-weight="700" font-family="serif" class="diploma-text dip-t2">CIS</text>
        <text x="120" y="128" text-anchor="middle" fill="white" fill-opacity="0.35" font-size="8" font-family="monospace" class="diploma-text dip-t3">COMPUTER INFORMATION</text>
        <text x="120" y="140" text-anchor="middle" fill="white" fill-opacity="0.35" font-size="8" font-family="monospace" class="diploma-text dip-t4">SYSTEMS</text>

        <circle cx="120" cy="175" r="20"
          stroke="white" stroke-opacity="0.3" stroke-width="2"
          fill="white" fill-opacity="0.08" class="diploma-seal"/>
        <circle cx="120" cy="175" r="14"
          stroke="white" stroke-opacity="0.2" stroke-width="1"
          fill="none" class="diploma-seal"/>
        <polygon points="120,164 122.4,171.6 130,171.6 124,176.4 126.4,184 120,179.2 113.6,184 116,176.4 110,171.6 117.6,171.6"
          fill="white" fill-opacity="0.35" class="diploma-star"/>
        <path d="M102 194 L110 202 L120 196 L130 202 L138 194" stroke="white" stroke-opacity="0.2" stroke-width="1.5" fill="none" stroke-linecap="round" class="diploma-star"/>
      </g>

      <!-- YEARS BADGE — y:140 stays. Outer ring r:82 means top edge at y:140-2=138, well inside safe zone. -->
      <g class="years-badge" transform="translate(1180, 140)">
        <circle cx="70" cy="80" r="82" stroke="white" stroke-opacity="0.1" stroke-width="1.5" fill="none" stroke-dasharray="6 4" class="badge-outer"/>
        <circle cx="70" cy="80" r="68" stroke="white" stroke-opacity="0.2" stroke-width="2" fill="white" fill-opacity="0.06" class="badge-ring"/>
        <circle cx="70" cy="80" r="54" stroke="white" stroke-opacity="0.12" stroke-width="1" fill="none" class="badge-ring"/>
        <text x="70" y="72" text-anchor="middle" fill="white" fill-opacity="0.65" font-size="36" font-weight="900" font-family="monospace" class="badge-num">10+</text>
        <text x="70" y="92" text-anchor="middle" fill="white" fill-opacity="0.4" font-size="10" font-family="monospace" letter-spacing="2" class="badge-num">YEARS</text>
        <text x="70" y="108" text-anchor="middle" fill="white" fill-opacity="0.3" font-size="8" font-family="monospace" letter-spacing="1" class="badge-num">EXPERIENCE</text>
        <line x1="70" y1="4" x2="70" y2="16" stroke="white" stroke-opacity="0.2" stroke-width="2" stroke-linecap="round" class="badge-ring"/>
        <line x1="70" y1="144" x2="70" y2="156" stroke="white" stroke-opacity="0.2" stroke-width="2" stroke-linecap="round" class="badge-ring"/>
        <line x1="-6" y1="80" x2="6" y2="80" stroke="white" stroke-opacity="0.2" stroke-width="2" stroke-linecap="round" class="badge-ring"/>
        <line x1="134" y1="80" x2="146" y2="80" stroke="white" stroke-opacity="0.2" stroke-width="2" stroke-linecap="round" class="badge-ring"/>
      </g>

      <!-- STARFIELD — top stars pulled DOWN. y:35,40,45 → y:75,80,85. Bottom stars y:250 already safe. -->
      <g class="starfield" fill="white">
        <circle cx="90" cy="80" r="1.4" class="star-tw star-tw-a"/>
        <circle cx="180" cy="120" r="1.1" class="star-tw star-tw-b"/>
        <circle cx="260" cy="100" r="2.2" class="star-tw star-tw-c"/>
        <circle cx="420" cy="105" r="1.3" class="star-tw star-tw-a"/>
        <circle cx="490" cy="80" r="1.7" class="star-tw star-tw-d"/>
        <circle cx="560" cy="150" r="1.1" class="star-tw star-tw-b"/>
        <circle cx="640" cy="100" r="2.0" class="star-tw star-tw-c"/>
        <circle cx="770" cy="110" r="1.3" class="star-tw star-tw-d"/>
        <circle cx="860" cy="85" r="1.6" class="star-tw star-tw-a"/>
        <circle cx="940" cy="140" r="1.2" class="star-tw star-tw-b"/>
        <circle cx="1020" cy="100" r="2.3" class="star-tw star-tw-c"/>
        <circle cx="1100" cy="80" r="1.2" class="star-tw star-tw-d"/>
        <circle cx="1360" cy="100" r="1.5" class="star-tw star-tw-a"/>
        <circle cx="1410" cy="180" r="1.0" class="star-tw star-tw-b"/>
        <circle cx="60" cy="200" r="1.1" class="star-tw star-tw-d"/>
        <circle cx="355" cy="180" r="1.4" class="star-tw star-tw-c"/>
        <circle cx="680" cy="220" r="1.0" class="star-tw star-tw-b"/>
        <circle cx="1150" cy="250" r="1.3" class="star-tw star-tw-a"/>
      </g>

      <g stroke="white" stroke-opacity="0.04" stroke-width="1">
        <line x1="0" y1="130" x2="1440" y2="130"/>
        <line x1="0" y1="260" x2="1440" y2="260"/>
        <line x1="360" y1="0" x2="360" y2="520"/>
        <line x1="720" y1="0" x2="720" y2="520"/>
        <line x1="1080" y1="0" x2="1080" y2="520"/>
      </g>
    </svg>

    <!-- MOBILE SVG -->
    <svg class="hero-bg-mobile" viewBox="0 0 400 600" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <defs>
        <linearGradient id="bgGradM" x1="0%" y1="0%" x2="100%" y2="100%">
          <stop offset="0%" style="stop-color:#1e3a8a;stop-opacity:1"/>
          <stop offset="100%" style="stop-color:#2563eb;stop-opacity:1"/>
        </linearGradient>
        <linearGradient id="glowGradM" x1="0%" y1="0%" x2="100%" y2="100%">
          <stop offset="0%" style="stop-color:#3b82f6;stop-opacity:0.3"/>
          <stop offset="100%" style="stop-color:#1d4ed8;stop-opacity:0"/>
        </linearGradient>
      </defs>
      <rect width="400" height="600" fill="url(#bgGradM)"/>
      <ellipse cx="100" cy="160" rx="220" ry="180" fill="url(#glowGradM)" class="glow-orb-1"/>
      <ellipse cx="320" cy="480" rx="220" ry="180" fill="url(#glowGradM)" class="glow-orb-2"/>

      <g class="mountains">
        <polygon points="0,600 80,450 180,530 280,400 380,490 400,470 400,600"
          fill="white" fill-opacity="0.05" stroke="white" stroke-opacity="0.08" stroke-width="1" class="mountain-back"/>
        <polygon points="0,600 50,510 140,570 240,460 340,550 400,510 400,600"
          fill="white" fill-opacity="0.08" stroke="white" stroke-opacity="0.14" stroke-width="1.5" class="mountain-front"/>
        <polygon points="280,400 296,378 312,400" fill="white" fill-opacity="0.22" class="snow snow-1"/>
        <polygon points="80,450 94,430 108,450" fill="white" fill-opacity="0.18" class="snow snow-2"/>
      </g>

      <!-- Diploma — y:140 stays. Bottom of seal at y:140+120=y:260. Safe. -->
      <g class="diploma-group" transform="translate(20, 140)">
        <rect x="0" y="16" width="140" height="110" rx="3"
          stroke="white" stroke-opacity="0.22" stroke-width="1.5"
          fill="white" fill-opacity="0.07" class="diploma-body"/>
        <ellipse cx="70" cy="16" rx="70" ry="10"
          stroke="white" stroke-opacity="0.2" stroke-width="1.5"
          fill="white" fill-opacity="0.08" class="diploma-curl-top"/>
        <ellipse cx="70" cy="126" rx="70" ry="10"
          stroke="white" stroke-opacity="0.2" stroke-width="1.5"
          fill="white" fill-opacity="0.08" class="diploma-curl-bot"/>
        <text x="70" y="42" text-anchor="middle" fill="white" fill-opacity="0.45" font-size="7.5" font-family="serif" font-style="italic" class="diploma-text dip-t1">Certificate of Achievement</text>
        <line x1="10" y1="49" x2="130" y2="49" stroke="white" stroke-opacity="0.15" stroke-width="1" class="diploma-rule"/>
        <text x="70" y="68" text-anchor="middle" fill="white" fill-opacity="0.6" font-size="13" font-weight="700" font-family="serif" class="diploma-text dip-t2">CIS</text>
        <text x="70" y="82" text-anchor="middle" fill="white" fill-opacity="0.3" font-size="6" font-family="monospace" class="diploma-text dip-t3">COMPUTER INFO</text>
        <text x="70" y="91" text-anchor="middle" fill="white" fill-opacity="0.3" font-size="6" font-family="monospace" class="diploma-text dip-t4">SYSTEMS</text>
        <circle cx="70" cy="108" r="12" stroke="white" stroke-opacity="0.28" stroke-width="1.5" fill="white" fill-opacity="0.08" class="diploma-seal"/>
        <polygon points="70,101 72,106.4 77.6,106.4 73.2,109.6 74.8,115 70,111.8 65.2,115 66.8,109.6 62.4,106.4 68,106.4" fill="white" fill-opacity="0.35" class="diploma-star"/>
      </g>

      <!-- Years badge — pulled DOWN from y:40 to y:65 (outer ring r:60 was extending to y:-4) -->
      <g class="years-badge" transform="translate(270, 65)">
        <circle cx="50" cy="56" r="60" stroke="white" stroke-opacity="0.08" stroke-width="1" fill="none" stroke-dasharray="4 3" class="badge-outer"/>
        <circle cx="50" cy="56" r="50" stroke="white" stroke-opacity="0.2" stroke-width="2" fill="white" fill-opacity="0.06" class="badge-ring"/>
        <circle cx="50" cy="56" r="40" stroke="white" stroke-opacity="0.1" stroke-width="1" fill="none" class="badge-ring"/>
        <text x="50" y="50" text-anchor="middle" fill="white" fill-opacity="0.65" font-size="24" font-weight="900" font-family="monospace" class="badge-num">10+</text>
        <text x="50" y="66" text-anchor="middle" fill="white" fill-opacity="0.38" font-size="7" font-family="monospace" letter-spacing="1" class="badge-num">YEARS</text>
        <text x="50" y="78" text-anchor="middle" fill="white" fill-opacity="0.28" font-size="6" font-family="monospace" class="badge-num">EXPERIENCE</text>
      </g>

      <!-- STARFIELD — top star at y:50 pulled to y:75; rest already safe -->
      <g class="starfield" fill="white">
        <circle cx="40" cy="75" r="1.2" class="star-tw star-tw-a"/>
        <circle cx="100" cy="110" r="1.5" class="star-tw star-tw-c"/>
        <circle cx="160" cy="95" r="1.1" class="star-tw star-tw-b"/>
        <circle cx="50" cy="340" r="1.3" class="star-tw star-tw-d"/>
        <circle cx="200" cy="140" r="1.6" class="star-tw star-tw-a"/>
        <circle cx="160" cy="330" r="1.1" class="star-tw star-tw-c"/>
        <circle cx="220" cy="220" r="1.2" class="star-tw star-tw-b"/>
        <circle cx="310" cy="180" r="1.4" class="star-tw star-tw-d"/>
        <circle cx="370" cy="240" r="1.1" class="star-tw star-tw-a"/>
        <circle cx="80" cy="300" r="1.3" class="star-tw star-tw-c"/>
        <circle cx="280" cy="320" r="1.2" class="star-tw star-tw-b"/>
        <circle cx="190" cy="360" r="1.0" class="star-tw star-tw-d"/>
      </g>

      <g stroke="white" stroke-opacity="0.04" stroke-width="1">
        <line x1="0" y1="150" x2="400" y2="150"/>
        <line x1="0" y1="300" x2="400" y2="300"/>
        <line x1="133" y1="0" x2="133" y2="600"/>
        <line x1="266" y1="0" x2="266" y2="600"/>
      </g>
    </svg>

    <!-- Hero text -->
    <div id="hero-content">
      <p class="hero-label">{content.headerLabel}</p>
      <h1 id="hero-wordmark">{content.headerTitle}</h1>
      <p id="hero-tagline">{content.headerSubtitle}</p>
      <a href="/contact" id="hero-cta">
        Get in Touch
        <svg style="height:1rem;width:1rem;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
      </a>
    </div>

    <div id="scroll-hint" aria-hidden="true" role="button" tabindex="-1" onclick="document.getElementById('about-content').scrollIntoView({behavior:'smooth'})" onkeydown="if(event.key==='Enter'||event.key===' '){event.preventDefault();document.getElementById('about-content').scrollIntoView({behavior:'smooth'})}">
      <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" style="height:1.5rem;width:1.5rem;"><path d="M12 5v14M5 12l7 7 7-7"/></svg>
    </div>
  </section>

  <!-- Main About Section -->
  <section id="about-content" style="background:white;padding:5rem 1.5rem;">
    <div style="max-width:80rem;margin:0 auto;">
      <div id="about-grid">
        <div>
          <p style="font-size:0.875rem;font-weight:600;text-transform:uppercase;letter-spacing:0.1em;color:#2563eb;">{content.storyLabel}</p>
          <h2 style="margin-top:0.75rem;font-size:2rem;font-weight:800;color:#111827;line-height:1.2;">{content.storyTitle}</h2>
          <p style="margin-top:1.25rem;line-height:1.75;color:#4b5563;font-size:1.05rem;">{content.story1}</p>
          <p style="margin-top:1rem;line-height:1.75;color:#4b5563;font-size:1.05rem;" set:html={content.story2.replace("Bachelor's Degree in Computer Information Systems", '<strong style="color:#111827;">Bachelor\'s Degree in Computer Information Systems</strong>')}></p>
          <p style="margin-top:1rem;line-height:1.75;color:#4b5563;font-size:1.05rem;" set:html={content.story3.replace("Do North Coworking Space", '<strong style="color:#111827;">Do North Coworking Space</strong>')}></p>
          <p style="margin-top:1rem;line-height:1.75;color:#4b5563;font-size:1.05rem;">{content.story4}</p>
          <p style="margin-top:1rem;line-height:1.75;color:#4b5563;font-size:1.05rem;">{content.story5}</p>
        </div>
        <div style="display:flex;flex-direction:column;gap:1.5rem;">
          <div style="display:flex;gap:1rem;"><div style="display:flex;height:2.75rem;width:2.75rem;flex-shrink:0;align-items:center;justify-content:center;border-radius:0.5rem;background:#dbeafe;color:#2563eb;"><svg style="height:1.25rem;width:1.25rem;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg></div><div><h3 style="font-weight:600;color:#111827;">{content.value1Title}</h3><p style="margin-top:0.25rem;font-size:0.875rem;line-height:1.625;color:#4b5563;">{content.value1Desc}</p></div></div>
          <div style="display:flex;gap:1rem;"><div style="display:flex;height:2.75rem;width:2.75rem;flex-shrink:0;align-items:center;justify-content:center;border-radius:0.5rem;background:#dbeafe;color:#2563eb;"><svg style="height:1.25rem;width:1.25rem;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="12" cy="8" r="6"/><path d="M15.477 12.89L17 22l-5-3-5 3 1.523-9.11"/></svg></div><div><h3 style="font-weight:600;color:#111827;">{content.value2Title}</h3><p style="margin-top:0.25rem;font-size:0.875rem;line-height:1.625;color:#4b5563;">{content.value2Desc}</p></div></div>
          <div style="display:flex;gap:1rem;"><div style="display:flex;height:2.75rem;width:2.75rem;flex-shrink:0;align-items:center;justify-content:center;border-radius:0.5rem;background:#dbeafe;color:#2563eb;"><svg style="height:1.25rem;width:1.25rem;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg></div><div><h3 style="font-weight:600;color:#111827;">{content.value3Title}</h3><p style="margin-top:0.25rem;font-size:0.875rem;line-height:1.625;color:#4b5563;">{content.value3Desc}</p></div></div>
          <div style="display:flex;gap:1rem;"><div style="display:flex;height:2.75rem;width:2.75rem;flex-shrink:0;align-items:center;justify-content:center;border-radius:0.5rem;background:#dbeafe;color:#2563eb;"><svg style="height:1.25rem;width:1.25rem;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/></svg></div><div><h3 style="font-weight:600;color:#111827;">{content.value4Title}</h3><p style="margin-top:0.25rem;font-size:0.875rem;line-height:1.625;color:#4b5563;">{content.value4Desc}</p></div></div>
          <img src={content.photo} alt={content.photoAlt} width="600" height="740" style="width:100%;border-radius:1rem;box-shadow:0 4px 24px rgba(0,0,0,0.12);margin-top:0.5rem;" />
        </div>
      </div>
    </div>
  </section>

  <!-- Credentials -->
  <section style="background:#f8fafc;padding:4rem 1.5rem;">
    <div style="max-width:80rem;margin:0 auto;">
      <div style="text-align:center;margin-bottom:3rem;">
        <p style="font-size:0.875rem;font-weight:600;text-transform:uppercase;letter-spacing:0.1em;color:#2563eb;">{content.credLabel}</p>
        <h2 style="font-size:2rem;font-weight:800;color:#111827;margin-top:0.5rem;">{content.credTitle}</h2>
      </div>
      <div id="credentials-grid">
        <div class="credential-card"><div class="credential-icon" aria-hidden="true"><svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/></svg></div><h3>{content.cred1Title}</h3><p>{content.cred1Desc}</p><p class="credential-sub">{content.cred1Sub}</p></div>
        <div class="credential-card"><div class="credential-icon" aria-hidden="true"><svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg></div><h3>{content.cred2Title}</h3><p>{content.cred2Desc}</p><p class="credential-sub">{content.cred2Sub}</p></div>
