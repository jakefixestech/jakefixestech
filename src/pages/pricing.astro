---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Pricing | Jake Fixes Tech — Affordable Computer Repair Littleton, NH"
description="Transparent flat rate pricing for all computer repair services. Starting at $50 diagnostic fee applied toward your repair. No hidden fees, no surprises.">

  <!-- Header Banner -->
  <section style="position:relative;overflow:hidden;background-color:rgb(30,64,175);">
    <img 
      src="/hero.jpg" 
      alt="Professional tech workspace with dual monitors" 
      width="1200"
      height="630"
      fetchpriority="high"
      decoding="async"
      style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;z-index:0;" 
    />
    <div style="position:absolute;inset:0;background:linear-gradient(135deg,rgba(30,64,175,0.88),rgba(37,99,235,0.88));z-index:1;"></div>
    <div style="max-width:56rem;margin:0 auto;padding:4rem 1.5rem;text-align:center;position:relative;z-index:2;">
      <p style="font-size:0.875rem;font-weight:600;text-transform:uppercase;letter-spacing:0.1em;color:#93c5fd;">Pricing</p>
      <h1 style="font-size:2.5rem;font-weight:800;color:white;margin-top:0.5rem;margin-bottom:1rem;">Transparent, Honest Pricing</h1>
      <p style="color:#bfdbfe;font-size:1.1rem;line-height:1.75;max-width:42rem;margin:0 auto;">Flat rate pricing paid upfront. No hidden fees, no surprises. Parts are extra where applicable.</p>
    </div>
  </section>

  <!-- Diagnostic Fee — Full Width Section -->
  <section style="background:#1e40af;padding:2rem 1.5rem;">
    <div style="max-width:56rem;margin:0 auto;display:flex;flex-wrap:wrap;align-items:center;gap:1.5rem;">
      <div style="display:flex;align-items:center;justify-content:center;background:rgba(255,255,255,0.15);border-radius:50%;height:3rem;width:3rem;flex-shrink:0;">
        <svg style="height:1.5rem;width:1.5rem;color:white;" aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
      </div>
      <div style="flex:1;min-width:200px;">
        <h2 style="font-size:1.1rem;font-weight:800;color:white;margin-bottom:0.25rem;">$50 Diagnostic Fee</h2>
        <p style="color:#bfdbfe;font-size:0.95rem;line-height:1.6;">All repairs start with a $50 diagnostic fee. If you proceed with the repair, that $50 is applied toward your total cost. If you decide not to repair, the fee covers my time and expertise.</p>
      </div>
      <a href="/contact" style="display:inline-flex;align-items:center;gap:0.5rem;background:white;color:#1e40af;font-weight:700;padding:0.75rem 1.5rem;border-radius:0.5rem;text-decoration:none;font-size:0.95rem;white-space:nowrap;flex-shrink:0;">
        Get a Free Quote
        <svg style="height:1rem;width:1rem;" aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>
  </section>

  <section style="background:white;padding:3rem 1.5rem 5rem 1.5rem;">
    <div style="max-width:56rem;margin:0 auto;">

      <div id="price-grid">

        <!-- Software Services — Blue -->
        <div class="price-category" style="border-color:#bfdbfe;border-left:4px solid #2563eb;">
          <h2 style="background:#eff6ff;color:#1e40af;border-bottom-color:#bfdbfe;">💻 Software Services</h2>
          <div class="price-table">
            <div class="price-row">
              <span>Virus & Malware Removal</span>
              <span class="price" style="color:#2563eb;">$75</span>
            </div>
            <div class="price-row">
              <span>OS Reinstall (Windows or macOS)</span>
              <span class="price" style="color:#2563eb;">$85</span>
            </div>
            <div class="price-row">
              <span>Software Troubleshooting & Tune-Up</span>
              <span class="price" style="color:#2563eb;">$60</span>
            </div>
            <div class="price-row">
              <span>Driver Installation & Updates</span>
              <span class="price" style="color:#2563eb;">$50</span>
            </div>
          </div>
        </div>

        <!-- Hardware Services — Orange -->
        <div class="price-category" style="border-color:#fed7aa;border-left:4px solid #c2410c;">
          <h2 style="background:#fff7ed;color:#7c2d12;border-bottom-color:#fed7aa;">🔧 Hardware Services</h2>
          <div class="price-table">
            <div class="price-row">
              <span>Screen Replacement (labor only)</span>
              <span class="price" style="color:#c2410c;">$75 + parts</span>
            </div>
            <div class="price-row">
              <span>RAM Upgrade (labor only)</span>
              <span class="price" style="color:#c2410c;">$60 + parts</span>
            </div>
            <div class="price-row">
              <span>SSD Installation & OS Migration</span>
              <span class="price" style="color:#c2410c;">$85 + parts</span>
            </div>
            <div class="price-row">
              <span>Hardware Diagnostics</span>
              <span class="price" style="color:#c2410c;">$75</span>
            </div>
            <div class="price-row">
              <span>Broken Tech Repair</span>
              <span class="price" style="color:#c2410c;">From $60 + parts</span>
            </div>
          </div>
        </div>

        <!-- Data Services — Green -->
        <div class="price-category" style="border-color:#bbf7d0;border-left:4px solid #15803d;">
          <h2 style="background:#f0fdf4;color:#14532d;border-bottom-color:#bbf7d0;">💾 Data Services</h2>
          <div class="price-table">
            <div class="price-row">
              <span>Data Recovery (software)</span>
              <span class="price" style="color:#15803d;">$100</span>
            </div>
            <div class="price-row">
              <span>Data Backup & Transfer</span>
              <span class="price" style="color:#15803d;">$60</span>
            </div>
          </div>
        </div>

        <!-- Gaming Console — Purple -->
        <div class="price-category" style="border-color:#ddd6fe;border-left:4px solid #6d28d9;">
          <h2 style="background:#f5f3ff;color:#4c1d95;border-bottom-color:#ddd6fe;">🎮 Gaming Console Repair</h2>
          <div class="price-table">
            <div class="price-row">
              <span>Console Diagnostics & Repair</span>
              <span class="price" style="color:#6d28d9;">From $60 + parts</span>
            </div>
            <div class="price-row">
              <span>Internal Cleaning & Dust Removal</span>
              <span class="price" style="color:#6d28d9;">$50</span>
            </div>
            <div class="price-row">
              <span>Disc Drive Repair</span>
              <span class="price" style="color:#6d28d9;">$65 + parts</span>
            </div>
          </div>
        </div>

        <!-- On-Site & Tutoring — Amber -->
        <div class="price-category" style="border-color:#fde68a;border-left:4px solid #b45309;">
          <h2 style="background:#fffbeb;color:#78350f;border-bottom-color:#fde68a;">🏠 On-Site & Tech Tutoring</h2>
          <div class="price-table">
            <div class="price-row">
              <span>On-Site Tech Support (per hour)</span>
              <span class="price" style="color:#b45309;">$65/hr</span>
            </div>
            <div class="price-row">
              <span>Tech Tutoring (per hour)</span>
              <span class="price" style="color:#b45309;">$50/hr</span>
            </div>
          </div>
        </div>

      </div>

      <!-- Disclaimer -->
      <div style="margin-top:2.5rem;text-align:center;background:#f9fafb;border-radius:0.75rem;padding:1.5rem;">
        <p style="color:#6b7280;font-size:0.9rem;line-height:1.75;">All prices are starting rates and may vary based on device make, model and complexity of the repair. Parts are charged separately at cost. A 30 day labor warranty is included on all completed repairs. Contact me for a free quote!</p>
        <a href="/contact" style="display:inline-flex;align-items:center;justify-content:center;margin-top:1rem;background:#2563eb;color:white;font-weight:600;padding:0.75rem 2rem;border-radius:0.5rem;text-decoration:none;font-size:0.95rem;">Schedule a Repair</a>
      </div>

    </div>
  </section>

</Layout>

<style>
  #price-grid {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .price-category {
    border: 1px solid #e5e7eb;
    border-radius: 0.75rem;
    overflow: hidden;
  }

  .price-category h2 {
    background: #f8fafc;
    padding: 1rem 1.5rem;
    font-size: 1rem;
    font-weight: 700;
    color: #111827;
    border-bottom: 1px solid #e5e7eb;
    margin: 0;
  }

  .price-table {
    padding: 0.5rem 0;
  }

  .price-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.75rem 1.5rem;
    border-bottom: 1px solid #f3f4f6;
  }

  .price-row:last-child {
    border-bottom: none;
  }

  .price-row span {
    font-size: 0.95rem;
    color: #374151;
  }

  .price-row .price {
    font-weight: 700;
    white-space: nowrap;
    margin-left: 1rem;
  }

  @media (max-width: 768px) {
    .price-row {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.25rem;
    }

    .price-row .price {
      margin-left: 0;
    }
  }
</style>