---
import Layout from '../layouts/Layout.astro';
import content from '../content/pricing.yml';
---

<Layout title="Pricing | Jake Fixes Tech — Affordable Computer Repair Littleton, NH"
description="Transparent flat rate pricing for all computer repair services. Starting at $50 diagnostic fee applied toward your repair. No hidden fees, no surprises.">

  <!-- Header Banner -->
  <section style="position:relative;overflow:hidden;background-color:rgb(30,64,175);">
    <img src="/hero.jpg" alt="Professional tech workspace with dual monitors" width="1200" height="630" fetchpriority="high" decoding="async" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;z-index:0;" />
    <div style="position:absolute;inset:0;background:linear-gradient(135deg,rgba(30,64,175,0.88),rgba(37,99,235,0.88));z-index:1;"></div>
    <div style="max-width:56rem;margin:0 auto;padding:4rem 1.5rem;text-align:center;position:relative;z-index:2;">
      <p style="font-size:0.875rem;font-weight:600;text-transform:uppercase;letter-spacing:0.1em;color:#93c5fd;">{content.headerLabel}</p>
      <h1 style="font-size:2.5rem;font-weight:800;color:white;margin-top:0.5rem;margin-bottom:1rem;">{content.headerTitle}</h1>
      <p style="color:#bfdbfe;font-size:1.1rem;line-height:1.75;max-width:42rem;margin:0 auto;">{content.headerSubtitle}</p>
    </div>
  </section>

  <!-- Diagnostic Fee -->
  <section style="background:#1e40af;padding:2rem 1.5rem;">
    <div style="max-width:56rem;margin:0 auto;display:flex;flex-wrap:wrap;align-items:center;gap:1.5rem;">
      <div style="display:flex;align-items:center;justify-content:center;background:rgba(255,255,255,0.15);border-radius:50%;height:3rem;width:3rem;flex-shrink:0;">
        <svg style="height:1.5rem;width:1.5rem;color:white;" aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12" y2="16" stroke-linecap="round" stroke-width="3"/></svg>
      </div>
      <div style="flex:1;min-width:200px;">
        <h2 style="font-size:1.1rem;font-weight:800;color:white;margin-bottom:0.25rem;">{content.diagTitle}</h2>
        <p style="color:#bfdbfe;font-size:0.95rem;line-height:1.6;">{content.diagDesc}</p>
      </div>
      <a href="/services" style="display:inline-flex;align-items:center;gap:0.5rem;background:white;color:#1e40af;font-weight:700;padding:0.75rem 1.5rem;border-radius:0.5rem;text-decoration:none;font-size:0.95rem;white-space:nowrap;flex-shrink:0;">
        Check Out All Services
        <svg style="height:1rem;width:1rem;" aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>
  </section>

  <section style="background:white;padding:3rem 1.5rem 5rem 1.5rem;">
    <div style="max-width:56rem;margin:0 auto;">
      <div id="price-grid">

        <!-- Software Services -->
        <div class="price-category" style="border-color:#bfdbfe;border-left:4px solid #2563eb;">
          <h2 style="background:#eff6ff;color:#1e40af;border-bottom-color:#bfdbfe;">
            <div class="cat-icon" style="background:#dbeafe;color:#2563eb;" aria-hidden="true">
              <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
            </div>
            Software Services
          </h2>
          <div class="price-table">
            <div class="price-row"><span>{content.soft1Name}</span><span class="price" style="color:#2563eb;">{content.soft1Price}</span></div>
            <div class="price-row"><span>{content.soft2Name}</span><span class="price" style="color:#2563eb;">{content.soft2Price}</span></div>
            <div class="price-row"><span>{content.soft3Name}</span><span class="price" style="color:#2563eb;">{content.soft3Price}</span></div>
            <div class="price-row"><span>{content.soft4Name}</span><span class="price" style="color:#2563eb;">{content.soft4Price}</span></div>
          </div>
        </div>

        <!-- Hardware Services -->
        <div class="price-category" style="border-color:#fed7aa;border-left:4px solid #c2410c;">
          <h2 style="background:#fff7ed;color:#7c2d12;border-bottom-color:#fed7aa;">
            <div class="cat-icon" style="background:#ffedd5;color:#c2410c;" aria-hidden="true">
              <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
            </div>
            Hardware Services
          </h2>
          <div class="price-table">
            <div class="price-row"><span>{content.hard1Name}</span><span class="price" style="color:#c2410c;">{content.hard1Price}</span></div>
            <div class="price-row"><span>{content.hard2Name}</span><span class="price" style="color:#c2410c;">{content.hard2Price}</span></div>
            <div class="price-row"><span>{content.hard3Name}</span><span class="price" style="color:#c2410c;">{content.hard3Price}</span></div>
            <div class="price-row"><span>{content.hard4Name}</span><span class="price" style="color:#c2410c;">{content.hard4Price}</span></div>
            <div class="price-row"><span>{content.hard5Name}</span><span class="price" style="color:#c2410c;">{content.hard5Price}</span></div>
          </div>
        </div>

        <!-- Data Services -->
        <div class="price-category" style="border-color:#bbf7d0;border-left:4px solid #15803d;">
          <h2 style="background:#f0fdf4;color:#14532d;border-bottom-color:#bbf7d0;">
            <div class="cat-icon" style="background:#dcfce7;color:#15803d;" aria-hidden="true">
              <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><ellipse cx="12" cy="12" rx="10" ry="3"/><path d="M2 12c0 1.66 4.48 3 10 3s10-1.34 10-3"/><path d="M2 12v6c0 1.66 4.48 3 10 3s10-1.34 10-3v-6"/></svg>
            </div>
            Data Services
          </h2>
          <div class="price-table">
            <div class="price-row"><span>{content.data1Name}</span><span class="price" style="color:#15803d;">{content.data1Price}</span></div>
            <div class="price-row"><span>{content.data2Name}</span><span class="price" style="color:#15803d;">{content.data2Price}</span></div>
          </div>
        </div>

        <!-- Mac & Apple Software -->
        <div class="price-category" style="border-color:#e2e8f0;border-left:4px solid #475569;">
          <h2 style="background:#f8fafc;color:#1e293b;border-bottom-color:#e2e8f0;">
            <div class="cat-icon" style="background:#e2e8f0;color:#475569;" aria-hidden="true">
              <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>
            </div>
            Mac & Apple Software
          </h2>
          <div class="price-table">
            <div class="price-row"><span>{content.mac1Name}</span><span class="price" style="color:#475569;">{content.mac1Price}</span></div>
            <div class="price-row"><span>{content.mac2Name}</span><span class="price" style="color:#475569;">{content.mac2Price}</span></div>
            <div class="price-row"><span>{content.mac3Name}</span><span class="price" style="color:#475569;">{content.mac3Price}</span></div>
            <div class="price-row"><span>{content.mac4Name}</span><span class="price" style="color:#475569;">{content.mac4Price}</span></div>
            <div class="price-row"><span>{content.mac5Name}</span><span class="price" style="color:#475569;">{content.mac5Price}</span></div>
          </div>
        </div>

        <!-- Gaming Console -->
        <div class="price-category" style="border-color:#ddd6fe;border-left:4px solid #6d28d9;">
          <h2 style="background:#f5f3ff;color:#4c1d95;border-bottom-color:#ddd6fe;">
            <div class="cat-icon" style="background:#ede9fe;color:#6d28d9;" aria-hidden="true">
              <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><rect x="2" y="6" width="20" height="12" rx="2"/><path d="M6 12h.01M10 12h.01M7 9l-1 3 1 3M13 9l1 3-1 3"/></svg>
            </div>
            Gaming Console Repair
          </h2>
          <div class="price-table">
            <div class="price-row"><span>{content.console1Name}</span><span class="price" style="color:#6d28d9;">{content.console1Price}</span></div>
            <div class="price-row"><span>{content.console2Name}</span><span class="price" style="color:#6d28d9;">{content.console2Price}</span></div>
            <div class="price-row"><span>{content.console3Name}</span><span class="price" style="color:#6d28d9;">{content.console3Price}</span></div>
          </div>
        </div>

        <!-- On-Site, Remote & Tutoring -->
        <div class="price-category" style="border-color:#fde68a;border-left:4px solid #b45309;">
          <h2 style="background:#fffbeb;color:#78350f;border-bottom-color:#fde68a;">
            <div class="cat-icon" style="background:#fef3c7;color:#b45309;" aria-hidden="true">
              <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            </div>
            On-Site, Remote & Tech Tutoring
          </h2>
          <div class="price-table">
            <div class="price-row"><span>{content.support1Name}</span><span class="price" style="color:#b45309;">{content.support1Price}</span></div>
            <div class="price-row"><span>{content.support2Name}</span><span class="price" style="color:#b45309;">{content.support2Price}</span></div>
            <div class="price-row"><span>{content.support3Name}</span><span class="price" style="color:#b45309;">{content.support3Price}</span></div>
          </div>
        </div>

      </div>

      <!-- Disclaimer -->
      <div style="margin-top:2.5rem;text-align:center;background:#f9fafb;border-radius:0.75rem;padding:1.5rem;">
        <p style="color:#6b7280;font-size:0.9rem;line-height:1.75;">{content.disclaimer}</p>
        <a href="/contact" style="display:inline-flex;align-items:center;justify-content:center;margin-top:1rem;background:#2563eb;color:white;font-weight:600;padding:0.75rem 2rem;border-radius:0.5rem;text-decoration:none;font-size:0.95rem;">Schedule a Repair</a>
      </div>

      <!-- Deals / Discounts -->
      <div style="margin-top:1rem;background:#eff6ff;border:2px solid #2563eb;border-radius:0.75rem;padding:1.25rem 1.5rem;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:1rem;">
        <div style="display:flex;align-items:center;gap:0.75rem;">
          <div style="display:flex;height:2.5rem;width:2.5rem;min-width:2.5rem;align-items:center;justify-content:center;border-radius:0.5rem;background:#dbeafe;color:#2563eb;flex-shrink:0;" aria-hidden="true">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" style="height:1.25rem;width:1.25rem;"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
          </div>
          <div>
            <div style="font-size:0.95rem;font-weight:700;color:#1e40af;">Military, First Responders, Seniors & Students</div>
            <div style="font-size:0.825rem;color:#2563eb;margin-top:0.1rem;">10% off all repair labor — forever, no expiration</div>
          </div>
        </div>
        <a href="/deals" style="display:inline-flex;align-items:center;gap:0.5rem;background:#2563eb;color:white;font-weight:700;padding:0.625rem 1.25rem;border-radius:0.5rem;text-decoration:none;font-size:0.875rem;white-space:nowrap;">
          See All Deals →
        </a>
      </div>

    </div>
  </section>

</Layout>

<style>
  #price-grid { display: flex; flex-direction: column; gap: 1.5rem; }
  .price-category { border: 1px solid #e5e7eb; border-radius: 0.75rem; overflow: hidden; }
  .price-category h2 { background: #f8fafc; padding: 0.875rem 1.5rem; font-size: 1rem; font-weight: 700; color: #111827; border-bottom: 1px solid #e5e7eb; margin: 0; display: flex; align-items: center; gap: 0.75rem; }
  .cat-icon { display: flex; height: 2rem; width: 2rem; min-width: 2rem; align-items: center; justify-content: center; border-radius: 0.375rem; flex-shrink: 0; }
  .cat-icon svg { height: 1.1rem; width: 1.1rem; }
  .price-table { padding: 0.5rem 0; }
  .price-row { display: flex; justify-content: space-between; align-items: center; padding: 0.75rem 1.5rem; border-bottom: 1px solid #f3f4f6; }
  .price-row:last-child { border-bottom: none; }
  .price-row span { font-size: 0.95rem; color: #374151; }
  .price-row .price { font-weight: 700; white-space: nowrap; margin-left: 1rem; }

  @media (max-width: 768px) {
    .price-row { flex-direction: column; align-items: flex-start; gap: 0.25rem; }
    .price-row .price { margin-left: 0; }
  }
</style>