---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <section style="background:white;padding:3rem 1.5rem 5rem 1.5rem;">
    <div style="max-width:56rem;margin:0 auto;">

      <!-- Header Banner -->
      <div style="background:linear-gradient(135deg,#1e40af,#2563eb);border-radius:0.75rem;padding:2.5rem;text-align:center;margin-bottom:3rem;">
        <p style="font-size:0.875rem;font-weight:600;text-transform:uppercase;letter-spacing:0.1em;color:#93c5fd;">Pricing</p>
        <h1 style="font-size:2rem;font-weight:800;color:white;margin-top:0.5rem;margin-bottom:0.5rem;">Transparent, Honest Pricing</h1>
        <p style="color:#bfdbfe;font-size:1rem;">Flat rate pricing paid upfront. No hidden fees, no surprises. Parts are extra where applicable.</p>
      </div>

      <!-- Diagnostic Fee Callout -->
      <div style="background:#eff6ff;border:2px solid #2563eb;border-radius:0.75rem;padding:1.5rem;margin-bottom:2.5rem;display:flex;align-items:flex-start;gap:1rem;">
        <div style="background:#2563eb;border-radius:50%;height:2.5rem;width:2.5rem;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
          <svg style="height:1.25rem;width:1.25rem;color:white;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        </div>
        <div>
          <h3 style="font-weight:700;color:#1e40af;font-size:1rem;margin-bottom:0.25rem;">$50 Diagnostic Fee</h3>
          <p style="color:#3b82f6;font-size:0.9rem;line-height:1.6;">All repairs start with a $50 diagnostic fee. If you proceed with the repair, that $50 is applied toward your total cost. If you decide not to repair, the fee covers my time and expertise.</p>
        </div>
      </div>

      <!-- Price List -->
      <div id="price-grid">

        <!-- Software Services -->
        <div class="price-category">
          <h2>💻 Software Services</h2>
          <div class="price-table">
            <div class="price-row">
              <span>Virus & Malware Removal</span>
              <span class="price">$75</span>
            </div>
            <div class="price-row">
              <span>OS Reinstall (Windows or macOS)</span>
              <span class="price">$85</span>
            </div>
            <div class="price-row">
              <span>Software Troubleshooting & Tune-Up</span>
              <span class="price">$60</span>
            </div>
            <div class="price-row">
              <span>Driver Installation & Updates</span>
              <span class="price">$50</span>
            </div>
          </div>
        </div>

        <!-- Hardware Services -->
        <div class="price-category">
          <h2>🔧 Hardware Services</h2>
          <div class="price-table">
            <div class="price-row">
              <span>Screen Replacement (labor only)</span>
              <span class="price">$75 + parts</span>
            </div>
            <div class="price-row">
              <span>RAM Upgrade (labor only)</span>
              <span class="price">$60 + parts</span>
            </div>
            <div class="price-row">
              <span>SSD Installation & OS Migration</span>
              <span class="price">$85 + parts</span>
            </div>
            <div class="price-row">
              <span>Hardware Diagnostics</span>
              <span class="price">$75</span>
            </div>
            <div class="price-row">
              <span>Broken Tech Repair</span>
              <span class="price">From $60 + parts</span>
            </div>
          </div>
        </div>

        <!-- Data Services -->
        <div class="price-category">
          <h2>💾 Data Services</h2>
          <div class="price-table">
            <div class="price-row">
              <span>Data Recovery (software)</span>
              <span class="price">$100</span>
            </div>
            <div class="price-row">
              <span>Data Backup & Transfer</span>
              <span class="price">$60</span>
            </div>
          </div>
        </div>

        <!-- Gaming Console -->
        <div class="price-category">
          <h2>🎮 Gaming Console Repair</h2>
          <div class="price-table">
            <div class="price-row">
              <span>Console Diagnostics & Repair</span>
              <span class="price">From $60 + parts</span>
            </div>
            <div class="price-row">
              <span>Internal Cleaning & Dust Removal</span>
              <span class="price">$50</span>
            </div>
            <div class="price-row">
              <span>Disc Drive Repair</span>
              <span class="price">$65 + parts</span>
            </div>
          </div>
        </div>

        <!-- On-Site & Tutoring -->
        <div class="price-category">
          <h2>🏠 On-Site & Tech Tutoring</h2>
          <div class="price-table">
            <div class="price-row">
              <span>On-Site Tech Support (per hour)</span>
              <span class="price">$65/hr</span>
            </div>
            <div class="price-row">
              <span>Tech Tutoring (per hour)</span>
              <span class="price">$50/hr</span>
            </div>
          </div>
        </div>

      </div>

      <!-- Disclaimer -->
      <div style="margin-top:2.5rem;text-align:center;background:#f9fafb;border-radius:0.75rem;padding:1.5rem;">
        <p style="color:#6b7280;font-size:0.9rem;line-height:1.75;">All prices are starting rates and may vary based on device make, model and complexity of the repair. Parts are charged separately at cost. A 30 day labor warranty is included on all completed repairs. Contact me for a free quote!</p>
        <a href="/location" style="display:inline-flex;align-items:center;justify-content:center;margin-top:1rem;background:#2563eb;color:white;font-weight:600;padding:0.75rem 2rem;border-radius:0.5rem;text-decoration:none;font-size:0.95rem;">Get a Free Quote</a>
      </div>

    </div>
  </section>
</Layout>

<style>
  #price-grid {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .price-category {
    border: 1px solid #e5e7eb;
    border-radius: 0.75rem;
    overflow: hidden;
  }

  .price-category h2 {
    background: #f8fafc;
    padding: 1rem 1.5rem;
    font-size: 1rem;
    font-weight: 700;
    color: #111827;
    border-bottom: 1px solid #e5e7eb;
    margin: 0;
  }

  .price-table {
    padding: 0.5rem 0;
  }

  .price-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.75rem 1.5rem;
    border-bottom: 1px solid #f3f4f6;
  }

  .price-row:last-child {
    border-bottom: none;
  }

  .price-row span {
    font-size: 0.95rem;
    color: #374151;
  }

  .price-row .price {
    font-weight: 700;
    color: #2563eb;
    white-space: nowrap;
    margin-left: 1rem;
  }

  @media (max-width: 768px) {
    .price-row {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.25rem;
    }

    .price-row .price {
      margin-left: 0;
    }
  }
</style>