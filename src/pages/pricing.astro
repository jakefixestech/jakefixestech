---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Pricing | Jake Fixes Tech — Affordable Computer Repair Littleton, NH"
description="Transparent flat rate pricing for all computer repair services. Starting at $50 diagnostic fee applied toward your repair. No hidden fees, no surprises.">

  <!-- Animated SVG Hero -->
  <section id="hero-svg" aria-label="Transparent pricing">

    <!-- DESKTOP SVG -->
    <svg class="hero-bg-desktop" viewBox="0 0 1440 520" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <defs>
        <linearGradient id="bgGrad" x1="0%" y1="0%" x2="100%" y2="100%">
          <stop offset="0%" style="stop-color:#1e3a8a;stop-opacity:1"/>
          <stop offset="100%" style="stop-color:#2563eb;stop-opacity:1"/>
        </linearGradient>
        <linearGradient id="glowGrad" x1="0%" y1="0%" x2="100%" y2="100%">
          <stop offset="0%" style="stop-color:#3b82f6;stop-opacity:0.25"/>
          <stop offset="100%" style="stop-color:#1d4ed8;stop-opacity:0"/>
        </linearGradient>
      </defs>
      <rect width="1440" height="520" fill="url(#bgGrad)"/>
      <ellipse cx="280" cy="240" rx="360" ry="260" fill="url(#glowGrad)" class="glow-orb-1"/>
      <ellipse cx="1200" cy="300" rx="340" ry="240" fill="url(#glowGrad)" class="glow-orb-2"/>

      <!-- PRICE TAG — left side. Pulled down 10px (y:120→130) to keep string clear of top edge on tall viewports -->
      <g class="price-tag" transform="translate(120, 130)">
        <line x1="70" y1="0" x2="70" y2="50" stroke="white" stroke-opacity="0.18" stroke-width="1.5" class="tag-string"/>
        <circle cx="70" cy="0" r="3" fill="white" fill-opacity="0.2" class="tag-pivot"/>
        <g class="tag-swing" transform-origin="70 0">
          <path d="M70 50 L30 70 L30 170 L180 170 L180 70 L70 50 Z"
            stroke="white" stroke-opacity="0.25" stroke-width="2"
            fill="white" fill-opacity="0.08" class="tag-body"/>
          <circle cx="70" cy="70" r="5" stroke="white" stroke-opacity="0.3" stroke-width="1.5" fill="#1e3a8a" class="tag-hole"/>
          <text x="110" y="105" text-anchor="middle" fill="white" fill-opacity="0.55" font-size="11" font-family="monospace" letter-spacing="2" font-weight="700" class="tag-text tag-t1">FLAT RATE</text>
          <line x1="50" y1="115" x2="170" y2="115" stroke="white" stroke-opacity="0.2" stroke-width="1" class="tag-text tag-t2"/>
          <text x="110" y="145" text-anchor="middle" fill="white" fill-opacity="0.7" font-size="28" font-weight="900" font-family="monospace" class="tag-text tag-t3">$50</text>
          <text x="110" y="160" text-anchor="middle" fill="white" fill-opacity="0.35" font-size="7" font-family="monospace" letter-spacing="1" class="tag-text tag-t4">DIAGNOSTIC</text>
        </g>
      </g>

      <!-- RECEIPT — right side. Pulled down 20px (y:90→110) to clear top edge cropping -->
      <g class="receipt" transform="translate(1080, 110)">
        <path d="M0 20 L220 20 L220 280 L210 290 L200 280 L190 290 L180 280 L170 290 L160 280 L150 290 L140 280 L130 290 L120 280 L110 290 L100 280 L90 290 L80 280 L70 290 L60 280 L50 290 L40 280 L30 290 L20 280 L10 290 L0 280 Z"
          stroke="white" stroke-opacity="0.22" stroke-width="2"
          fill="white" fill-opacity="0.07" class="receipt-body"/>
        <text x="110" y="50" text-anchor="middle" fill="white" fill-opacity="0.55" font-size="11" font-family="monospace" letter-spacing="2" font-weight="700" class="receipt-line rc-l1">INVOICE</text>
        <line x1="20" y1="62" x2="200" y2="62" stroke="white" stroke-opacity="0.2" stroke-width="1" stroke-dasharray="3 3" class="receipt-line rc-l2"/>

        <text x="20" y="90" fill="white" fill-opacity="0.5" font-size="9" font-family="monospace" letter-spacing="1" class="receipt-line rc-l3">SERVICE</text>
        <text x="20" y="110" fill="white" fill-opacity="0.7" font-size="13" font-family="monospace" font-weight="700" class="receipt-line rc-l4">PC Tune-Up</text>

        <g class="receipt-line rc-l5">
          <text x="20" y="135" fill="white" fill-opacity="0.4" font-size="9" font-family="monospace">Optimization + cleanup</text>
        </g>

        <line x1="20" y1="155" x2="200" y2="155" stroke="white" stroke-opacity="0.25" stroke-width="1" class="receipt-line rc-l6"/>

        <g class="receipt-line rc-l7">
          <text x="20" y="180" fill="white" fill-opacity="0.5" font-size="11" font-family="monospace" font-weight="700">TOTAL</text>
          <text x="200" y="180" text-anchor="end" fill="white" fill-opacity="0.85" font-size="18" font-family="monospace" font-weight="900">$60</text>
        </g>

        <text x="110" y="205" text-anchor="middle" fill="white" fill-opacity="0.4" font-size="8" font-family="monospace" letter-spacing="1" class="receipt-line rc-l8">THANK YOU!</text>

        <g class="receipt-stamp" transform="translate(150, 125) rotate(-12)">
          <rect x="-42" y="-20" width="84" height="40" rx="3" stroke="white" stroke-opacity="0.5" stroke-width="2.5" fill="none"/>
          <rect x="-38" y="-16" width="76" height="32" rx="2" stroke="white" stroke-opacity="0.25" stroke-width="1" fill="none"/>
          <text x="0" y="6" text-anchor="middle" fill="white" fill-opacity="0.7" font-size="18" font-family="monospace" letter-spacing="2" font-weight="900">PAID</text>
        </g>
      </g>

      <!-- COIN STACKS — pulled up 40px (y:420→380) so bottom of tallest stack (y:412 in scene) sits in safe zone -->
      <g class="coins" transform="translate(480, 380)">
        <g class="coin-stack stack-1">
          <ellipse cx="0" cy="40" rx="26" ry="7" stroke="white" stroke-opacity="0.25" stroke-width="1.5" fill="white" fill-opacity="0.08" class="coin c1a"/>
          <ellipse cx="0" cy="28" rx="26" ry="7" stroke="white" stroke-opacity="0.25" stroke-width="1.5" fill="white" fill-opacity="0.08" class="coin c1b"/>
          <ellipse cx="0" cy="16" rx="26" ry="7" stroke="white" stroke-opacity="0.28" stroke-width="1.5" fill="white" fill-opacity="0.1" class="coin c1c"/>
          <text x="0" y="19" text-anchor="middle" fill="white" fill-opacity="0.45" font-size="11" font-weight="900" font-family="monospace">$</text>
        </g>
        <g class="coin-stack stack-2" transform="translate(80, 0)">
          <ellipse cx="0" cy="40" rx="28" ry="7.5" stroke="white" stroke-opacity="0.25" stroke-width="1.5" fill="white" fill-opacity="0.08" class="coin c2a"/>
          <ellipse cx="0" cy="28" rx="28" ry="7.5" stroke="white" stroke-opacity="0.25" stroke-width="1.5" fill="white" fill-opacity="0.08" class="coin c2b"/>
          <ellipse cx="0" cy="16" rx="28" ry="7.5" stroke="white" stroke-opacity="0.25" stroke-width="1.5" fill="white" fill-opacity="0.08" class="coin c2c"/>
          <ellipse cx="0" cy="4" rx="28" ry="7.5" stroke="white" stroke-opacity="0.25" stroke-width="1.5" fill="white" fill-opacity="0.08" class="coin c2d"/>
          <ellipse cx="0" cy="-8" rx="28" ry="7.5" stroke="white" stroke-opacity="0.3" stroke-width="1.5" fill="white" fill-opacity="0.1" class="coin c2e"/>
          <text x="0" y="-5" text-anchor="middle" fill="white" fill-opacity="0.45" font-size="12" font-weight="900" font-family="monospace">$</text>
        </g>
        <g class="coin-stack stack-3" transform="translate(170, 0)">
          <ellipse cx="0" cy="40" rx="26" ry="7" stroke="white" stroke-opacity="0.25" stroke-width="1.5" fill="white" fill-opacity="0.08" class="coin c3a"/>
          <ellipse cx="0" cy="28" rx="26" ry="7" stroke="white" stroke-opacity="0.25" stroke-width="1.5" fill="white" fill-opacity="0.08" class="coin c3b"/>
          <ellipse cx="0" cy="16" rx="26" ry="7" stroke="white" stroke-opacity="0.25" stroke-width="1.5" fill="white" fill-opacity="0.08" class="coin c3c"/>
          <ellipse cx="0" cy="4" rx="26" ry="7" stroke="white" stroke-opacity="0.28" stroke-width="1.5" fill="white" fill-opacity="0.1" class="coin c3d"/>
          <text x="0" y="7" text-anchor="middle" fill="white" fill-opacity="0.45" font-size="11" font-weight="900" font-family="monospace">$</text>
        </g>
        <g class="coin-stack stack-4" transform="translate(250, 0)">
          <ellipse cx="0" cy="40" rx="24" ry="6.5" stroke="white" stroke-opacity="0.25" stroke-width="1.5" fill="white" fill-opacity="0.08" class="coin c4a"/>
          <ellipse cx="0" cy="28" rx="24" ry="6.5" stroke="white" stroke-opacity="0.28" stroke-width="1.5" fill="white" fill-opacity="0.1" class="coin c4b"/>
          <text x="0" y="31" text-anchor="middle" fill="white" fill-opacity="0.45" font-size="10" font-weight="900" font-family="monospace">$</text>
        </g>
        <g class="coin-stack stack-5" transform="translate(330, 0)">
          <ellipse cx="0" cy="40" rx="25" ry="7" stroke="white" stroke-opacity="0.25" stroke-width="1.5" fill="white" fill-opacity="0.08" class="coin c5a"/>
          <ellipse cx="0" cy="28" rx="25" ry="7" stroke="white" stroke-opacity="0.25" stroke-width="1.5" fill="white" fill-opacity="0.08" class="coin c5b"/>
          <ellipse cx="0" cy="16" rx="25" ry="7" stroke="white" stroke-opacity="0.28" stroke-width="1.5" fill="white" fill-opacity="0.1" class="coin c5c"/>
          <text x="0" y="19" text-anchor="middle" fill="white" fill-opacity="0.45" font-size="11" font-weight="900" font-family="monospace">$</text>
        </g>
      </g>

      <!-- AMBIENT PRICING GLYPHS — top row pulled from y:45-65 to y:75-95, all kept inside safe zone (y:75 to y:445) -->
      <g class="glyph-field" font-family="monospace" font-weight="700" fill="white">
        <text x="80" y="85" font-size="18" fill-opacity="0.1" class="glyph-tw gl-a">$</text>
        <text x="340" y="75" font-size="14" fill-opacity="0.1" class="glyph-tw gl-b">%</text>
        <text x="420" y="125" font-size="22" fill-opacity="0.12" class="glyph-tw gl-c">$</text>
        <text x="510" y="80" font-size="13" fill-opacity="0.1" class="glyph-tw gl-d">$</text>
        <text x="580" y="160" font-size="15" fill-opacity="0.1" class="glyph-tw gl-a">%</text>
        <text x="680" y="90" font-size="17" fill-opacity="0.11" class="glyph-tw gl-b">$</text>
        <text x="770" y="130" font-size="13" fill-opacity="0.1" class="glyph-tw gl-c">%</text>
        <text x="860" y="80" font-size="20" fill-opacity="0.12" class="glyph-tw gl-d">$</text>
        <text x="940" y="150" font-size="14" fill-opacity="0.1" class="glyph-tw gl-a">$</text>
        <text x="1010" y="90" font-size="16" fill-opacity="0.1" class="glyph-tw gl-b">%</text>
        <text x="1340" y="100" font-size="18" fill-opacity="0.11" class="glyph-tw gl-c">$</text>
        <text x="1360" y="180" font-size="13" fill-opacity="0.1" class="glyph-tw gl-d">%</text>
        <text x="420" y="290" font-size="14" fill-opacity="0.09" class="glyph-tw gl-a">$</text>
        <text x="900" y="300" font-size="13" fill-opacity="0.09" class="glyph-tw gl-b">%</text>
      </g>

      <!-- Grid -->
      <g stroke="white" stroke-opacity="0.04" stroke-width="1">
        <line x1="0" y1="130" x2="1440" y2="130"/>
        <line x1="0" y1="260" x2="1440" y2="260"/>
        <line x1="360" y1="0" x2="360" y2="520"/>
        <line x1="720" y1="0" x2="720" y2="520"/>
        <line x1="1080" y1="0" x2="1080" y2="520"/>
      </g>
    </svg>

    <!-- MOBILE SVG -->
    <svg class="hero-bg-mobile" viewBox="0 0 400 600" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <defs>
        <linearGradient id="bgGradM" x1="0%" y1="0%" x2="100%" y2="100%">
          <stop offset="0%" style="stop-color:#1e3a8a;stop-opacity:1"/>
          <stop offset="100%" style="stop-color:#2563eb;stop-opacity:1"/>
        </linearGradient>
        <linearGradient id="glowGradM" x1="0%" y1="0%" x2="100%" y2="100%">
          <stop offset="0%" style="stop-color:#3b82f6;stop-opacity:0.3"/>
          <stop offset="100%" style="stop-color:#1d4ed8;stop-opacity:0"/>
        </linearGradient>
      </defs>
      <rect width="400" height="600" fill="url(#bgGradM)"/>
      <ellipse cx="100" cy="160" rx="220" ry="180" fill="url(#glowGradM)" class="glow-orb-1"/>
      <ellipse cx="320" cy="480" rx="220" ry="180" fill="url(#glowGradM)" class="glow-orb-2"/>

      <!-- Price tag — top-left. Pulled down from y:30 to y:60 so the string isn't right at viewport edge -->
      <g class="price-tag" transform="translate(20, 60)">
        <line x1="45" y1="0" x2="45" y2="30" stroke="white" stroke-opacity="0.18" stroke-width="1.5" class="tag-string"/>
        <circle cx="45" cy="0" r="2.5" fill="white" fill-opacity="0.2" class="tag-pivot"/>
        <g class="tag-swing" transform-origin="45 0">
          <path d="M45 30 L18 44 L18 110 L118 110 L118 44 L45 30 Z"
            stroke="white" stroke-opacity="0.25" stroke-width="1.5"
            fill="white" fill-opacity="0.08" class="tag-body"/>
          <circle cx="45" cy="44" r="3.5" stroke="white" stroke-opacity="0.3" stroke-width="1" fill="#1e3a8a" class="tag-hole"/>
          <text x="71" y="68" text-anchor="middle" fill="white" fill-opacity="0.55" font-size="8" font-family="monospace" letter-spacing="1.5" font-weight="700" class="tag-text tag-t1">FLAT RATE</text>
          <line x1="30" y1="76" x2="108" y2="76" stroke="white" stroke-opacity="0.2" stroke-width="1" class="tag-text tag-t2"/>
          <text x="71" y="95" text-anchor="middle" fill="white" fill-opacity="0.7" font-size="20" font-weight="900" font-family="monospace" class="tag-text tag-t3">$50</text>
          <text x="71" y="105" text-anchor="middle" fill="white" fill-opacity="0.35" font-size="5.5" font-family="monospace" letter-spacing="1" class="tag-text tag-t4">DIAGNOSTIC</text>
        </g>
      </g>

      <!-- Receipt — top-right. Pulled down from y:30 to y:60 (top of receipt was getting cropped on tall phones) -->
      <g class="receipt" transform="translate(240, 60)">
        <path d="M0 14 L140 14 L140 170 L132 178 L124 170 L116 178 L108 170 L100 178 L92 170 L84 178 L76 170 L68 178 L60 170 L52 178 L44 170 L36 178 L28 170 L20 178 L12 170 L4 178 L0 170 Z"
          stroke="white" stroke-opacity="0.22" stroke-width="1.5"
          fill="white" fill-opacity="0.07" class="receipt-body"/>
        <text x="70" y="35" text-anchor="middle" fill="white" fill-opacity="0.55" font-size="8" font-family="monospace" letter-spacing="1.5" font-weight="700" class="receipt-line rc-l1">INVOICE</text>
        <line x1="14" y1="44" x2="126" y2="44" stroke="white" stroke-opacity="0.2" stroke-width="1" stroke-dasharray="2 2" class="receipt-line rc-l2"/>

        <text x="14" y="62" fill="white" fill-opacity="0.5" font-size="6.5" font-family="monospace" letter-spacing="1" class="receipt-line rc-l3">SERVICE</text>
        <text x="14" y="78" fill="white" fill-opacity="0.7" font-size="10" font-family="monospace" font-weight="700" class="receipt-line rc-l4">PC Tune-Up</text>

        <text x="14" y="94" fill="white" fill-opacity="0.4" font-size="6.5" font-family="monospace" class="receipt-line rc-l5">Optimization + cleanup</text>

        <line x1="14" y1="108" x2="126" y2="108" stroke="white" stroke-opacity="0.25" stroke-width="1" class="receipt-line rc-l6"/>

        <g class="receipt-line rc-l7">
          <text x="14" y="126" fill="white" fill-opacity="0.5" font-size="8" font-family="monospace" font-weight="700">TOTAL</text>
          <text x="126" y="126" text-anchor="end" fill="white" fill-opacity="0.85" font-size="13" font-family="monospace" font-weight="900">$60</text>
        </g>

        <text x="70" y="146" text-anchor="middle" fill="white" fill-opacity="0.4" font-size="6" font-family="monospace" letter-spacing="1" class="receipt-line rc-l8">THANK YOU!</text>

        <g class="receipt-stamp" transform="translate(96, 82) rotate(-12)">
          <rect x="-26" y="-12" width="52" height="24" rx="2" stroke="white" stroke-opacity="0.5" stroke-width="1.8" fill="none"/>
          <rect x="-23" y="-9" width="46" height="18" rx="1.5" stroke="white" stroke-opacity="0.25" stroke-width="0.8" fill="none"/>
          <text x="0" y="4" text-anchor="middle" fill="white" fill-opacity="0.7" font-size="11" font-family="monospace" letter-spacing="1.5" font-weight="900">PAID</text>
        </g>
      </g>

      <!-- Coin stacks — pulled up from y:470 to y:430 so bottom of coins (y:458 in scene) is safely above viewport edge -->
      <g class="coins" transform="translate(80, 430)">
        <g class="coin-stack stack-1">
          <ellipse cx="0" cy="28" rx="18" ry="5" stroke="white" stroke-opacity="0.25" stroke-width="1.5" fill="white" fill-opacity="0.08" class="coin c1a"/>
          <ellipse cx="0" cy="20" rx="18" ry="5" stroke="white" stroke-opacity="0.25" stroke-width="1.5" fill="white" fill-opacity="0.08" class="coin c1b"/>
          <ellipse cx="0" cy="12" rx="18" ry="5" stroke="white" stroke-opacity="0.28" stroke-width="1.5" fill="white" fill-opacity="0.1" class="coin c1c"/>
          <text x="0" y="15" text-anchor="middle" fill="white" fill-opacity="0.45" font-size="9" font-weight="900" font-family="monospace">$</text>
        </g>
        <g class="coin-stack stack-2" transform="translate(60, 0)">
          <ellipse cx="0" cy="28" rx="20" ry="5.5" stroke="white" stroke-opacity="0.25" stroke-width="1.5" fill="white" fill-opacity="0.08" class="coin c2a"/>
          <ellipse cx="0" cy="20" rx="20" ry="5.5" stroke="white" stroke-opacity="0.25" stroke-width="1.5" fill="white" fill-opacity="0.08" class="coin c2b"/>
          <ellipse cx="0" cy="12" rx="20" ry="5.5" stroke="white" stroke-opacity="0.25" stroke-width="1.5" fill="white" fill-opacity="0.08" class="coin c2c"/>
          <ellipse cx="0" cy="4" rx="20" ry="5.5" stroke="white" stroke-opacity="0.3" stroke-width="1.5" fill="white" fill-opacity="0.1" class="coin c2d"/>
          <text x="0" y="7" text-anchor="middle" fill="white" fill-opacity="0.45" font-size="10" font-weight="900" font-family="monospace">$</text>
        </g>
        <g class="coin-stack stack-3" transform="translate(130, 0)">
          <ellipse cx="0" cy="28" rx="18" ry="5" stroke="white" stroke-opacity="0.25" stroke-width="1.5" fill="white" fill-opacity="0.08" class="coin c3a"/>
          <ellipse cx="0" cy="20" rx="18" ry="5" stroke="white" stroke-opacity="0.28" stroke-width="1.5" fill="white" fill-opacity="0.1" class="coin c3b"/>
          <text x="0" y="23" text-anchor="middle" fill="white" fill-opacity="0.45" font-size="9" font-weight="900" font-family="monospace">$</text>
        </g>
        <g class="coin-stack stack-4" transform="translate(200, 0)">
          <ellipse cx="0" cy="28" rx="17" ry="4.5" stroke="white" stroke-opacity="0.25" stroke-width="1.5" fill="white" fill-opacity="0.08" class="coin c4a"/>
          <ellipse cx="0" cy="20" rx="17" ry="4.5" stroke="white" stroke-opacity="0.25" stroke-width="1.5" fill="white" fill-opacity="0.08" class="coin c4b"/>
          <ellipse cx="0" cy="12" rx="17" ry="4.5" stroke="white" stroke-opacity="0.28" stroke-width="1.5" fill="white" fill-opacity="0.1" class="coin c4c"/>
          <text x="0" y="15" text-anchor="middle" fill="white" fill-opacity="0.45" font-size="9" font-weight="900" font-family="monospace">$</text>
        </g>
      </g>

      <!-- Floating pricing glyphs — kept inside safe zone (y:70 to y:540, was y:40 to y:560) -->
      <g class="glyph-field" font-family="monospace" font-weight="700" fill="white">
        <text x="185" y="70" font-size="14" fill-opacity="0.11" class="glyph-tw gl-a">$</text>
        <text x="195" y="120" font-size="11" fill-opacity="0.09" class="glyph-tw gl-c">%</text>
        <text x="170" y="170" font-size="13" fill-opacity="0.1" class="glyph-tw gl-b">$</text>
        <text x="30" y="240" font-size="14" fill-opacity="0.1" class="glyph-tw gl-d">%</text>
        <text x="120" y="220" font-size="12" fill-opacity="0.1" class="glyph-tw gl-a">$</text>
        <text x="220" y="250" font-size="15" fill-opacity="0.11" class="glyph-tw gl-c">$</text>
        <text x="350" y="230" font-size="13" fill-opacity="0.1" class="glyph-tw gl-b">%</text>
        <text x="60" y="310" font-size="12" fill-opacity="0.09" class="glyph-tw gl-d">$</text>
        <text x="300" y="310" font-size="13" fill-opacity="0.1" class="glyph-tw gl-a">%</text>
        <text x="30" y="390" font-size="14" fill-opacity="0.1" class="glyph-tw gl-b">$</text>
        <text x="370" y="380" font-size="13" fill-opacity="0.1" class="glyph-tw gl-c">%</text>
        <text x="190" y="540" font-size="12" fill-opacity="0.09" class="glyph-tw gl-d">$</text>
      </g>

      <!-- Grid -->
      <g stroke="white" stroke-opacity="0.04" stroke-width="1">
        <line x1="0" y1="150" x2="400" y2="150"/>
        <line x1="0" y1="300" x2="400" y2="300"/>
        <line x1="133" y1="0" x2="133" y2="600"/>
        <line x1="266" y1="0" x2="266" y2="600"/>
      </g>
    </svg>

    <!-- Hero text -->
    <div id="hero-content">
      <p class="hero-label">TRANSPARENT PRICING</p>
      <h1 id="hero-wordmark">Flat Rates. No Surprises.</h1>
      <p id="hero-tagline">Honest pricing on every repair. The $50 diagnostic fee is applied toward your repair — you only pay it once.</p>
