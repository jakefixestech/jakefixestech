---

<Layout
  title="Website Portfolio & Examples | Jake Fixes Tech — Littleton, NH"
  description="Browse example websites built by Jake Fixes Tech. Starter, Professional and Premium package examples showing real-world results for small businesses."
>

  <!-- Animated SVG Hero -->
  <section id="hero-svg" aria-label="Website portfolio examples">

    <!-- DESKTOP SVG -->
    <svg class="hero-bg-desktop" viewBox="0 0 1440 520" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <defs>
        <linearGradient id="bgGrad" x1="0%" y1="0%" x2="100%" y2="100%">
          <stop offset="0%" style="stop-color:#1e3a8a;stop-opacity:1"/>
          <stop offset="100%" style="stop-color:#2563eb;stop-opacity:1"/>
        </linearGradient>
        <linearGradient id="glowGrad" x1="0%" y1="0%" x2="100%" y2="100%">
          <stop offset="0%" style="stop-color:#3b82f6;stop-opacity:0.25"/>
          <stop offset="100%" style="stop-color:#1d4ed8;stop-opacity:0"/>
        </linearGradient>
      </defs>
      <rect width="1440" height="520" fill="url(#bgGrad)"/>
      <ellipse cx="320" cy="240" rx="360" ry="240" fill="url(#glowGrad)" class="glow-orb-1"/>
      <ellipse cx="1180" cy="320" rx="320" ry="220" fill="url(#glowGrad)" class="glow-orb-2"/>

      <!-- LEFT: stacked browser window frames - back, middle, front -->
      <g class="window-stack" transform="translate(90, 130)">
        <!-- Back window -->
        <g class="win win-back">
          <rect x="80" y="70" width="280" height="190" rx="8" stroke="white" stroke-opacity="0.18" stroke-width="1.5" fill="white" fill-opacity="0.04"/>
          <rect x="80" y="70" width="280" height="22" rx="8" fill="white" fill-opacity="0.08"/>
          <circle cx="95" cy="81" r="3" fill="white" fill-opacity="0.3"/>
          <circle cx="107" cy="81" r="3" fill="white" fill-opacity="0.3"/>
          <circle cx="119" cy="81" r="3" fill="white" fill-opacity="0.3"/>
          <line x1="100" y1="115" x2="280" y2="115" stroke="white" stroke-opacity="0.15" stroke-width="2"/>
          <line x1="100" y1="135" x2="240" y2="135" stroke="white" stroke-opacity="0.12" stroke-width="2"/>
          <line x1="100" y1="155" x2="260" y2="155" stroke="white" stroke-opacity="0.12" stroke-width="2"/>
        </g>
        <!-- Middle window -->
        <g class="win win-mid">
          <rect x="40" y="40" width="280" height="200" rx="8" stroke="white" stroke-opacity="0.22" stroke-width="1.5" fill="white" fill-opacity="0.06"/>
          <rect x="40" y="40" width="280" height="24" rx="8" fill="white" fill-opacity="0.1"/>
          <circle cx="56" cy="52" r="3.5" fill="white" fill-opacity="0.4"/>
          <circle cx="69" cy="52" r="3.5" fill="white" fill-opacity="0.4"/>
          <circle cx="82" cy="52" r="3.5" fill="white" fill-opacity="0.4"/>
          <line x1="60" y1="88" x2="300" y2="88" stroke="white" stroke-opacity="0.2" stroke-width="2"/>
          <line x1="60" y1="112" x2="240" y2="112" stroke="white" stroke-opacity="0.16" stroke-width="2"/>
          <line x1="60" y1="136" x2="260" y2="136" stroke="white" stroke-opacity="0.16" stroke-width="2"/>
          <rect x="60" y="160" width="80" height="50" rx="4" stroke="white" stroke-opacity="0.18" stroke-width="1.5" fill="white" fill-opacity="0.05"/>
          <rect x="150" y="160" width="80" height="50" rx="4" stroke="white" stroke-opacity="0.18" stroke-width="1.5" fill="white" fill-opacity="0.05"/>
        </g>
        <!-- Front window (most prominent) -->
        <g class="win win-front">
          <rect x="0" y="0" width="280" height="210" rx="8" stroke="white" stroke-opacity="0.3" stroke-width="2" fill="white" fill-opacity="0.08"/>
          <rect x="0" y="0" width="280" height="26" rx="8" fill="white" fill-opacity="0.13"/>
          <circle cx="18" cy="13" r="4" fill="white" fill-opacity="0.55"/>
          <circle cx="32" cy="13" r="4" fill="white" fill-opacity="0.55"/>
          <circle cx="46" cy="13" r="4" fill="white" fill-opacity="0.55"/>
          <!-- URL bar -->
