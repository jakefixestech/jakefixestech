          <text x="26" y="30" text-anchor="middle" fill="white" fill-opacity="0.85" font-size="11" font-weight="900" font-family="ui-monospace, monospace" class="gauge-num gauge-num-4">100</text>
        </g>
      </g>

      <!-- Ambient code labels -->
      <g font-family="ui-monospace, SFMono-Regular, Menlo, monospace" font-weight="700" fill="white">
        <text x="30" y="290" font-size="10" fill-opacity="0.1" class="code-tw ct-a">&lt;header /&gt;</text>
        <text x="280" y="290" font-size="10" fill-opacity="0.1" class="code-tw ct-b">100/100</text>
