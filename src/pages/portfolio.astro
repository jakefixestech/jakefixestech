---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Website Portfolio & Examples | Jake Fixes Tech — Littleton, NH"
description="Browse example websites built by Jake Fixes Tech. Starter, Professional and Premium package examples showing real-world results for small businesses.">

  <!-- Header Banner -->
  <section style="position:relative;overflow:hidden;background-color:rgb(30,64,175);">
    <img src="/hero.jpg" alt="Professional tech workspace with dual monitors" fetchpriority="high" decoding="async" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;z-index:0;" />
    <div style="position:absolute;inset:0;background:linear-gradient(135deg,rgba(30,64,175,0.88),rgba(37,99,235,0.88));z-index:1;"></div>
    <div style="max-width:56rem;margin:0 auto;padding:4rem 1.5rem 7rem 1.5rem;text-align:center;position:relative;z-index:2;">
      <p style="font-size:0.875rem;font-weight:600;text-transform:uppercase;letter-spacing:0.1em;color:#93c5fd;">Portfolio</p>
      <h1 style="margin-top:0.5rem;font-size:2.5rem;font-weight:800;color:white;line-height:1.2;">Example Websites</h1>
      <p style="margin-top:1rem;color:#bfdbfe;font-size:1.1rem;line-height:1.75;max-width:42rem;margin-left:auto;margin-right:auto;">
        Every example site below is mobile responsive, WCAG AA accessible, scores 10/10 on WAVE and 100/100 on Lighthouse. This is the standard I hold all my work to.
      </p>
    </div>
  </section>

  <section style="background:#f8fafc;padding:4rem 1.5rem;">
    <div style="max-width:72rem;margin:0 auto;">

      <!-- Starter Examples -->
      <div style="margin-bottom:4rem;">
        <div style="display:flex;align-items:center;gap:1rem;margin-bottom:0.5rem;">
          <h2 style="font-size:1.5rem;font-weight:800;color:#111827;">Starter Package Examples</h2>
          <span style="background:#dbeafe;color:#1e40af;font-size:0.75rem;font-weight:700;padding:0.25rem 0.75rem;border-radius:9999px;white-space:nowrap;">$750</span>
        </div>
        <p style="color:#6b7280;font-size:0.9rem;margin-bottom:1.5rem;line-height:1.75;">1–3 page websites for local businesses, tradespeople and simple landing pages.</p>
        <div class="portfolio-grid">
          <a href="https://starter1.jakefixestech.com" target="_blank" rel="noopener noreferrer" class="portfolio-card">
            <div class="portfolio-preview" style="background:linear-gradient(135deg,#0f2942,#1e4976);">
              <div style="color:white;font-weight:700;font-size:1rem;text-align:center;padding:1rem;">Granite State Plumbing & Drain</div>
              <div style="color:#93c5fd;font-size:0.75rem;text-align:center;">Plumbing & Drain Services</div>
            </div>
            <div class="portfolio-info">
              <div style="font-weight:600;color:#111827;font-size:0.95rem;">Granite State Plumbing & Drain</div>
              <div style="color:#4b5563;font-size:0.8rem;margin-top:0.25rem;">Littleton, NH · 3 pages</div>
              <div class="portfolio-link">View Example →</div>
            </div>
          </a>
          <a href="https://starter2.jakefixestech.com" target="_blank" rel="noopener noreferrer" class="portfolio-card">
            <div class="portfolio-preview" style="background:linear-gradient(135deg,#78350f,#b45309);">
              <div style="color:white;font-weight:700;font-size:1rem;text-align:center;padding:1rem;">White Mountain Maple Co.</div>
              <div style="color:#fde68a;font-size:0.75rem;text-align:center;">Small Batch NH Maple Syrup</div>
            </div>
            <div class="portfolio-info">
              <div style="font-weight:600;color:#111827;font-size:0.95rem;">White Mountain Maple Co.</div>
              <div style="color:#4b5563;font-size:0.8rem;margin-top:0.25rem;">Littleton, NH · 3 pages</div>
              <div class="portfolio-link">View Example →</div>
            </div>
          </a>
          <a href="https://starter3.jakefixestech.com" target="_blank" rel="noopener noreferrer" class="portfolio-card">
            <div class="portfolio-preview" style="background:linear-gradient(135deg,#14532d,#15803d);">
              <div style="color:white;font-weight:700;font-size:1rem;text-align:center;padding:1rem;">North Country Lawn & Landscape</div>
              <div style="color:#bbf7d0;font-size:0.75rem;text-align:center;">Lawn Care & Landscaping</div>
            </div>
            <div class="portfolio-info">
              <div style="font-weight:600;color:#111827;font-size:0.95rem;">North Country Lawn & Landscape</div>
              <div style="color:#4b5563;font-size:0.8rem;margin-top:0.25rem;">Littleton, NH · 3 pages</div>
              <div class="portfolio-link">View Example →</div>
            </div>
          </a>
        </div>
      </div>

      <!-- Professional Examples -->
      <div style="margin-bottom:4rem;">
        <div style="display:flex;align-items:center;gap:1rem;margin-bottom:0.5rem;">
          <h2 style="font-size:1.5rem;font-weight:800;color:#111827;">Professional Package Examples</h2>
          <span style="background:#dbeafe;color:#1e40af;font-size:0.75rem;font-weight:700;padding:0.25rem 0.75rem;border-radius:9999px;white-space:nowrap;">$2,000</span>
        </div>
        <p style="color:#6b7280;font-size:0.9rem;margin-bottom:1.5rem;line-height:1.75;">5–15 page websites for small businesses, restaurants and service companies.</p>
        <div class="portfolio-grid">
          <a href="https://pro1.jakefixestech.com" target="_blank" rel="noopener noreferrer" class="portfolio-card">
            <div class="portfolio-preview" style="background:linear-gradient(135deg,#0369a1,#0284c7);">
              <div style="color:white;font-weight:700;font-size:1rem;text-align:center;padding:1rem;">Franconia Family Dental</div>
              <div style="color:#bae6fd;font-size:0.75rem;text-align:center;">Family Dental Practice</div>
            </div>
            <div class="portfolio-info">
              <div style="font-weight:600;color:#111827;font-size:0.95rem;">Franconia Family Dental</div>
              <div style="color:#4b5563;font-size:0.8rem;margin-top:0.25rem;">Franconia, NH · 15 pages</div>
              <div class="portfolio-link">View Example →</div>
            </div>
          </a>
          <a href="https://pro2.jakefixestech.com" target="_blank" rel="noopener noreferrer" class="portfolio-card">
            <div class="portfolio-preview" style="background:linear-gradient(135deg,#18181b,#ea580c);">
              <div style="color:white;font-weight:700;font-size:1rem;text-align:center;padding:1rem;">Summit Fitness & CrossFit</div>
              <div style="color:#fed7aa;font-size:0.75rem;text-align:center;">Fitness & CrossFit Gym</div>
            </div>
            <div class="portfolio-info">
              <div style="font-weight:600;color:#111827;font-size:0.95rem;">Summit Fitness & CrossFit</div>
              <div style="color:#4b5563;font-size:0.8rem;margin-top:0.25rem;">Littleton, NH · 10 pages</div>
              <div class="portfolio-link">View Example →</div>
            </div>
          </a>
          <a href="https://pro3.jakefixestech.com" target="_blank" rel="noopener noreferrer" class="portfolio-card">
            <div class="portfolio-preview" style="background:linear-gradient(135deg,#1B2A4A,#2a3f6e);">
              <div style="color:white;font-weight:700;font-size:1rem;text-align:center;padding:1rem;">North Country Realty Group</div>
              <div style="color:#C9A84C;font-size:0.75rem;text-align:center;">Real Estate — Lancaster, NH</div>
            </div>
            <div class="portfolio-info">
              <div style="font-weight:600;color:#111827;font-size:0.95rem;">North Country Realty Group</div>
              <div style="color:#4b5563;font-size:0.8rem;margin-top:0.25rem;">Lancaster, NH · 13 pages</div>
              <div class="portfolio-link">View Example →</div>
            </div>
          </a>
        </div>
      </div>

      <!-- Premium Examples -->
      <div style="margin-bottom:4rem;">
        <div style="display:flex;align-items:center;gap:1rem;margin-bottom:0.5rem;">
          <h2 style="font-size:1.5rem;font-weight:800;color:#111827;">Premium Package Examples</h2>
          <span style="background:#dbeafe;color:#1e40af;font-size:0.75rem;font-weight:700;padding:0.25rem 0.75rem;border-radius:9999px;white-space:nowrap;">$3,500+</span>
        </div>
        <p style="color:#6b7280;font-size:0.9rem;margin-bottom:1.5rem;line-height:1.75;">30+ page custom builds for schools, municipalities and large organizations.</p>
        <div class="portfolio-grid">
          <a href="https://premium1.jakefixestech.com" target="_blank" rel="noopener noreferrer" class="portfolio-card">
            <div class="portfolio-preview" style="background:linear-gradient(135deg,#1B2E4B,#2C4A7C);">
              <div style="color:white;font-weight:700;font-size:1rem;text-align:center;padding:1rem;">Town of Littleton, NH</div>
              <div style="color:#C8973A;font-size:0.75rem;text-align:center;">Official Municipal Website</div>
            </div>
            <div class="portfolio-info">
              <div style="font-weight:600;color:#111827;font-size:0.95rem;">Town of Littleton, NH</div>
              <div style="color:#4b5563;font-size:0.8rem;margin-top:0.25rem;">Littleton, NH · 34 pages</div>
              <div class="portfolio-link">View Example →</div>
            </div>
          </a>
          <div class="portfolio-card coming-soon">
            <div class="portfolio-preview coming-soon-preview">
              <div style="color:#4b5563;font-size:2rem;">🚧</div>
              <div style="color:#4b5563;font-weight:600;font-size:0.9rem;margin-top:0.5rem;">Coming Soon</div>
            </div>
            <div class="portfolio-info">
              <div style="font-weight:600;color:#4b5563;font-size:0.95rem;">Example in progress</div>
              <div style="color:#4b5563;font-size:0.8rem;margin-top:0.25rem;">80+ page custom build · Est. $6,000</div>
            </div>
          </div>
          <div class="portfolio-card coming-soon">
            <div class="portfolio-preview coming-soon-preview">
              <div style="color:#4b5563;font-size:2rem;">🚧</div>
              <div style="color:#4b5563;font-weight:600;font-size:0.9rem;margin-top:0.5rem;">Coming Soon</div>
            </div>
            <div class="portfolio-info">
              <div style="font-weight:600;color:#4b5563;font-size:0.95rem;">Example in progress</div>
              <div style="color:#4b5563;font-size:0.8rem;margin-top:0.25rem;">150+ page custom build · Est. $10,000</div>
            </div>
          </div>
        </div>
      </div>

      <!-- Back to Web Design -->
      <div style="text-align:center;padding-top:1rem;border-top:1px solid #e5e7eb;">
        <a href="/web-services" style="display:inline-flex;align-items:center;gap:0.5rem;color:#2563eb;font-weight:600;font-size:0.95rem;text-decoration:none;">
          <svg style="height:1rem;width:1rem;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M19 12H5M12 5l-7 7 7 7"/></svg>
          Back to Web Design & Pricing
        </a>
      </div>

    </div>
  </section>

</Layout>

<style>
  .portfolio-grid {
    display: grid;
    gap: 1.5rem;
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .portfolio-card {
    border: 1px solid #e5e7eb;
    border-radius: 0.75rem;
    overflow: hidden;
    background: white;
    text-decoration: none;
    transition: box-shadow 0.2s, transform 0.2s;
  }

  .portfolio-card:not(.coming-soon):hover {
    box-shadow: 0 4px 20px rgba(0,0,0,0.1);
    transform: translateY(-2px);
  }

  .portfolio-preview {
    height: 120px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 1rem;
  }

  .coming-soon-preview {
    background: #f3f4f6;
    border-bottom: 1px solid #e5e7eb;
  }

  .portfolio-info {
    padding: 1rem;
  }

  .portfolio-link {
    color: #2563eb;
    font-size: 0.8rem;
    font-weight: 600;
    margin-top: 0.5rem;
  }

  .coming-soon {
    cursor: default;
  }

  @media (max-width: 768px) {
    .portfolio-grid {
      grid-template-columns: 1fr;
    }
  }
</style>