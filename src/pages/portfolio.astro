          <rect x="103" y="120" width="74" height="74" rx="4" stroke="white" stroke-opacity="0.22" stroke-width="1.5" fill="white" fill-opacity="0.06" class="win-card wc-2"/>
          <rect x="186" y="120" width="74" height="74" rx="4" stroke="white" stroke-opacity="0.22" stroke-width="1.5" fill="white" fill-opacity="0.06" class="win-card wc-3"/>
        </g>
      </g>

      <!-- RIGHT: Lighthouse-style score gauges -->
      <g class="score-panel" transform="translate(895, 140)">
        <!-- Gauge 1: 100 Performance -->
        <g class="gauge gauge-1">
          <circle cx="40" cy="40" r="32" stroke="white" stroke-opacity="0.15" stroke-width="4" fill="none"/>
          <circle cx="40" cy="40" r="32" stroke="white" stroke-opacity="0.7" stroke-width="4" fill="none"
            stroke-dasharray="201" stroke-dashoffset="201" stroke-linecap="round"
            transform="rotate(-90 40 40)" class="gauge-arc gauge-arc-1"/>
          <text x="40" y="46" text-anchor="middle" fill="white" fill-opacity="0.85" font-size="20" font-weight="900" font-family="ui-monospace, monospace" class="gauge-num gauge-num-1">100</text>
          <text x="40" y="92" text-anchor="middle" fill="white" fill-opacity="0.5" font-size="9" font-family="ui-monospace, monospace" letter-spacing="1">PERF</text>
        </g>
        <!-- Gauge 2: 100 Accessibility -->
        <g class="gauge gauge-2" transform="translate(85, 0)">
          <circle cx="40" cy="40" r="32" stroke="white" stroke-opacity="0.15" stroke-width="4" fill="none"/>
          <circle cx="40" cy="40" r="32" stroke="white" stroke-opacity="0.7" stroke-width="4" fill="none"
            stroke-dasharray="201" stroke-dashoffset="201" stroke-linecap="round"
            transform="rotate(-90 40 40)" class="gauge-arc gauge-arc-2"/>
          <text x="40" y="46" text-anchor="middle" fill="white" fill-opacity="0.85" font-size="20" font-weight="900" font-family="ui-monospace, monospace" class="gauge-num gauge-num-2">100</text>
          <text x="40" y="92" text-anchor="middle" fill="white" fill-opacity="0.5" font-size="9" font-family="ui-monospace, monospace" letter-spacing="1">ACCESS</text>
        </g>
        <!-- Gauge 3: 100 Best Practices -->
        <g class="gauge gauge-3" transform="translate(170, 0)">
          <circle cx="40" cy="40" r="32" stroke="white" stroke-opacity="0.15" stroke-width="4" fill="none"/>
          <circle cx="40" cy="40" r="32" stroke="white" stroke-opacity="0.7" stroke-width="4" fill="none"
            stroke-dasharray="201" stroke-dashoffset="201" stroke-linecap="round"
            transform="rotate(-90 40 40)" class="gauge-arc gauge-arc-3"/>
          <text x="40" y="46" text-anchor="middle" fill="white" fill-opacity="0.85" font-size="20" font-weight="900" font-family="ui-monospace, monospace" class="gauge-num gauge-num-3">100</text>
          <text x="40" y="92" text-anchor="middle" fill="white" fill-opacity="0.5" font-size="9" font-family="ui-monospace, monospace" letter-spacing="1">BEST</text>
        </g>
        <!-- Gauge 4: 100 SEO -->
        <g class="gauge gauge-4" transform="translate(255, 0)">
          <circle cx="40" cy="40" r="32" stroke="white" stroke-opacity="0.15" stroke-width="4" fill="none"/>
          <circle cx="40" cy="40" r="32" stroke="white" stroke-opacity="0.7" stroke-width="4" fill="none"
            stroke-dasharray="201" stroke-dashoffset="201" stroke-linecap="round"
            transform="rotate(-90 40 40)" class="gauge-arc gauge-arc-4"/>
          <text x="40" y="46" text-anchor="middle" fill="white" fill-opacity="0.85" font-size="20" font-weight="900" font-family="ui-monospace, monospace" class="gauge-num gauge-num-4">100</text>
          <text x="40" y="92" text-anchor="middle" fill="white" fill-opacity="0.5" font-size="9" font-family="ui-monospace, monospace" letter-spacing="1">SEO</text>
        </g>
        <!-- WAVE 10/10 stamp — outer group positions, inner group animates opacity only -->
        <g transform="translate(105, 130)">
          <g class="wave-stamp">
            <rect x="0" y="0" width="120" height="36" rx="4" stroke="white" stroke-opacity="0.45" stroke-width="2" fill="none"/>
            <rect x="4" y="4" width="112" height="28" rx="2" stroke="white" stroke-opacity="0.2" stroke-width="1" fill="none"/>
            <text x="60" y="24" text-anchor="middle" fill="white" fill-opacity="0.7" font-size="13" font-family="ui-monospace, monospace" letter-spacing="2" font-weight="900">WAVE 10/10</text>
          </g>
        </g>
      </g>

      <!-- Cursor moving from windows toward gauges, with click flash -->
      <g class="cursor-group">
        <g class="cursor-shape">
          <path d="M0 0 L0 16 L4 12 L7 18 L10 17 L7 11 L13 11 Z"
                fill="white" fill-opacity="0.8" stroke="#1e3a8a" stroke-width="1"/>
        </g>
        <circle class="click-pulse" cx="0" cy="0" r="3" fill="white" fill-opacity="0"/>
      </g>

      <!-- AMBIENT MONOSPACE CODE/LABELS -->
      <g font-family="ui-monospace, SFMono-Regular, Menlo, monospace" font-weight="700" fill="white">
        <text x="80" y="100" font-size="11" fill-opacity="0.1" class="code-tw ct-a">&lt;header /&gt;</text>
        <text x="120" y="430" font-size="11" fill-opacity="0.1" class="code-tw ct-b">&lt;section /&gt;</text>
        <text x="660" y="90" font-size="11" fill-opacity="0.11" class="code-tw ct-c">&lt;footer /&gt;</text>
        <text x="700" y="430" font-size="11" fill-opacity="0.1" class="code-tw ct-d">.css {`{ ... }`}</text>
        <text x="900" y="430" font-size="11" fill-opacity="0.1" class="code-tw ct-a">build · ship</text>
        <text x="600" y="450" font-size="10" fill-opacity="0.09" class="code-tw ct-c">10/10</text>
        <text x="80" y="450" font-size="10" fill-opacity="0.09" class="code-tw ct-d">100/100</text>
      </g>

      <!-- Grid -->
      <g stroke="white" stroke-opacity="0.04" stroke-width="1">
        <line x1="0" y1="130" x2="1440" y2="130"/>
        <line x1="0" y1="260" x2="1440" y2="260"/>
        <line x1="0" y1="390" x2="1440" y2="390"/>
        <line x1="360" y1="0" x2="360" y2="520"/>
        <line x1="720" y1="0" x2="720" y2="520"/>
        <line x1="1080" y1="0" x2="1080" y2="520"/>
      </g>
    </svg>

    <!-- MOBILE SVG -->
    <svg class="hero-bg-mobile" viewBox="0 0 400 600" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <defs>
        <linearGradient id="bgGradM" x1="0%" y1="0%" x2="100%" y2="100%">
          <stop offset="0%" style="stop-color:#1e3a8a;stop-opacity:1"/>
          <stop offset="100%" style="stop-color:#2563eb;stop-opacity:1"/>
        </linearGradient>
        <linearGradient id="glowGradM" x1="0%" y1="0%" x2="100%" y2="100%">
          <stop offset="0%" style="stop-color:#3b82f6;stop-opacity:0.3"/>
          <stop offset="100%" style="stop-color:#1d4ed8;stop-opacity:0"/>
        </linearGradient>
      </defs>
      <rect width="400" height="600" fill="url(#bgGradM)"/>
      <ellipse cx="100" cy="160" rx="220" ry="180" fill="url(#glowGradM)" class="glow-orb-1"/>
      <ellipse cx="320" cy="500" rx="220" ry="180" fill="url(#glowGradM)" class="glow-orb-2"/>

      <!-- Browser window - top center -->
      <g class="window-stack" transform="translate(80, 20)">
        <g class="win win-mid">
          <rect x="14" y="14" width="220" height="130" rx="6" stroke="white" stroke-opacity="0.2" stroke-width="1.5" fill="white" fill-opacity="0.05"/>
        </g>
        <g class="win win-front">
          <rect x="0" y="0" width="220" height="140" rx="6" stroke="white" stroke-opacity="0.3" stroke-width="1.5" fill="white" fill-opacity="0.08"/>
          <rect x="0" y="0" width="220" height="20" rx="6" fill="white" fill-opacity="0.13"/>
          <circle cx="12" cy="10" r="2.5" fill="white" fill-opacity="0.55"/>
          <circle cx="22" cy="10" r="2.5" fill="white" fill-opacity="0.55"/>
          <circle cx="32" cy="10" r="2.5" fill="white" fill-opacity="0.55"/>
          <rect x="45" y="5" width="165" height="10" rx="3" fill="white" fill-opacity="0.12"/>
          <rect x="16" y="32" width="188" height="36" rx="4" fill="white" fill-opacity="0.08"/>
          <line x1="26" y1="48" x2="140" y2="48" stroke="white" stroke-opacity="0.45" stroke-width="2.5" stroke-linecap="round" class="win-line wl-1"/>
          <line x1="26" y1="60" x2="170" y2="60" stroke="white" stroke-opacity="0.3" stroke-width="2" stroke-linecap="round" class="win-line wl-2"/>
          <rect x="16" y="78" width="56" height="50" rx="4" stroke="white" stroke-opacity="0.22" stroke-width="1.5" fill="white" fill-opacity="0.06" class="win-card wc-1"/>
          <rect x="82" y="78" width="56" height="50" rx="4" stroke="white" stroke-opacity="0.22" stroke-width="1.5" fill="white" fill-opacity="0.06" class="win-card wc-2"/>
          <rect x="148" y="78" width="56" height="50" rx="4" stroke="white" stroke-opacity="0.22" stroke-width="1.5" fill="white" fill-opacity="0.06" class="win-card wc-3"/>
        </g>
      </g>

      <!-- Score gauges row - bottom (below CTA button) -->
      <g class="score-panel" transform="translate(40, 470)">
        <g class="gauge gauge-1">
          <circle cx="26" cy="26" r="20" stroke="white" stroke-opacity="0.15" stroke-width="2.5" fill="none"/>
          <circle cx="26" cy="26" r="20" stroke="white" stroke-opacity="0.7" stroke-width="2.5" fill="none"
            stroke-dasharray="126" stroke-dashoffset="126" stroke-linecap="round"
            transform="rotate(-90 26 26)" class="gauge-arc gauge-arc-1"/>
          <text x="26" y="30" text-anchor="middle" fill="white" fill-opacity="0.85" font-size="11" font-weight="900" font-family="ui-monospace, monospace" class="gauge-num gauge-num-1">100</text>
        </g>
        <g class="gauge gauge-2" transform="translate(80, 0)">
          <circle cx="26" cy="26" r="20" stroke="white" stroke-opacity="0.15" stroke-width="2.5" fill="none"/>
          <circle cx="26" cy="26" r="20" stroke="white" stroke-opacity="0.7" stroke-width="2.5" fill="none"
            stroke-dasharray="126" stroke-dashoffset="126" stroke-linecap="round"
            transform="rotate(-90 26 26)" class="gauge-arc gauge-arc-2"/>
          <text x="26" y="30" text-anchor="middle" fill="white" fill-opacity="0.85" font-size="11" font-weight="900" font-family="ui-monospace, monospace" class="gauge-num gauge-num-2">100</text>
        </g>
        <g class="gauge gauge-3" transform="translate(160, 0)">
          <circle cx="26" cy="26" r="20" stroke="white" stroke-opacity="0.15" stroke-width="2.5" fill="none"/>
          <circle cx="26" cy="26" r="20" stroke="white" stroke-opacity="0.7" stroke-width="2.5" fill="none"
            stroke-dasharray="126" stroke-dashoffset="126" stroke-linecap="round"
            transform="rotate(-90 26 26)" class="gauge-arc gauge-arc-3"/>
          <text x="26" y="30" text-anchor="middle" fill="white" fill-opacity="0.85" font-size="11" font-weight="900" font-family="ui-monospace, monospace" class="gauge-num gauge-num-3">100</text>
        </g>
        <g class="gauge gauge-4" transform="translate(240, 0)">
          <circle cx="26" cy="26" r="20" stroke="white" stroke-opacity="0.15" stroke-width="2.5" fill="none"/>
          <circle cx="26" cy="26" r="20" stroke="white" stroke-opacity="0.7" stroke-width="2.5" fill="none"
            stroke-dasharray="126" stroke-dashoffset="126" stroke-linecap="round"
