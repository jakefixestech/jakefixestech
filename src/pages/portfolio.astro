const tierLabels: Record<string, { label: string; price: string; desc: string; color: string }> = {
  starter: { label: 'Starter', price: '$750', desc: '1–3 page websites for local businesses and simple landing pages.', color: '#1e40af' },
  pro:     { label: 'Professional', price: '$2,000', desc: '5–15 page websites for small businesses and service companies.', color: '#065f46' },
  premium: { label: 'Premium', price: '$3,500+', desc: '30+ page custom builds for schools, municipalities and large organizations.', color: '#7c3aed' },
  demo:    { label: 'Demo', price: 'Free preview', desc: 'Homepage-only design examples showing range and aesthetic variety.', color: '#92400e' },
};
---

<Layout title="Website Portfolio & Examples | Jake Fixes Tech — Littleton, NH"
description="Browse example websites built by Jake Fixes Tech. Starter, Professional and Premium package examples showing real-world results for small businesses.">

  <!-- Header Banner -->
  <section style="position:relative;overflow:hidden;background-color:rgb(30,64,175);">
    <img src="/hero.jpg" alt="Professional tech workspace with dual monitors" fetchpriority="high" decoding="async" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;z-index:0;" />
    <div style="position:absolute;inset:0;background:linear-gradient(135deg,rgba(30,64,175,0.88),rgba(37,99,235,0.88));z-index:1;"></div>
    <div style="max-width:56rem;margin:0 auto;padding:4rem 1.5rem 5rem 1.5rem;text-align:center;position:relative;z-index:2;">
      <p style="font-size:0.875rem;font-weight:600;text-transform:uppercase;letter-spacing:0.1em;color:#93c5fd;">Portfolio</p>
      <h1 style="margin-top:0.5rem;font-size:2.5rem;font-weight:800;color:white;line-height:1.2;">Example Websites</h1>
      <p style="margin-top:1rem;color:#bfdbfe;font-size:1.1rem;line-height:1.75;max-width:42rem;margin-left:auto;margin-right:auto;">
        Every example site is mobile responsive, WCAG AA accessible, scores 10/10 on WAVE and 100/100 on Lighthouse. This is the standard I hold all my work to.
      </p>

      <!-- Score badges -->
      <div style="display:flex;flex-wrap:wrap;justify-content:center;gap:0.75rem;margin-top:1.5rem;">
        <span class="score-badge">✅ 10/10 WAVE</span>
        <span class="score-badge">✅ 100/100 Lighthouse</span>
        <span class="score-badge">✅ WCAG AA</span>
        <span class="score-badge">✅ Mobile Responsive</span>
      </div>
    </div>
  </section>

  <!-- Filter Tabs -->
  <div class="filter-bar" role="tablist" aria-label="Filter portfolio by tier">
    <button class="filter-tab active" data-filter="all" role="tab" aria-selected="true">All</button>
    <button class="filter-tab" data-filter="starter" role="tab" aria-selected="false">Starter <span class="tab-price">$750</span></button>
    <button class="filter-tab" data-filter="pro" role="tab" aria-selected="false">Professional <span class="tab-price">$2,000</span></button>
    <button class="filter-tab" data-filter="premium" role="tab" aria-selected="false">Premium <span class="tab-price">$3,500+</span></button>
    <button class="filter-tab" data-filter="demo" role="tab" aria-selected="false">Demos</button>
  </div>

  <!-- Results count -->
  <div style="max-width:72rem;margin:0 auto;padding:1.25rem 1.5rem 0;">
    <p id="results-count" style="color:#6b7280;font-size:0.875rem;"></p>
  </div>

  <!-- Grid -->
  <section style="background:#f8fafc;padding:1.5rem 1.5rem 4rem;">
    <div style="max-width:72rem;margin:0 auto;">

      <div class="portfolio-grid" id="portfolio-grid">
        {sites.map((site) => (
          site.url ? (
            <a
              href={site.url}
              target="_blank"
              rel="noopener noreferrer"
              class="portfolio-card"
              data-tier={site.tier}
            >
              <div class="portfolio-preview" style={`background:${site.gradient};`}>
                <div style="color:white;font-weight:700;font-size:1rem;text-align:center;padding:1rem;">{site.name}</div>
                <div style={`color:${site.accent};font-size:0.75rem;text-align:center;`}>{site.industry}</div>
              </div>
              <div class="portfolio-info">
                <div style="display:flex;align-items:center;gap:0.5rem;margin-bottom:0.375rem;">
                  <span class={`tier-pill tier-${site.tier}`}>{tierLabels[site.tier].label}</span>
                </div>
                <div style="font-weight:600;color:#111827;font-size:0.95rem;">{site.name}</div>
                <div style="color:#4b5563;font-size:0.8rem;margin-top:0.25rem;">
                  {site.location && `${site.location} · `}{site.pages} page{site.pages !== 1 ? 's' : ''}{site.tier === 'premium' && site.pages > 0 ? ' · Est. $3,500' : ''}
                </div>
                <div class="portfolio-link">View Example →</div>
              </div>
            </a>
          ) : (
            <div class="portfolio-card coming-soon" data-tier={site.tier}>
              <div class="portfolio-preview coming-soon-preview">
                <div style="color:#4b5563;font-size:2rem;">🚧</div>
                <div style="color:#4b5563;font-weight:600;font-size:0.9rem;margin-top:0.5rem;">Coming Soon</div>
              </div>
              <div class="portfolio-info">
                <span class={`tier-pill tier-${site.tier}`}>{tierLabels[site.tier].label}</span>
                <div style="font-weight:600;color:#4b5563;font-size:0.95rem;margin-top:0.375rem;">{site.industry}</div>
              </div>
            </div>
          )
        ))}
      </div>

      <!-- Empty state -->
      <div id="empty-state" style="display:none;text-align:center;padding:4rem 1.5rem;">
        <p style="color:#6b7280;font-size:1rem;">No examples in this category yet — check back soon!</p>
      </div>

      <!-- Back to Web Design -->
      <div style="text-align:center;padding-top:2rem;border-top:1px solid #e5e7eb;margin-top:2rem;">
        <a href="/web-services" style="display:inline-flex;align-items:center;gap:0.5rem;color:#2563eb;font-weight:600;font-size:0.95rem;text-decoration:none;">
          <svg style="height:1rem;width:1rem;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M19 12H5M12 5l-7 7 7 7"/></svg>
          Back to Web Design & Pricing
        </a>
      </div>

    </div>
  </section>

</Layout>

<style>
  .score-badge {
    background: rgba(255,255,255,0.15);
    color: white;
    font-size: 0.8rem;
    font-weight: 600;
    padding: 0.375rem 0.875rem;
    border-radius: 9999px;
    border: 1px solid rgba(255,255,255,0.25);
  }

  .filter-bar {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    justify-content: center;
    background: white;
    padding: 1.25rem 1.5rem;
    border-bottom: 1px solid #e5e7eb;
    box-shadow: 0 1px 4px rgba(0,0,0,0.06);
  }

  .filter-tab {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.5rem 1.125rem;
    border-radius: 9999px;
    border: 2px solid #e5e7eb;
    background: white;
    color: #374151;
    font-size: 0.875rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.15s;
  }

  .filter-tab:hover {
    border-color: #2563eb;
    color: #2563eb;
  }

  .filter-tab.active {
    background: #2563eb;
    border-color: #2563eb;
    color: white;
  }

  .tab-price {
    font-size: 0.75rem;
    font-weight: 500;
    color: inherit;
  }

  .portfolio-grid {
    display: grid;
    gap: 1.5rem;
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .portfolio-card {
    border: 1px solid #e5e7eb;
    border-radius: 0.75rem;
    overflow: hidden;
    background: white;
    text-decoration: none;
    transition: box-shadow 0.2s, transform 0.2s;
  }

  .portfolio-card:not(.coming-soon):hover {
    box-shadow: 0 4px 20px rgba(0,0,0,0.1);
    transform: translateY(-2px);
  }

  .portfolio-card[hidden] {
    display: none;
  }

  .portfolio-preview {
    height: 120px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 1rem;
  }

  .coming-soon-preview {
    background: #f3f4f6;
    border-bottom: 1px solid #e5e7eb;
  }

  .portfolio-info {
    padding: 1rem;
  }

  .portfolio-link {
    color: #2563eb;
    font-size: 0.8rem;
    font-weight: 600;
    margin-top: 0.5rem;
  }

  .coming-soon {
    cursor: default;
  }

  .tier-pill {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.125rem 0.5rem;
    border-radius: 9999px;
  }

  .tier-starter { background: #dbeafe; color: #1e40af; }
  .tier-pro     { background: #d1fae5; color: #065f46; }
  .tier-premium { background: #ede9fe; color: #7c3aed; }
  .tier-demo    { background: #fef3c7; color: #92400e; }

  @media (max-width: 900px) {
    .portfolio-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }

  @media (max-width: 600px) {
    .portfolio-grid { grid-template-columns: 1fr; }
    .filter-tab { font-size: 0.8rem; padding: 0.4rem 0.875rem; }
  }
</style>

<script>
  const tabs = document.querySelectorAll<HTMLButtonElement>('.filter-tab');
  const cards = document.querySelectorAll<HTMLElement>('.portfolio-card');
  const countEl = document.getElementById('results-count');
  const emptyState = document.getElementById('empty-state');

  function updateCount(filter: string) {
    const visible = filter === 'all'
      ? cards.length
      : [...cards].filter(c => c.dataset.tier === filter).length;
    if (countEl) {
      countEl.textContent = `Showing ${visible} example${visible !== 1 ? 's' : ''}${filter !== 'all' ? ` in ${filter === 'demo' ? 'Demos' : filter.charAt(0).toUpperCase() + filter.slice(1)}` : ''}`;
    }
    if (emptyState) {
      emptyState.style.display = visible === 0 ? 'block' : 'none';
    }
  }

  function filterCards(filter: string) {
    cards.forEach(card => {
      if (filter === 'all' || card.dataset.tier === filter) {
        card.hidden = false;
      } else {
        card.hidden = true;
      }
    });
    updateCount(filter);
  }

  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      tabs.forEach(t => {
        t.classList.remove('active');
        t.setAttribute('aria-selected', 'false');
      });
      tab.classList.add('active');
      tab.setAttribute('aria-selected', 'true');
      filterCards(tab.dataset.filter ?? 'all');
    });
  });

  // Init count
  updateCount('all');
</script>