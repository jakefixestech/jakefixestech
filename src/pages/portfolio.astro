    accent: '#bbf7d0',
  },
  // Pro
  {
    tier: 'pro',
    name: 'Franconia Family Dental',
    industry: 'Family Dental Practice',
    location: 'Franconia, NH',
    pages: 15,
    url: 'https://pro1.jakefixestech.com',
    gradient: 'linear-gradient(135deg,#0369a1,#0284c7)',
    accent: '#bae6fd',
  },
  {
    tier: 'pro',
    name: 'Summit Fitness & CrossFit',
    industry: 'Fitness & CrossFit Gym',
    location: 'Littleton, NH',
