    location: 'Littleton, NH',
    pages: 3,
    url: 'https://starter1.jakefixestech.com',
    gradient: 'linear-gradient(135deg,#0f2942,#1e4976)',
    accent: '#93c5fd',
  },
  {
    tier: 'starter',
    name: 'White Mountain Maple Co.',
    industry: 'Small Batch NH Maple Syrup',
    location: 'Littleton, NH',
    pages: 3,
    url: 'https://starter2.jakefixestech.com',
    gradient: 'linear-gradient(135deg,#78350f,#b45309)',
    accent: '#fde68a',
  },
  {
    tier: 'starter',
    name: 'North Country Lawn & Landscape',
    industry: 'Lawn Care & Landscaping',
