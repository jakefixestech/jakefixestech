      <!-- Grid -->
      <g stroke="white" stroke-opacity="0.04" stroke-width="1">
        <line x1="0" y1="150" x2="400" y2="150"/>
        <line x1="0" y1="300" x2="400" y2="300"/>
        <line x1="133" y1="0" x2="133" y2="600"/>
        <line x1="266" y1="0" x2="266" y2="600"/>
      </g>
    </svg>

    <!-- Hero text -->
    <div id="hero-content">
      <p class="hero-label">PORTFOLIO · LIVE EXAMPLES</p>
      <h1 id="hero-wordmark">Sites I've Built</h1>
      <p id="hero-tagline">Every example is mobile responsive, WCAG AA accessible, scores 10/10 on WAVE, and 100s across the board on Lighthouse. That's the standard — every time.</p>
