<style>
  /* Hero */
  #hero-svg {
    position: relative;
    width: 100%;
    height: 72vh;
    min-height: 460px;
    max-height: 720px;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #1e3a8a;
  }

  .hero-bg-desktop, .hero-bg-mobile {
    position: absolute; inset: 0;
    width: 100%; height: 100%;
  }
  .hero-bg-desktop { display: block; }
  .hero-bg-mobile  { display: none; }

  /* Window stack entrance */
  .win-back  { opacity: 0; animation: winSlide 0.7s ease 0.4s both; transform-origin: center; }
  .win-mid   { opacity: 0; animation: winSlide 0.7s ease 0.6s both; transform-origin: center; }
  .win-front { opacity: 0; animation: winSlide 0.7s ease 0.8s both; transform-origin: center; }
  @keyframes winSlide {
    from { opacity: 0; transform: translateY(20px) scale(0.96); }
    to   { opacity: 1; transform: translateY(0) scale(1); }
  }

  /* Window content lines draw in */
  .win-line { stroke-dasharray: 220; stroke-dashoffset: 220; animation: drawLine 0.6s ease forwards; }
  .wl-1 { animation-delay: 1.2s; }
  .wl-2 { animation-delay: 1.4s; }
  .wl-3 { animation-delay: 1.6s; }
  @keyframes drawLine { to { stroke-dashoffset: 0; } }

  .win-card { opacity: 0; animation: cardPop 0.4s cubic-bezier(0.34,1.56,0.64,1) both; }
  .wc-1 { animation-delay: 1.7s; }
  .wc-2 { animation-delay: 1.85s; }
  .wc-3 { animation-delay: 2.0s; }
  @keyframes cardPop {
    from { opacity: 0; transform: translateY(8px) scale(0.9); }
    to   { opacity: 1; transform: translateY(0) scale(1); }
  }

  /* Lighthouse gauges fill in */
  .gauge-arc-1 { animation: gaugeFill 1.2s ease 2.2s forwards; }
  .gauge-arc-2 { animation: gaugeFill 1.2s ease 2.5s forwards; }
  .gauge-arc-3 { animation: gaugeFill 1.2s ease 2.8s forwards; }
  .gauge-arc-4 { animation: gaugeFill 1.2s ease 3.1s forwards; }
  @keyframes gaugeFill {
    from { stroke-dashoffset: 201; }
    to   { stroke-dashoffset: 0; }
  }

  .gauge-num { opacity: 0; animation: fadeIn 0.4s ease both; }
  .gauge-num-1 { animation-delay: 3.0s; }
  .gauge-num-2 { animation-delay: 3.3s; }
  .gauge-num-3 { animation-delay: 3.6s; }
  .gauge-num-4 { animation-delay: 3.9s; }
  @keyframes fadeIn { from{opacity:0} to{opacity:1} }

  /* WAVE stamp — opacity-only animation; outer group handles positioning */
  .wave-stamp { opacity: 0; animation: stampFade 0.6s ease 4.2s forwards; }
  @keyframes stampFade {
    from { opacity: 0; }
    to   { opacity: 1; }
  }

  /* Cursor — slow loop with real pauses: hover window → move → hover gauge → click → return */
  .cursor-group { animation: cursorPath 14s ease-in-out infinite 1.5s; }
  @keyframes cursorPath {
    /* Pause hovering over a card in the front window for ~3s */
    0%   { transform: translate(290px, 290px); }
    20%  { transform: translate(290px, 290px); }
    /* Slow drift toward gauges over ~2s */
    30%  { transform: translate(620px, 230px); }
    /* Pause mid-route briefly */
    40%  { transform: translate(620px, 230px); }
    /* Glide to gauges over ~2s, settle on gauge */
    52%  { transform: translate(960px, 200px); }
    /* Hold on gauge for click moment */
    62%  { transform: translate(960px, 200px); }
    /* Drift back slowly */
    80%  { transform: translate(620px, 250px); }
    /* Final pause back near windows */
    92%  { transform: translate(290px, 290px); }
    100% { transform: translate(290px, 290px); }
  }
  .click-pulse {
    transform-origin: center;
    animation: clickPulse 14s ease-out infinite 1.5s;
  }
  @keyframes clickPulse {
    /* Click happens during the gauge-hover hold, around 56-58% */
    0%, 55%, 60%, 100% { r: 0; opacity: 0; }
    57%                 { r: 16; opacity: 0.7; }
  }

  /* Ambient code labels */
  .code-tw { animation-fill-mode: both; opacity: 0; }
  .ct-a { animation: codeBlink 5s ease-in-out infinite 0.5s; }
  .ct-b { animation: codeBlink 6s ease-in-out infinite 0.8s; }
  .ct-c { animation: codeBlink 4.5s ease-in-out infinite 1.0s; }
  .ct-d { animation: codeBlink 5.5s ease-in-out infinite 1.3s; }
  @keyframes codeBlink {
    0%   { opacity: 0; }
    20%  { opacity: 0.9; }
    60%  { opacity: 0.4; }
    100% { opacity: 0.85; }
  }

  /* Glow orbs */
  .glow-orb-1 { animation: glowPulse 4s ease-in-out infinite; }
  .glow-orb-2 { animation: glowPulse 5s ease-in-out infinite reverse; }
  @keyframes glowPulse { 0%,100%{opacity:0.6} 50%{opacity:1} }

  /* Hero text */
  #hero-content {
    position: relative; z-index: 2;
    text-align: center;
    display: flex; flex-direction: column;
    align-items: center; gap: 1rem;
    padding: 0 1.5rem;
    max-width: 48rem;
  }
  .hero-label { font-size:0.875rem;font-weight:600;text-transform:uppercase;letter-spacing:0.1em;color:#93c5fd;margin:0;opacity:0;animation:fadeUp 0.6s ease 0.3s forwards; }
  #hero-wordmark { font-size:clamp(2.25rem,6vw,3.5rem);font-weight:900;color:white;margin:0;line-height:1.1;text-shadow:0 2px 30px rgba(0,0,0,0.3);opacity:0;animation:fadeUp 0.7s ease 0.6s forwards; }
  #hero-tagline { font-size:clamp(0.875rem,1.8vw,1rem);color:#bfdbfe;margin:0;max-width:38rem;line-height:1.75;opacity:0;animation:fadeUp 0.6s ease 0.9s forwards; }
  #hero-cta { display:inline-flex;align-items:center;gap:0.5rem;background:white;color:#1e40af;font-weight:700;padding:0.875rem 2rem;border-radius:0.5rem;text-decoration:none;font-size:1rem;opacity:0;animation:fadeUp 0.6s ease 1.2s forwards;transition:transform 0.2s,box-shadow 0.2s; }
  #hero-cta:hover { transform:translateY(-2px);box-shadow:0 8px 24px rgba(0,0,0,0.2); }
  @keyframes fadeUp { from{opacity:0;transform:translateY(14px)} to{opacity:1;transform:translateY(0)} }

  #scroll-hint {
    position:absolute; bottom:1.5rem; left:50%;
    transform:translateX(-50%);
    color:rgba(255,255,255,0.85);
    animation:scrollBounce 2s ease-in-out infinite, fadeUp 0.6s ease 1.6s both;
    opacity:0; z-index:2; cursor:pointer;
  }
  @keyframes scrollBounce {
    0%,100%{transform:translateX(-50%) translateY(0)}
    50%{transform:translateX(-50%) translateY(6px)}
  }

  @media (max-width: 768px) {
    #hero-svg { height:70vh;min-height:440px; }
    .hero-bg-desktop { display:none; }
    .hero-bg-mobile  { display:block; }
  }

  @media (prefers-reduced-motion:reduce) {
    .win-back,.win-mid,.win-front,.win-line,.win-card,
    .gauge-arc-1,.gauge-arc-2,.gauge-arc-3,.gauge-arc-4,
    .gauge-num,.wave-stamp,.cursor-group,.click-pulse,
    .code-tw,.glow-orb-1,.glow-orb-2,#scroll-hint { animation: none; }
    .hero-label,#hero-wordmark,#hero-tagline,#hero-cta,#scroll-hint { opacity:1; transform:none; }
    .win-back,.win-mid,.win-front,.win-card,.gauge-num,.wave-stamp { opacity:1; }
    .win-line { stroke-dashoffset: 0; }
