    .float-dot, .glow-orb-1, .glow-orb-2, #scroll-hint { animation: none; }
    .hero-label, #hero-wordmark, #hero-tagline, #hero-cta, #scroll-hint { opacity: 1; transform: none; }
    .tag, .icon-grid, .grid-icon { opacity: 1; }
