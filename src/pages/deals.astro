  .hero-bg-desktop, .hero-bg-mobile {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }
  .hero-bg-desktop { display: block; }
  .hero-bg-mobile  { display: none; }

  /* === TAG STACK === */
  .tag {
    opacity: 0;
    transform-origin: center;
  }
  .tag-back  { animation: tagFadeIn 0.7s ease 0.6s forwards, tagSway 5s ease-in-out infinite 1.5s; }
  .tag-mid   { animation: tagFadeIn 0.7s ease 0.85s forwards, tagSway 6s ease-in-out infinite 1.7s; }
  .tag-front { animation: tagFadeIn 0.7s ease 1.1s forwards, tagSway 5.5s ease-in-out infinite 1.9s; }
  @keyframes tagFadeIn { from { opacity: 0 } to { opacity: 1 } }
  @keyframes tagSway {
    0%, 100% { transform: translate(0, 0); }
    50%      { transform: translate(0, -4px); }
  }

  /* === ICON GRID === */
  /* Each icon pops in staggered (0.15s apart), then bobs gently in place forever.
     The grid-icon class handles the entrance fade+scale.
     The bob class (inner) handles the continuous in-place movement. */
  .icon-grid {
    opacity: 0;
    animation: gridFadeIn 0.5s ease 1s forwards;
  }
  @keyframes gridFadeIn { from { opacity: 0 } to { opacity: 1 } }

  .grid-glow {
    animation: glowPulse 4s ease-in-out infinite;
    transform-origin: center;
  }
  @keyframes glowPulse {
    0%, 100% { opacity: 0.7; }
    50%      { opacity: 1; }
  }

  /* Each icon: invisible until its turn, then pops in and stays */
  .grid-icon {
    opacity: 0;
    transform-origin: center;
  }
  .gi-1 { animation: iconPopIn 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) 1.2s forwards; }
  .gi-2 { animation: iconPopIn 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) 1.4s forwards; }
  .gi-3 { animation: iconPopIn 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) 1.6s forwards; }
  .gi-4 { animation: iconPopIn 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) 1.8s forwards; }
  .gi-5 { animation: iconPopIn 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) 2.0s forwards; }
  @keyframes iconPopIn {
    0%   { opacity: 0; }
    100% { opacity: 1; }
  }

  /* Inner bob group — synchronized 3-group wave on a 6s cycle.
     Phase 1 (0-33%): icons 1 + 3 bob up together
     Phase 2 (33-66%): icons 2 + 4 bob up together
     Phase 3 (66-100%): icon 5 bobs up alone
     All on the same 6s timeline so the wave is visibly rhythmic. */
  .bob-1, .bob-3 { animation: bobPhase1 6s ease-in-out infinite 2.5s; transform-origin: center; }
  .bob-2, .bob-4 { animation: bobPhase2 6s ease-in-out infinite 2.5s; transform-origin: center; }
  .bob-5         { animation: bobPhase3 6s ease-in-out infinite 2.5s; transform-origin: center; }

  @keyframes bobPhase1 {
    0%, 33%, 100% { transform: translateY(0); }
    16%           { transform: translateY(-6px); }
  }
  @keyframes bobPhase2 {
    0%, 33%, 66%, 100% { transform: translateY(0); }
    50%                { transform: translateY(-6px); }
  }
  @keyframes bobPhase3 {
    0%, 66%, 100% { transform: translateY(0); }
    83%           { transform: translateY(-6px); }
  }

  /* === AMBIENT === */
  .float-dot { animation: dotFloat 4s ease-in-out infinite; }
