  .deal-desc { font-size: 0.95rem; color: #4b5563; line-height: 1.75; margin: 0 0 0.5rem 0; }
  .deal-fine { font-size: 0.8rem; color: #6b7280; margin: 0; font-style: italic; }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 900px) {
    #hero-svg { height: 70vh; min-height: 440px; }
