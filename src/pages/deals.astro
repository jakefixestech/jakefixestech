    cursor: pointer;
  }
  @keyframes scrollBounce {
    0%,100%{transform:translateX(-50%) translateY(0)}
    50%{transform:translateX(-50%) translateY(6px)}
  }

  /* ===== DEAL CARDS ===== */
  .deal-card {
    display: flex;
    align-items: center;
