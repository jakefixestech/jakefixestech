---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Community Discounts & Deals | Jake Fixes Tech — Littleton, NH"
description="10% off all computer repair services for military, first responders, police, firefighters, seniors and students. Jake Fixes Tech — Littleton, NH.">

  <!-- Animated SVG Hero -->
  <section id="hero-svg" aria-label="Community Discounts">

    <!-- DESKTOP SVG -->
    <svg class="hero-bg-desktop" viewBox="0 0 1440 520" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <defs>
        <linearGradient id="bgGrad" x1="0%" y1="0%" x2="100%" y2="100%">
          <stop offset="0%" style="stop-color:#1e3a8a;stop-opacity:1"/>
          <stop offset="100%" style="stop-color:#2563eb;stop-opacity:1"/>
        </linearGradient>
        <linearGradient id="glowGrad" x1="0%" y1="0%" x2="100%" y2="100%">
          <stop offset="0%" style="stop-color:#3b82f6;stop-opacity:0.3"/>
          <stop offset="100%" style="stop-color:#1d4ed8;stop-opacity:0"/>
        </linearGradient>
        <radialGradient id="spotGrad" cx="50%" cy="50%" r="50%">
          <stop offset="0%" style="stop-color:white;stop-opacity:0.15"/>
          <stop offset="70%" style="stop-color:white;stop-opacity:0.04"/>
          <stop offset="100%" style="stop-color:white;stop-opacity:0"/>
        </radialGradient>
      </defs>
      <rect width="1440" height="520" fill="url(#bgGrad)"/>
      <ellipse cx="320" cy="260" rx="380" ry="280" fill="url(#glowGrad)" class="glow-orb-1"/>
      <ellipse cx="1150" cy="260" rx="340" ry="260" fill="url(#glowGrad)" class="glow-orb-2"/>

      <!-- LEFT: 10% OFF tag stack — anchored x:160 y:200.
           Outer <g> handles position+rotation (stays put);
           inner <g class="tag"> handles fade+sway animation. -->
      <g class="tag-stack" transform="translate(160, 200)">
        <g transform="rotate(-12 90 40)">
          <g class="tag tag-back">
            <path d="M0 25 L80 0 L180 0 L180 80 L80 80 L0 55 Z" fill="white" fill-opacity="0.05" stroke="white" stroke-opacity="0.18" stroke-width="1.5"/>
            <circle cx="20" cy="40" r="4" fill="none" stroke="white" stroke-opacity="0.2" stroke-width="1.5"/>
            <text x="105" y="48" text-anchor="middle" fill="white" fill-opacity="0.3" font-size="22" font-weight="900" font-family="monospace" letter-spacing="1">10%</text>
          </g>
        </g>
        <g transform="translate(35, 50) rotate(-4 90 40)">
          <g class="tag tag-mid">
            <path d="M0 25 L80 0 L180 0 L180 80 L80 80 L0 55 Z" fill="white" fill-opacity="0.08" stroke="white" stroke-opacity="0.3" stroke-width="1.5"/>
            <circle cx="20" cy="40" r="4" fill="none" stroke="white" stroke-opacity="0.4" stroke-width="1.5"/>
            <text x="105" y="48" text-anchor="middle" fill="white" fill-opacity="0.55" font-size="22" font-weight="900" font-family="monospace" letter-spacing="1">10%</text>
          </g>
        </g>
        <g transform="translate(70, 100)">
          <g class="tag tag-front">
            <path d="M0 25 L80 0 L180 0 L180 80 L80 80 L0 55 Z" fill="white" fill-opacity="0.14" stroke="white" stroke-opacity="0.6" stroke-width="2"/>
            <circle cx="20" cy="40" r="4" fill="white" fill-opacity="0.55"/>
            <text x="105" y="42" text-anchor="middle" fill="white" fill-opacity="0.9" font-size="26" font-weight="900" font-family="monospace" letter-spacing="1">10%</text>
            <text x="105" y="63" text-anchor="middle" fill="white" fill-opacity="0.7" font-size="11" font-weight="700" font-family="monospace" letter-spacing="3">OFF</text>
          </g>
        </g>
      </g>

      <!-- RIGHT: All 5 community icons arranged in a 3+2 grid.
           Group anchor x:1180 y:260 (center of grid).
           Top row (3 icons): y:-50 row, x: -100, 0, 100
           Bottom row (2 icons): y:+70 row, x: -50, 50
           Each icon pops in staggered, then gently bobs in place.  -->
      <g class="icon-grid" transform="translate(1180, 260)">
        <!-- Soft ambient glow behind grid (no longer the carousel ring) -->
        <ellipse cx="0" cy="0" rx="170" ry="130" fill="url(#spotGrad)" class="grid-glow"/>

        <!-- Top row -->
        <g class="grid-icon gi-1" transform="translate(-100, -50)">
          <g class="bob bob-1">
            <!-- Shield (Military) -->
            <path d="M0 -32 L-20 -24 L-20 6 C-20 20 -10 29 0 33 C10 29 20 20 20 6 L20 -24 Z" fill="none" stroke="white" stroke-opacity="0.75" stroke-width="2.5" stroke-linejoin="round"/>
            <polygon points="0,-17 4,-5 16,-5 6,2 10,14 0,7 -10,14 -6,2 -16,-5 -4,-5" fill="white" fill-opacity="0.85"/>
          </g>
          <text x="0" y="56" text-anchor="middle" fill="white" fill-opacity="0.75" font-size="11" font-weight="700" font-family="monospace" letter-spacing="2">MILITARY</text>
        </g>

        <g class="grid-icon gi-2" transform="translate(0, -50)">
          <g class="bob bob-2">
            <!-- Police badge -->
            <path d="M0 -33 L7 -25 L18 -25 L18 -14 L26 -6 L18 2 L18 13 L7 13 L0 21 L-7 13 L-18 13 L-18 2 L-26 -6 L-18 -14 L-18 -25 L-7 -25 Z" fill="none" stroke="white" stroke-opacity="0.75" stroke-width="2.5" stroke-linejoin="round"/>
            <circle cx="0" cy="-6" r="8" fill="none" stroke="white" stroke-opacity="0.85" stroke-width="2"/>
            <line x1="0" y1="-16" x2="0" y2="-13" stroke="white" stroke-opacity="0.85" stroke-width="2" stroke-linecap="round"/>
            <line x1="0" y1="2" x2="0" y2="5" stroke="white" stroke-opacity="0.85" stroke-width="2" stroke-linecap="round"/>
            <line x1="-10" y1="-6" x2="-7" y2="-6" stroke="white" stroke-opacity="0.85" stroke-width="2" stroke-linecap="round"/>
            <line x1="7" y1="-6" x2="10" y2="-6" stroke="white" stroke-opacity="0.85" stroke-width="2" stroke-linecap="round"/>
          </g>
          <text x="0" y="56" text-anchor="middle" fill="white" fill-opacity="0.75" font-size="11" font-weight="700" font-family="monospace" letter-spacing="2">POLICE</text>
        </g>

        <g class="grid-icon gi-3" transform="translate(100, -50)">
          <g class="bob bob-3">
            <!-- Fire/EMS maltese cross -->
            <path d="M0 -28 L7 -16 L19 -24 L13 -12 L26 -6 L13 0 L26 6 L13 12 L19 24 L7 16 L0 28 L-7 16 L-19 24 L-13 12 L-26 6 L-13 0 L-26 -6 L-13 -12 L-19 -24 L-7 -16 Z" fill="none" stroke="white" stroke-opacity="0.7" stroke-width="2" stroke-linejoin="round"/>
            <path d="M0 -7 C-4 -1 -7 3 -7 7 C-7 12 -4 16 0 16 C4 16 7 12 7 7 C7 3 4 -1 0 -7 Z" fill="white" fill-opacity="0.85"/>
          </g>
          <text x="0" y="56" text-anchor="middle" fill="white" fill-opacity="0.75" font-size="11" font-weight="700" font-family="monospace" letter-spacing="2">FIRE / EMS</text>
        </g>

        <!-- Bottom row -->
        <g class="grid-icon gi-4" transform="translate(-50, 70)">
          <g class="bob bob-4">
            <!-- Heart (Seniors) -->
            <path d="M0 22 C0 22 -24 9 -24 -7 C-24 -16 -17 -22 -10 -22 C-5 -22 -1 -19 0 -15 C1 -19 5 -22 10 -22 C17 -22 24 -16 24 -7 C24 9 0 22 0 22 Z" fill="white" fill-opacity="0.2" stroke="white" stroke-opacity="0.85" stroke-width="2.5" stroke-linejoin="round"/>
          </g>
          <text x="0" y="56" text-anchor="middle" fill="white" fill-opacity="0.75" font-size="11" font-weight="700" font-family="monospace" letter-spacing="2">SENIORS</text>
        </g>

        <g class="grid-icon gi-5" transform="translate(50, 70)">
          <g class="bob bob-5">
            <!-- Grad cap (Students) -->
            <polygon points="0,-19 27,-6 0,7 -27,-6" fill="white" fill-opacity="0.18" stroke="white" stroke-opacity="0.85" stroke-width="2.5" stroke-linejoin="round"/>
            <path d="M16 0 L16 17 C16 17 10 22 0 22 C-10 22 -16 17 -16 17 L-16 0" fill="none" stroke="white" stroke-opacity="0.85" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
            <line x1="27" y1="-6" x2="27" y2="11" stroke="white" stroke-opacity="0.85" stroke-width="2.5" stroke-linecap="round"/>
            <circle cx="27" cy="14" r="3" fill="white" fill-opacity="0.85"/>
          </g>
          <text x="0" y="56" text-anchor="middle" fill="white" fill-opacity="0.75" font-size="11" font-weight="700" font-family="monospace" letter-spacing="2">STUDENTS</text>
        </g>
      </g>

      <!-- Ambient floating dots -->
      <g class="ambient-dots">
        <circle cx="500" cy="120" r="2" fill="white" fill-opacity="0.25" class="float-dot d1"/>
        <circle cx="940" cy="100" r="2.5" fill="white" fill-opacity="0.3" class="float-dot d2"/>
        <circle cx="600" cy="420" r="2" fill="white" fill-opacity="0.25" class="float-dot d3"/>
        <circle cx="820" cy="440" r="2" fill="white" fill-opacity="0.3" class="float-dot d4"/>
      </g>

      <!-- Subtle grid -->
      <g stroke="white" stroke-opacity="0.04" stroke-width="1">
        <line x1="0" y1="130" x2="1440" y2="130"/>
        <line x1="0" y1="260" x2="1440" y2="260"/>
        <line x1="0" y1="390" x2="1440" y2="390"/>
        <line x1="360" y1="0" x2="360" y2="520"/>
        <line x1="720" y1="0" x2="720" y2="520"/>
        <line x1="1080" y1="0" x2="1080" y2="520"/>
      </g>
    </svg>

    <!-- MOBILE SVG -->
    <svg class="hero-bg-mobile" viewBox="0 0 400 600" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <defs>
        <linearGradient id="bgGradM" x1="0%" y1="0%" x2="100%" y2="100%">
          <stop offset="0%" style="stop-color:#1e3a8a;stop-opacity:1"/>
          <stop offset="100%" style="stop-color:#2563eb;stop-opacity:1"/>
        </linearGradient>
        <linearGradient id="glowGradM" x1="0%" y1="0%" x2="100%" y2="100%">
          <stop offset="0%" style="stop-color:#3b82f6;stop-opacity:0.3"/>
          <stop offset="100%" style="stop-color:#1d4ed8;stop-opacity:0"/>
        </linearGradient>
        <radialGradient id="spotGradM" cx="50%" cy="50%" r="50%">
          <stop offset="0%" style="stop-color:white;stop-opacity:0.15"/>
          <stop offset="70%" style="stop-color:white;stop-opacity:0.04"/>
          <stop offset="100%" style="stop-color:white;stop-opacity:0"/>
        </radialGradient>
      </defs>
      <rect width="400" height="600" fill="url(#bgGradM)"/>
      <ellipse cx="100" cy="180" rx="220" ry="180" fill="url(#glowGradM)" class="glow-orb-1"/>
      <ellipse cx="320" cy="500" rx="220" ry="180" fill="url(#glowGradM)" class="glow-orb-2"/>

      <!-- TOP: Tag stack — y:75-175 -->
      <g class="tag-stack" transform="translate(60, 75)">
        <g transform="rotate(-10 65 30)">
          <g class="tag tag-back">
            <path d="M0 18 L60 0 L130 0 L130 60 L60 60 L0 42 Z" fill="white" fill-opacity="0.05" stroke="white" stroke-opacity="0.18" stroke-width="1"/>
            <circle cx="14" cy="30" r="3" fill="none" stroke="white" stroke-opacity="0.2" stroke-width="1"/>
            <text x="78" y="36" text-anchor="middle" fill="white" fill-opacity="0.3" font-size="16" font-weight="900" font-family="monospace">10%</text>
          </g>
        </g>
        <g transform="translate(25, 35) rotate(-3 65 30)">
          <g class="tag tag-mid">
            <path d="M0 18 L60 0 L130 0 L130 60 L60 60 L0 42 Z" fill="white" fill-opacity="0.08" stroke="white" stroke-opacity="0.3" stroke-width="1.2"/>
            <circle cx="14" cy="30" r="3" fill="none" stroke="white" stroke-opacity="0.4" stroke-width="1.2"/>
            <text x="78" y="36" text-anchor="middle" fill="white" fill-opacity="0.55" font-size="16" font-weight="900" font-family="monospace">10%</text>
          </g>
        </g>
        <g transform="translate(50, 70)">
          <g class="tag tag-front">
            <path d="M0 18 L60 0 L130 0 L130 60 L60 60 L0 42 Z" fill="white" fill-opacity="0.14" stroke="white" stroke-opacity="0.6" stroke-width="1.5"/>
            <circle cx="14" cy="30" r="3" fill="white" fill-opacity="0.55"/>
            <text x="78" y="30" text-anchor="middle" fill="white" fill-opacity="0.9" font-size="18" font-weight="900" font-family="monospace">10%</text>
            <text x="78" y="46" text-anchor="middle" fill="white" fill-opacity="0.7" font-size="8" font-weight="700" font-family="monospace" letter-spacing="2">OFF</text>
          </g>
        </g>
      </g>

      <!-- BOTTOM: All 5 icons in a row across bottom — y:475 -->
      <g class="icon-grid" transform="translate(0, 0)">
        <!-- Soft ambient glow behind row -->
        <ellipse cx="200" cy="495" rx="180" ry="50" fill="url(#spotGradM)" class="grid-glow"/>

        <g class="grid-icon gi-1" transform="translate(60, 495)">
          <g class="bob bob-1">
            <path d="M0 -20 L-12 -15 L-12 4 C-12 13 -6 19 0 21 C6 19 12 13 12 4 L12 -15 Z" fill="none" stroke="white" stroke-opacity="0.75" stroke-width="1.8" stroke-linejoin="round"/>
            <polygon points="0,-11 2.5,-3 10,-3 4,2 6,9 0,4 -6,9 -4,2 -10,-3 -2.5,-3" fill="white" fill-opacity="0.85"/>
          </g>
        </g>

        <g class="grid-icon gi-2" transform="translate(130, 495)">
          <g class="bob bob-2">
            <path d="M0 -21 L4 -16 L11 -16 L11 -9 L16 -4 L11 1 L11 8 L4 8 L0 13 L-4 8 L-11 8 L-11 1 L-16 -4 L-11 -9 L-11 -16 L-4 -16 Z" fill="none" stroke="white" stroke-opacity="0.75" stroke-width="1.8" stroke-linejoin="round"/>
            <circle cx="0" cy="-4" r="5" fill="none" stroke="white" stroke-opacity="0.85" stroke-width="1.5"/>
          </g>
        </g>

        <g class="grid-icon gi-3" transform="translate(200, 495)">
          <g class="bob bob-3">
            <path d="M0 -18 L4 -10 L12 -15 L8 -7 L16 -4 L8 0 L16 4 L8 7 L12 15 L4 10 L0 18 L-4 10 L-12 15 L-8 7 L-16 4 L-8 0 L-16 -4 L-8 -7 L-12 -15 L-4 -10 Z" fill="none" stroke="white" stroke-opacity="0.7" stroke-width="1.5" stroke-linejoin="round"/>
            <path d="M0 -5 C-2 -1 -4 1 -4 4 C-4 7 -2 10 0 10 C2 10 4 7 4 4 C4 1 2 -1 0 -5 Z" fill="white" fill-opacity="0.85"/>
          </g>
        </g>

        <g class="grid-icon gi-4" transform="translate(270, 495)">
          <g class="bob bob-4">
            <path d="M0 14 C0 14 -15 5 -15 -4 C-15 -10 -11 -14 -6 -14 C-3 -14 -1 -11 0 -9 C1 -11 3 -14 6 -14 C11 -14 15 -10 15 -4 C15 5 0 14 0 14 Z" fill="white" fill-opacity="0.2" stroke="white" stroke-opacity="0.85" stroke-width="1.8" stroke-linejoin="round"/>
          </g>
        </g>

        <g class="grid-icon gi-5" transform="translate(340, 495)">
          <g class="bob bob-5">
            <polygon points="0,-12 17,-4 0,4 -17,-4" fill="white" fill-opacity="0.18" stroke="white" stroke-opacity="0.85" stroke-width="1.8" stroke-linejoin="round"/>
            <path d="M10 0 L10 10 C10 10 6 13 0 13 C-6 13 -10 10 -10 10 L-10 0" fill="none" stroke="white" stroke-opacity="0.85" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
            <line x1="17" y1="-4" x2="17" y2="6" stroke="white" stroke-opacity="0.85" stroke-width="1.8" stroke-linecap="round"/>
            <circle cx="17" cy="8" r="2" fill="white" fill-opacity="0.85"/>
          </g>
        </g>
      </g>

      <g stroke="white" stroke-opacity="0.04" stroke-width="1">
        <line x1="0" y1="150" x2="400" y2="150"/>
        <line x1="0" y1="300" x2="400" y2="300"/>
        <line x1="0" y1="450" x2="400" y2="450"/>
        <line x1="133" y1="0" x2="133" y2="600"/>
        <line x1="266" y1="0" x2="266" y2="600"/>
      </g>
    </svg>

    <!-- Hero text overlay -->
    <div id="hero-content">
      <p class="hero-label">Community Discounts</p>
      <h1 id="hero-wordmark">Deals for the People<br/>Who Show Up for Us</h1>
      <p id="hero-tagline">Some people give more than they take. This is my small way of giving back. 10% off all computer repair labor — no expiration, no fine print, forever.</p>
      <a href="#deals-section" id="hero-cta">
        See Who Qualifies
        <svg style="height:1rem;width:1rem;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M12 5v14M5 12l7 7 7-7"/></svg>
      </a>
    </div>

    <div id="scroll-hint" aria-hidden="true" role="button" tabindex="-1" onclick="document.getElementById('claim-section').scrollIntoView({behavior:'smooth'})">
      <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" style="height:1.5rem;width:1.5rem;"><path d="M12 5v14M5 12l7 7 7-7"/></svg>
    </div>
  </section>

  <!-- How to Claim -->
  <section id="claim-section" style="background:#1e40af;padding:1.5rem;">
    <div style="max-width:56rem;margin:0 auto;text-align:center;">
      <p style="color:white;font-size:0.95rem;line-height:1.75;margin:0;"><strong style="color:#bfdbfe;">How to claim:</strong> Just mention it when you reach out or drop off. Show valid ID, badge, student ID or military ID. That's it. No forms, no codes, no hassle.</p>
    </div>
  </section>

  <!-- Discount Cards -->
  <section id="deals-section" style="background:#f8fafc;padding:5rem 1.5rem;">
    <div style="max-width:52rem;margin:0 auto;display:flex;flex-direction:column;gap:2rem;">

      <div class="deal-card reveal-left" data-delay="0">
        <div class="deal-icon-wrap deal-icon-military">
          <svg viewBox="0 0 120 120" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M60 8L20 24V56C20 78 38 97 60 104C82 97 100 78 100 56V24L60 8Z" stroke="currentColor" stroke-width="5" stroke-linejoin="round" fill="none"/>
            <polygon points="60,32 65,47 81,47 68,56 73,71 60,62 47,71 52,56 39,47 55,47" fill="currentColor" opacity="0.9"/>
          </svg>
        </div>
        <div class="deal-content">
          <div class="deal-badge">10% Off — Forever</div>
          <h2 class="deal-title">Military</h2>
          <p class="deal-desc">Active duty, reserves, veterans — all branches, all ranks. Army, Navy, Air Force, Marines, Coast Guard, Space Force. You served. This one's easy.</p>
          <p class="deal-fine">Valid military ID or DD-214 required.</p>
        </div>
      </div>

      <div class="deal-card reveal-right" data-delay="100">
        <div class="deal-icon-wrap deal-icon-police">
          <svg viewBox="0 0 120 120" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M60 6L72 18H90V36L102 48L90 60V78H72L60 90L48 78H30V60L18 48L30 36V18H48L60 6Z" stroke="currentColor" stroke-width="5" stroke-linejoin="round" fill="none"/>
            <circle cx="60" cy="48" r="14" stroke="currentColor" stroke-width="4" fill="none"/>
            <line x1="60" y1="34" x2="60" y2="38" stroke="currentColor" stroke-width="4" stroke-linecap="round"/>
            <line x1="60" y1="58" x2="60" y2="62" stroke="currentColor" stroke-width="4" stroke-linecap="round"/>
            <line x1="46" y1="48" x2="50" y2="48" stroke="currentColor" stroke-width="4" stroke-linecap="round"/>
            <line x1="70" y1="48" x2="74" y2="48" stroke="currentColor" stroke-width="4" stroke-linecap="round"/>
          </svg>
        </div>
        <div class="deal-content">
          <div class="deal-badge">10% Off — Forever</div>
          <h2 class="deal-title">Law Enforcement</h2>
          <p class="deal-desc">Local police, state police, sheriff's deputies, corrections officers, federal law enforcement. You keep communities safe — the least I can do is keep your tech running.</p>
          <p class="deal-fine">Valid badge or department ID required.</p>
        </div>
      </div>

      <div class="deal-card reveal-left" data-delay="200">
        <div class="deal-icon-wrap deal-icon-fire">
          <svg viewBox="0 0 120 120" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M60 10 L72 30 L90 18 L78 36 L100 48 L80 60 L100 72 L78 84 L90 102 L72 90 L60 110 L48 90 L30 102 L42 84 L20 72 L40 60 L20 48 L42 36 L30 18 L48 30 Z" stroke="currentColor" stroke-width="4" stroke-linejoin="round" fill="none"/>
            <path d="M60 40 C52 48 48 54 48 62 C48 71 53 78 60 80 C67 78 72 71 72 62 C72 54 68 48 60 40Z" fill="currentColor" opacity="0.85"/>
            <path d="M60 52 C57 57 56 61 57 65 C58 68 59 70 60 71 C61 70 62 68 63 65 C64 61 63 57 60 52Z" fill="#f8fafc" opacity="0.5"/>
          </svg>
        </div>
        <div class="deal-content">
          <div class="deal-badge">10% Off — Forever</div>
          <h2 class="deal-title">Firefighters & EMS</h2>
          <p class="deal-desc">Career and volunteer firefighters, EMTs, paramedics. Whether you're running into buildings or running calls at 3am — you've got a standing discount here.</p>
          <p class="deal-fine">Valid department ID, badge or volunteer card required.</p>
        </div>
      </div>

      <div class="deal-card reveal-right" data-delay="300">
        <div class="deal-icon-wrap deal-icon-senior">
          <svg viewBox="0 0 120 120" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M60 90 C60 90 22 68 22 44 C22 32 31 24 42 24 C50 24 57 29 60 35 C63 29 70 24 78 24 C89 24 98 32 98 44 C98 68 60 90 60 90Z" stroke="currentColor" stroke-width="5" stroke-linejoin="round" fill="none"/>
            <path d="M44 56 C44 56 50 64 60 68 C70 64 76 56 76 56" stroke="currentColor" stroke-width="4" stroke-linecap="round" fill="none"/>
          </svg>
        </div>
        <div class="deal-content">
          <div class="deal-badge">10% Off — Forever</div>
          <h2 class="deal-title">Seniors (65+)</h2>
          <p class="deal-desc">Tech shouldn't be a barrier for anyone. If you're 65 or older, you get 10% off every repair, every time — plus I'll always take the extra time to explain exactly what happened and why.</p>
          <p class="deal-fine">Just mention your age. No ID required.</p>
        </div>
      </div>

      <div class="deal-card reveal-left" data-delay="400">
        <div class="deal-icon-wrap deal-icon-student">
          <svg viewBox="0 0 120 120" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <polygon points="60,22 104,44 60,66 16,44" stroke="currentColor" stroke-width="5" stroke-linejoin="round" fill="none"/>
